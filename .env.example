# ─── App ───────────────────────────────────────────────────────────────────────
PUBLIC_URL='http://localhost:4321'

# ─── Cloudinary (subida de imágenes) ───────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── Base de datos (AstroDB / Turso) ───────────────────────────────────────────
ASTRO_DB_REMOTE_URL=libsql://your-db.turso.io
ASTRO_DB_APP_TOKEN=your_turso_token

# ─── Firebase Web SDK — Área Admin ─────────────────────────────────────────────
#
# Usamos el Firebase Web SDK oficial (firebase/app, firebase/auth).
# NO se requiere Admin SDK ni Service Account.
#
# Cómo obtener los valores:
#   1. Ir a Firebase Console → tu proyecto → ⚙ Configuración del proyecto
#   2. Pestaña "General" → sección "Tus apps"
#   3. Crear o seleccionar una Web App
#   4. Copiar el objeto firebaseConfig completo
#
# En Authentication → Sign-in method: habilitar "Correo electrónico/contraseña"
# En Authentication → Users: agregar el usuario admin
#
# NOTA: La Web API Key es pública por diseño (el SDK la expone en el browser).
# Para mayor seguridad, restringila en Google Cloud Console → APIs y Servicios →
# Credenciales → seleccionar la API key → Restricciones de aplicación.
#
PUBLIC_FIREBASE_API_KEY=your_web_api_key
PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
PUBLIC_FIREBASE_PROJECT_ID=your-project-id
PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
PUBLIC_FIREBASE_APP_ID=1:123456789:web:abcdef123456
PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX
