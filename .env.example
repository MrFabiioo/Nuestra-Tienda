# ─── App ───────────────────────────────────────────────────────────────────────
# En Railway staging/production, cambiá PUBLIC_URL por la URL pública real.
PUBLIC_URL='http://localhost:4321'

# ─── Cloudinary (subida de imágenes) ───────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── Base de datos remota (Astro DB / libSQL) ─────────────────────────────────
# Requeridas para `npm run build`, `npm run build:remote` y `npm run dev:remote`.
# `dev:remote` escribe contra la DB remota configurada: usá una instancia de staging
# si no querés tocar datos productivos durante desarrollo o smoke tests.
ASTRO_DB_REMOTE_URL=libsql://your-db.turso.io
ASTRO_DB_APP_TOKEN=your_remote_db_token

# ─── Firebase Web SDK — Área Admin ─────────────────────────────────────────────
#
# Usamos el Firebase Web SDK oficial (firebase/app, firebase/auth).
# NO se requiere Admin SDK ni Service Account.
#
# Cómo obtener los valores:
#   1. Ir a Firebase Console → tu proyecto → ⚙ Configuración del proyecto
#   2. Pestaña "General" → sección "Tus apps"
#   3. Crear o seleccionar una Web App
#   4. Copiar el objeto firebaseConfig completo
#
# En Authentication → Sign-in method: habilitar "Correo electrónico/contraseña"
# En Authentication → Users: agregar el usuario admin
#
# NOTA: La Web API Key es pública por diseño (el SDK la expone en el browser).
# Para mayor seguridad, restringila en Google Cloud Console → APIs y Servicios →
# Credenciales → seleccionar la API key → Restricciones de aplicación.
#
PUBLIC_FIREBASE_API_KEY=your_web_api_key
PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
PUBLIC_FIREBASE_PROJECT_ID=your-project-id
PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
PUBLIC_FIREBASE_APP_ID=1:123456789:web:abcdef123456
PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX
ADMIN_ALLOWED_EMAILS=admin1@tu-dominio.com,admin2@tu-dominio.com

# ─── Pedidos / tokens públicos ────────────────────────────────────────────────
ORDER_PUBLIC_TOKEN_SECRET=change_me_with_a_long_random_secret

# ─── Notificaciones por email (Resend) ───────────────────────────────────────
RESEND_API_KEY=re_your_api_key
RESEND_FROM_EMAIL=Guacamole Shop <pedidos@tu-dominio.com>
RESEND_FROM_NAME=Guacamole Shop
RESEND_DEV_TO_OVERRIDE=qa@tu-dominio.com

# ─── Notificaciones por WhatsApp (Cloud API) ─────────────────────────────────
WHATSAPP_CLOUD_API_TOKEN=your_whatsapp_cloud_token
WHATSAPP_CLOUD_PHONE_NUMBER_ID=your_phone_number_id

# ─── Comercio / backoffice notifications ──────────────────────────────────────
ORDER_NOTIFICATIONS_ADMIN_EMAIL=jfsoftware@hotmail.com
ORDER_NOTIFICATIONS_ADMIN_WHATSAPP=573502018487
# Mantener en false por ahora para conservar el flujo email-only.
# Cambiar a true cuando quieras reactivar los envíos reales por WhatsApp.
ORDER_NOTIFICATIONS_WHATSAPP_ENABLED=false

# ─── Runtime SSR / Railway ─────────────────────────────────────────────────────
# Railway inyecta PORT automáticamente. Con Astro Node standalone + server.host=true
# alcanza con usar `npm start` como comando de arranque.
