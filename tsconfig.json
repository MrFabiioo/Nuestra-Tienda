{
  "extends": "astro/tsconfigs/strict",
  "include": [
    ".astro/types.d.ts",
    "**/*"
  ],
  "exclude": [
    "dist"
  ],
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "preact",
    "baseUrl": ".",
    "paths": {
      "@layouts/*":["src/layouts/*"],
      "@interfaces/*":["src/interfaces/*"],
      "@utils/*":["src/utils/*"],
    }
  },
  
}