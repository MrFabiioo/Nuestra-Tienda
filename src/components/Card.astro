---
import type { ProductWithImages } from '../interfaces/products-with-images.interface';

interface Props {
    product: ProductWithImages;
}

const product = Astro.props;
// Support both flat structure and legacy nested structure
const displayProduct = product.product ?? product;
const currentImage = displayProduct.images.split(',');
---

<article class="product-card group relative overflow-hidden rounded-2xl border border-neutral-100 bg-white shadow-sm transition-all duration-300 ease-out hover:-translate-y-1 hover:border-neutral-200 hover:shadow-lg hover:shadow-neutral-200/80">
    <a href={`products/${displayProduct.slug}`} class="flex flex-col h-full">
        <!-- Imagen con proporción fija -->
        <div class="relative aspect-[4/3] overflow-hidden bg-neutral-50">
            <img
                src={currentImage[0]}
                alt={displayProduct.title}
                class="w-full h-full object-cover transition-transform duration-500 ease-out group-hover:scale-[1.04]"
                loading="lazy"
            />
            
            <!-- Tag artesanal -->
            <span class="absolute top-3 left-3 bg-guacamole-b text-white text-[10px] font-bold tracking-widest uppercase px-2.5 py-1 rounded-full shadow-sm">
                Artesanal
            </span>
        </div>

        <!-- Contenido -->
        <div class="flex flex-grow flex-col gap-1 px-4 pb-4 pt-4 sm:px-5 sm:pb-5">
            <!-- Título -->
            <h3 class="text-base font-bold text-neutral-900 leading-snug line-clamp-2 group-hover:text-guacamole-b transition-colors duration-200">
                {displayProduct.title}
            </h3>
            
            <!-- Descripción -->
            <p class="text-sm text-neutral-500 leading-relaxed line-clamp-2 flex-grow mt-1">
                {displayProduct.description}
            </p>
            
            <!-- Precio y CTA -->
            <div class="mt-3 flex items-center justify-between gap-3 sm:mt-4">
                <span class="text-lg font-bold tracking-tight text-guacamole-a sm:text-xl">
                    ${displayProduct.price.toLocaleString()}
                </span>
                <span class="inline-flex items-center gap-1.5 rounded-full bg-guacamole-b px-3.5 py-2 text-sm font-semibold text-white transition-all duration-200 group-hover:bg-guacamole-a group-hover:shadow-md group-hover:shadow-guacamole-a/25 sm:px-4">
                    Ver más
                    <svg class="w-3.5 h-3.5 transition-transform duration-200 group-hover:translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/>
                    </svg>
                </span>
            </div>
        </div>
    </a>
</article>

<style>
    .product-card {
        min-height: 320px;
        display: flex;
        flex-direction: column;
    }
</style>
