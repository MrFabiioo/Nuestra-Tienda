---
import type { ProductWithImages } from '../interfaces/products-with-images.interface';

interface Props {
    product: ProductWithImages;
}

const product = Astro.props;
// Support both flat structure and legacy nested structure
const displayProduct = product.product ?? product;
const currentImage = displayProduct.images.split(',');
---

<article class="product-card product-card-theme group relative overflow-hidden rounded-2xl transition-all duration-300 ease-out hover:-translate-y-1">
    <a href={`products/${displayProduct.slug}`} class="flex flex-col h-full">
        <!-- Imagen con proporción fija -->
        <div class="product-card__media relative aspect-[4/3] overflow-hidden">
            <img
                src={currentImage[0]}
                alt={displayProduct.title}
                class="w-full h-full object-cover transition-transform duration-500 ease-out group-hover:scale-[1.04]"
                loading="lazy"
            />
            
            <!-- Tag artesanal -->
            <span class="product-card__badge absolute left-3 top-3 rounded-full px-2.5 py-1 text-[10px] font-bold uppercase tracking-widest shadow-sm">
                Artesanal
            </span>
        </div>

        <!-- Contenido -->
        <div class="flex flex-grow flex-col gap-1 px-4 pb-4 pt-4 sm:px-5 sm:pb-5">
            <!-- Título -->
            <h3 class="product-card__title text-base font-bold leading-snug line-clamp-2 transition-colors duration-200 group-hover:text-guacamole-b">
                {displayProduct.title}
            </h3>
            
            <!-- Descripción -->
            <p class="product-card__description mt-1 flex-grow line-clamp-2 text-sm leading-relaxed">
                {displayProduct.description}
            </p>
            
            <!-- Precio y CTA -->
            <div class="mt-3 flex items-center justify-between gap-3 sm:mt-4">
                <span class="product-card__price text-lg font-bold tracking-tight sm:text-xl">
                    ${displayProduct.price.toLocaleString()}
                </span>
                <span class="product-card__cta inline-flex items-center gap-1.5 rounded-full px-3.5 py-2 text-sm font-semibold transition-all duration-200 sm:px-4">
                    Ver más
                    <svg class="w-3.5 h-3.5 transition-transform duration-200 group-hover:translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/>
                    </svg>
                </span>
            </div>
        </div>
    </a>
</article>

<style>
    .product-card {
        min-height: 320px;
        height: 100%;
        display: flex;
        flex-direction: column;
    }

    .product-card-theme {
        border: 1px solid var(--color-border);
        background: color-mix(in srgb, var(--color-surface-elevated) 94%, transparent);
        box-shadow: 0 12px 28px var(--color-shadow-soft);
    }

    .product-card-theme:hover {
        border-color: var(--color-border-strong);
        box-shadow: 0 16px 32px var(--color-shadow-strong);
    }

    .product-card__media {
        background: color-mix(in srgb, var(--color-surface) 92%, var(--color-accent) 8%);
    }

    .product-card__badge {
        background: linear-gradient(135deg, var(--color-accent) 0%, var(--color-accent-strong) 100%);
        color: var(--color-text-on-accent);
    }

    .product-card__title {
        color: var(--color-text);
    }

    .product-card__description {
        color: var(--color-text-muted);
    }

    .product-card__price {
        color: var(--color-accent);
    }

    .product-card__cta {
        background: linear-gradient(135deg, var(--color-accent) 0%, var(--color-accent-strong) 100%);
        color: var(--color-text-on-accent);
        box-shadow: 0 8px 18px color-mix(in srgb, var(--color-accent) 22%, transparent);
    }

    .group:hover .product-card__cta {
        background: linear-gradient(135deg, var(--color-accent-strong) 0%, var(--color-accent) 100%);
        box-shadow: 0 12px 22px color-mix(in srgb, var(--color-accent-strong) 28%, transparent);
    }
</style>
