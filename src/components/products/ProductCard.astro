---
import { resolveProductImageUrl } from '@utils/product-images';
import { parseProductSizes } from '@utils/product-sizes';

interface Props {
  id?: string;
  name: string;
  price: number;
  description: string;
  image: string;
  sizes?: string;
  slug?: string;
  borderColor?: string;
  isEnabled?: boolean;
}

const {
  id,
  name,
  price,
  description,
  image,
  sizes = '',
  slug = "#",
  isEnabled = true,
} = Astro.props;

const resolvedImage = resolveProductImageUrl(image, {
  baseUrl: import.meta.env.PUBLIC_URL,
});
const availableSizes = parseProductSizes(sizes);
const quickAddSize = availableSizes.length === 1 ? availableSizes[0] : null;
---

<article
  class:list={["product-card group relative overflow-hidden rounded-2xl border transition-all duration-300 ease-out", { "product-card--disabled": !isEnabled, "hover:-translate-y-1": isEnabled }]}
>
  <a href={slug} class="flex flex-col h-full">
    <!-- Imagen -->
    <div class="product-card__media relative aspect-[4/3] overflow-hidden">
      <img
        src={resolvedImage}
        alt={name}
        class="w-full h-full object-cover transition-transform duration-500 ease-out group-hover:scale-[1.04]"
        width="640"
        height="480"
        sizes="(min-width: 1280px) 18rem, (min-width: 640px) 50vw, 100vw"
        loading="lazy"
        decoding="async"
      />

      {isEnabled ? (
        <span class="absolute top-3 left-3 bg-guacamole-b text-white text-[10px] font-bold tracking-widest uppercase px-2.5 py-1 rounded-full shadow-sm">
          Artesanal
        </span>
      ) : (
        <span class="absolute top-3 left-3 bg-neutral-500 text-white text-[10px] font-bold tracking-widest uppercase px-2.5 py-1 rounded-full shadow-sm">
          Próximamente
        </span>
      )}

      {!isEnabled && (
        <div class="product-card__disabled-overlay absolute inset-0 flex items-center justify-center">
          <span class="rounded-xl bg-black/60 px-4 py-2 text-xs font-bold uppercase tracking-widest text-white backdrop-blur-sm">
            Producto no disponible
          </span>
        </div>
      )}
    </div>

    <!-- Contenido -->
    <div class="flex flex-col flex-grow gap-1 px-4 pb-4 pt-4 sm:px-5 sm:pb-5">
      <!-- Nombre -->
      <div class="flex items-start gap-2">
        <h3 class="product-card__title text-base font-bold leading-snug line-clamp-2 group-hover:text-guacamole-b transition-colors duration-200">
          {name}
        </h3>
      </div>

      <!-- Descripción -->
      <p class="product-card__description text-sm leading-relaxed line-clamp-2 mt-1 flex-grow">
        {description}
      </p>

      <!-- Precio y CTA — siempre pegado al fondo del contenido -->
      <div class="mt-3 flex items-center justify-between gap-3 sm:mt-4">
        <span class="product-card__price text-lg font-bold tracking-tight text-guacamole-a sm:text-xl">
          ${price.toLocaleString()}
        </span>
        {isEnabled ? (
          <span class="product-card__link-pill inline-flex items-center gap-1.5 rounded-full bg-guacamole-b px-3.5 py-2 text-sm font-semibold text-white transition-all duration-200 group-hover:bg-guacamole-a group-hover:shadow-md group-hover:shadow-guacamole-a/25 sm:px-4">
            Ver más
            <svg class="w-3.5 h-3.5 transition-transform duration-200 group-hover:translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/>
            </svg>
          </span>
        ) : (
          <span class="inline-flex items-center gap-1.5 rounded-full bg-neutral-300 px-3.5 py-2 text-sm font-semibold text-neutral-500 sm:px-4 dark:bg-neutral-700 dark:text-neutral-400">
            Próximamente
          </span>
        )}
      </div>
    </div>
  </a>

  <!-- Botón agregar al carrito — solo visible si hay id de producto y está habilitado -->
  {id && !isEnabled && (
    <div class="product-card__cart-zone flex items-center justify-center border-t px-4 py-3">
      <span class="text-xs font-semibold uppercase tracking-wider text-neutral-400 dark:text-neutral-500">
        No disponible para compra
      </span>
    </div>
  )}

  {id && isEnabled && quickAddSize && (
    <div class="product-card__cart-zone add-to-cart-zone flex flex-col gap-3 border-t border-neutral-100 bg-neutral-50/60 px-4 py-3 sm:flex-row sm:items-center sm:justify-between sm:px-5">
      <!-- Selector de cantidad -->
      <div class="qty-control flex items-center gap-1">
        <button class="qty-btn qty-decrease flex h-11 w-11 items-center justify-center rounded-full border text-base font-bold transition-all hover:border-guacamole-b hover:bg-guacamole-b hover:text-white disabled:cursor-not-allowed disabled:opacity-40" data-action="decrease" aria-label="Disminuir cantidad">−</button>
        <span class="qty-value min-w-[20px] text-center text-sm font-semibold">1</span>
        <button class="qty-btn qty-increase flex h-11 w-11 items-center justify-center rounded-full border text-base font-bold transition-all hover:border-guacamole-b hover:bg-guacamole-b hover:text-white disabled:cursor-not-allowed disabled:opacity-40" data-action="increase" aria-label="Aumentar cantidad">+</button>
      </div>

      <button 
        class="add-to-cart-btn flex min-h-11 w-full flex-1 items-center justify-center rounded-full bg-guacamole-b px-3 py-2 text-sm font-bold uppercase tracking-wide text-white transition-all duration-200 hover:bg-guacamole-a hover:shadow-md hover:shadow-guacamole-a/25 active:scale-[0.97] disabled:cursor-wait disabled:opacity-80 disabled:hover:bg-guacamole-b disabled:hover:shadow-none sm:w-auto"
        data-product-id={id}
        data-product-name={name}
        data-product-price={price}
        data-product-image={resolvedImage}
        data-product-size={quickAddSize}
        aria-live="polite"
      >
        Agregar
      </button>
    </div>
  )}

  {id && isEnabled && !quickAddSize && (
    <div class="product-card__cart-zone flex items-center justify-center border-t border-neutral-100 bg-neutral-50/60 px-4 py-3 sm:px-5">
      <a
        href={slug}
        class="flex min-h-11 w-full items-center justify-center rounded-full border border-guacamole-b/20 px-3 py-2 text-sm font-bold uppercase tracking-wide text-guacamole-a transition-all duration-200 hover:border-guacamole-b hover:bg-guacamole-b hover:text-white hover:shadow-md hover:shadow-guacamole-a/20"
      >
        Elegir tamaño
      </a>
    </div>
  )}
</article>

<script>
  import { cartItems } from "../../store/cart.store";
  import { CartCookiesClient } from "@utils/cart-cookies";
  import { emitCartFeedback, emitCartOpen } from "@utils/cart-feedback";

  document.addEventListener('astro:page-load', initProductCards);
  document.addEventListener('astro:beforematch', initProductCards);

  function initProductCards() {
    initAddToCartButtons();
    initQuantitySelectors();
  }

  function initAddToCartButtons() {
    const buttons = document.querySelectorAll<HTMLButtonElement>('.add-to-cart-zone .add-to-cart-btn[data-product-id]');
    
    buttons.forEach((button) => {
      if ((button as any).__cartInitialized) return;
      (button as any).__cartInitialized = true;

      button.addEventListener('click', (e) => {
        if (!button.dataset.productId) return;

        e.preventDefault();
        e.stopPropagation();
        
        const btn = button as HTMLButtonElement;
        if (btn.disabled) return;

        const productId = btn.dataset.productId;
        const productName = btn.dataset.productName;
        const productPrice = parseFloat(btn.dataset.productPrice || '0');
        const productImage = btn.dataset.productImage;
        const productSize = btn.dataset.productSize;
        
        if (!productId || !productSize) return;
        
        const zone = btn.closest('.add-to-cart-zone');
        const qtyDisplay = zone?.querySelector('.qty-value');
        const currentCart = CartCookiesClient.getCart();
        const existingItem = currentCart.find(
          (item) => item.productId === productId && item.size === productSize
        );
        const quantity = parseInt(qtyDisplay?.textContent || '1', 10);

        btn.disabled = true;
        btn.setAttribute('aria-busy', 'true');
        btn.textContent = 'Agregando...';
        
        const cart = CartCookiesClient.addItem({
          productId,
          size: productSize,
          quantity,
          name: productName,
          price: productPrice,
          image: productImage
        });
        
        cartItems.set(cart);
        emitCartFeedback({
          type: 'add',
          productName,
          quantity,
          size: productSize,
          totalItems: cart.reduce((total, item) => total + item.quantity, 0),
          message: existingItem
            ? `Agregamos ${quantity} ${quantity === 1 ? 'unidad' : 'unidades'} más a tu selección.`
            : `Ya está en tu carrito para que sigas comprando con tranquilidad.`,
        });
        emitCartOpen();
        
        // Feedback visual
        btn.textContent = existingItem ? `+${quantity} más` : '✓ Agregado';
        btn.classList.remove('bg-guacamole-b');
        btn.classList.add('bg-guacamole-a');
        btn.setAttribute('aria-label', `${productName} agregado al carrito`);
        setTimeout(() => {
          btn.textContent = 'Agregar';
          btn.setAttribute('aria-label', `Agregar ${productName} al carrito`);
          btn.removeAttribute('aria-busy');
          btn.disabled = false;
          btn.classList.remove('bg-guacamole-a');
          btn.classList.add('bg-guacamole-b');
        }, 1500);
        
        // Reset qty
        if (qtyDisplay) {
          qtyDisplay.textContent = '1';
          const decBtn = zone?.querySelector('.qty-decrease') as HTMLButtonElement;
          const incBtn = zone?.querySelector('.qty-increase') as HTMLButtonElement;
          if (decBtn) decBtn.disabled = true;
          if (incBtn) incBtn.disabled = false;
        }
      });
    });
  }
  
  function initQuantitySelectors() {
    const zones = document.querySelectorAll('.add-to-cart-zone');
    
    zones.forEach((zone) => {
      if ((zone as any).__qtyInitialized) return;
      (zone as any).__qtyInitialized = true;

      const decreaseBtn = zone.querySelector('.qty-decrease') as HTMLButtonElement;
      const increaseBtn = zone.querySelector('.qty-increase') as HTMLButtonElement;
      const qtyDisplay = zone.querySelector('.qty-value') as HTMLSpanElement;
      
      if (!decreaseBtn || !increaseBtn || !qtyDisplay) return;
      
      decreaseBtn.disabled = true;
      
      decreaseBtn.addEventListener('click', (e) => {
        e.stopPropagation();
        e.preventDefault();
        
        let qty = parseInt(qtyDisplay.textContent || '1', 10);
        if (qty > 1) {
          qty--;
          qtyDisplay.textContent = String(qty);
          decreaseBtn.disabled = qty <= 1;
          increaseBtn.disabled = false;
        }
      });
      
      increaseBtn.addEventListener('click', (e) => {
        e.stopPropagation();
        e.preventDefault();
        
        let qty = parseInt(qtyDisplay.textContent || '1', 10);
        if (qty < 5) {
          qty++;
          qtyDisplay.textContent = String(qty);
          increaseBtn.disabled = qty >= 5;
          decreaseBtn.disabled = false;
        }
      });
    });
  }
</script>

<style>
  .product-card {
    min-height: 280px;
    display: flex;
    flex-direction: column;
    background: color-mix(in srgb, var(--color-surface-elevated) 96%, transparent);
    border-color: var(--color-border);
    box-shadow: 0 12px 28px var(--color-shadow-soft);
  }

  .product-card:hover {
    border-color: var(--color-border-strong);
    box-shadow: 0 18px 36px var(--color-shadow-soft);
  }

  .product-card--disabled {
    filter: grayscale(1);
    opacity: 0.72;
    cursor: default;
  }

  .product-card--disabled:hover {
    border-color: var(--color-border);
    box-shadow: 0 12px 28px var(--color-shadow-soft);
    transform: none;
  }

  .product-card__disabled-overlay {
    background: linear-gradient(
      to bottom,
      transparent 40%,
      rgba(0, 0, 0, 0.35) 100%
    );
  }

  .product-card__media {
    background: color-mix(in srgb, var(--color-surface-soft) 62%, var(--color-surface) 38%);
  }

  .product-card__title {
    color: var(--color-text);
  }

  .product-card__description {
    color: var(--color-text-muted);
  }

  .product-card__price {
    color: var(--color-accent);
  }

  .product-card__link-pill {
    color: var(--color-text-on-accent);
  }

  .product-card__cart-zone {
    border-top-color: var(--color-border);
    background: color-mix(in srgb, var(--color-surface-soft) 58%, var(--color-surface) 42%);
  }

  .qty-btn {
    background: color-mix(in srgb, var(--color-surface-elevated) 96%, transparent);
    border-color: var(--color-border);
    color: var(--color-text-muted);
  }

  .qty-value {
    color: var(--color-text);
  }
</style>
