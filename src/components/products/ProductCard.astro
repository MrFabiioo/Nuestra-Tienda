---
interface Props {
  id?: string;
  name: string;
  price: number;
  description: string;
  image: string;
  slug?: string;
  borderColor?: string;
}

const {
  id,
  name,
  price,
  description,
  image,
  slug = "#",
} = Astro.props;
---

<article 
  class="product-card group relative bg-white rounded-2xl border border-neutral-100 shadow-sm overflow-hidden transition-all duration-300 ease-out hover:-translate-y-1 hover:shadow-lg hover:shadow-neutral-200/80 hover:border-neutral-200"
>
  <a href={slug} class="flex flex-col">
    <!-- Imagen -->
    <div class="relative aspect-[4/3] overflow-hidden bg-neutral-50">
      <img
        src={image}
        alt={name}
        class="w-full h-full object-cover transition-transform duration-500 ease-out group-hover:scale-[1.04]"
        loading="lazy"
      />

      <!-- Tag artesanal — identidad de marca -->
      <span class="absolute top-3 left-3 bg-guacamole-b text-white text-[10px] font-bold tracking-widest uppercase px-2.5 py-1 rounded-full shadow-sm">
        Artesanal
      </span>
    </div>

    <!-- Contenido -->
    <div class="px-5 pt-4 pb-5 flex flex-col gap-1">
      <!-- Nombre -->
      <div class="flex items-start gap-2">
        <h3 class="text-base font-bold text-neutral-900 leading-snug line-clamp-2 group-hover:text-guacamole-b transition-colors duration-200">
          {name}
        </h3>
      </div>

      <!-- Descripción -->
      <p class="text-sm text-neutral-500 leading-relaxed line-clamp-2 mt-1">
        {description}
      </p>

      <!-- Precio y CTA -->
      <div class="mt-4 flex items-center justify-between gap-3">
        <span class="text-xl font-bold text-guacamole-a tracking-tight">
          ${price.toLocaleString()}
        </span>
        <span class="inline-flex items-center gap-1.5 px-4 py-2 bg-guacamole-b text-white text-sm font-semibold rounded-full transition-all duration-200 group-hover:bg-guacamole-a group-hover:shadow-md group-hover:shadow-guacamole-a/25">
          Ver más
          <svg class="w-3.5 h-3.5 transition-transform duration-200 group-hover:translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/>
          </svg>
        </span>
      </div>
    </div>
  </a>

  <!-- Botón agregar al carrito — solo visible si hay id de producto -->
  {id && (
    <div class="add-to-cart-zone border-t border-neutral-100 px-5 py-3 flex items-center justify-between gap-3 bg-neutral-50/60">
      <!-- Selector de cantidad -->
      <div class="qty-control flex items-center gap-1">
        <button class="qty-btn qty-decrease w-7 h-7 rounded-full border border-neutral-200 bg-white text-neutral-600 font-bold text-base flex items-center justify-center transition-all hover:bg-guacamole-b hover:text-white hover:border-guacamole-b disabled:opacity-40 disabled:cursor-not-allowed" data-action="decrease" aria-label="Disminuir cantidad">−</button>
        <span class="qty-value min-w-[20px] text-center text-sm font-semibold text-neutral-700">1</span>
        <button class="qty-btn qty-increase w-7 h-7 rounded-full border border-neutral-200 bg-white text-neutral-600 font-bold text-base flex items-center justify-center transition-all hover:bg-guacamole-b hover:text-white hover:border-guacamole-b disabled:opacity-40 disabled:cursor-not-allowed" data-action="increase" aria-label="Aumentar cantidad">+</button>
      </div>

      <button 
        class="add-to-cart-btn flex-1 bg-guacamole-b text-white text-sm font-bold py-2 px-3 rounded-full tracking-wide uppercase transition-all duration-200 hover:bg-guacamole-a hover:shadow-md hover:shadow-guacamole-a/25 active:scale-[0.97]"
        data-product-id={id}
        data-product-name={name}
        data-product-price={price}
        data-product-image={image}
      >
        Agregar
      </button>
    </div>
  )}
</article>

<script>
  import { cartItems } from "src/store/cart.store";
  import { CartCookiesClient } from "src/utils/cart-cookies";
  import { emitCartFeedback, emitCartOpen } from "src/utils/cart-feedback";

  document.addEventListener('astro:page-load', initProductCards);
  document.addEventListener('astro:beforematch', initProductCards);

  function initProductCards() {
    initAddToCartButtons();
    initQuantitySelectors();
  }

  function initAddToCartButtons() {
    const buttons = document.querySelectorAll('.add-to-cart-btn');
    
    buttons.forEach((button) => {
      if ((button as any).__cartInitialized) return;
      (button as any).__cartInitialized = true;

      button.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();
        
        const btn = button as HTMLButtonElement;
        const productId = btn.dataset.productId;
        const productName = btn.dataset.productName;
        const productPrice = parseFloat(btn.dataset.productPrice || '0');
        const productImage = btn.dataset.productImage;
        
        if (!productId) return;
        
        const zone = btn.closest('.add-to-cart-zone');
        const qtyDisplay = zone?.querySelector('.qty-value');
        const currentCart = CartCookiesClient.getCart();
        const existingItem = currentCart.find(
          (item) => item.productId === productId && item.size === 'Normal'
        );
        const quantity = parseInt(qtyDisplay?.textContent || '1', 10);
        
        const cart = CartCookiesClient.addItem({
          productId,
          size: 'Normal',
          quantity,
          name: productName,
          price: productPrice,
          image: productImage
        });
        
        cartItems.set(cart);
        emitCartFeedback({
          type: 'add',
          productName,
          quantity,
          size: 'Normal',
          totalItems: cart.reduce((total, item) => total + item.quantity, 0),
          message: existingItem
            ? `Le sumamos ${quantity} ${quantity === 1 ? 'unidad' : 'unidades'} más a tu selección.`
            : `Quedó listo en tu mini carrito para que sigas comprando sin fricción.`,
        });
        emitCartOpen();
        
        // Feedback visual
        btn.textContent = existingItem ? `+${quantity} más` : '✓ Agregado';
        btn.classList.remove('bg-guacamole-b');
        btn.classList.add('bg-guacamole-a');
        btn.setAttribute('aria-label', `${productName} agregado al carrito`);
        setTimeout(() => {
          btn.textContent = 'Agregar';
          btn.setAttribute('aria-label', `Agregar ${productName} al carrito`);
          btn.classList.remove('bg-guacamole-a');
          btn.classList.add('bg-guacamole-b');
        }, 1500);
        
        // Reset qty
        if (qtyDisplay) {
          qtyDisplay.textContent = '1';
          const decBtn = zone?.querySelector('.qty-decrease') as HTMLButtonElement;
          const incBtn = zone?.querySelector('.qty-increase') as HTMLButtonElement;
          if (decBtn) decBtn.disabled = true;
          if (incBtn) incBtn.disabled = false;
        }
      });
    });
  }
  
  function initQuantitySelectors() {
    const zones = document.querySelectorAll('.add-to-cart-zone');
    
    zones.forEach((zone) => {
      if ((zone as any).__qtyInitialized) return;
      (zone as any).__qtyInitialized = true;

      const decreaseBtn = zone.querySelector('.qty-decrease') as HTMLButtonElement;
      const increaseBtn = zone.querySelector('.qty-increase') as HTMLButtonElement;
      const qtyDisplay = zone.querySelector('.qty-value') as HTMLSpanElement;
      
      if (!decreaseBtn || !increaseBtn || !qtyDisplay) return;
      
      decreaseBtn.disabled = true;
      
      decreaseBtn.addEventListener('click', (e) => {
        e.stopPropagation();
        e.preventDefault();
        
        let qty = parseInt(qtyDisplay.textContent || '1', 10);
        if (qty > 1) {
          qty--;
          qtyDisplay.textContent = String(qty);
          decreaseBtn.disabled = qty <= 1;
          increaseBtn.disabled = false;
        }
      });
      
      increaseBtn.addEventListener('click', (e) => {
        e.stopPropagation();
        e.preventDefault();
        
        let qty = parseInt(qtyDisplay.textContent || '1', 10);
        if (qty < 5) {
          qty++;
          qtyDisplay.textContent = String(qty);
          increaseBtn.disabled = qty >= 5;
          decreaseBtn.disabled = false;
        }
      });
    });
  }
</script>

<style>
  .product-card {
    min-height: 300px;
    display: flex;
    flex-direction: column;
  }
</style>
