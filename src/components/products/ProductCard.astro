---
interface Props {
  id: string;
  name: string;
  price: number;
  description: string;
  image: string;
  slug?: string;
  rating?: number;
  borderColor?: string;
  tag?: string;
}

const {
  id,
  name,
  price,
  description,
  image,
  slug = "#",
  rating = 5,
  borderColor = "#568203",
  tag = "ARTESANAL"
} = Astro.props;

const stars = "★".repeat(rating) + "☆".repeat(5 - rating);
---

<div 
  class="product-card group relative w-full max-w-[280px] mx-auto bg-white/60 backdrop-blur-xl border-4 rounded-3xl shadow-[0_4px_40px_-8px_rgba(0,0,0,0.15)] transition-all duration-500 hover:shadow-[0_8px_60px_-4px_rgba(0,0,0,0.25)] hover:-translate-y-1 hover:scale-[1.015] cursor-pointer"
  style={{ borderColor }}
>
  <!-- Inner wrapper: clips image and tag, allows button to protrude -->
  <div class="card-inner overflow-hidden rounded-[inherit]">
    <a href={slug}>
      <!-- Imagen con proporción dorada (φ ≈ 1.618) -->
      <div class="card-image relative aspect-[1/0.618] overflow-hidden">
        <img
          src={image}
          alt={name}
          class="w-full h-full object-cover transition-transform duration-[1600ms] ease-[cubic-bezier(0.19,1,0.22,1)] group-hover:scale-110"
        />
    
        <!-- Degradado suave -->
        <div class="absolute inset-0 bg-gradient-to-t from-black/40 via-black/10 to-transparent"></div>
    
        <!-- Precio flotante -->
        <span class="absolute bottom-4 left-4 text-sm tracking-wide font-semibold text-neutral-900 bg-white/70 backdrop-blur-md border border-white/40 rounded-full px-4 py-1 shadow-sm">
          ${price.toLocaleString()}
        </span>

        <!-- Boton Comprar (hover) -->
        <a 
          href={slug}
          class="absolute bottom-0 left-0 right-0 bg-guacamole-pulpa text-white text-center font-bold text-sm py-3 tracking-wider uppercase opacity-0 group-hover:opacity-100 transition-all duration-300 hover:bg-guacamole-f hover:scale-[1.02]"
        >
          Ver producto
        </a>
      </div>
    
      <!-- Contenido con altura consistente -->
      <div class="card-content px-5 py-6 flex flex-col gap-2.5 min-h-[140px]">
        <div class="flex items-center justify-between gap-2">
          <h3 class="text-lg font-semibold tracking-tight text-neutral-900 line-clamp-1">
            {name}
          </h3>
          <span class="text-lg text-guacamole-pulpa font-semibold shrink-0">
            {stars}
          </span>
        </div>
        <p class="text-sm text-neutral-600 leading-relaxed line-clamp-3 mt-auto">
          {description}
        </p>
      </div>
    
      <!-- Tag o sello -->
      <span class="absolute top-6 right-[-42px] rotate-45 bg-black text-guacamole-pulpa text-[10px] tracking-[0.2em] font-mono px-10 py-1 shadow-[2px_2px_0px_rgba(0,0,0,0.7)] text-center z-50">
        {tag}
      </span>
      
      <!-- Detalle visual sutil -->
      <div class="absolute inset-0 pointer-events-none rounded-3xl border border-white/20"></div>
    </a>
  </div>
  
  <!-- Botón Agregar al carrito (semicircular, sobresale por el borde inferior) -->
  <div class="add-to-cart-wrapper">
    <!-- Selector de cantidad -->
    <div class="quantity-selector">
      <button class="qty-btn qty-decrease" data-action="decrease" aria-label="Disminuir cantidad">−</button>
      <span class="qty-value">1</span>
      <button class="qty-btn qty-increase" data-action="increase" aria-label="Aumentar cantidad">+</button>
    </div>
    
    <button 
      class="add-to-cart-btn bg-guacamole-pulpa text-white text-center font-bold text-sm py-3 tracking-wider uppercase hover:bg-guacamole-f transition-all duration-300"
      data-product-id={id}
      data-product-name={name}
      data-product-price={price}
      data-product-image={image}
    >
      Agregar
    </button>
  </div>
</div>

<input type="hidden" id="product-sizes-{id}" value="chico,mediano,grande" />

<script>
  import { navigate } from "astro:transitions/client";
  import { cartItems } from "src/store/cart.store";
  import { CartCookiesClient } from "src/utils/cart-cookies";

  document.addEventListener('astro:page-load', initAddToCartButtons);
  document.addEventListener('astro:beforematch', initAddToCartButtons);

  function initAddToCartButtons() {
    const buttons = document.querySelectorAll('.add-to-cart-btn');
    
    buttons.forEach((button) => {
      button.addEventListener('click', async (e) => {
        e.preventDefault();
        e.stopPropagation();
        
        const btn = button as HTMLButtonElement;
        const productId = btn.dataset.productId;
        const productName = btn.dataset.productName;
        const productPrice = parseFloat(btn.dataset.productPrice || '0');
        const productImage = btn.dataset.productImage;
        
        if (!productId) return;
        
        // Get sizes from hidden input (default to "chico,mediano,grande" if not found)
        const sizesInput = document.querySelector(`#product-sizes-${productId}`) as HTMLInputElement;
        const sizes = sizesInput?.value?.split(',') || ['Normal', 'mediano', 'grande'];
        
        // Use first available size
        const selectedSize = sizes[0];
        
        // Get quantity from sibling quantity selector
        const wrapper = btn.closest('.add-to-cart-wrapper');
        const qtyDisplay = wrapper?.querySelector('.qty-value');
        const quantity = parseInt(qtyDisplay?.textContent || '1', 10);
        
        const cart = CartCookiesClient.addItem({
          productId: productId,
          size: selectedSize,
          quantity: quantity,
          name: productName,
          price: productPrice,
          image: productImage
        });
        
        cartItems.set(cart);
        
        // Optional: show feedback
        btn.textContent = '✓ Agregado';
        setTimeout(() => {
          btn.textContent = 'Agregar';
        }, 1500);
        
        // Reset quantity to 1 after adding
        const qtyDecrease = wrapper?.querySelector('.qty-decrease') as HTMLButtonElement;
        const qtyIncrease = wrapper?.querySelector('.qty-increase') as HTMLButtonElement;
        if (qtyDisplay) {
          qtyDisplay.textContent = '1';
          // Update button states
          if (qtyDecrease) qtyDecrease.disabled = true;
          if (qtyIncrease) qtyIncrease.disabled = false;
        }
        
        // Navigate to cart (optional - can be removed if not desired)
        // await navigate('/cart');
      });
    });
    
    // Initialize quantity selector buttons
    initQuantitySelectors();
  }
  
  function initQuantitySelectors() {
    const wrappers = document.querySelectorAll('.add-to-cart-wrapper');
    
    wrappers.forEach((wrapper) => {
      const decreaseBtn = wrapper.querySelector('.qty-decrease') as HTMLButtonElement;
      const increaseBtn = wrapper.querySelector('.qty-increase') as HTMLButtonElement;
      const qtyDisplay = wrapper.querySelector('.qty-value') as HTMLSpanElement;
      
      if (!decreaseBtn || !increaseBtn || !qtyDisplay) return;
      
      // Initialize button states
      decreaseBtn.disabled = true; // Start at quantity 1
      
      decreaseBtn.addEventListener('click', (e) => {
        e.stopPropagation(); // Prevent bubbling to add-to-cart button
        e.preventDefault();
        
        let currentQty = parseInt(qtyDisplay.textContent || '1', 10);
        if (currentQty > 1) {
          currentQty--;
          qtyDisplay.textContent = currentQty.toString();
          decreaseBtn.disabled = currentQty <= 1;
          increaseBtn.disabled = false;
        }
      });
      
      increaseBtn.addEventListener('click', (e) => {
        e.stopPropagation(); // Prevent bubbling to add-to-cart button
        e.preventDefault();
        
        let currentQty = parseInt(qtyDisplay.textContent || '1', 10);
        if (currentQty < 5) {
          currentQty++;
          qtyDisplay.textContent = currentQty.toString();
          increaseBtn.disabled = currentQty >= 5;
          decreaseBtn.disabled = false;
        }
      });
    });
  }
</script>

<style>
  /* Tarjeta con proporción dorada para consistencia */
  .product-card {
    /* Altura fija para desktop, permitir flexibilidad en mobile */
    height: 100%;
    min-height: 380px;
    display: flex;
    flex-direction: column;
  }

  /* Inner wrapper: clips image and tag, allows button to protrude */
  .card-inner {
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  /* Imagen con proporción áurea (φ = 1.618) */
  .card-image {
    aspect-ratio: 1 / 0.618;
  }

  /* Contenido con altura mínima consistente */
  .card-content {
    min-height: 140px;
    flex: 1;
  }

  /* Botón Agregar al carrito */
  .add-to-cart-btn {
    border: none;
    cursor: pointer;
    flex-shrink: 0;
  }

  /* Wrapper para posicionar el botón semicircular */
  .add-to-cart-wrapper {
    position: absolute;
    bottom: -1rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 10;
    width: 70%;
    max-width: 160px;
  }

  /* Botón semicircular */
  .add-to-cart-btn {
    width: 100%;
    border-radius: 9999px;
    padding-top: 0.75rem;
    padding-bottom: 0.75rem;
    box-shadow: 0 4px 12px rgba(86, 130, 3, 0.3);
  }

  .add-to-cart-btn:hover {
    box-shadow: 0 6px 20px rgba(86, 130, 3, 0.4);
    transform: translateY(-1px);
  }

  .add-to-cart-btn:active {
    transform: scale(0.98);
  }

  /* Quantity selector */
  .quantity-selector {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.25rem;
    background: white;
    border-radius: 9999px;
    padding: 0.25rem;
    margin-bottom: 0.5rem;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
  }

  .qty-btn {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    border: none;
    background: #568203;
    color: white;
    font-size: 1rem;
    font-weight: bold;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s ease;
    line-height: 1;
  }

  .qty-btn:hover:not(:disabled) {
    background: #3d5f02;
    transform: scale(1.1);
  }

  .qty-btn:active:not(:disabled) {
    transform: scale(0.95);
  }

  .qty-btn:disabled {
    background: #d1d5db;
    color: #9ca3af;
    cursor: not-allowed;
  }

  .qty-value {
    min-width: 24px;
    text-align: center;
    font-weight: bold;
    font-size: 0.875rem;
    color: #374151;
  }

  @media (max-width: 640px) {
    .product-card {
      min-height: 320px;
    }
    
    .card-content {
      min-height: 120px;
    }
  }
</style>
