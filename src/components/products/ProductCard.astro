---
interface Props {
  name: string;
  price: number;
  description: string;
  image: string;
  slug?: string;
  rating?: number;
  borderColor?: string;
  tag?: string;
}

const {
  name,
  price,
  description,
  image,
  slug = "#",
  rating = 5,
  borderColor = "#568203",
  tag = "ARTESANAL"
} = Astro.props;

const stars = "★".repeat(rating) + "☆".repeat(5 - rating);
---

<div 
  class="group relative w-full max-w-[280px] mx-auto bg-white/60 backdrop-blur-xl border-4 rounded-3xl overflow-hidden shadow-[0_4px_40px_-8px_rgba(0,0,0,0.15)] transition-all duration-500 hover:shadow-[0_8px_60px_-4px_rgba(0,0,0,0.25)] hover:-translate-y-1 hover:scale-[1.015] cursor-pointer"
  style={{ borderColor }}
>
  <a href={slug}>
    <!-- Imagen -->
    <div class="relative aspect-[1/0.68] overflow-hidden">
      <img
        src={image}
        alt={name}
        class="w-full h-full object-cover transition-transform duration-[1600ms] ease-[cubic-bezier(0.19,1,0.22,1)] group-hover:scale-110"
      />
  
      <!-- Degradado suave -->
      <div class="absolute inset-0 bg-gradient-to-t from-black/40 via-black/10 to-transparent"></div>
  
      <!-- Precio flotante -->
      <span class="absolute bottom-4 left-4 text-sm tracking-wide font-semibold text-neutral-900 bg-white/70 backdrop-blur-md border border-white/40 rounded-full px-4 py-1 shadow-sm">
        ${price.toLocaleString()}
      </span>

      <!-- Boton Comprar -->
      <a 
        href={slug}
        class="absolute bottom-0 left-0 right-0 bg-guacamole-pulpa text-white text-center font-bold text-sm py-3 tracking-wider uppercase opacity-0 group-hover:opacity-100 transition-all duration-300 hover:bg-guacamole-f hover:scale-[1.02]"
      >
        Comprar Ahora
      </a>
    </div>
  
    <!-- Contenido -->
    <div class="px-5 py-6 flex flex-col gap-2.5">
      <div class="flex items-center justify-between">
        <h3 class="text-lg font-semibold tracking-tight text-neutral-900">
          {name}
        </h3>
        <span class="text-lg text-guacamole-pulpa font-semibold">
          {stars}
        </span>
      </div>
      <p class="text-sm text-neutral-600 leading-relaxed line-clamp-3">
        {description}
      </p>
    </div>
  
    <!-- Tag o sello -->
    <span class="absolute top-6 right-[-42px] rotate-45 bg-black text-guacamole-pulpa text-[10px] tracking-[0.2em] font-mono px-10 py-1 shadow-[2px_2px_0px_rgba(0,0,0,0.7)] text-center">
      {tag}
    </span>
  
    <!-- Detalle visual sutil -->
    <div class="absolute inset-0 pointer-events-none rounded-3xl border border-white/20"></div>
  </a>
</div>
