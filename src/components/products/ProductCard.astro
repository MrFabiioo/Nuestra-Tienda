---
import { resolveProductImageUrl } from '@utils/product-images';
import { parseProductSizes } from '@utils/product-sizes';

interface Props {
  id?: string;
  name: string;
  price: number;
  description: string;
  image: string;
  sizes?: string;
  slug?: string;
  borderColor?: string;
  isEnabled?: boolean;
}

const {
  id,
  name,
  price,
  description,
  image,
  sizes = '',
  slug = "#",
  isEnabled = true,
} = Astro.props;

const resolvedImage = resolveProductImageUrl(image, {
  baseUrl: import.meta.env.PUBLIC_URL,
});
const availableSizes = parseProductSizes(sizes);
const quickAddSize = availableSizes.length === 1 ? availableSizes[0] : null;
const needsSizeSelection = availableSizes.length > 1;
---

<article
  class:list={["product-card group relative overflow-hidden rounded-2xl border transition-all duration-300 ease-out", { "product-card--disabled": !isEnabled, "hover:-translate-y-1": isEnabled }]}
>
  <a href={slug} class="flex flex-col h-full">
    <!-- Imagen -->
    <div class="product-card__media relative aspect-[4/3] overflow-hidden">
      <img
        src={resolvedImage}
        alt={name}
        class="w-full h-full object-cover transition-transform duration-500 ease-out group-hover:scale-[1.04]"
        width="640"
        height="480"
        sizes="(min-width: 1280px) 18rem, (min-width: 640px) 50vw, 100vw"
        loading="lazy"
        decoding="async"
      />

      {isEnabled ? (
        <span class="absolute top-3 left-3 bg-guacamole-b text-white text-[10px] font-bold tracking-widest uppercase px-2.5 py-1 rounded-full shadow-sm">
          Artesanal
        </span>
      ) : (
        <span class="absolute top-3 left-3 bg-neutral-500 text-white text-[10px] font-bold tracking-widest uppercase px-2.5 py-1 rounded-full shadow-sm">
          Próximamente
        </span>
      )}

      {!isEnabled && (
        <div class="product-card__disabled-overlay absolute inset-0 flex items-center justify-center">
          <span class="rounded-xl bg-black/60 px-4 py-2 text-xs font-bold uppercase tracking-widest text-white backdrop-blur-sm">
            Producto no disponible
          </span>
        </div>
      )}
    </div>

    <!-- Contenido -->
    <div class="flex flex-col flex-grow gap-1 px-4 pb-4 pt-4 sm:px-5 sm:pb-5">
      <!-- Nombre -->
      <div class="flex items-start gap-2">
        <h3 class="product-card__title text-base font-bold leading-snug line-clamp-2 group-hover:text-guacamole-b transition-colors duration-200">
          {name}
        </h3>
      </div>

      <!-- Descripción -->
      <p class="product-card__description text-sm leading-relaxed line-clamp-2 mt-1 flex-grow">
        {description}
      </p>

      <!-- Precio y CTA — siempre pegado al fondo del contenido -->
      <div class="mt-3 flex items-center justify-between gap-3 sm:mt-4">
        <span class="product-card__price text-lg font-bold tracking-tight text-guacamole-a sm:text-xl">
          ${price.toLocaleString()}
        </span>
        {isEnabled ? (
          <span class="product-card__link-pill inline-flex items-center gap-1.5 rounded-full bg-guacamole-b px-3.5 py-2 text-sm font-semibold text-white transition-all duration-200 group-hover:bg-guacamole-a group-hover:shadow-md group-hover:shadow-guacamole-a/25 sm:px-4">
            Ver más
            <svg class="w-3.5 h-3.5 transition-transform duration-200 group-hover:translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/>
            </svg>
          </span>
        ) : (
          <span class="inline-flex items-center gap-1.5 rounded-full bg-neutral-300 px-3.5 py-2 text-sm font-semibold text-neutral-500 sm:px-4 dark:bg-neutral-700 dark:text-neutral-400">
            Próximamente
          </span>
        )}
      </div>
    </div>
  </a>

  <!-- Botón agregar al carrito — solo visible si hay id de producto y está habilitado -->
  {id && !isEnabled && (
    <div class="product-card__cart-zone flex items-center justify-center border-t px-4 py-3">
      <span class="text-xs font-semibold uppercase tracking-wider text-neutral-400 dark:text-neutral-500">
        No disponible para compra
      </span>
    </div>
  )}

  {id && isEnabled && quickAddSize && (
    <div class="product-card__cart-zone product-card__cart-zone--quick add-to-cart-zone border-t px-4 py-3 sm:px-5">
      <!-- Selector de cantidad -->
      <div class="product-card__cart-actions">
        <div class="qty-control product-card__qty-control" aria-label="Selector de cantidad">
          <button class="qty-btn product-card__qty-btn qty-decrease" data-action="decrease" aria-label="Disminuir cantidad">−</button>
          <span class="qty-value product-card__qty-value" aria-live="polite">1</span>
          <button class="qty-btn product-card__qty-btn qty-increase" data-action="increase" aria-label="Aumentar cantidad">+</button>
        </div>

        <button 
          class="add-to-cart-btn product-card__cart-button"
        data-product-id={id}
        data-product-name={name}
        data-product-price={price}
        data-product-image={resolvedImage}
        data-product-size={quickAddSize}
        aria-live="polite"
        >
          Agregar
        </button>
      </div>
    </div>
  )}

  {id && isEnabled && needsSizeSelection && (
    <div class="product-card__cart-zone product-card__cart-zone--select add-to-cart-zone border-t px-4 py-3 sm:px-5" data-requires-size="true">
      <div class="product-card__size-picker">
        <label class="product-card__size-label" for={`product-card-size-${id}`}>
          Elegí tamaño
        </label>

        <div class="product-card__size-select-wrap">
          <select
            id={`product-card-size-${id}`}
            class="product-card__size-select"
            data-size-selector
            aria-label={`Elegí tamaño para ${name}`}
          >
            <option value="">Seleccionar</option>
            {availableSizes.map((sizeOption) => (
              <option value={sizeOption}>{sizeOption}</option>
            ))}
          </select>
        </div>
      </div>

      <div class="product-card__cart-actions">
        <div class="qty-control product-card__qty-control" aria-label="Selector de cantidad">
          <button class="qty-btn product-card__qty-btn qty-decrease" data-action="decrease" aria-label="Disminuir cantidad">−</button>
          <span class="qty-value product-card__qty-value" aria-live="polite">1</span>
          <button class="qty-btn product-card__qty-btn qty-increase" data-action="increase" aria-label="Aumentar cantidad">+</button>
        </div>

        <button
          class="add-to-cart-btn product-card__cart-button"
          data-product-id={id}
          data-product-name={name}
          data-product-price={price}
          data-product-image={resolvedImage}
          aria-live="polite"
          disabled
          aria-disabled="true"
        >
          Elegí tamaño
        </button>
      </div>
    </div>
  )}
</article>

<script>
  import { cartItems } from "../../store/cart.store";
  import { CartCookiesClient } from "@utils/cart-cookies";
  import { emitCartFeedback, emitCartOpen } from "@utils/cart-feedback";
  import { bindDocumentEventOnce } from '../../utils/bind-document-event-once';

  initProductCards();
  bindDocumentEventOnce('astro:page-load', 'product-cards', initProductCards);
  bindDocumentEventOnce('astro:beforematch', 'product-cards-beforematch', initProductCards);

  function initProductCards() {
    initAddToCartButtons();
    initQuantitySelectors();
    initSizeSelectors();
  }

  function initAddToCartButtons() {
    const buttons = document.querySelectorAll<HTMLButtonElement>('.add-to-cart-zone .add-to-cart-btn[data-product-id]');
    
    buttons.forEach((button) => {
      if ((button as any).__cartInitialized) return;
      (button as any).__cartInitialized = true;

      button.addEventListener('click', (e) => {
        if (!button.dataset.productId) return;

        e.preventDefault();
        e.stopPropagation();
        
        const btn = button as HTMLButtonElement;
        if (btn.disabled) return;

        const productId = btn.dataset.productId;
        const productName = btn.dataset.productName;
        const productPrice = parseFloat(btn.dataset.productPrice || '0');
        const productImage = btn.dataset.productImage;
        const productSize = btn.dataset.productSize;
        
        if (!productId || !productSize) return;
        
        const zone = btn.closest('.add-to-cart-zone');
        const qtyDisplay = zone?.querySelector('.qty-value');
        const currentCart = CartCookiesClient.getCart();
        const existingItem = currentCart.find(
          (item) => item.productId === productId && item.size === productSize
        );
        const quantity = parseInt(qtyDisplay?.textContent || '1', 10);

        btn.disabled = true;
        btn.setAttribute('aria-busy', 'true');
        btn.textContent = 'Agregando...';
        
        const cart = CartCookiesClient.addItem({
          productId,
          size: productSize,
          quantity,
          name: productName,
          price: productPrice,
          image: productImage
        });
        
        cartItems.set(cart);
        emitCartFeedback({
          type: 'add',
          productName,
          quantity,
          size: productSize,
          totalItems: cart.reduce((total, item) => total + item.quantity, 0),
          message: existingItem
            ? `Agregamos ${quantity} ${quantity === 1 ? 'unidad' : 'unidades'} más a tu selección.`
            : `Ya está en tu carrito para que sigas comprando con tranquilidad.`,
        });
        emitCartOpen();
        
        // Feedback visual
        btn.textContent = existingItem ? `+${quantity} más` : '✓ Agregado';
        btn.classList.remove('bg-guacamole-b');
        btn.classList.add('bg-guacamole-a');
        btn.setAttribute('aria-label', `${productName} agregado al carrito`);
        setTimeout(() => {
          btn.textContent = 'Agregar';
          btn.setAttribute('aria-label', `Agregar ${productName} al carrito`);
          btn.removeAttribute('aria-busy');
          btn.disabled = false;
          btn.classList.remove('bg-guacamole-a');
          btn.classList.add('bg-guacamole-b');
        }, 1500);
        
        // Reset qty
        if (qtyDisplay) {
          qtyDisplay.textContent = '1';
          const decBtn = zone?.querySelector('.qty-decrease') as HTMLButtonElement;
          const incBtn = zone?.querySelector('.qty-increase') as HTMLButtonElement;
          if (decBtn) decBtn.disabled = true;
          if (incBtn) incBtn.disabled = false;
        }
      });
    });
  }
  
  function initQuantitySelectors() {
    const zones = document.querySelectorAll('.add-to-cart-zone');
    
    zones.forEach((zone) => {
      if ((zone as any).__qtyInitialized) return;
      (zone as any).__qtyInitialized = true;

      const decreaseBtn = zone.querySelector('.qty-decrease') as HTMLButtonElement;
      const increaseBtn = zone.querySelector('.qty-increase') as HTMLButtonElement;
      const qtyDisplay = zone.querySelector('.qty-value') as HTMLSpanElement;
      
      if (!decreaseBtn || !increaseBtn || !qtyDisplay) return;
      
      decreaseBtn.disabled = true;
      
      decreaseBtn.addEventListener('click', (e) => {
        e.stopPropagation();
        e.preventDefault();
        
        let qty = parseInt(qtyDisplay.textContent || '1', 10);
        if (qty > 1) {
          qty--;
          qtyDisplay.textContent = String(qty);
          decreaseBtn.disabled = qty <= 1;
          increaseBtn.disabled = false;
        }
      });
      
      increaseBtn.addEventListener('click', (e) => {
        e.stopPropagation();
        e.preventDefault();
        
        let qty = parseInt(qtyDisplay.textContent || '1', 10);
        if (qty < 5) {
          qty++;
          qtyDisplay.textContent = String(qty);
          increaseBtn.disabled = qty >= 5;
          decreaseBtn.disabled = false;
        }
      });
    });
  }

  function initSizeSelectors() {
    const zones = document.querySelectorAll<HTMLElement>('.add-to-cart-zone[data-requires-size="true"]');

    zones.forEach((zone) => {
      if ((zone as any).__sizeInitialized) return;
      (zone as any).__sizeInitialized = true;

      const sizeSelector = zone.querySelector<HTMLSelectElement>('[data-size-selector]');
      const addButton = zone.querySelector<HTMLButtonElement>('.add-to-cart-btn[data-product-id]');

      if (!sizeSelector || !addButton) return;

      const syncSelectedSize = () => {
        const selectedSize = sizeSelector.value.trim();

        if (!selectedSize) {
          delete addButton.dataset.productSize;
          addButton.disabled = true;
          addButton.setAttribute('aria-disabled', 'true');
          addButton.textContent = 'Elegí tamaño';
          addButton.setAttribute('aria-label', `Elegí tamaño para ${addButton.dataset.productName ?? 'producto'}`);
          return;
        }

        addButton.dataset.productSize = selectedSize;
        addButton.disabled = false;
        addButton.setAttribute('aria-disabled', 'false');
        addButton.textContent = 'Agregar';
        addButton.setAttribute('aria-label', `Agregar ${selectedSize} de ${addButton.dataset.productName ?? 'producto'} al carrito`);
      };

      sizeSelector.addEventListener('change', syncSelectedSize);
      syncSelectedSize();
    });
  }
</script>

<style>
  .product-card {
    min-height: 280px;
    display: flex;
    flex-direction: column;
    background: color-mix(in srgb, var(--color-surface-elevated) 96%, transparent);
    border-color: var(--color-border);
    box-shadow: 0 12px 28px var(--color-shadow-soft);
  }

  .product-card:hover {
    border-color: var(--color-border-strong);
    box-shadow: 0 18px 36px var(--color-shadow-soft);
  }

  .product-card--disabled {
    filter: grayscale(1);
    opacity: 0.72;
    cursor: default;
  }

  .product-card--disabled:hover {
    border-color: var(--color-border);
    box-shadow: 0 12px 28px var(--color-shadow-soft);
    transform: none;
  }

  .product-card__disabled-overlay {
    background: linear-gradient(
      to bottom,
      transparent 40%,
      rgba(0, 0, 0, 0.35) 100%
    );
  }

  .product-card__media {
    background: color-mix(in srgb, var(--color-surface-soft) 62%, var(--color-surface) 38%);
  }

  .product-card__title {
    color: var(--color-text);
  }

  .product-card__description {
    color: var(--color-text-muted);
  }

  .product-card__price {
    color: var(--color-accent);
  }

  .product-card__link-pill {
    color: var(--color-text-on-accent);
  }

  .product-card__cart-zone {
    border-top-color: var(--color-border);
    background:
      linear-gradient(180deg, color-mix(in srgb, var(--color-surface-soft) 62%, var(--color-surface) 38%) 0%, color-mix(in srgb, var(--color-surface-elevated) 94%, transparent) 100%);
  }

  .product-card__cart-zone--quick {
    padding-top: 0.75rem;
    padding-bottom: 0.75rem;
  }

  .product-card__cart-zone--select {
    display: grid;
    gap: 0.75rem;
  }

  .product-card__cart-actions {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    align-items: center;
    gap: 0.75rem;
  }

  .product-card__qty-control {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    width: fit-content;
    padding: 0.25rem;
    border-radius: 999px;
    border: 1px solid var(--color-border);
    background: color-mix(in srgb, var(--color-surface-elevated) 94%, transparent);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.28);
  }

  .qty-btn {
    border: 1px solid var(--color-border);
    background: color-mix(in srgb, var(--color-surface-elevated) 96%, transparent);
    color: var(--color-text-muted);
  }

  .product-card__qty-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.35rem;
    height: 2.35rem;
    border-width: 1px;
    border-radius: 999px;
    font-size: 1rem;
    font-weight: 700;
    line-height: 1;
    transition: transform 180ms ease, border-color 180ms ease, background-color 180ms ease, color 180ms ease, box-shadow 180ms ease;
  }

  .product-card__qty-btn:hover:not(:disabled) {
    border-color: var(--color-accent);
    background: color-mix(in srgb, var(--color-accent) 92%, var(--color-accent-strong) 8%);
    color: var(--color-text-on-accent);
    box-shadow: 0 10px 20px color-mix(in srgb, var(--color-accent) 18%, transparent);
    transform: translateY(-1px);
  }

  .product-card__qty-btn:active:not(:disabled) {
    transform: translateY(0);
    box-shadow: none;
  }

  .product-card__qty-btn:disabled {
    cursor: not-allowed;
    opacity: 0.42;
    box-shadow: none;
  }

  .product-card__qty-btn:focus-visible,
  .product-card__cart-button:focus-visible {
    outline: 2px solid color-mix(in srgb, var(--color-accent) 82%, white 18%);
    outline-offset: 2px;
  }

  .qty-value {
    color: var(--color-text);
  }

  .product-card__qty-value {
    min-width: 1.9rem;
    text-align: center;
    font-size: 0.9rem;
    font-weight: 700;
    letter-spacing: -0.01em;
  }

  .product-card__size-label {
    color: var(--color-text-subtle);
  }

  .product-card__size-picker {
    display: grid;
    gap: 0.35rem;
    min-width: 0;
    padding: 0.75rem 0.875rem;
    border-radius: 1rem;
    border: 1px solid var(--color-border);
    background:
      linear-gradient(180deg, color-mix(in srgb, var(--color-surface-elevated) 94%, transparent) 0%, color-mix(in srgb, var(--color-surface-soft) 56%, var(--color-surface) 44%) 100%);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.28);
  }

  .product-card__size-select-wrap {
    position: relative;
    min-width: 0;
  }

  .product-card__size-select-wrap::after {
    content: '';
    position: absolute;
    top: 50%;
    right: 0.95rem;
    width: 0.55rem;
    height: 0.55rem;
    border-right: 2px solid var(--color-text-muted);
    border-bottom: 2px solid var(--color-text-muted);
    transform: translateY(-65%) rotate(45deg);
    pointer-events: none;
  }

  .product-card__size-select {
    width: 100%;
    min-height: 2.35rem;
    appearance: none;
    border-radius: 999px;
    border: 1px solid var(--color-border);
    background: color-mix(in srgb, var(--color-surface) 92%, transparent);
    color: var(--color-text);
    padding: 0.5rem 2.35rem 0.5rem 0.85rem;
    font-size: 0.8125rem;
    font-weight: 700;
    line-height: 1;
    transition: border-color 180ms ease, box-shadow 180ms ease, background-color 180ms ease;
  }

  .product-card__size-select:hover {
    border-color: color-mix(in srgb, var(--color-accent) 65%, var(--color-border));
  }

  .product-card__size-select:focus-visible {
    outline: 2px solid color-mix(in srgb, var(--color-accent) 82%, white 18%);
    outline-offset: 2px;
    border-color: var(--color-accent);
    box-shadow: 0 10px 22px color-mix(in srgb, var(--color-accent) 24%, transparent);
  }

  .product-card__cart-button {
    display: inline-flex;
    width: 100%;
    min-height: 2.85rem;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    padding: 0.75rem 1rem;
    background: linear-gradient(135deg, var(--color-accent) 0%, var(--color-accent-strong) 100%);
    color: var(--color-text-on-accent);
    font-size: 0.75rem;
    font-weight: 800;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    box-shadow: 0 12px 24px color-mix(in srgb, var(--color-accent) 22%, transparent);
    transition: transform 180ms ease, box-shadow 180ms ease, filter 180ms ease, background-position 180ms ease;
  }

  .product-card__cart-button:hover:not(:disabled) {
    transform: translateY(-1px);
    box-shadow: 0 16px 28px color-mix(in srgb, var(--color-accent-strong) 28%, transparent);
    filter: saturate(1.05);
  }

  .product-card__cart-button:active:not(:disabled) {
    transform: translateY(0);
    box-shadow: 0 10px 18px color-mix(in srgb, var(--color-accent) 18%, transparent);
  }

  .product-card__cart-button:disabled {
    cursor: not-allowed;
    opacity: 0.72;
    box-shadow: none;
  }

  .product-card__cart-button:disabled:hover {
    transform: none;
    filter: none;
    box-shadow: none;
  }

  @media (max-width: 420px) {
    .product-card__cart-actions {
      grid-template-columns: 1fr;
    }

    .product-card__qty-control {
      justify-self: center;
    }
  }

  @media (min-width: 640px) {
    .product-card__cart-zone--quick {
      display: flex;
      align-items: center;
    }

    .product-card__cart-zone--select {
      gap: 0.625rem;
    }

    .product-card__size-picker {
      grid-template-columns: auto minmax(0, 1fr);
      align-items: center;
      gap: 0.75rem;
    }
  }
</style>
