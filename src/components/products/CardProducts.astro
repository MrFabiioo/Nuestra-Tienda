---
import ProductCard from "./ProductCard.astro";

interface Product {
    id?: string;
    name: string;
    price: number;
    description: string;
    image: string;
    slug?: string;
    rating?: number;
    borderColor?: string;
    tag?: string;
}

interface Props {
    title: string;
    products: Product[];
}

const { title, products } = Astro.props;
const sliderId = `slider-${title.replace(/\s+/g, '-').toLowerCase()}`;
---

<section class="products-section">
    <div class="products-section__header">
        <h2 class="products-section__title">{title}</h2>
    </div>

    <!-- Desktop: Grid sin carousel -->
    <div class="products-grid">
        {products.map((product) => (
            <ProductCard {...product} />
        ))}
    </div>

    <!-- Mobile/Tablet: Carousel con peek effect -->
    <div class="carousel-container">
        <!-- Botón izquierdo -->
        <button 
            class="carousel-btn carousel-btn--prev" 
            data-slider={sliderId}
            aria-label="Anterior"
        >
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="15 18 9 12 15 6"></polyline>
            </svg>
        </button>

        <!-- Viewport con scroll horizontal y peek -->
        <div 
            class="carousel-viewport" 
            id={sliderId}
        >
            <div class="carousel-track">
                {products.map((product) => (
                    <div class="carousel-slide">
                        <ProductCard {...product} />
                    </div>
                ))}
            </div>
        </div>

        <!-- Botón derecho -->
        <button 
            class="carousel-btn carousel-btn--next" 
            data-slider={sliderId}
            aria-label="Siguiente"
        >
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="9 18 15 12 9 6"></polyline>
            </svg>
        </button>
    </div>
</section>

<style>
    .products-section {
        background: white;
        border-radius: 1.5rem;
        padding: 2rem;
        box-shadow: 0 2px 12px -2px rgba(0, 0, 0, 0.07), 0 1px 3px rgba(0, 0, 0, 0.04);
        border: 1px solid #f1f5f9;
        margin: 2rem 0;
        position: relative;
    }

    .products-section__header {
        display: flex;
        justify-content: flex-start;
        margin-bottom: 1.75rem;
    }

    .products-section__title {
        font-size: 0.875rem;
        font-weight: 700;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        padding: 0.375rem 1rem;
        border-radius: 9999px;
        background: #568203;
        color: white;
    }

    /* Mobile first: grid hidden, carousel visible */
    .products-grid {
        display: none;
    }

    /* Carousel Container */
    .carousel-container {
        position: relative;
        display: flex;
        align-items: center;
        width: 100%;
    }

    /* Desktop Grid */
    @media (min-width: 1024px) {
        .products-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
            gap: 1.25rem;
        }
        .carousel-container {
            display: none;
        }
    }

    /* Viewport con peek effect */
    .carousel-viewport {
        overflow-x: auto;
        overflow-y: hidden;
        width: 100%;
        scroll-snap-type: x mandatory;
        scroll-behavior: smooth;
        -webkit-overflow-scrolling: touch;
        scrollbar-width: none;
        -ms-overflow-style: none;
        padding: 1rem 0 1.5rem;
    }

    .carousel-viewport::-webkit-scrollbar {
        display: none;
    }

    .carousel-track {
        display: flex;
        gap: 0;
        width: max-content;
    }

    .carousel-slide {
        scroll-snap-align: center;
        flex-shrink: 0;
        width: 82vw;
        max-width: 300px;
        padding: 0 0.5rem;
        box-sizing: border-box;
    }

    /* Botones de navegación */
    .carousel-btn {
        position: absolute;
        top: 50%;
        transform: translateY(-50%);
        width: 36px;
        height: 36px;
        border-radius: 50%;
        background: white;
        border: 1px solid #e5e7eb;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #374151;
        transition: all 0.2s ease;
        z-index: 20;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
        flex-shrink: 0;
    }

    .carousel-btn:hover {
        background: #568203;
        color: white;
        border-color: #568203;
        box-shadow: 0 4px 12px rgba(86, 130, 3, 0.3);
    }

    .carousel-btn:active {
        transform: translateY(-50%) scale(0.95);
    }

    .carousel-btn--prev {
        left: -18px;
    }

    .carousel-btn--next {
        right: -18px;
    }

    @media (max-width: 640px) {
        .carousel-slide {
            width: 80vw;
            max-width: 280px;
        }

        .products-section {
            padding: 1.5rem 1rem;
        }

        .carousel-btn {
            width: 32px;
            height: 32px;
        }

        .carousel-btn--prev {
            left: -16px;
        }

        .carousel-btn--next {
            right: -16px;
        }
    }
</style>

<script>
    document.addEventListener("astro:page-load", initCarousels);
    document.addEventListener("astro:beforematch", initCarousels);

    function initCarousels() {
        const viewports = document.querySelectorAll('.carousel-viewport');
        
        viewports.forEach((viewport) => {
            if ((viewport as any).__carouselInitialized) return;
            (viewport as any).__carouselInitialized = true;

            const container = viewport.closest('.carousel-container');
            const prevBtn = container?.querySelector('.carousel-btn--prev');
            const nextBtn = container?.querySelector('.carousel-btn--next');
            
            function getSlides() {
                return Array.from(viewport.querySelectorAll('.carousel-slide')) as HTMLElement[];
            }

            function getCurrentIndex(): number {
                const slides = getSlides();
                const center = (viewport as HTMLElement).scrollLeft + (viewport as HTMLElement).clientWidth / 2;
                let idx = 0;
                let minDist = Infinity;
                slides.forEach((slide, i) => {
                    const dist = Math.abs(slide.offsetLeft + slide.offsetWidth / 2 - center);
                    if (dist < minDist) { minDist = dist; idx = i; }
                });
                return idx;
            }

            function scrollToIndex(index: number) {
                const slides = getSlides();
                const target = slides[Math.max(0, Math.min(index, slides.length - 1))];
                if (!target) return;
                (viewport as HTMLElement).scrollTo({
                    left: target.offsetLeft + target.offsetWidth / 2 - (viewport as HTMLElement).clientWidth / 2,
                    behavior: 'smooth'
                });
            }
            
            prevBtn?.addEventListener('click', () => scrollToIndex(getCurrentIndex() - 1));
            nextBtn?.addEventListener('click', () => scrollToIndex(getCurrentIndex() + 1));
        });
    }
</script>
