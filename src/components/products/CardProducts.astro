---
import ProductCard from "./ProductCard.astro";

interface Product {
    name: string;
    price: number;
    description: string;
    image: string;
    slug?: string;
    rating?: number;
    borderColor?: string;
    tag?: string;
}

interface Props {
    title: string;
    products: Product[];
}

const { title, products } = Astro.props;
---

<section class="products-section">
    <div class="products-section__header">
        <h2 class="products-section__title">{title}</h2>
    </div>

    <div class="products-section__grid">
        {products.map((product) => (
            <ProductCard {...product} />
        ))}
    </div>
</section>

<style>
    .products-section {
        background: white;
        border-radius: 1.5rem;
        padding: 2rem;
        box-shadow: 0 4px 20px -2px rgba(0, 0, 0, 0.1);
        margin: 2rem 0;
    }

    .products-section__header {
        display: flex;
        justify-content: center;
        margin-bottom: 2rem;
    }

    .products-section__title {
        font-size: 1.25rem;
        font-weight: 700;
        padding: 0.5rem 1.5rem;
        border-radius: 9999px;
        background: #568203;
        color: white;
        text-align: center;
    }

    .products-section__grid {
        display: flex;
        gap: 1.5rem;
        justify-content: center;
        flex-wrap: wrap;
    }

    @media (max-width: 768px) {
        .products-section__grid {
            flex-direction: column;
            align-items: center;
        }
    }
</style>
