---
import ProductCard from "./ProductCard.astro";

interface Product {
    name: string;
    price: number;
    description: string;
    image: string;
    slug?: string;
    rating?: number;
    borderColor?: string;
    tag?: string;
}

interface Props {
    title: string;
    products: Product[];
}

const { title, products } = Astro.props;
const sliderId = `slider-${title.replace(/\s+/g, '-').toLowerCase()}`;
---

<section class="products-section">
    <div class="products-section__header">
        <h2 class="products-section__title">{title}</h2>
    </div>

    <!-- Desktop: Grid de 3 columnas sin carousel -->
    <div class="products-grid">
        {products.map((product) => (
            <div class="grid-item">
                <ProductCard {...product} />
            </div>
        ))}
    </div>

    <!-- Mobile/Tablet: Carousel con peek effect -->
    <div class="carousel-container">
        <!-- Botón izquierdo -->
        <button 
            class="carousel-btn carousel-btn--prev" 
            data-slider={sliderId}
            aria-label="Anterior"
        >
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="15 18 9 12 15 6"></polyline>
            </svg>
        </button>

        <!-- Viewport con scroll horizontal y peek -->
        <div 
            class="carousel-viewport" 
            id={sliderId}
        >
            <div class="carousel-track">
                {products.map((product) => (
                    <div class="carousel-slide">
                        <ProductCard {...product} />
                    </div>
                ))}
            </div>
        </div>

        <!-- Botón derecho -->
        <button 
            class="carousel-btn carousel-btn--next" 
            data-slider={sliderId}
            aria-label="Siguiente"
        >
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="9 18 15 12 9 6"></polyline>
            </svg>
        </button>
    </div>
</section>

<style>
    .products-section {
        background: white;
        border-radius: 1.5rem;
        padding: 2rem;
        box-shadow: 0 4px 20px -2px rgba(0, 0, 0, 0.1);
        margin: 2rem 0;
        position: relative;
    }

    .products-section__header {
        display: flex;
        justify-content: center;
        margin-bottom: 2rem;
    }

    .products-section__title {
        font-size: 1.25rem;
        font-weight: 700;
        padding: 0.5rem 1.5rem;
        border-radius: 9999px;
        background: #568203;
        color: white;
        text-align: center;
    }

    /* Mobile first: grid hidden, carousel visible */
    .products-grid {
        display: none;
    }

    /* Carousel Container - defined BEFORE media query to avoid override */
    .carousel-container {
        position: relative;
        display: flex;
        align-items: center;
        width: 100%;
    }

    .products-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 1.5rem;
        justify-items: center;
        justify-content: center;
    }

    .grid-item {
        max-width: 280px;
        width: 100%;
    }

    /* Desktop Grid - only show at 1200px+ */
    @media (min-width: 1200px) {
        .products-grid {
            display: grid;
        }
        .carousel-container {
            display: none;
        }
    }

    /* Viewport con peek effect - muestra ~85% del slide para que se vea el peek */
    .carousel-viewport {
        overflow-x: auto;
        overflow-y: hidden;
        width: 100%;
        scroll-snap-type: x mandatory;
        scroll-behavior: smooth;
        -webkit-overflow-scrolling: touch;
        scrollbar-width: none; /* Firefox */
        -ms-overflow-style: none; /* IE */
        padding: 0.5rem 0;
    }

    .carousel-viewport::-webkit-scrollbar {
        display: none; /* Chrome/Safari */
    }

    /* Track con flexbox */
    .carousel-track {
        display: flex;
        gap: 0;
        width: max-content;
    }

    /* Slide con scroll-snap-center y ancho fijo para peek */
    .carousel-slide {
        scroll-snap-align: center;
        flex-shrink: 0;
        width: 85vw;
        max-width: 320px;
        padding: 0 0.5rem;
        box-sizing: border-box;
    }

    /* Botones de navegación - rojos circulares */
    .carousel-btn {
        position: absolute;
        top: 50%;
        transform: translateY(-50%);
        width: 48px;
        height: 48px;
        border-radius: 50%;
        background: #dc2626;
        border: 3px solid white;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        transition: all 0.3s ease;
        z-index: 20;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.25);
        flex-shrink: 0;
    }

    .carousel-btn:hover {
        background: #b91c1c;
        transform: translateY(-50%) scale(1.1);
    }

    .carousel-btn:active {
        transform: translateY(-50%) scale(0.95);
    }

    .carousel-btn--prev {
        left: -24px;
    }

    .carousel-btn--next {
        right: -24px;
    }

    .carousel-btn svg {
        width: 20px;
        height: 20px;
    }

    /* Responsive adjustments */
    @media (max-width: 640px) {
        .carousel-slide {
            width: 80vw;
            max-width: 280px;
        }

        .carousel-btn {
            width: 40px;
            height: 40px;
        }

        .carousel-btn--prev {
            left: -20px;
        }

        .carousel-btn--next {
            right: -20px;
        }

        .carousel-btn svg {
            width: 16px;
            height: 16px;
        }

        .products-section {
            padding: 1.5rem 1rem;
        }
    }
</style>

<script>
    document.addEventListener("astro:page-load", initCarousels);
    document.addEventListener("astro:beforematch", initCarousels);

    function initCarousels() {
        const carousels = document.querySelectorAll('.carousel-viewport');
        
        carousels.forEach((viewport) => {
            const sliderId = viewport.id;
            const container = viewport.closest('.carousel-container');
            const prevBtn = container?.querySelector('.carousel-btn--prev');
            const nextBtn = container?.querySelector('.carousel-btn--next');
            
            // Scroll suave al centro
            function scrollToCenter() {
                const viewportRect = viewport.getBoundingClientRect();
                const viewportCenter = viewportRect.left + viewportRect.width / 2;
                
                const slides = viewport.querySelectorAll('.carousel-slide');
                let closestSlide: Element | null = null;
                let minDistance = Infinity;
                
                slides.forEach((slide) => {
                    const slideRect = slide.getBoundingClientRect();
                    const slideCenter = slideRect.left + slideRect.width / 2;
                    const distance = Math.abs(slideCenter - viewportCenter);
                    
                    if (distance < minDistance) {
                        minDistance = distance;
                        closestSlide = slide;
                    }
                });
                
                if (closestSlide) {
                    (closestSlide as HTMLElement).scrollIntoView({
                        behavior: 'smooth',
                        inline: 'center',
                        block: 'nearest'
                    });
                }
            }
            
            // Botón anterior
            prevBtn?.addEventListener('click', () => {
                const slides = viewport.querySelectorAll('.carousel-slide');
                const viewportCenter = viewport.scrollLeft + viewport.clientWidth / 2;
                
                let currentIndex = 0;
                slides.forEach((slide, index) => {
                    const slideLeft = (slide as HTMLElement).offsetLeft;
                    const slideWidth = (slide as HTMLElement).offsetWidth;
                    const slideCenter = slideLeft + slideWidth / 2;
                    
                    if (slideCenter < viewportCenter) {
                        currentIndex = index;
                    }
                });
                
                // Ir al slide anterior
                const targetIndex = Math.max(0, currentIndex - 1);
                const targetSlide = slides[targetIndex] as HTMLElement;
                
                if (targetSlide) {
                    const targetCenter = targetSlide.offsetLeft + targetSlide.offsetWidth / 2;
                    viewport.scrollTo({
                        left: targetCenter - viewport.clientWidth / 2,
                        behavior: 'smooth'
                    });
                }
            });
            
            // Botón siguiente
            nextBtn?.addEventListener('click', () => {
                const slides = viewport.querySelectorAll('.carousel-slide');
                const viewportCenter = viewport.scrollLeft + viewport.clientWidth / 2;
                
                let currentIndex = slides.length - 1;
                slides.forEach((slide, index) => {
                    const slideLeft = (slide as HTMLElement).offsetLeft;
                    const slideWidth = (slide as HTMLElement).offsetWidth;
                    const slideCenter = slideLeft + slideWidth / 2;
                    
                    if (slideCenter < viewportCenter) {
                        currentIndex = index;
                    }
                });
                
                // Ir al siguiente slide
                const targetIndex = Math.min(slides.length - 1, currentIndex + 1);
                const targetSlide = slides[targetIndex] as HTMLElement;
                
                if (targetSlide) {
                    const targetCenter = targetSlide.offsetLeft + targetSlide.offsetWidth / 2;
                    viewport.scrollTo({
                        left: targetCenter - viewport.clientWidth / 2,
                        behavior: 'smooth'
                    });
                }
            });
            
            // Centrar slide inicial
            setTimeout(scrollToCenter, 100);
            
            // Recentrar en resize
            let resizeTimeout: number;
            window.addEventListener('resize', () => {
                clearTimeout(resizeTimeout);
                resizeTimeout = window.setTimeout(scrollToCenter, 150);
            });
        });
    }
</script>
