---
interface FeaturedProduct {
  id:    string;
  title: string;
  slug:  string;
  image: string | null;
}

interface SlideItem {
  src: string;
  alt: string;
  href: string | null;
  title: string;
}

interface Props {
  featuredProducts?: FeaturedProduct[];
}

const { featuredProducts = [] } = Astro.props;

const hasFeaturedProducts = featuredProducts.length > 0;

const FALLBACK_IMAGES: SlideItem[] = [
  {
    src: "/images/guacamole-caricatura-partida.png",
    alt: "Guacamole fresco recien hecho",
    href: null,
    title: "Frescura artesanal",
  },
  {
    src: "/images/guacamole-caricatura.png",
    alt: "Guacamole tradicional",
    href: null,
    title: "Sabor que invita",
  },
  {
    src: "/images/guacamoleIA.png",
    alt: "Guacamole especial",
    href: null,
    title: "Momentos para compartir",
  },
];

const images: SlideItem[] = hasFeaturedProducts
  ? featuredProducts.map(p => ({
      src:  p.image ?? '/images/no-image.png',
      alt:  p.title,
      href: `/products/${p.slug}`,
      title: p.title,
    }))
  : FALLBACK_IMAGES;

const sectionEyebrow = hasFeaturedProducts ? 'Favoritos' : 'Selección visual';
const sectionTitle = hasFeaturedProducts
  ? 'Los elegidos de la casa'
  : 'Una ventana a la identidad visual de la marca';
const showControls = images.length > 1;
---

<section class="slider-section" aria-label={hasFeaturedProducts ? 'Productos favoritos y destacados' : 'Galería visual de la marca'}>
  <div class="slider-section__header">
    <span class="slider-section__eyebrow">{sectionEyebrow}</span>
    <div class="slider-section__copy">
      <h2 class="slider-section__title">{sectionTitle}</h2>
    </div>
  </div>

  <div class="slider-container" data-slider-root>
    <div class="slider-wrapper">
      <div class="slider-track" data-slider-track>
        {images.map((image, index) => (
          <div class="slide" data-index={index}>
             {image.href
               ? <a href={image.href} class="slide-link">
                   <img src={image.src} alt={image.alt} />
                 </a>
               : <div class="slide-media">
                   <img src={image.src} alt={image.alt} />
                 </div>
             }
          </div>
        ))}
      </div>

      {showControls && <button class="slider-btn prev" data-slider-prev aria-label="Imagen anterior">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="15 18 9 12 15 6"></polyline>
        </svg>
      </button>}

      {showControls && <button class="slider-btn next" data-slider-next aria-label="Siguiente imagen">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="9 18 15 12 9 6"></polyline>
        </svg>
      </button>}

      {showControls && <div class="slider-dots">
        {images.map((image, index) => (
          <button 
            class={`dot ${index === 0 ? 'active' : ''}`} 
            data-index={index}
            aria-label={`Ir a ${image.title}`}
          ></button>
        ))}
      </div>}
    </div>
  </div>
</section>

<style>
  .slider-section {
    display: grid;
    gap: 1rem;
    margin: 2rem 0 1.5rem;
  }

  .slider-section__header {
    display: grid;
    gap: 0.75rem;
  }

  .slider-section__eyebrow {
    display: inline-flex;
    align-items: center;
    width: fit-content;
    border-radius: 999px;
    border: 1px solid var(--color-border);
    background: color-mix(in srgb, var(--color-surface-elevated) 92%, transparent);
    padding: 0.45rem 0.9rem;
    font-size: 0.76rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-accent);
    box-shadow: 0 12px 28px var(--color-shadow-soft);
  }

  .slider-section__copy {
    display: grid;
    gap: 0.65rem;
    max-width: 760px;
  }

  .slider-section__title {
    margin: 0;
    font-size: clamp(1.75rem, 4vw, 2.85rem);
    line-height: 1.08;
    letter-spacing: -0.04em;
    color: var(--color-text);
  }

  .slider-container {
    width: 100%;
    position: relative;
    overflow: hidden;
    border-radius: 1.5rem;
    border: 1px solid color-mix(in srgb, var(--color-border-strong) 84%, transparent);
    background: linear-gradient(180deg, color-mix(in srgb, var(--color-surface) 94%, transparent) 0%, color-mix(in srgb, var(--color-bg-alt) 94%, transparent) 100%);
    box-shadow: 0 24px 50px var(--color-shadow-soft);
  }

  .slider-wrapper {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 7;
  }

  .slider-track {
    display: flex;
    width: 100%;
    height: 100%;
    transition: transform 0.5s ease-in-out;
  }

  .slide {
    min-width: 100%;
    height: 100%;
    position: relative;
    overflow: hidden;
  }

  .slide img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    transform: scale(1.02);
  }

  .slide-link,
  .slide-media {
    display: grid;
    width: 100%;
    height: 100%;
    color: #fff;
    text-decoration: none;
  }

  .slide-link > *,
  .slide-media > * {
    grid-area: 1 / 1;
  }

  .slide-link {
    transition: transform 0.3s ease;
  }

  .slide-link:hover {
    transform: scale(1.01);
  }

  .slider-btn {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 50px;
    height: 50px;
    border-radius: 50%;
    background: color-mix(in srgb, var(--color-surface-elevated) 90%, transparent);
    backdrop-filter: blur(4px);
    border: 1px solid var(--color-border);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-text);
    transition: all 0.3s ease;
    z-index: 10;
  }

  .slider-btn:hover {
    background: color-mix(in srgb, var(--color-surface-elevated) 92%, var(--color-accent) 8%);
    border-color: var(--color-border-strong);
    transform: translateY(-50%) scale(1.1);
    box-shadow: 0 8px 20px var(--color-shadow-soft);
  }

  .slider-btn:active {
    transform: translateY(-50%) scale(0.95);
  }

  .slider-btn.prev {
    left: 1.5rem;
  }

  .slider-btn.next {
    right: 1.5rem;
  }

  .slider-btn svg {
    width: 24px;
    height: 24px;
  }

  .slider-dots {
    position: absolute;
    bottom: 1.5rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 0.75rem;
    z-index: 10;
  }

  .dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: color-mix(in srgb, var(--color-surface-elevated) 72%, transparent);
    border: 2px solid color-mix(in srgb, var(--color-border-strong) 80%, transparent);
    cursor: pointer;
    transition: all 0.3s ease;
    padding: 0;
  }

  .dot:hover {
    background: color-mix(in srgb, var(--color-surface-elevated) 88%, var(--color-accent) 12%);
    transform: scale(1.2);
  }

  .dot.active {
    background: var(--color-accent);
    border-color: var(--color-accent);
    transform: scale(1.2);
    box-shadow: 0 0 12px color-mix(in srgb, var(--color-accent) 48%, transparent);
  }

  @media (max-width: 768px) {
    .slider-section {
      margin-top: 1.5rem;
    }

    .slider-section__title {
      font-size: clamp(1.55rem, 8vw, 2.2rem);
    }

    .slider-wrapper {
      aspect-ratio: 4 / 5;
    }

    .slider-btn {
      width: 40px;
      height: 40px;
    }

    .slider-btn svg {
      width: 20px;
      height: 20px;
    }

    .slider-btn.prev {
      left: 0.75rem;
    }

    .slider-btn.next {
      right: 0.75rem;
    }

    .dot {
      width: 10px;
      height: 10px;
    }
  }

  @media (max-width: 480px) {
    .slider-section__eyebrow {
      font-size: 0.68rem;
      letter-spacing: 0.12em;
    }

    .slider-dots {
      bottom: 1rem;
      gap: 0.5rem;
    }

  }
</style>

<script>
  type SliderCleanup = () => void;

  type SliderWindow = Window & {
    __sliderImageAutomaticBound?: boolean;
    __sliderImageAutomaticCleanups?: Set<SliderCleanup>;
  };

  const sliderWindow = window as SliderWindow;
  sliderWindow.__sliderImageAutomaticCleanups ??= new Set();

  function cleanupSliders() {
    sliderWindow.__sliderImageAutomaticCleanups?.forEach(cleanup => cleanup());
    sliderWindow.__sliderImageAutomaticCleanups?.clear();
  }

  function initSlider(root: HTMLElement) {
    if (root.dataset.sliderInitialized === 'true') return;

    const sliderTrack = root.querySelector<HTMLElement>('[data-slider-track]');
    const prevBtn = root.querySelector<HTMLButtonElement>('[data-slider-prev]');
    const nextBtn = root.querySelector<HTMLButtonElement>('[data-slider-next]');
    const dots = Array.from(root.querySelectorAll<HTMLButtonElement>('.dot'));
    const slides = Array.from(root.querySelectorAll<HTMLElement>('.slide'));
    const slideCount = slides.length;

    if (!sliderTrack || slideCount === 0) return;

    root.dataset.sliderInitialized = 'true';

    let currentIndex = 0;
    let autoPlayInterval: ReturnType<typeof setInterval> | null = null;

    function goToSlide(index: number) {
      if (index < 0) {
        currentIndex = slideCount - 1;
      } else if (index >= slideCount) {
        currentIndex = 0;
      } else {
        currentIndex = index;
      }

      sliderTrack.style.transform = `translateX(-${currentIndex * 100}%)`;

      dots.forEach((dot, dotIndex) => {
        dot.classList.toggle('active', dotIndex === currentIndex);
      });
    }

    function nextSlide() {
      goToSlide(currentIndex + 1);
    }

    function prevSlide() {
      goToSlide(currentIndex - 1);
    }

    function startAutoPlay() {
      if (slideCount <= 1) return;
      if (autoPlayInterval) clearInterval(autoPlayInterval);
      autoPlayInterval = setInterval(nextSlide, 3000);
    }

    function stopAutoPlay() {
      if (!autoPlayInterval) return;
      clearInterval(autoPlayInterval);
      autoPlayInterval = null;
    }

    const handlePrevClick = () => {
      prevSlide();
      startAutoPlay();
    };

    const handleNextClick = () => {
      nextSlide();
      startAutoPlay();
    };

    prevBtn?.addEventListener('click', handlePrevClick);
    nextBtn?.addEventListener('click', handleNextClick);

    const dotHandlers = dots.map((dot, index) => {
      const handler = () => {
        goToSlide(index);
        startAutoPlay();
      };

      dot.addEventListener('click', handler);
      return { dot, handler };
    });

    root.addEventListener('mouseenter', stopAutoPlay);
    root.addEventListener('mouseleave', startAutoPlay);

    if (slideCount > 1) {
      startAutoPlay();
    }

    sliderWindow.__sliderImageAutomaticCleanups?.add(() => {
      stopAutoPlay();
      prevBtn?.removeEventListener('click', handlePrevClick);
      nextBtn?.removeEventListener('click', handleNextClick);

      dotHandlers.forEach(({ dot, handler }) => {
        dot.removeEventListener('click', handler);
      });

      root.removeEventListener('mouseenter', stopAutoPlay);
      root.removeEventListener('mouseleave', startAutoPlay);
      delete root.dataset.sliderInitialized;
    });
  }

  function initSliders() {
    cleanupSliders();

    document
      .querySelectorAll<HTMLElement>('[data-slider-root]')
      .forEach(initSlider);
  }

  if (!sliderWindow.__sliderImageAutomaticBound) {
    document.addEventListener('astro:page-load', initSliders);
    sliderWindow.__sliderImageAutomaticBound = true;
  }

  initSliders();
</script>
