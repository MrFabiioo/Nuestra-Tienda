---
// HowItWorks.astro
// Bloque "Cómo funciona" — proceso de 3 pasos para conversión
// Sprint 3 micro-batch B
---

<section class="hiw-section" aria-labelledby="hiw-title">
  <header class="hiw-header">
    <span class="hiw-eyebrow">Así de simple</span>
    <h2 id="hiw-title" class="hiw-title">De nuestra cocina a tu mesa</h2>
    <p class="hiw-subtitle">
      Sin complicaciones. Elegís, pagás y te llega fresco.
    </p>
  </header>

  <ol class="hiw-steps" aria-label="Pasos para pedir">
    <li class="hiw-step">
      <div class="hiw-step__number" aria-hidden="true">01</div>
      <div class="hiw-step__icon" aria-hidden="true">
        <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none"
          stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="8" />
          <line x1="21" y1="21" x2="16.65" y2="16.65" />
        </svg>
      </div>
      <h3 class="hiw-step__title">Explorá el catálogo</h3>
      <p class="hiw-step__desc">
        Recetas clásicas, versiones picantes y sabores de temporada. Encontrá lo que tu paladar
        está buscando.
      </p>
    </li>

    <li class="hiw-step">
      <div class="hiw-step__number" aria-hidden="true">02</div>
      <div class="hiw-step__icon" aria-hidden="true">
        <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none"
          stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="9" cy="21" r="1" />
          <circle cx="20" cy="21" r="1" />
          <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6" />
        </svg>
      </div>
      <h3 class="hiw-step__title">Armá tu pedido</h3>
      <p class="hiw-step__desc">
        Sumá los productos que quieras, elegí la cantidad y confirmá. El proceso tarda menos de
        dos minutos.
      </p>
    </li>

    <li class="hiw-step">
      <div class="hiw-step__number" aria-hidden="true">03</div>
      <div class="hiw-step__icon" aria-hidden="true">
        <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none"
          stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2A19.79 19.79 0 0 1 11.63 18a19.5 19.5 0 0 1-6-6A19.79 19.79 0 0 1 2.12 3.18 2 2 0 0 1 4.11 1h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 8.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z" />
        </svg>
      </div>
      <h3 class="hiw-step__title">Lo recibís en casa</h3>
      <p class="hiw-step__desc">
        Preparamos tu pedido el mismo día y lo enviamos refrigerado para que llegue con toda
        su frescura intacta.
      </p>
    </li>
  </ol>

  <div class="hiw-cta-wrap">
    <a href="/tienda" class="hiw-cta">
      Ver todos los productos
    </a>
  </div>
</section>

<style>
  .hiw-section {
    padding: 3rem 0 3.5rem;
  }

  /* ── Header ─────────────────────────────────── */
  .hiw-header {
    text-align: center;
    margin-bottom: 2.75rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.875rem;
  }

  .hiw-eyebrow {
    display: inline-block;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-accent);
    background: color-mix(in srgb, var(--color-surface-soft) 92%, transparent);
    padding: 0.25rem 0.875rem;
    border-radius: 999px;
    border: 1px solid var(--color-border);
  }

  .hiw-title {
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 800;
    color: var(--color-text);
    letter-spacing: -0.02em;
    margin: 0;
    line-height: 1.25;
  }

  .hiw-subtitle {
    font-size: 1rem;
    color: var(--color-text-muted);
    margin: 0;
    max-width: 420px;
    line-height: 1.6;
  }

  /* ── Steps ──────────────────────────────────── */
  .hiw-steps {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    position: relative;
  }

  /* Línea conectora entre steps (desktop) */
  .hiw-steps::before {
    content: '';
    position: absolute;
    top: 52px;
    left: calc(33.33% - 0px);
    right: calc(33.33% - 0px);
    height: 2px;
    background: linear-gradient(90deg, color-mix(in srgb, var(--color-accent) 28%, transparent), color-mix(in srgb, var(--color-accent) 28%, transparent));
    z-index: 0;
    pointer-events: none;
  }

  .hiw-step {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0.875rem;
    position: relative;
    z-index: 1;
    padding: 1.5rem 1rem;
    background: color-mix(in srgb, var(--color-surface-elevated) 95%, transparent);
    border: 1px solid var(--color-border);
    border-radius: 1rem;
    transition: border-color 0.2s, box-shadow 0.2s, transform 0.2s;
  }

  .hiw-step:hover {
    border-color: var(--color-border-strong);
    box-shadow: 0 12px 30px var(--color-shadow-soft);
    transform: translateY(-3px);
  }

  .hiw-step__number {
    font-size: 0.7rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    color: var(--color-accent);
    font-variant-numeric: tabular-nums;
  }

  .hiw-step__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 60px;
    height: 60px;
    background: linear-gradient(135deg, var(--color-surface-soft-strong), color-mix(in srgb, var(--color-surface-soft) 78%, transparent));
    border-radius: 50%;
    color: var(--color-accent);
    border: 2px solid var(--color-border);
  }

  .hiw-step__title {
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--color-text);
    margin: 0;
    letter-spacing: -0.01em;
  }

  .hiw-step__desc {
    font-size: 0.875rem;
    line-height: 1.65;
    color: var(--color-text-muted);
    margin: 0;
  }

  /* ── CTA ─────────────────────────────────────── */
  .hiw-cta-wrap {
    display: flex;
    justify-content: center;
    margin-top: 2.5rem;
  }

  .hiw-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: linear-gradient(135deg, var(--color-accent) 0%, var(--color-accent-strong) 100%);
    color: var(--color-text-on-accent);
    text-decoration: none;
    font-size: 0.95rem;
    font-weight: 600;
    padding: 0.8rem 2rem;
    border-radius: 0.625rem;
    transition: background 0.2s ease, transform 0.15s ease, box-shadow 0.2s ease;
    box-shadow: 0 8px 22px color-mix(in srgb, var(--color-accent) 28%, transparent);
    letter-spacing: 0.01em;
  }

  .hiw-cta:hover {
    background: linear-gradient(135deg, var(--color-accent-strong) 0%, var(--color-accent) 100%);
    transform: translateY(-1px);
    box-shadow: 0 12px 28px color-mix(in srgb, var(--color-accent-strong) 34%, transparent);
  }

  .hiw-cta:active {
    transform: translateY(0);
    box-shadow: 0 4px 12px color-mix(in srgb, var(--color-accent-strong) 24%, transparent);
  }

  /* ── Responsive ─────────────────────────────── */
  @media (max-width: 768px) {
    .hiw-steps {
      grid-template-columns: 1fr;
      gap: 1rem;
    }

    .hiw-steps::before {
      display: none;
    }

    .hiw-step {
      flex-direction: row;
      text-align: left;
      align-items: flex-start;
      gap: 1.25rem;
      padding: 1.25rem;
    }

    .hiw-step__icon {
      flex-shrink: 0;
      width: 52px;
      height: 52px;
    }

    .hiw-step__number {
      display: none;
    }
  }

  @media (max-width: 480px) {
    .hiw-cta {
      width: 100%;
      justify-content: center;
    }
  }
</style>
