---
import { allProducts } from "@data/products";

const productsJson = JSON.stringify(allProducts);
---

<div class="search-wrapper" id="searchWrapper">
    <div class="search-box">
        <svg class="search-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="11" cy="11" r="8"></circle>
            <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
        </svg>
        <input 
            type="text" 
            class="search-input" 
            id="searchInput"
            placeholder="Buscar..."
            autocomplete="off"
        />
    </div>

    <!-- Dropdown de sugerencias -->
    <div class="search-dropdown" id="searchDropdown">
        <div class="dropdown-results" id="dropdownResults"></div>
        <div class="dropdown-empty" id="dropdownEmpty">
            No se encontraron productos
        </div>
    </div>
</div>

<style>
    .search-wrapper {
        position: relative;
        width: 100%;
        max-width: 380px;
    }

    .search-box {
        display: flex;
        align-items: center;
        background: #f5f5f5;
        border: 1px solid #e0e0e0;
        border-radius: 25px;
        padding: 0 16px;
        height: 44px;
        transition: all 0.2s ease;
    }

    .search-box:focus-within {
        border-color: #568203;
        box-shadow: 0 0 0 3px rgba(86, 130, 4, 0.15);
        background: white;
    }

    .search-icon {
        color: #888;
        flex-shrink: 0;
        margin-right: 10px;
    }

    .search-box:focus-within .search-icon {
        color: #568203;
    }

    .search-input {
        flex: 1;
        border: none;
        background: transparent;
        font-size: 14px;
        color: #333;
        outline: none;
    }

    .search-input::placeholder {
        color: #aaa;
    }

    /* Dropdown */
    .search-dropdown {
        position: absolute;
        top: calc(100% + 8px);
        left: 0;
        right: 0;
        background: white;
        border: 1px solid #e8e8e8;
        border-radius: 12px;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.12);
        overflow: hidden;
        display: none;
        z-index: 1000;
    }

    .search-dropdown.active {
        display: block;
    }

    .dropdown-results {
        max-height: 360px;
        overflow-y: auto;
    }

    .dropdown-empty {
        padding: 24px 16px;
        text-align: center;
        color: #999;
        font-size: 14px;
        display: none;
    }

    .dropdown-empty.show {
        display: block;
    }

    /* Result item */
    .search-result {
        display: flex;
        align-items: center;
        padding: 10px 14px;
        cursor: pointer;
        text-decoration: none;
        color: inherit;
        transition: background 0.15s ease;
    }

    .search-result:hover {
        background: #fff8e1;
    }

    .search-result img {
        width: 50px;
        height: 50px;
        border-radius: 8px;
        object-fit: cover;
        background: #f0f0f0;
        margin-right: 14px;
        flex-shrink: 0;
    }

    .result-content {
        flex: 1;
        min-width: 0;
    }

    .result-name {
        font-size: 14px;
        font-weight: 600;
        color: #333;
        margin-bottom: 3px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .result-category {
        font-size: 12px;
        color: #999;
    }

    .result-arrow {
        color: #ccc;
        flex-shrink: 0;
        margin-left: 10px;
    }

    /* Scrollbar personalizado */
    .dropdown-results::-webkit-scrollbar {
        width: 6px;
    }

    .dropdown-results::-webkit-scrollbar-track {
        background: transparent;
    }

    .dropdown-results::-webkit-scrollbar-thumb {
        background: #ddd;
        border-radius: 3px;
    }

    @media (max-width: 640px) {
        .search-wrapper {
            display: none;
        }
    }
</style>

<script define:vars={{ productsJson }}>
    const products = JSON.parse(productsJson);
    
    const searchWrapper = document.getElementById('searchWrapper');
    const searchInput = document.getElementById('searchInput');
    const searchDropdown = document.getElementById('searchDropdown');
    const dropdownResults = document.getElementById('dropdownResults');
    const dropdownEmpty = document.getElementById('dropdownEmpty');

    function showDropdown() {
        searchDropdown.classList.add('active');
    }

    function hideDropdown() {
        searchDropdown.classList.remove('active');
    }

    function renderResults(results) {
        if (results.length === 0) {
            dropdownResults.innerHTML = '';
            dropdownEmpty.classList.add('show');
        } else {
            dropdownEmpty.classList.remove('show');
            dropdownResults.innerHTML = results.map(product => `
<a href="/${product.slug}" 
   class="flex items-center gap-3 px-4 py-3 hover:bg-gray-100 transition border-b border-gray-200">

    <!-- Imagen -->
    <img 
        class="w-12 h-12 rounded-lg object-cover flex-shrink-0"
        src="${product.image}" 
        alt="${product.name}" 
        loading="lazy"
        decoding="async"
    />

    <!-- Contenido -->
    <div class="flex flex-col flex-1 min-w-0">
        <div class="text-sm font-semibold text-gray-800 truncate">
            ${product.name}
        </div>
        <div class="text-xs text-gray-500">
            ${product.category}
        </div>
    </div>

    <!-- Flecha -->
    <svg 
        class="w-4 h-4 text-gray-400 flex-shrink-0"
        xmlns="http://www.w3.org/2000/svg" 
        fill="none" 
        viewBox="0 0 24 24" 
        stroke="currentColor"
    >
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
    </svg>
</a>
            `).join('');
        }
    }

    function searchProducts(query) {
        const normalizedQuery = query.toLowerCase().trim();
        
        if (!normalizedQuery) {
            dropdownResults.innerHTML = '';
            dropdownEmpty.classList.remove('show');
            return;
        }

        const results = products.filter(product => 
            product.name.toLowerCase().includes(normalizedQuery) ||
            product.category.toLowerCase().includes(normalizedQuery) ||
            product.description.toLowerCase().includes(normalizedQuery)
        ).slice(0, 8);

        renderResults(results);
    }

    // Event listeners
    searchInput.addEventListener('input', (e) => {
        const query = e.target.value;
        searchProducts(query);
        
        if (query.length > 0) {
            showDropdown();
        } else {
            hideDropdown();
        }
    });

    searchInput.addEventListener('focus', () => {
        if (searchInput.value.length > 0) {
            showDropdown();
        }
    });

    // Cerrar al hacer click fuera
    document.addEventListener('click', (e) => {
        if (!searchWrapper.contains(e.target)) {
            hideDropdown();
        }
    });

    // Cerrar con ESC
    searchInput.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') {
            hideDropdown();
            searchInput.blur();
        }
    });
</script>
