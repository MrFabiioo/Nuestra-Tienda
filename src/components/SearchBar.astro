---
import { allProducts } from "@data/products";

const productsJson = JSON.stringify(allProducts);
---

<!-- Botón de búsqueda para mobile (visible solo en mobile) -->
<button
    class="search-trigger"
    id="searchTrigger"
    aria-label="Abrir búsqueda"
    aria-expanded="false"
    aria-controls="searchWrapper"
>
    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="11" cy="11" r="8"></circle>
        <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
    </svg>
</button>

<!-- Wrapper de búsqueda: visible en desktop, overlay en mobile -->
<div class="search-wrapper" id="searchWrapper" role="search" aria-label="Buscar productos">
    <div class="search-box">
        <svg class="search-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="11" cy="11" r="8"></circle>
            <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
        </svg>
        <input 
            type="search" 
            class="search-input" 
            id="searchInput"
            placeholder="Buscar productos..."
            autocomplete="off"
            aria-label="Buscar productos"
            aria-autocomplete="list"
            aria-expanded="false"
            aria-controls="searchDropdown"
        />
        <!-- Botón cerrar: solo visible en mobile overlay -->
        <button class="search-close" id="searchClose" aria-label="Cerrar búsqueda">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <line x1="18" y1="6" x2="6" y2="18"></line>
                <line x1="6" y1="6" x2="18" y2="18"></line>
            </svg>
        </button>
    </div>

    <!-- Dropdown de sugerencias -->
    <div
        class="search-dropdown"
        id="searchDropdown"
        role="listbox"
        aria-label="Resultados de búsqueda"
        aria-live="polite"
        aria-atomic="false"
    >
        <div class="dropdown-results" id="dropdownResults"></div>
        <div class="dropdown-empty" id="dropdownEmpty" role="status">
            No se encontraron productos
        </div>
    </div>
</div>

<style>
    /* Botón trigger solo mobile */
    .search-trigger {
        display: none;
        align-items: center;
        justify-content: center;
        width: 40px;
        height: 40px;
        background: transparent;
        border: 1px solid rgba(255, 255, 255, 0.15);
        border-radius: 8px;
        color: rgba(255, 255, 255, 0.8);
        cursor: pointer;
        transition: border-color 0.2s ease, color 0.2s ease;
        flex-shrink: 0;
    }

    .search-trigger:hover {
        border-color: rgba(86, 130, 4, 0.5);
        color: #568203;
    }

    /* Wrapper */
    .search-wrapper {
        position: relative;
        width: 100%;
        max-width: 380px;
    }

    .search-box {
        display: flex;
        align-items: center;
        background: rgba(255, 255, 255, 0.08);
        border: 1px solid rgba(255, 255, 255, 0.15);
        border-radius: 25px;
        padding: 0 16px;
        height: 44px;
        transition: all 0.2s ease;
    }

    .search-box:focus-within {
        border-color: #568203;
        box-shadow: 0 0 0 3px rgba(86, 130, 4, 0.2);
        background: rgba(255, 255, 255, 0.12);
    }

    .search-icon {
        color: rgba(255, 255, 255, 0.4);
        flex-shrink: 0;
        margin-right: 10px;
    }

    .search-box:focus-within .search-icon {
        color: #568203;
    }

    .search-input {
        flex: 1;
        border: none;
        background: transparent;
        font-size: 14px;
        color: rgba(255, 255, 255, 0.9);
        outline: none;
        min-width: 0;
    }

    .search-input::placeholder {
        color: rgba(255, 255, 255, 0.35);
    }

    /* Botón cerrar — oculto por defecto */
    .search-close {
        display: none;
        align-items: center;
        justify-content: center;
        width: 28px;
        height: 28px;
        background: transparent;
        border: none;
        color: rgba(255, 255, 255, 0.5);
        cursor: pointer;
        padding: 4px;
        border-radius: 50%;
        flex-shrink: 0;
        transition: color 0.2s ease;
    }

    .search-close:hover {
        color: rgba(255, 255, 255, 0.9);
    }

    /* Dropdown */
    .search-dropdown {
        position: absolute;
        top: calc(100% + 8px);
        left: 0;
        right: 0;
        background: white;
        border: 1px solid #e8e8e8;
        border-radius: 12px;
        box-shadow: 0 4px 24px rgba(0, 0, 0, 0.18);
        overflow: hidden;
        display: none;
        z-index: 1000;
    }

    .search-dropdown.active {
        display: block;
    }

    .dropdown-results {
        max-height: 360px;
        overflow-y: auto;
    }

    .dropdown-empty {
        padding: 24px 16px;
        text-align: center;
        color: #999;
        font-size: 14px;
        display: none;
    }

    .dropdown-empty.show {
        display: block;
    }

    /* Result item */
    .search-result {
        display: flex;
        align-items: center;
        padding: 10px 14px;
        cursor: pointer;
        text-decoration: none;
        color: inherit;
        transition: background 0.15s ease;
        border-bottom: 1px solid #f5f5f5;
    }

    .search-result:last-child {
        border-bottom: none;
    }

    .search-result:hover,
    .search-result:focus {
        background: #f5fde8;
        outline: none;
    }

    .search-result img {
        width: 48px;
        height: 48px;
        border-radius: 8px;
        object-fit: cover;
        background: #f0f0f0;
        margin-right: 14px;
        flex-shrink: 0;
    }

    .result-content {
        flex: 1;
        min-width: 0;
    }

    .result-name {
        font-size: 14px;
        font-weight: 600;
        color: #2d2d2d;
        margin-bottom: 2px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .result-category {
        font-size: 12px;
        color: #999;
    }

    .result-arrow {
        color: #c5c5c5;
        flex-shrink: 0;
        margin-left: 8px;
    }

    /* Scrollbar personalizado */
    .dropdown-results::-webkit-scrollbar {
        width: 5px;
    }

    .dropdown-results::-webkit-scrollbar-track {
        background: transparent;
    }

    .dropdown-results::-webkit-scrollbar-thumb {
        background: #ddd;
        border-radius: 3px;
    }

    /* --- RESPONSIVE --- */
    @media (max-width: 767px) {
        /* En mobile ocultamos el wrapper y mostramos el trigger */
        .search-wrapper {
            display: none;
            position: fixed;
            top: 64px; /* altura del navbar */
            left: 0;
            right: 0;
            z-index: 49;
            max-width: none;
            padding: 0.75rem 1rem;
            background: rgba(22, 22, 24, 0.98);
            backdrop-filter: blur(16px);
            border-bottom: 1px solid rgba(86, 130, 4, 0.3);
            box-shadow: 0 4px 16px rgba(0, 0, 0, 0.3);
        }

        .search-wrapper.mobile-open {
            display: block;
        }

        .search-trigger {
            display: flex;
        }

        .search-close {
            display: flex;
        }

        .search-box {
            background: rgba(255, 255, 255, 0.1);
            height: 48px;
            border-radius: 12px;
        }

        .search-dropdown {
            top: calc(100% + 4px);
        }
    }
</style>

<script define:vars={{ productsJson }}>
    const products = JSON.parse(productsJson);
    
    const searchWrapper = document.getElementById('searchWrapper');
    const searchInput = document.getElementById('searchInput');
    const searchDropdown = document.getElementById('searchDropdown');
    const dropdownResults = document.getElementById('dropdownResults');
    const dropdownEmpty = document.getElementById('dropdownEmpty');
    const searchTrigger = document.getElementById('searchTrigger');
    const searchClose = document.getElementById('searchClose');

    function showDropdown() {
        searchDropdown.classList.add('active');
        searchInput?.setAttribute('aria-expanded', 'true');
    }

    function hideDropdown() {
        searchDropdown.classList.remove('active');
        searchInput?.setAttribute('aria-expanded', 'false');
    }

    function openMobileSearch() {
        searchWrapper?.classList.add('mobile-open');
        searchTrigger?.setAttribute('aria-expanded', 'true');
        searchTrigger?.setAttribute('aria-label', 'Cerrar búsqueda');
        // Focus en el input con pequeño delay para animación
        setTimeout(() => searchInput?.focus(), 50);
    }

    function closeMobileSearch() {
        searchWrapper?.classList.remove('mobile-open');
        hideDropdown();
        searchTrigger?.setAttribute('aria-expanded', 'false');
        searchTrigger?.setAttribute('aria-label', 'Abrir búsqueda');
        searchInput.value = '';
        dropdownResults.innerHTML = '';
        dropdownEmpty?.classList.remove('show');
        searchTrigger?.focus();
    }

    function renderResults(results) {
        if (results.length === 0) {
            dropdownResults.innerHTML = '';
            dropdownEmpty.classList.add('show');
        } else {
            dropdownEmpty.classList.remove('show');
            dropdownResults.innerHTML = results.map(product => `
                <a
                    href="${product.slug}"
                    class="search-result"
                    role="option"
                    tabindex="0"
                >
                    <img
                        src="${product.image}"
                        alt="${product.name}"
                        loading="lazy"
                        decoding="async"
                    />
                    <div class="result-content">
                        <div class="result-name">${product.name}</div>
                        <div class="result-category">${product.category}</div>
                    </div>
                    <svg
                        class="result-arrow"
                        xmlns="http://www.w3.org/2000/svg"
                        width="16"
                        height="16"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                        aria-hidden="true"
                    >
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                    </svg>
                </a>
            `).join('');
        }
    }

    function searchProducts(query) {
        const normalizedQuery = query.toLowerCase().trim();
        
        if (!normalizedQuery) {
            dropdownResults.innerHTML = '';
            dropdownEmpty.classList.remove('show');
            return;
        }

        const results = products.filter(product => 
            product.name.toLowerCase().includes(normalizedQuery) ||
            product.category.toLowerCase().includes(normalizedQuery) ||
            product.description.toLowerCase().includes(normalizedQuery)
        ).slice(0, 8);

        renderResults(results);
    }

    // Trigger mobile
    searchTrigger?.addEventListener('click', () => {
        const isOpen = searchWrapper?.classList.contains('mobile-open');
        isOpen ? closeMobileSearch() : openMobileSearch();
    });

    // Botón cerrar dentro del overlay mobile
    searchClose?.addEventListener('click', closeMobileSearch);

    // Input events
    searchInput?.addEventListener('input', (e) => {
        const query = e.target.value;
        searchProducts(query);
        
        if (query.length > 0) {
            showDropdown();
        } else {
            hideDropdown();
        }
    });

    searchInput?.addEventListener('focus', () => {
        if (searchInput.value.length > 0) {
            showDropdown();
        }
    });

    // Cerrar al hacer click fuera
    document.addEventListener('click', (e) => {
        if (searchWrapper && !searchWrapper.contains(e.target) && e.target !== searchTrigger) {
            hideDropdown();
        }
    });

    // Teclado: ESC cierra
    searchInput?.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') {
            if (searchWrapper?.classList.contains('mobile-open')) {
                closeMobileSearch();
            } else {
                hideDropdown();
                searchInput.blur();
            }
        }

        // Navegación por teclado en resultados
        if (e.key === 'ArrowDown') {
            e.preventDefault();
            const firstResult = dropdownResults?.querySelector('.search-result');
            if (firstResult) firstResult.focus();
        }
    });

    // Navegación por teclado dentro del dropdown
    dropdownResults?.addEventListener('keydown', (e) => {
        const focused = document.activeElement;
        if (!focused?.classList.contains('search-result')) return;

        if (e.key === 'ArrowDown') {
            e.preventDefault();
            const next = focused.nextElementSibling;
            if (next) next.focus();
        } else if (e.key === 'ArrowUp') {
            e.preventDefault();
            const prev = focused.previousElementSibling;
            if (prev) {
                prev.focus();
            } else {
                searchInput?.focus();
            }
        } else if (e.key === 'Escape') {
            hideDropdown();
            searchInput?.focus();
        }
    });
</script>
