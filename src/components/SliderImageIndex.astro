---
import { createBrandedPlaceholderImage } from '@utils/product-images';

const images=[
    {
        src: createBrandedPlaceholderImage('Guacamole especial', {
        accentColor: '#D88C2D',
        subtitle: 'Placeholder temporal para slider legacy.',
    }),
        alt: 'Guacamole especial',
    },
    {
        src: createBrandedPlaceholderImage('Guacamole tradicional', {
        accentColor: '#7BA428',
        subtitle: 'Placeholder temporal para slider legacy.',
    }),
        alt: 'Guacamole tradicional',
    },
    {
        src: createBrandedPlaceholderImage('Guacamole artesanal', {
        accentColor: '#5C8C2B',
        subtitle: 'Placeholder temporal para slider legacy.',
    }),
        alt: 'Guacamole artesanal',
    },
]

const currentPath = Astro.url.pathname;
//console.log(currentPath)
---

<section class="slider-container">
    <div class="slicer-wrapper">
        <div class="slider">
            {images.map((image,index) => (
                
                    <img
                        src={image.src}
                        alt={image.alt}
                        class=""
                        id={`slide-${index+1}`}
                        width="1600"
                        height="900"
                        loading={index === 0 ? 'eager' : 'lazy'}
                        decoding={index === 0 ? 'sync' : 'async'}
                        fetchpriority={index === 0 ? 'high' : 'auto'}
                        sizes="100vw"
                    />
                
            ))}
        </div>
        <div class="slider-nav">
            <a href={`#slide-1`}></a>
            <a href={`#slide-2`}></a>
            <a href={`#slide-3`}></a>
            
        </div>
    </div>
</section>

<style>
    input{
        width: 100px;
        height: 20px;
    }
    .slider-container{
       width:100%;

    }
    .slider-wrapper{
        position: relative;
        max-width: none;
        margin: 0 auto;
        
    }

    .slider{
        display: flex;
        overflow-x: hidden;
        scroll-snap-type: x mandatory;
        scroll-behavior: smooth;
        box-shadow: 0 1.5rem 3rem --0.75rem hsla(0, 0%, 0%, 0.25);
        border-radius: 0.5rem;
        
    }

    .slider img{
        flex: 1 0 100%;
        scroll-snap-align: start;
        object-fit: cover;
        height: 66vh;
       
    }

    .slider-nav{
        display: flex;
        column-gap: 1rem;
        position: relative;
        bottom: 1.25rem;
        left: 85%;
        transform: translateX(-50%);
        z-index: 1;
    }

    .slider-nav a{
        width: 1.5rem;
        height: 0.5rem;
        border-radius: 16px;
        background-color: white;
        opacity: 0.75;
        transition: opacity ease 250ms;
        
    }

    .slider-nav a:hover{
        opacity: 1;
    }

    .input:active{
        background-color: red;
    }
</style>
