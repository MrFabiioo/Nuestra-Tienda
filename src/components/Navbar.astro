---
import ShoppingCart from "./CartButton.jsx";
import SearchBar from "./SearchBar.astro";
---

<header class="navbar">
    <div class="navbar__container">
        <!-- Izquierda: Menu hamburguesa -->
        <button class="hamburger" id="menuToggle" aria-label="Menu">
            <span class="hamburger__line"></span>
            <span class="hamburger__line"></span>
            <span class="hamburger__line"></span>
        </button>

        <!-- Centro: Barra de busqueda con sugerencias -->
        <SearchBar />

        <!-- Derecha: Logo + Carrito -->
        <div class="navbar__right">
            <a href="/" class="logo">
                <span class="logo__text">Guaca</span>
                <span class="logo__highlight">Shop</span>
            </a>
            <div class="cart-icon">
                <ShoppingCart client:only="preact" transition:persist />
            </div>
        </div>
    </div>

    <!-- Menu desplegable (mobile) -->
    <nav class="mobile-menu" id="mobileMenu">
        <ul class="mobile-menu__list">
            <li><a href="/" class="mobile-menu__link">Inicio</a></li>
            <li><a href="/tienda" class="mobile-menu__link">Productos</a></li>
            <li><a href="/admin/dashboard" class="mobile-menu__link">Admin</a></li>
            <li><a href="/guacamole" class="mobile-menu__link">Comprar</a></li>
        </ul>
    </nav>
</header>

<style>
    .navbar {
        background: rgba(29, 29, 31, 0.95);
        backdrop-filter: blur(20px) saturate(180%);
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        z-index: 50;
        border-bottom: 2px solid rgba(86, 130, 4, 0.3);
    }

    .navbar__container {
        max-width: 1200px;
        margin: 0 auto;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 1.5rem;
        height: 64px;
        gap: 1rem;
    }

    /* Hamburguesa */
    .hamburger {
        display: flex;
        flex-direction: column;
        justify-content: center;
        gap: 5px;
        width: 36px;
        height: 36px;
        background: transparent;
        border: none;
        cursor: pointer;
        padding: 4px;
    }

    .hamburger__line {
        width: 100%;
        height: 2px;
        background: #568203;
        border-radius: 2px;
        transition: all 0.3s ease;
    }

    .hamburger:hover .hamburger__line {
        background: #6da204;
    }

    /* Derecha */
    .navbar__right {
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    .logo {
        text-decoration: none;
        font-size: 22px;
        font-weight: 600;
        letter-spacing: -0.5px;
    }

    .logo__text {
        color: white;
    }

    .logo__highlight {
        color: #568203;
    }

    .cart-icon {
        display: flex;
        align-items: center;
    }

    /* Menu mobile */
    .mobile-menu {
        display: none;
        background: rgba(29, 29, 31, 0.98);
        border-top: 1px solid rgba(86, 130, 4, 0.2);
        padding: 1rem 0;
    }

    .mobile-menu--open {
        display: block;
    }

    .mobile-menu__list {
        list-style: none;
        margin: 0;
        padding: 0;
    }

    .mobile-menu__link {
        display: block;
        padding: 0.75rem 1.5rem;
        color: rgba(255, 255, 255, 0.8);
        text-decoration: none;
        font-size: 15px;
        transition: all 0.2s ease;
    }

    .mobile-menu__link:hover {
        background: rgba(86, 130, 4, 0.2);
        color: #568203;
    }

    /* Responsive */
    @media (max-width: 640px) {
        .navbar__container {
            padding: 0 1rem;
        }

        .logo {
            font-size: 18px;
        }
    }
</style>

<script>
    document.addEventListener("astro:page-load", () => {
        const menuToggle = document.getElementById('menuToggle');
        const mobileMenu = document.getElementById('mobileMenu');

        menuToggle?.addEventListener('click', () => {
            mobileMenu?.classList.toggle('mobile-menu--open');
            menuToggle.classList.toggle('hamburger--open');
        });

        document.querySelectorAll('.mobile-menu__link').forEach(link => {
            link.addEventListener('click', () => {
                mobileMenu?.classList.remove('mobile-menu--open');
                menuToggle?.classList.remove('hamburger--open');
            });
        });
    });
</script>
