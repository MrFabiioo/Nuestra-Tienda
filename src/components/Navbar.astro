---
import CartButton from "./CartButton.tsx";
import { getPendingOrderFromCookies } from '../services/orders/pending-order';

// Mostrar link Admin solo cuando hay sesión válida
const user = Astro.locals.user;
const pendingOrder = await getPendingOrderFromCookies(Astro.cookies);
---

<header class="navbar">
    <div class="navbar__container">
        <!-- Izquierda: Logo -->
        <a href="/" class="logo" aria-label="Nuestra Tienda — Ir al inicio">
            <!-- Logo full: isotipo N + wordmark (desktop) -->
            <svg class="logo__svg logo__svg--full" viewBox="0 0 210 40" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
                <circle cx="20" cy="20" r="15" stroke="currentColor" stroke-width="1.8" class="logo__circle"/>
                <path d="M12.5 29.5 L12.5 10.5 L27.5 29.5 L27.5 10.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" fill="none" class="logo__n"/>
                <line x1="42" y1="7" x2="42" y2="33" stroke="currentColor" stroke-opacity="0.2" stroke-width="1"/>
                <text x="50" y="17.5" font-family="Inter, system-ui, Arial, sans-serif" font-size="13" font-weight="700" letter-spacing="2.5" fill="currentColor" class="logo__wordmark-top">NUESTRA</text>
                <text x="51" y="35" font-family="Inter, system-ui, Arial, sans-serif" font-size="13" font-weight="300" letter-spacing="1.2" fill="currentColor" opacity="0.65" class="logo__wordmark-sub">Tienda</text>
            </svg>
            <!-- Logo compact: solo isotipo N (mobile) -->
            <svg class="logo__svg logo__svg--compact" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
                <circle cx="20" cy="20" r="15" stroke="currentColor" stroke-width="1.8" class="logo__circle"/>
                <path d="M12.5 29.5 L12.5 10.5 L27.5 29.5 L27.5 10.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" fill="none" class="logo__n"/>
            </svg>
        </a>

        <!-- Derecha: Nav desktop + Carrito + Hamburguesa mobile -->
        <div class="navbar__right">
            <nav class="desktop-nav" aria-label="Navegación principal">
                <ul class="desktop-nav__list">
                    <li><a href="/" class="desktop-nav__link">Inicio</a></li>
                    <li><a href="/tienda" class="desktop-nav__link">Tienda</a></li>
                    {user ? (
                        <>
                            <li>
                                <a href="/admin/dashboard" class="desktop-nav__link desktop-nav__link--admin" aria-label="Ir al panel admin">
                                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="desktop-nav__admin-icon" aria-hidden="true">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 016 3.75h2.25A2.25 2.25 0 0110.5 6v2.25a2.25 2.25 0 01-2.25 2.25H6a2.25 2.25 0 01-2.25-2.25V6zM3.75 15.75A2.25 2.25 0 016 13.5h2.25a2.25 2.25 0 012.25 2.25V18a2.25 2.25 0 01-2.25 2.25H6A2.25 2.25 0 013.75 18v-2.25zM13.5 6a2.25 2.25 0 012.25-2.25H18A2.25 2.25 0 0120.25 6v2.25A2.25 2.25 0 0118 10.5h-2.25a2.25 2.25 0 01-2.25-2.25V6zM13.5 15.75a2.25 2.25 0 012.25-2.25H18a2.25 2.25 0 012.25 2.25V18A2.25 2.25 0 0118 20.25h-2.25A2.25 2.25 0 0113.5 18v-2.25z" />
                                    </svg>
                                    Admin
                                </a>
                            </li>
                            <li>
                                <a href="/admin/logout" class="desktop-nav__link desktop-nav__link--logout" aria-label="Cerrar sesión admin">
                                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="desktop-nav__admin-icon" aria-hidden="true">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 9V5.25A2.25 2.25 0 0013.5 3h-6a2.25 2.25 0 00-2.25 2.25v13.5A2.25 2.25 0 007.5 21h6a2.25 2.25 0 002.25-2.25V15M12 9l-3 3m0 0l3 3m-3-3h12.75" />
                                    </svg>
                                    Salir
                                </a>
                            </li>
                        </>
                    ) : (
                        <li>
                            <a href="/admin/login" class="desktop-nav__link desktop-nav__link--admin-login" aria-label="Acceso al panel admin">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="desktop-nav__admin-icon" aria-hidden="true">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z" />
                                </svg>
                                Admin
                            </a>
                        </li>
                    )}
                </ul>
            </nav>
            <button
                class="theme-toggle"
                type="button"
                data-theme-toggle
                aria-label="Cambiar entre tema claro y oscuro"
                aria-pressed="false"
            >
                <span class="theme-toggle__icon" aria-hidden="true">☼</span>
                <span class="theme-toggle__label" data-theme-label>Modo claro</span>
            </button>
            <div class="cart-icon">
                <CartButton client:only="preact" pendingOrderUrl={pendingOrder ? `/pagos/${pendingOrder.token}` : null}>
                    <button
                        slot="fallback"
                        type="button"
                        aria-hidden="true"
                        tabindex="-1"
                        class="cart-fallback"
                    >
                        <span class="cart-fallback__icon premium-skeleton"></span>
                        <span class="cart-fallback__badge premium-skeleton"></span>
                    </button>
                </CartButton>
            </div>
            <!-- Hamburguesa: solo visible en mobile -->
            <button
                class="hamburger"
                id="menuToggle"
                aria-label="Abrir menú de navegación"
                aria-expanded="false"
                aria-controls="mobileMenu"
            >
                <span class="hamburger__line"></span>
                <span class="hamburger__line"></span>
                <span class="hamburger__line"></span>
            </button>
        </div>
    </div>

    <!-- Menu desplegable (mobile) -->
    <nav class="mobile-menu" id="mobileMenu" aria-label="Menú mobile" aria-hidden="true">
        <ul class="mobile-menu__list">
            <li><a href="/" class="mobile-menu__link">Inicio</a></li>
            <li><a href="/tienda" class="mobile-menu__link">Tienda</a></li>
            {user ? (
                <>
                    <li><a href="/admin/dashboard" class="mobile-menu__link mobile-menu__link--admin">Admin · Dashboard</a></li>
                    <li>
                        <a href="/admin/logout" class="mobile-menu__link mobile-menu__link--logout">
                            Cerrar sesión
                        </a>
                    </li>
                </>
            ) : (
                <li><a href="/admin/login" class="mobile-menu__link mobile-menu__link--admin">Admin</a></li>
            )}
        </ul>
    </nav>
</header>

<style>
    .navbar {
        background: var(--color-navbar-bg);
        backdrop-filter: blur(20px) saturate(180%);
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        z-index: 50;
        border-bottom: 1px solid var(--color-navbar-border);
        box-shadow: 0 10px 28px var(--color-navbar-shadow);
    }

    .navbar__container {
        max-width: 1200px;
        margin: 0 auto;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 1.5rem;
        height: 64px;
        gap: 1rem;
    }

    /* Logo */
    .logo {
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        flex-shrink: 0;
        color: var(--color-text);
        transition: opacity 0.2s ease;
    }

    .logo:hover {
        opacity: 0.82;
    }

    .logo__svg {
        height: 36px;
        width: auto;
    }

    /* Full: isotipo + wordmark — visible en tablet/desktop */
    .logo__svg--full {
        display: none;
    }

    /* Compact: solo isotipo N — visible en mobile */
    .logo__svg--compact {
        display: block;
    }

    .logo__circle {
        color: var(--color-accent);
    }

    .logo__n {
        color: var(--color-accent);
    }

    .logo__wordmark-top {
        fill: var(--color-text);
    }

    .logo__wordmark-sub {
        fill: var(--color-text);
    }

    /* Nav desktop */
    .desktop-nav {
        display: none; /* oculto en mobile */
    }

    .desktop-nav__list {
        list-style: none;
        margin: 0;
        padding: 0;
        display: flex;
        gap: 0.25rem;
    }

    .desktop-nav__link {
        display: block;
        padding: 0.4rem 0.875rem;
        color: var(--color-text-muted);
        text-decoration: none;
        font-size: 14px;
        font-weight: 500;
        border-radius: 6px;
        transition: color 0.2s ease, background 0.2s ease;
    }

    .desktop-nav__link:hover,
    .desktop-nav__link[aria-current="page"] {
        color: var(--color-text);
        background: var(--color-overlay-strong);
    }

    /* Derecha */
    .navbar__right {
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }

    .theme-toggle {
        display: inline-flex;
        align-items: center;
        gap: 0.55rem;
        min-height: 40px;
        padding: 0.55rem 0.85rem;
        border-radius: 999px;
        border: 1px solid var(--color-navbar-border);
        background: var(--color-overlay-soft);
        color: var(--color-text);
        cursor: pointer;
        font: inherit;
        font-size: 0.85rem;
        font-weight: 600;
        line-height: 1;
    }

    .theme-toggle:hover {
        background: var(--color-overlay-strong);
        border-color: var(--color-accent);
    }

    .theme-toggle__icon {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 1.35rem;
        height: 1.35rem;
        color: var(--color-accent);
        font-size: 1rem;
    }

    .theme-toggle__label {
        white-space: nowrap;
    }

    .cart-icon {
        display: flex;
        align-items: center;
        position: relative;
    }

    .cart-fallback {
        position: relative;
        display: flex;
        align-items: center;
        justify-content: center;
        width: 40px;
        height: 40px;
        border: 0;
        border-radius: 999px;
        background: transparent;
        padding: 0;
        pointer-events: none;
    }

    .cart-fallback__icon {
        width: 28px;
        height: 28px;
        border-radius: 999px;
        opacity: 0.9;
    }

    .cart-fallback__badge {
        position: absolute;
        top: 0;
        right: 0;
        width: 18px;
        height: 18px;
        border-radius: 999px;
        border: 2px solid var(--color-surface);
    }

    /* Hamburguesa */
    .hamburger {
        display: flex;
        flex-direction: column;
        justify-content: center;
        gap: 5px;
        width: 40px;
        height: 40px;
        background: var(--color-overlay-soft);
        border: 1px solid var(--color-navbar-border);
        border-radius: 8px;
        cursor: pointer;
        padding: 8px;
        transition: border-color 0.2s ease;
    }

    .hamburger:hover {
        border-color: var(--color-accent);
        background: var(--color-overlay-strong);
    }

    .hamburger__line {
        width: 100%;
        height: 2px;
        background: var(--color-accent);
        border-radius: 2px;
        transition: all 0.3s ease;
        transform-origin: center;
    }

    /* Animación X al abrir */
    .hamburger--open .hamburger__line:nth-child(1) {
        transform: translateY(7px) rotate(45deg);
    }

    .hamburger--open .hamburger__line:nth-child(2) {
        opacity: 0;
        transform: scaleX(0);
    }

    .hamburger--open .hamburger__line:nth-child(3) {
        transform: translateY(-7px) rotate(-45deg);
    }

    /* Menu mobile */
    .mobile-menu {
        display: none;
        background: var(--color-navbar-bg);
        border-top: 1px solid var(--color-navbar-border);
        padding: 0.5rem 0 1rem;
    }

    .mobile-menu--open {
        display: block;
    }

    .mobile-menu__list {
        list-style: none;
        margin: 0;
        padding: 0;
    }

    .mobile-menu__link {
        display: block;
        padding: 0.875rem 1.5rem;
        color: var(--color-text-muted);
        text-decoration: none;
        font-size: 15px;
        font-weight: 500;
        transition: background 0.2s ease, color 0.2s ease;
        border-left: 3px solid transparent;
    }

    .mobile-menu__link:hover,
    .mobile-menu__link[aria-current="page"] {
        background: var(--color-overlay-strong);
        color: var(--color-text);
        border-left-color: var(--color-accent);
    }

    /* Admin nav links */
    .desktop-nav__link--admin {
        display: inline-flex;
        align-items: center;
        gap: 0.375rem;
        color: var(--color-accent);
        font-weight: 600;
        border: 1px solid var(--color-border);
        background: color-mix(in srgb, var(--color-accent) 06%, var(--color-surface-elevated));
    }

    .desktop-nav__link--admin:hover {
        background: color-mix(in srgb, var(--color-accent) 14%, var(--color-surface-elevated));
        color: var(--color-accent-strong);
        border-color: color-mix(in srgb, var(--color-accent) 36%, var(--color-border));
    }

    .desktop-nav__link--admin-login {
        display: inline-flex;
        align-items: center;
        gap: 0.375rem;
        border: 1px solid var(--color-border);
        background: color-mix(in srgb, var(--color-surface-elevated) 94%, transparent);
    }

    .desktop-nav__link--logout {
        display: inline-flex;
        align-items: center;
        gap: 0.375rem;
        background: none;
        border: 1px solid transparent;
        cursor: pointer;
        font: inherit;
        padding: 0.4rem 0.875rem;
        color: var(--color-text-muted);
        font-size: 14px;
        font-weight: 500;
        border-radius: 6px;
        transition: color 0.2s ease, background 0.2s ease, border-color 0.2s ease;
    }

    .desktop-nav__link--logout:hover {
        color: var(--color-danger-text);
        background: var(--color-danger-surface);
        border-color: var(--color-danger-border);
    }

    .desktop-nav__admin-icon {
        width: 0.9rem;
        height: 0.9rem;
    }

    /* Mobile admin links */
    .mobile-menu__link--admin {
        color: var(--color-accent);
        font-weight: 600;
        border-left-color: var(--color-accent) !important;
    }

    .mobile-menu__link--logout {
        width: 100%;
        background: none;
        border: none;
        cursor: pointer;
        font: inherit;
        text-align: left;
        border-left: 3px solid var(--color-danger-border);
        color: var(--color-danger-text);
    }

    .mobile-menu__link--logout:hover {
        background: var(--color-danger-surface);
        color: var(--color-danger);
        border-left-color: var(--color-danger);
    }

    /* Responsive: en tablet/desktop mostramos nav y ocultamos hamburguesa */
    @media (min-width: 768px) {
        .desktop-nav {
            display: block;
        }

        .hamburger {
            display: none;
        }

        /* Mostrar logo full en tablet/desktop */
        .logo__svg--full {
            display: block;
        }

        .logo__svg--compact {
            display: none;
        }
    }

    @media (max-width: 767px) {
        .navbar__container {
            padding: 0 1rem;
        }

        .logo__svg {
            height: 32px;
        }

        .cart-fallback {
            width: 44px;
            height: 44px;
        }

        .theme-toggle {
            min-width: 40px;
            padding: 0.55rem;
        }

        .theme-toggle__label {
            display: none;
        }
    }
</style>

<script>
    document.addEventListener("astro:page-load", () => {
        const storageKey = 'guacashop-theme';
        const root = document.documentElement;
        const menuToggle = document.getElementById('menuToggle') as HTMLButtonElement | null;
        const mobileMenu = document.getElementById('mobileMenu');
        const themeToggle = document.querySelector('[data-theme-toggle]') as HTMLButtonElement | null;
        const themeLabel = themeToggle?.querySelector('[data-theme-label]') as HTMLSpanElement | null;

        function getResolvedTheme() {
            let storedTheme: string | null = null;

            try {
                storedTheme = window.localStorage.getItem(storageKey);
            } catch {
                storedTheme = null;
            }

            if (storedTheme === 'dark' || storedTheme === 'light') {
                return storedTheme;
            }

            return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
        }

        function syncThemeToggle(theme: 'dark' | 'light') {
            const isDark = theme === 'dark';
            root.dataset.theme = theme;
            root.style.colorScheme = theme;
            themeToggle?.setAttribute('aria-pressed', String(isDark));
            themeToggle?.setAttribute('aria-label', isDark ? 'Cambiar a tema claro' : 'Cambiar a tema oscuro');

            if (themeLabel) {
                themeLabel.textContent = isDark ? 'Modo oscuro' : 'Modo claro';
            }

            const icon = themeToggle?.querySelector('.theme-toggle__icon');
            if (icon) {
                icon.textContent = isDark ? '☾' : '☼';
            }
        }

        syncThemeToggle(getResolvedTheme() as 'dark' | 'light');

        function openMenu() {
            mobileMenu?.classList.add('mobile-menu--open');
            menuToggle?.classList.add('hamburger--open');
            menuToggle?.setAttribute('aria-expanded', 'true');
            menuToggle?.setAttribute('aria-label', 'Cerrar menú de navegación');
            mobileMenu?.removeAttribute('aria-hidden');
        }

        function closeMenu() {
            mobileMenu?.classList.remove('mobile-menu--open');
            menuToggle?.classList.remove('hamburger--open');
            menuToggle?.setAttribute('aria-expanded', 'false');
            menuToggle?.setAttribute('aria-label', 'Abrir menú de navegación');
            mobileMenu?.setAttribute('aria-hidden', 'true');
        }

        menuToggle?.addEventListener('click', () => {
            const isOpen = mobileMenu?.classList.contains('mobile-menu--open');
            isOpen ? closeMenu() : openMenu();
        });

        themeToggle?.addEventListener('click', () => {
            const nextTheme = (root.dataset.theme === 'dark' ? 'light' : 'dark') as 'dark' | 'light';

            try {
                window.localStorage.setItem(storageKey, nextTheme);
            } catch {
                // noop: si storage no está disponible, igual aplicamos el tema en memoria
            }

            syncThemeToggle(nextTheme);
        });

        document.querySelectorAll('.mobile-menu__link').forEach(link => {
            link.addEventListener('click', closeMenu);
        });

        // Cerrar con ESC
        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape' && mobileMenu?.classList.contains('mobile-menu--open')) {
                closeMenu();
                menuToggle?.focus();
            }
        });

        // Marcar link activo
        const currentPath = window.location.pathname;
        document.querySelectorAll('.mobile-menu__link, .desktop-nav__link').forEach((link) => {
            const anchor = link as HTMLAnchorElement;
            const isActive = anchor.getAttribute('href') === currentPath ||
                (currentPath !== '/' && anchor.getAttribute('href') !== '/' && currentPath.startsWith(anchor.getAttribute('href') ?? ''));
            if (isActive) {
                anchor.setAttribute('aria-current', 'page');
            } else {
                anchor.removeAttribute('aria-current');
            }
        });
    });
</script>
