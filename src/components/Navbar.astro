---
import CartButton from "./CartButton.tsx";
import SearchBar from "./SearchBar.astro";
---

<header class="navbar">
    <div class="navbar__container">
        <!-- Izquierda: Logo -->
        <a href="/" class="logo" aria-label="GuacaShop — Ir al inicio">
            <span class="logo__text">Guaca</span>
            <span class="logo__highlight">Shop</span>
        </a>

        <!-- Centro: Barra de busqueda con sugerencias -->
        <SearchBar />

        <!-- Derecha: Nav desktop + Carrito + Hamburguesa mobile -->
        <div class="navbar__right">
            <nav class="desktop-nav" aria-label="Navegación principal">
                <ul class="desktop-nav__list">
                    <li><a href="/" class="desktop-nav__link">Inicio</a></li>
                    <li><a href="/tienda" class="desktop-nav__link">Tienda</a></li>
                    <li><a href="/pagos" class="desktop-nav__link">Pagos</a></li>
                </ul>
            </nav>
            <button
                class="theme-toggle"
                type="button"
                data-theme-toggle
                aria-label="Cambiar entre tema claro y oscuro"
                aria-pressed="false"
            >
                <span class="theme-toggle__icon" aria-hidden="true">☼</span>
                <span class="theme-toggle__label" data-theme-label>Modo claro</span>
            </button>
            <div class="cart-icon">
                <CartButton client:only="preact" transition:persist>
                    <button
                        slot="fallback"
                        type="button"
                        aria-hidden="true"
                        tabindex="-1"
                        class="cart-fallback"
                    >
                        <span class="cart-fallback__icon premium-skeleton"></span>
                        <span class="cart-fallback__badge premium-skeleton"></span>
                    </button>
                </CartButton>
            </div>
            <!-- Hamburguesa: solo visible en mobile -->
            <button
                class="hamburger"
                id="menuToggle"
                aria-label="Abrir menú de navegación"
                aria-expanded="false"
                aria-controls="mobileMenu"
            >
                <span class="hamburger__line"></span>
                <span class="hamburger__line"></span>
                <span class="hamburger__line"></span>
            </button>
        </div>
    </div>

    <!-- Menu desplegable (mobile) -->
    <nav class="mobile-menu" id="mobileMenu" aria-label="Menú mobile" aria-hidden="true">
        <ul class="mobile-menu__list">
            <li><a href="/" class="mobile-menu__link">Inicio</a></li>
            <li><a href="/tienda" class="mobile-menu__link">Tienda</a></li>
            <li><a href="/pagos" class="mobile-menu__link">Pagos</a></li>
        </ul>
    </nav>
</header>

<style>
    .navbar {
        background: var(--color-navbar-bg);
        backdrop-filter: blur(20px) saturate(180%);
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        z-index: 50;
        border-bottom: 1px solid var(--color-navbar-border);
        box-shadow: 0 10px 28px var(--color-navbar-shadow);
    }

    .navbar__container {
        max-width: 1200px;
        margin: 0 auto;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 1.5rem;
        height: 64px;
        gap: 1rem;
    }

    /* Logo */
    .logo {
        text-decoration: none;
        font-size: 22px;
        font-weight: 600;
        letter-spacing: -0.5px;
        flex-shrink: 0;
    }

    .logo__text {
        color: var(--color-text);
    }

    .logo__highlight {
        color: var(--color-accent);
    }

    /* Nav desktop */
    .desktop-nav {
        display: none; /* oculto en mobile */
    }

    .desktop-nav__list {
        list-style: none;
        margin: 0;
        padding: 0;
        display: flex;
        gap: 0.25rem;
    }

    .desktop-nav__link {
        display: block;
        padding: 0.4rem 0.875rem;
        color: var(--color-text-muted);
        text-decoration: none;
        font-size: 14px;
        font-weight: 500;
        border-radius: 6px;
        transition: color 0.2s ease, background 0.2s ease;
    }

    .desktop-nav__link:hover,
    .desktop-nav__link[aria-current="page"] {
        color: var(--color-text);
        background: var(--color-overlay-strong);
    }

    /* Derecha */
    .navbar__right {
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }

    .theme-toggle {
        display: inline-flex;
        align-items: center;
        gap: 0.55rem;
        min-height: 40px;
        padding: 0.55rem 0.85rem;
        border-radius: 999px;
        border: 1px solid var(--color-navbar-border);
        background: var(--color-overlay-soft);
        color: var(--color-text);
        cursor: pointer;
        font: inherit;
        font-size: 0.85rem;
        font-weight: 600;
        line-height: 1;
    }

    .theme-toggle:hover {
        background: var(--color-overlay-strong);
        border-color: var(--color-accent);
    }

    .theme-toggle__icon {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 1.35rem;
        height: 1.35rem;
        color: var(--color-accent);
        font-size: 1rem;
    }

    .theme-toggle__label {
        white-space: nowrap;
    }

    .cart-icon {
        display: flex;
        align-items: center;
        position: relative;
    }

    .cart-fallback {
        position: relative;
        display: flex;
        align-items: center;
        justify-content: center;
        width: 40px;
        height: 40px;
        border: 0;
        border-radius: 999px;
        background: transparent;
        padding: 0;
        pointer-events: none;
    }

    .cart-fallback__icon {
        width: 28px;
        height: 28px;
        border-radius: 999px;
        opacity: 0.9;
    }

    .cart-fallback__badge {
        position: absolute;
        top: 0;
        right: 0;
        width: 18px;
        height: 18px;
        border-radius: 999px;
        border: 2px solid var(--color-surface);
    }

    /* Hamburguesa */
    .hamburger {
        display: flex;
        flex-direction: column;
        justify-content: center;
        gap: 5px;
        width: 40px;
        height: 40px;
        background: var(--color-overlay-soft);
        border: 1px solid var(--color-navbar-border);
        border-radius: 8px;
        cursor: pointer;
        padding: 8px;
        transition: border-color 0.2s ease;
    }

    .hamburger:hover {
        border-color: var(--color-accent);
        background: var(--color-overlay-strong);
    }

    .hamburger__line {
        width: 100%;
        height: 2px;
        background: var(--color-accent);
        border-radius: 2px;
        transition: all 0.3s ease;
        transform-origin: center;
    }

    /* Animación X al abrir */
    .hamburger--open .hamburger__line:nth-child(1) {
        transform: translateY(7px) rotate(45deg);
    }

    .hamburger--open .hamburger__line:nth-child(2) {
        opacity: 0;
        transform: scaleX(0);
    }

    .hamburger--open .hamburger__line:nth-child(3) {
        transform: translateY(-7px) rotate(-45deg);
    }

    /* Menu mobile */
    .mobile-menu {
        display: none;
        background: var(--color-navbar-bg);
        border-top: 1px solid var(--color-navbar-border);
        padding: 0.5rem 0 1rem;
    }

    .mobile-menu--open {
        display: block;
    }

    .mobile-menu__list {
        list-style: none;
        margin: 0;
        padding: 0;
    }

    .mobile-menu__link {
        display: block;
        padding: 0.875rem 1.5rem;
        color: var(--color-text-muted);
        text-decoration: none;
        font-size: 15px;
        font-weight: 500;
        transition: background 0.2s ease, color 0.2s ease;
        border-left: 3px solid transparent;
    }

    .mobile-menu__link:hover,
    .mobile-menu__link[aria-current="page"] {
        background: var(--color-overlay-strong);
        color: var(--color-text);
        border-left-color: var(--color-accent);
    }

    /* Responsive: en tablet/desktop mostramos nav y ocultamos hamburguesa */
    @media (min-width: 768px) {
        .desktop-nav {
            display: block;
        }

        .hamburger {
            display: none;
        }
    }

    @media (max-width: 767px) {
        .navbar__container {
            padding: 0 1rem;
        }

        .logo {
            font-size: 19px;
        }

        .cart-fallback {
            width: 44px;
            height: 44px;
        }

        .theme-toggle {
            min-width: 40px;
            padding: 0.55rem;
        }

        .theme-toggle__label {
            display: none;
        }
    }
</style>

<script>
    document.addEventListener("astro:page-load", () => {
        const storageKey = 'guacashop-theme';
        const root = document.documentElement;
        const menuToggle = document.getElementById('menuToggle') as HTMLButtonElement | null;
        const mobileMenu = document.getElementById('mobileMenu');
        const themeToggle = document.querySelector('[data-theme-toggle]') as HTMLButtonElement | null;
        const themeLabel = themeToggle?.querySelector('[data-theme-label]') as HTMLSpanElement | null;

        function getResolvedTheme() {
            let storedTheme: string | null = null;

            try {
                storedTheme = window.localStorage.getItem(storageKey);
            } catch {
                storedTheme = null;
            }

            if (storedTheme === 'dark' || storedTheme === 'light') {
                return storedTheme;
            }

            return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
        }

        function syncThemeToggle(theme: 'dark' | 'light') {
            const isDark = theme === 'dark';
            root.dataset.theme = theme;
            root.style.colorScheme = theme;
            themeToggle?.setAttribute('aria-pressed', String(isDark));
            themeToggle?.setAttribute('aria-label', isDark ? 'Cambiar a tema claro' : 'Cambiar a tema oscuro');

            if (themeLabel) {
                themeLabel.textContent = isDark ? 'Modo oscuro' : 'Modo claro';
            }

            const icon = themeToggle?.querySelector('.theme-toggle__icon');
            if (icon) {
                icon.textContent = isDark ? '☾' : '☼';
            }
        }

        syncThemeToggle(getResolvedTheme() as 'dark' | 'light');

        function openMenu() {
            mobileMenu?.classList.add('mobile-menu--open');
            menuToggle?.classList.add('hamburger--open');
            menuToggle?.setAttribute('aria-expanded', 'true');
            menuToggle?.setAttribute('aria-label', 'Cerrar menú de navegación');
            mobileMenu?.removeAttribute('aria-hidden');
        }

        function closeMenu() {
            mobileMenu?.classList.remove('mobile-menu--open');
            menuToggle?.classList.remove('hamburger--open');
            menuToggle?.setAttribute('aria-expanded', 'false');
            menuToggle?.setAttribute('aria-label', 'Abrir menú de navegación');
            mobileMenu?.setAttribute('aria-hidden', 'true');
        }

        menuToggle?.addEventListener('click', () => {
            const isOpen = mobileMenu?.classList.contains('mobile-menu--open');
            isOpen ? closeMenu() : openMenu();
        });

        themeToggle?.addEventListener('click', () => {
            const nextTheme = (root.dataset.theme === 'dark' ? 'light' : 'dark') as 'dark' | 'light';

            try {
                window.localStorage.setItem(storageKey, nextTheme);
            } catch {
                // noop: si storage no está disponible, igual aplicamos el tema en memoria
            }

            syncThemeToggle(nextTheme);
        });

        document.querySelectorAll('.mobile-menu__link').forEach(link => {
            link.addEventListener('click', closeMenu);
        });

        // Cerrar con ESC
        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape' && mobileMenu?.classList.contains('mobile-menu--open')) {
                closeMenu();
                menuToggle?.focus();
            }
        });

        // Marcar link activo
        const currentPath = window.location.pathname;
        document.querySelectorAll('.mobile-menu__link, .desktop-nav__link').forEach((link) => {
            const anchor = link as HTMLAnchorElement;
            const isActive = anchor.getAttribute('href') === currentPath ||
                (currentPath !== '/' && anchor.getAttribute('href') !== '/' && currentPath.startsWith(anchor.getAttribute('href') ?? ''));
            if (isActive) {
                anchor.setAttribute('aria-current', 'page');
            } else {
                anchor.removeAttribute('aria-current');
            }
        });
    });
</script>
