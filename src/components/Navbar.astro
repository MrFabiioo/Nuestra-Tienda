---
import CartButton from "./CartButton.tsx";
import SearchBar from "./SearchBar.astro";
---

<header class="navbar">
    <div class="navbar__container">
        <!-- Izquierda: Logo -->
        <a href="/" class="logo" aria-label="GuacaShop — Ir al inicio">
            <span class="logo__text">Guaca</span>
            <span class="logo__highlight">Shop</span>
        </a>

        <!-- Centro: Barra de busqueda con sugerencias -->
        <SearchBar />

        <!-- Derecha: Nav desktop + Carrito + Hamburguesa mobile -->
        <div class="navbar__right">
            <nav class="desktop-nav" aria-label="Navegación principal">
                <ul class="desktop-nav__list">
                    <li><a href="/" class="desktop-nav__link">Inicio</a></li>
                    <li><a href="/tienda" class="desktop-nav__link">Tienda</a></li>
                    <li><a href="/guacamole" class="desktop-nav__link">Guacamole</a></li>
                </ul>
            </nav>
            <div class="cart-icon">
                <CartButton client:only="preact" transition:persist />
            </div>
            <!-- Hamburguesa: solo visible en mobile -->
            <button
                class="hamburger"
                id="menuToggle"
                aria-label="Abrir menú de navegación"
                aria-expanded="false"
                aria-controls="mobileMenu"
            >
                <span class="hamburger__line"></span>
                <span class="hamburger__line"></span>
                <span class="hamburger__line"></span>
            </button>
        </div>
    </div>

    <!-- Menu desplegable (mobile) -->
    <nav class="mobile-menu" id="mobileMenu" aria-label="Menú mobile" aria-hidden="true">
        <ul class="mobile-menu__list">
            <li><a href="/" class="mobile-menu__link">Inicio</a></li>
            <li><a href="/tienda" class="mobile-menu__link">Tienda</a></li>
            <li><a href="/guacamole" class="mobile-menu__link">Guacamole</a></li>
        </ul>
    </nav>
</header>

<style>
    .navbar {
        background: rgba(29, 29, 31, 0.95);
        backdrop-filter: blur(20px) saturate(180%);
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        z-index: 50;
        border-bottom: 2px solid rgba(86, 130, 4, 0.3);
    }

    .navbar__container {
        max-width: 1200px;
        margin: 0 auto;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 1.5rem;
        height: 64px;
        gap: 1rem;
    }

    /* Logo */
    .logo {
        text-decoration: none;
        font-size: 22px;
        font-weight: 600;
        letter-spacing: -0.5px;
        flex-shrink: 0;
    }

    .logo__text {
        color: white;
    }

    .logo__highlight {
        color: #568203;
    }

    /* Nav desktop */
    .desktop-nav {
        display: none; /* oculto en mobile */
    }

    .desktop-nav__list {
        list-style: none;
        margin: 0;
        padding: 0;
        display: flex;
        gap: 0.25rem;
    }

    .desktop-nav__link {
        display: block;
        padding: 0.4rem 0.875rem;
        color: rgba(255, 255, 255, 0.75);
        text-decoration: none;
        font-size: 14px;
        font-weight: 500;
        border-radius: 6px;
        transition: color 0.2s ease, background 0.2s ease;
    }

    .desktop-nav__link:hover,
    .desktop-nav__link[aria-current="page"] {
        color: #568203;
        background: rgba(86, 130, 4, 0.1);
    }

    /* Derecha */
    .navbar__right {
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }

    .cart-icon {
        display: flex;
        align-items: center;
        position: relative;
    }

    /* Hamburguesa */
    .hamburger {
        display: flex;
        flex-direction: column;
        justify-content: center;
        gap: 5px;
        width: 40px;
        height: 40px;
        background: transparent;
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 8px;
        cursor: pointer;
        padding: 8px;
        transition: border-color 0.2s ease;
    }

    .hamburger:hover {
        border-color: rgba(86, 130, 4, 0.5);
    }

    .hamburger__line {
        width: 100%;
        height: 2px;
        background: #568203;
        border-radius: 2px;
        transition: all 0.3s ease;
        transform-origin: center;
    }

    /* Animación X al abrir */
    .hamburger--open .hamburger__line:nth-child(1) {
        transform: translateY(7px) rotate(45deg);
    }

    .hamburger--open .hamburger__line:nth-child(2) {
        opacity: 0;
        transform: scaleX(0);
    }

    .hamburger--open .hamburger__line:nth-child(3) {
        transform: translateY(-7px) rotate(-45deg);
    }

    /* Menu mobile */
    .mobile-menu {
        display: none;
        background: rgba(22, 22, 24, 0.98);
        border-top: 1px solid rgba(86, 130, 4, 0.2);
        padding: 0.5rem 0 1rem;
    }

    .mobile-menu--open {
        display: block;
    }

    .mobile-menu__list {
        list-style: none;
        margin: 0;
        padding: 0;
    }

    .mobile-menu__link {
        display: block;
        padding: 0.875rem 1.5rem;
        color: rgba(255, 255, 255, 0.8);
        text-decoration: none;
        font-size: 15px;
        font-weight: 500;
        transition: background 0.2s ease, color 0.2s ease;
        border-left: 3px solid transparent;
    }

    .mobile-menu__link:hover,
    .mobile-menu__link[aria-current="page"] {
        background: rgba(86, 130, 4, 0.12);
        color: #6da204;
        border-left-color: #568203;
    }

    /* Responsive: en tablet/desktop mostramos nav y ocultamos hamburguesa */
    @media (min-width: 768px) {
        .desktop-nav {
            display: block;
        }

        .hamburger {
            display: none;
        }
    }

    @media (max-width: 767px) {
        .navbar__container {
            padding: 0 1rem;
        }

        .logo {
            font-size: 19px;
        }
    }
</style>

<script>
    document.addEventListener("astro:page-load", () => {
        const menuToggle = document.getElementById('menuToggle') as HTMLButtonElement | null;
        const mobileMenu = document.getElementById('mobileMenu');

        function openMenu() {
            mobileMenu?.classList.add('mobile-menu--open');
            menuToggle?.classList.add('hamburger--open');
            menuToggle?.setAttribute('aria-expanded', 'true');
            menuToggle?.setAttribute('aria-label', 'Cerrar menú de navegación');
            mobileMenu?.removeAttribute('aria-hidden');
        }

        function closeMenu() {
            mobileMenu?.classList.remove('mobile-menu--open');
            menuToggle?.classList.remove('hamburger--open');
            menuToggle?.setAttribute('aria-expanded', 'false');
            menuToggle?.setAttribute('aria-label', 'Abrir menú de navegación');
            mobileMenu?.setAttribute('aria-hidden', 'true');
        }

        menuToggle?.addEventListener('click', () => {
            const isOpen = mobileMenu?.classList.contains('mobile-menu--open');
            isOpen ? closeMenu() : openMenu();
        });

        document.querySelectorAll('.mobile-menu__link').forEach(link => {
            link.addEventListener('click', closeMenu);
        });

        // Cerrar con ESC
        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape' && mobileMenu?.classList.contains('mobile-menu--open')) {
                closeMenu();
                menuToggle?.focus();
            }
        });

        // Marcar link activo
        const currentPath = window.location.pathname;
        document.querySelectorAll('.mobile-menu__link, .desktop-nav__link').forEach((link) => {
            const anchor = link as HTMLAnchorElement;
            const isActive = anchor.getAttribute('href') === currentPath ||
                (currentPath !== '/' && anchor.getAttribute('href') !== '/' && currentPath.startsWith(anchor.getAttribute('href') ?? ''));
            if (isActive) {
                anchor.setAttribute('aria-current', 'page');
            } else {
                anchor.removeAttribute('aria-current');
            }
        });
    });
</script>
