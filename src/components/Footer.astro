---
const currentYear = new Date().getFullYear();
---

<footer class="footer">
    <div class="footer__container">
        <!-- Logo y descripcion -->
        <div class="footer__brand">
            <a href="/" class="footer__logo" aria-label="Nuestra Tienda — inicio">
                <!-- Logo full: isotipo N + wordmark -->
                <svg class="footer__logo-svg footer__logo-svg--full" viewBox="0 0 210 40" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
                    <circle cx="20" cy="20" r="15" stroke="currentColor" stroke-width="1.8" class="footer__logo-circle"/>
                    <path d="M12.5 29.5 L12.5 10.5 L27.5 29.5 L27.5 10.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" fill="none" class="footer__logo-n"/>
                    <line x1="42" y1="7" x2="42" y2="33" stroke="currentColor" stroke-opacity="0.2" stroke-width="1"/>
                    <text x="50" y="17.5" font-family="Inter, system-ui, Arial, sans-serif" font-size="13" font-weight="700" letter-spacing="2.5" fill="currentColor" class="footer__logo-wordmark-top">NUESTRA</text>
                    <text x="51" y="36" font-family="Inter, system-ui, Arial, sans-serif" font-size="13" font-weight="300" letter-spacing="1.2" fill="currentColor" opacity="0.65" class="footer__logo-wordmark-sub">Tienda</text>
                </svg>
            </a>
            <p class="footer__description">
                Una tienda pensada para disfrutar recetas frescas, antojos especiales y compras con una experiencia cuidada de principio a fin.
            </p>
        </div>

        <!-- Enlaces -->
        <nav class="footer__links" aria-label="Navegación del pie de página">
            <h4 class="footer__title">Navegación</h4>
            <ul class="footer__list">
                <li><a href="/" class="footer__link">Inicio</a></li>
                <li><a href="/tienda" class="footer__link">Tienda</a></li>
                <li><a href="/checkout" class="footer__link">Tu pedido</a></li>
            </ul>
        </nav>

        <!-- Contacto -->
        <address class="footer__contact">
            <h4 class="footer__title">Contacto</h4>
            <ul class="footer__list">
                <li class="footer__contact-item">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
                        <polyline points="22,6 12,13 2,6"></polyline>
                    </svg>
                    <a href="mailto:hola@guacamole.com" class="footer__contact-link">hola@guacamole.com</a>
                </li>
                <li class="footer__contact-item">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
                    </svg>
                    <a href="tel:+573001234567" class="footer__contact-link">+57 300 123 4567</a>
                </li>
            </ul>
        </address>

        <!-- Redes sociales -->
        <div class="footer__social">
            <h4 class="footer__title">Síguenos</h4>
            <div class="footer__social-icons">
                <!-- Instagram -->
                <a href="https://instagram.com" target="_blank" rel="noopener noreferrer" class="footer__social-link" aria-label="Instagram">
                    <svg viewBox="0 0 24 24" fill="currentColor" width="24" height="24">
                        <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
                    </svg>
                </a>
                <!-- Facebook -->
                <a href="https://facebook.com" target="_blank" rel="noopener noreferrer" class="footer__social-link" aria-label="Facebook">
                    <svg viewBox="0 0 24 24" fill="currentColor" width="24" height="24">
                        <path d="M9 8h-3v4h3v12h5v-12h3.642l.358-4h-4v-1.667c0-.955.192-1.333 1.115-1.333h2.885v-5h-3.808c-3.596 0-5.192 1.583-5.192 4.615v3.385z"/>
                    </svg>
                </a>
                <!-- TikTok -->
                <a href="https://tiktok.com" target="_blank" rel="noopener noreferrer" class="footer__social-link" aria-label="TikTok">
                    <svg viewBox="0 0 24 24" fill="currentColor" width="24" height="24">
                        <path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-5.2 1.74 2.89 2.89 0 0 1 2.31-4.64 2.93 2.93 0 0 1 .88.13V9.4a6.84 6.84 0 0 0-1-.05A6.33 6.33 0 0 0 5 20.1a6.34 6.34 0 0 0 10.86-4.43v-7a8.16 8.16 0 0 0 4.77 1.52v-3.4a4.85 4.85 0 0 1-1-.1z"/>
                    </svg>
                </a>
            </div>
        </div>
    </div>

    <!-- Footer bottom -->
    <div class="footer__bottom">
        <p>&copy; {currentYear} Nuestra Tienda · by Fabio Ortega</p>
    </div>
</footer>

<style>
    .footer {
        background: var(--color-footer-bg);
        backdrop-filter: blur(20px) saturate(180%);
        border-top: 1px solid var(--color-border);
        margin-top: auto;
        box-shadow: 0 -12px 30px var(--color-footer-shadow);
    }

    .footer__container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 3rem 1.5rem 2rem;
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 2.5rem;
    }

    /* Brand */
    .footer__brand {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .footer__logo {
        display: inline-flex;
        align-items: center;
        text-decoration: none;
        color: var(--color-text);
        transition: opacity 0.2s ease;
    }

    .footer__logo:hover {
        opacity: 0.82;
    }

    .footer__logo-svg {
        height: 38px;
        width: auto;
    }

    .footer__logo-svg--full {
        display: block;
    }

    .footer__logo-circle {
        color: var(--color-accent);
    }

    .footer__logo-n {
        color: var(--color-accent);
    }

    .footer__logo-wordmark-top {
        fill: var(--color-text);
    }

    .footer__logo-wordmark-sub {
        fill: var(--color-text);
    }

    .footer__description {
        color: var(--color-text-muted);
        font-size: 0.9rem;
        line-height: 1.6;
        max-width: 280px;
    }

    /* Titulos */
    .footer__title {
        color: var(--color-accent);
        font-size: 1rem;
        font-weight: 600;
        margin-bottom: 1rem;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    /* Links */
    .footer__list {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
    }

    .footer__link {
        color: var(--color-text-muted);
        text-decoration: none;
        font-size: 0.9rem;
        transition: color 0.2s ease;
    }

    .footer__link:hover {
        color: var(--color-text);
    }

    /* Contacto */
    .footer__contact-item {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        color: var(--color-text-muted);
        font-size: 0.9rem;
        font-style: normal;
    }

    .footer__contact-item svg {
        color: var(--color-accent);
        flex-shrink: 0;
    }

    .footer__contact-link {
        color: var(--color-text-muted);
        text-decoration: none;
        transition: color 0.2s ease;
    }

    .footer__contact-link:hover {
        color: var(--color-text);
    }

    /* Social */
    .footer__social-icons {
        display: flex;
        gap: 1rem;
    }

    .footer__social-link {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 44px;
        height: 44px;
        border-radius: 50%;
        background: var(--color-overlay-soft);
        border: 1px solid var(--color-border);
        color: var(--color-text);
        transition: all 0.3s ease;
    }

    .footer__social-link:hover {
        background: var(--color-accent-strong);
        border-color: var(--color-accent);
        color: var(--color-text-on-accent);
        transform: translateY(-3px);
    }

    /* Bottom */
    .footer__bottom {
        border-top: 1px solid var(--color-border);
        padding: 1.5rem;
        text-align: center;
        color: var(--color-text-muted);
        font-size: 0.85rem;
    }

    /* Responsive */
    @media (max-width: 640px) {
        .footer__container {
            grid-template-columns: 1fr;
            text-align: center;
            padding: 2rem 1rem 1.5rem;
        }

        .footer__description {
            max-width: none;
        }

        .footer__contact-item {
            justify-content: center;
        }

        .footer__social-icons {
            justify-content: center;
        }
    }
</style>
