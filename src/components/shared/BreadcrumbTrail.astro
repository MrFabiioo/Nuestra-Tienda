---
type BreadcrumbItem = {
  label: string;
  href?: string;
};

interface Props {
  items: BreadcrumbItem[];
  eyebrow?: string;
  summary?: string;
}

const { items, eyebrow, summary } = Astro.props;
---

<div class="rounded-2xl border px-4 py-3 shadow-sm backdrop-blur-sm sm:px-5" style="border-color: var(--color-border); background: color-mix(in srgb, var(--color-surface-elevated) 94%, transparent); box-shadow: 0 10px 24px var(--color-shadow-soft);">
  {eyebrow && (
    <p class="text-[11px] font-semibold uppercase tracking-[0.18em]" style="color: color-mix(in srgb, var(--color-accent) 82%, var(--color-text) 18%);">{eyebrow}</p>
  )}

  <nav class:list={["mt-1", !eyebrow && "mt-0"]} aria-label="Breadcrumb">
    <ol class="flex flex-wrap items-center gap-x-2 gap-y-1 text-sm" style="color: var(--color-text-muted);">
      {items.map((item, index) => {
        const isLast = index === items.length - 1;

        return (
          <li class="flex items-center gap-2">
            {item.href && !isLast ? (
              <a href={item.href} class="transition-colors duration-200 hover:text-guacamole-b" style="color: inherit;">
                {item.label}
              </a>
            ) : (
              <span class:list={[isLast && "font-semibold"]} style={isLast ? 'color: var(--color-text);' : undefined} aria-current={isLast ? 'page' : undefined}>
                {item.label}
              </span>
            )}

            {!isLast && <span style="color: var(--color-text-subtle);">/</span>}
          </li>
        );
      })}
    </ol>
  </nav>

  {summary && <p class="mt-2 text-sm leading-relaxed" style="color: var(--color-text-muted);">{summary}</p>}
</div>
