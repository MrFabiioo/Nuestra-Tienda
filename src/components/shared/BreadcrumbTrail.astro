---
type BreadcrumbItem = {
  label: string;
  href?: string;
};

interface Props {
  items: BreadcrumbItem[];
  eyebrow?: string;
  summary?: string;
}

const { items, eyebrow, summary } = Astro.props;
---

<div class="rounded-2xl border border-white/70 bg-white/80 px-4 py-3 shadow-sm backdrop-blur-sm sm:px-5">
  {eyebrow && (
    <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-guacamole-b/80">{eyebrow}</p>
  )}

  <nav class:list={["mt-1", !eyebrow && "mt-0"]} aria-label="Breadcrumb">
    <ol class="flex flex-wrap items-center gap-x-2 gap-y-1 text-sm text-neutral-500">
      {items.map((item, index) => {
        const isLast = index === items.length - 1;

        return (
          <li class="flex items-center gap-2">
            {item.href && !isLast ? (
              <a href={item.href} class="transition-colors duration-200 hover:text-guacamole-b">
                {item.label}
              </a>
            ) : (
              <span class:list={[isLast && "font-semibold text-neutral-900"]} aria-current={isLast ? 'page' : undefined}>
                {item.label}
              </span>
            )}

            {!isLast && <span class="text-neutral-300">/</span>}
          </li>
        );
      })}
    </ol>
  </nav>

  {summary && <p class="mt-2 text-sm leading-relaxed text-neutral-600">{summary}</p>}
</div>
