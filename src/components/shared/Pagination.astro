---
interface Props {
    totalPages: number;
    pageParam: number;
}

const { totalPages, pageParam } = Astro.props;
const url = Astro.url;
const currentPage = Math.max(1, Math.min(pageParam > totalPages ? totalPages : pageParam, totalPages));
const path = url.pathname;

// Construir rango de páginas visible con ellipsis
function buildPageRange(current: number, total: number): (number | '...')[] {
    if (total <= 7) return Array.from({ length: total }, (_, i) => i + 1);
    
    const pages: (number | '...')[] = [];
    
    // Siempre mostrar primera página
    pages.push(1);
    
    if (current > 3) pages.push('...');
    
    const start = Math.max(2, current - 1);
    const end = Math.min(total - 1, current + 1);
    
    for (let i = start; i <= end; i++) {
        pages.push(i);
    }
    
    if (current < total - 2) pages.push('...');
    
    // Siempre mostrar última página
    if (total > 1) pages.push(total);
    
    return pages;
}

const pageRange = buildPageRange(currentPage, totalPages);
const hasPrev = currentPage > 1;
const hasNext = currentPage < totalPages;
---

<nav class="pagination" aria-label="Paginación">
    <!-- Anterior -->
    {hasPrev ? (
        <a 
            href={`${path}?page=${currentPage - 1}`}
            class="pagination__arrow pagination__arrow--active"
            aria-label="Página anterior"
        >
            <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="15 18 9 12 15 6"/>
            </svg>
            <span class="pagination__arrow-label">Anterior</span>
        </a>
    ) : (
        <span class="pagination__arrow pagination__arrow--disabled" aria-disabled="true">
            <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="15 18 9 12 15 6"/>
            </svg>
            <span class="pagination__arrow-label">Anterior</span>
        </span>
    )}

    <!-- Números de página -->
    <div class="pagination__pages">
        {pageRange.map((page) =>
            page === '...' ? (
                <span class="pagination__ellipsis" aria-hidden="true">…</span>
            ) : page === currentPage ? (
                <span class="pagination__page pagination__page--current" aria-current="page">
                    {page}
                </span>
            ) : (
                <a 
                    href={`${path}?page=${page}`}
                    class="pagination__page pagination__page--link"
                    aria-label={`Ir a página ${page}`}
                >
                    {page}
                </a>
            )
        )}
    </div>

    <!-- Siguiente -->
    {hasNext ? (
        <a 
            href={`${path}?page=${currentPage + 1}`}
            class="pagination__arrow pagination__arrow--active"
            aria-label="Página siguiente"
        >
            <span class="pagination__arrow-label">Siguiente</span>
            <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="9 18 15 12 9 6"/>
            </svg>
        </a>
    ) : (
        <span class="pagination__arrow pagination__arrow--disabled" aria-disabled="true">
            <span class="pagination__arrow-label">Siguiente</span>
            <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="9 18 15 12 9 6"/>
            </svg>
        </span>
    )}
</nav>

<style>
    .pagination {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        padding: 1.5rem 0;
        user-select: none;
    }

    /* Flechas anterior/siguiente */
    .pagination__arrow {
        display: inline-flex;
        align-items: center;
        gap: 0.375rem;
        padding: 0.5rem 0.875rem;
        border-radius: 9999px;
        font-size: 0.8125rem;
        font-weight: 600;
        letter-spacing: 0.02em;
        transition: all 0.2s ease;
        white-space: nowrap;
    }

    .pagination__arrow--active {
        background: color-mix(in srgb, var(--color-surface-elevated) 96%, transparent);
        color: var(--color-accent);
        border: 1.5px solid var(--color-border-strong);
        text-decoration: none;
        box-shadow: 0 8px 18px var(--color-shadow-soft);
    }

    .pagination__arrow--active:hover {
        background: linear-gradient(135deg, var(--color-accent) 0%, var(--color-accent-strong) 100%);
        color: var(--color-text-on-accent);
        box-shadow: 0 12px 24px color-mix(in srgb, var(--color-accent) 26%, transparent);
        transform: translateY(-1px);
    }

    .pagination__arrow--disabled {
        background: transparent;
        color: var(--color-text-subtle);
        border: 1.5px solid var(--color-border);
        cursor: not-allowed;
    }

    /* Ocultar etiqueta en móvil muy pequeño */
    @media (max-width: 380px) {
        .pagination__arrow-label {
            display: none;
        }
        .pagination__arrow {
            padding: 0.5rem 0.625rem;
        }
    }

    /* Números de página */
    .pagination__pages {
        display: flex;
        align-items: center;
        gap: 0.25rem;
    }

    .pagination__page {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 36px;
        height: 36px;
        border-radius: 8px;
        font-size: 0.875rem;
        font-weight: 500;
        transition: all 0.15s ease;
    }

    .pagination__page--current {
        background: linear-gradient(135deg, var(--color-accent) 0%, var(--color-accent-strong) 100%);
        color: var(--color-text-on-accent);
        font-weight: 700;
        box-shadow: 0 10px 20px color-mix(in srgb, var(--color-accent) 26%, transparent);
    }

    .pagination__page--link {
        color: var(--color-text-muted);
        background: transparent;
        text-decoration: none;
        border: 1px solid transparent;
    }

    .pagination__page--link:hover {
        background: color-mix(in srgb, var(--color-surface-elevated) 84%, var(--color-accent) 16%);
        color: var(--color-accent);
        border-color: var(--color-border-strong);
    }

    .pagination__ellipsis {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 36px;
        height: 36px;
        color: var(--color-text-subtle);
        font-size: 1rem;
        letter-spacing: -0.05em;
    }
</style>
