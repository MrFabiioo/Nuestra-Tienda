---
interface Props {
    totalPages:number;
    pageParam:number;
}

const{totalPages,pageParam} = Astro.props;
const url = Astro.url;
const currentPage = Math.max(pageParam > totalPages ? totalPages:pageParam,1);
const path = url.pathname;


//export const prerender = true


---




<div class="flex justify-between lg:mt-auto mx-6 my-6 sm:mt-auto md:mt-12">
    <a class="button" href={`${path}?page=${Math.max(currentPage-1,1)}`}>ANTERIOR </a>
    <p class="font-bold">{`Pagina   ${currentPage}  de  ${totalPages}`}</p>
    <a class="button" href={`${path}?page=${Math.min(currentPage+1,totalPages)}`}>SIGUIENTE</a>

</div>

<style>
    .button{
        @apply p-2 bg-black-medium text-guacamole-f rounded font-bold
    }
</style>