---
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import { ClientRouter } from "astro:transitions";

interface Props {
	title?: string;
	description?: string;
	image?: string;
}

const {
	title = "GuacaShop",
	description = "El mejor guacamole artesanal, hecho con amor y los ingredientes más frescos.",
	image = "/og-image.png",
} = Astro.props;

const pageTitle = title === "GuacaShop" ? title : `${title} | GuacaShop`;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<meta property="og:title" content={pageTitle} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={image} />
		<meta property="og:type" content="website" />
		<title>{pageTitle}</title>
		<ClientRouter />
	</head>
	<body>
		<a class="skip-link" href="#main-content">Saltar al contenido principal</a>
		<Navbar />
		<main id="main-content" tabindex="-1">
			<slot />
		</main>
		<Footer />
	</body>
</html>

<style>
	html,
	body {
		width: 100%;
		height: 100%;
		box-sizing: border-box;
		overflow-x: hidden;
	}

	/* Focus-visible global: solo muestra outline al navegar con teclado */
	:focus-visible {
		outline: 2px solid #568203;
		outline-offset: 3px;
		border-radius: 4px;
	}

	/* Remover outline en click (ya cubierto por :focus-visible) */
	:focus:not(:focus-visible) {
		outline: none;
	}

	.skip-link {
		position: fixed;
		top: 1rem;
		left: 50%;
		transform: translate(-50%, -200%);
		padding: 0.75rem 1.25rem;
		background: #568203;
		color: #ffffff;
		text-decoration: none;
		font-size: 0.95rem;
		font-weight: 600;
		border-radius: 999px;
		box-shadow: 0 10px 30px rgba(0, 0, 0, 0.25);
		z-index: 100;
		transition: transform 0.2s ease;
	}

	.skip-link:focus-visible {
		transform: translate(-50%, 0);
	}

	main {
		padding-top: 80px;
		max-width: 1200px;
		margin: 0 auto;
		min-width: 0;
		padding-left: 1rem;
		padding-right: 1rem;
		scroll-margin-top: 96px;
	}
</style>
