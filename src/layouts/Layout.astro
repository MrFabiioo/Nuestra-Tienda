---
import Navbar from "../components/Navbar.astro";
import NavBarVertical from "@components/NavBarVertical.astro";
import Footer from "../components/Footer.astro";
import { ClientRouter } from "astro:transitions";
import NavBarSearch from "@components/NavBarSearch.astro";


interface Props {
	title?: String;
	description?: string;
	image?: string;
}
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>Guacamole Shop</title>
		<ClientRouter />
	</head>
	<body class="flex flex-row min-h-screen bg-white-medium">
		<NavBarSearch />
		<main class="flex flex-col  flex-1">
			<slot />
		</main>
		<!-- <Footer /> -->
	</body>
</html>

<style>
	
	html,
	body {
		/* Evitar 100vw (incluye scrollbar) que puede causar overflow horizontal */
		width: 100%;
		height: 100%;
		box-sizing: border-box;
		/* Como parche final, ocultamos cualquier overflow horizontal pequeño */
		overflow-x: hidden;	
	
		
	}

main{
		padding-top:80px;
		max-width: 1080px;
		margin:auto;
		/* Permitir que los hijos flex se encojan y no provoquen overflow */
		min-width: 0;
	}

/* Layout en grid: columna fija para el navbar y una columna flexible para el contenido.
   Esto evita cálculos manuales y garantiza que el navbar ocupe toda la altura. */
body {
  display: grid;
  grid-template-columns: 72px 1fr;
  min-height: 100vh;
}

	
	

	/* main {
		background-image: url("textura-de-papel-blanco.jpg") ;
		background-size: cover;
		
	} */
</style>

