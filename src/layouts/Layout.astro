---
import "../styles/global.css";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import { ClientRouter } from "astro:transitions";

interface Props {
	title?: string;
	description?: string;
	image?: string;
}

const {
	title = "Nuestra Tienda",
	description = "Guacamole y recetas frescas con una experiencia de compra clara, ágil y deliciosa.",
	image = "/og-image.png",
} = Astro.props;

const pageTitle = title === "Nuestra Tienda" ? title : `${title} | Nuestra Tienda`;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="color-scheme" content="light dark" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<meta property="og:title" content={pageTitle} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={image} />
		<meta property="og:type" content="website" />
		<title>{pageTitle}</title>
		<script is:inline>
			const storageKey = "guacashop-theme";
			let storedTheme = null;

			try {
				storedTheme = window.localStorage.getItem(storageKey);
			} catch {
				storedTheme = null;
			}

			const systemPrefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
			const resolvedTheme = storedTheme === "dark" || storedTheme === "light"
				? storedTheme
				: systemPrefersDark
					? "dark"
					: "light";

			document.documentElement.dataset.theme = resolvedTheme;
			document.documentElement.style.colorScheme = resolvedTheme;
		</script>
		<ClientRouter />
	</head>
	<body>
		<a class="skip-link" href="#main-content">Saltar al contenido principal</a>
		<Navbar />
		<main id="main-content" tabindex="-1">
			<slot />
		</main>
		<Footer />
	</body>
</html>

<style>
	html,
	body {
		width: 100%;
		min-height: 100%;
		box-sizing: border-box;
		overflow-x: hidden;
	}

	body {
		display: flex;
		flex-direction: column;
		min-height: 100dvh;
	}

	/* Focus-visible global: solo muestra outline al navegar con teclado */
	:focus-visible {
		outline: 2px solid var(--color-focus-ring);
		outline-offset: 3px;
		border-radius: 4px;
	}

	/* Remover outline en click (ya cubierto por :focus-visible) */
	:focus:not(:focus-visible) {
		outline: none;
	}

	.skip-link {
		position: fixed;
		top: 1rem;
		left: 50%;
		transform: translate(-50%, -200%);
		padding: 0.75rem 1.25rem;
		background: var(--color-accent-strong);
		color: var(--color-text-on-accent);
		text-decoration: none;
		font-size: 0.95rem;
		font-weight: 600;
		border-radius: 999px;
		box-shadow: 0 10px 30px var(--color-shadow-soft);
		z-index: 100;
		transition: transform 0.2s ease;
	}

	.skip-link:focus-visible {
		transform: translate(-50%, 0);
	}

	main {
		flex: 1 0 auto;
		width: 100%;
		padding-top: 80px;
		max-width: 1200px;
		margin: 0 auto;
		min-width: 0;
		padding-left: 1rem;
		padding-right: 1rem;
		scroll-margin-top: 96px;
	}
</style>
