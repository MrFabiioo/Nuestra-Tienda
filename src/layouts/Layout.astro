---
import "../styles/global.css";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import { BRAND_NAME, DEFAULT_OG_IMAGE_PATH, buildPageTitle, getSiteOrigin, isSensitiveSeoPath, toAbsoluteUrl } from "../utils/seo";

interface Props {
	title?: string;
	description?: string;
	image?: string;
	robots?: string;
	canonical?: string;
	noindex?: boolean;
	ogType?: string;
}

const {
	title,
	description = "Guacamole y recetas frescas con una experiencia de compra clara, ágil y deliciosa.",
	image = DEFAULT_OG_IMAGE_PATH,
	robots,
	canonical,
	noindex = false,
	ogType = "website",
} = Astro.props;

const siteOrigin = getSiteOrigin(Astro.url);
const canonicalUrl = toAbsoluteUrl(canonical, siteOrigin ?? Astro.url) ?? (siteOrigin ? new URL(Astro.url.pathname, siteOrigin) : undefined);
const socialImageUrl = image?.startsWith('data:') ? undefined : toAbsoluteUrl(image, siteOrigin ?? Astro.url);
const pageTitle = buildPageTitle(title);
const robotsContent = robots ?? (noindex || isSensitiveSeoPath(Astro.url.pathname) ? "noindex, nofollow" : "index, follow");
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="color-scheme" content="light dark" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<meta name="robots" content={robotsContent} />
		{canonicalUrl && <link rel="canonical" href={canonicalUrl.href} />}
		<meta property="og:title" content={pageTitle} />
		<meta property="og:description" content={description} />
		{canonicalUrl && <meta property="og:url" content={canonicalUrl.href} />}
		<meta property="og:site_name" content={BRAND_NAME} />
		<meta property="og:locale" content="es_CO" />
		{socialImageUrl && <meta property="og:image" content={socialImageUrl.href} />}
		<meta property="og:type" content={ogType} />
		<meta name="twitter:card" content={socialImageUrl ? "summary_large_image" : "summary"} />
		<meta name="twitter:title" content={pageTitle} />
		<meta name="twitter:description" content={description} />
		{socialImageUrl && <meta name="twitter:image" content={socialImageUrl.href} />}
		<title>{pageTitle}</title>
		<script is:inline>
			const storageKey = "guacashop-theme";
			let storedTheme = null;

			try {
				storedTheme = window.localStorage.getItem(storageKey);
			} catch {
				storedTheme = null;
			}

			const systemPrefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
			const resolvedTheme = storedTheme === "dark" || storedTheme === "light"
				? storedTheme
				: systemPrefersDark
					? "dark"
					: "light";

			document.documentElement.dataset.theme = resolvedTheme;
			document.documentElement.style.colorScheme = resolvedTheme;
		</script>
	</head>
	<body>
		<a class="skip-link" href="#main-content">Saltar al contenido principal</a>
		<Navbar />
		<main id="main-content" tabindex="-1">
			<slot />
		</main>
		<Footer />
	</body>
</html>

<style>
	html,
	body {
		width: 100%;
		min-height: 100%;
		box-sizing: border-box;
		overflow-x: clip;
	}

	body {
		display: flex;
		flex-direction: column;
		min-height: 100dvh;
	}

	/* Focus-visible global: solo muestra outline al navegar con teclado */
	:focus-visible {
		outline: 2px solid var(--color-focus-ring);
		outline-offset: 3px;
		border-radius: 4px;
	}

	/* Remover outline en click (ya cubierto por :focus-visible) */
	:focus:not(:focus-visible) {
		outline: none;
	}

	.skip-link {
		position: fixed;
		top: 1rem;
		left: 50%;
		transform: translate(-50%, -200%);
		padding: 0.75rem 1.25rem;
		background: var(--color-accent-strong);
		color: var(--color-text-on-accent);
		text-decoration: none;
		font-size: 0.95rem;
		font-weight: 600;
		border-radius: 999px;
		box-shadow: 0 10px 30px var(--color-shadow-soft);
		z-index: 100;
		transition: transform 0.2s ease;
	}

	.skip-link:focus-visible {
		transform: translate(-50%, 0);
	}

	main {
		flex: 1 0 auto;
		width: 100%;
		padding-top: 80px;
		max-width: 1200px;
		margin: 0 auto;
		min-width: 0;
		padding-left: 1rem;
		padding-right: 1rem;
		scroll-margin-top: 96px;
	}
</style>
