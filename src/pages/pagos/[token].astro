---
import Layout from '@layouts/Layout.astro';
import BreadcrumbTrail from '../../components/shared/BreadcrumbTrail.astro';
import { actions } from 'astro:actions';
import { Formatter } from '@utils/formatter';
import { getPaymentSettings } from '../../actions/settings/get-payment-settings.action';
import { formatOrderStatus, ORDER_STATUS, PAYMENT_METHODS } from '../../services/orders/constants';
import { clearPendingOrderPointerForToken, reconcilePendingOrderPointer } from '../../services/orders/pending-order';

export const prerender = false;

const token = Astro.params.token ?? '';
const paymentBreadcrumbs = [
  { label: 'Inicio', href: '/' },
  { label: 'Tienda', href: '/tienda' },
  { label: 'Checkout', href: '/checkout' },
  { label: 'Pago' },
];

const { data: order, error } = await Astro.callAction(actions.getOrderByToken, { token });

if (error || !order) {
  clearPendingOrderPointerForToken(Astro.cookies, token);
  return Astro.redirect('/checkout');
}

reconcilePendingOrderPointer(Astro.cookies, order);

const canUploadProof = order.status === ORDER_STATUS.pendingPayment || order.status === ORDER_STATUS.rejected;
const uploadSuccess = Astro.url.searchParams.get('uploaded') === '1';
const isProofSubmitted = uploadSuccess || order.status === ORDER_STATUS.underReview || order.status === ORDER_STATUS.approved;
const statusLabel = formatOrderStatus(order.status);
const proofIsImage = order.latestProof?.mimeType?.startsWith('image/') ?? false;

const { data: paymentSettingsData } = await Astro.callAction(getPaymentSettings, undefined);
const normalizedAvailableMethods: string[] = [];

for (const method of paymentSettingsData?.availableMethods ?? []) {
  if (typeof method === 'string') {
    normalizedAvailableMethods.push(method as string);
  }
}

const paymentSettings = {
  bancolombia: paymentSettingsData?.bancolombia ?? null,
  nequi: paymentSettingsData?.nequi ?? null,
  qr: paymentSettingsData?.qr ?? null,
  availableMethods: normalizedAvailableMethods,
};

const paymentQr = paymentSettings.qr;

const paymentMethodLabels: Record<string, string> = {
  [PAYMENT_METHODS.bancolombia]: 'Bancolombia',
  [PAYMENT_METHODS.nequi]: 'Nequi',
  [PAYMENT_METHODS.qr]: 'QR',
};

function labelPaymentMethod(method: string) {
  return paymentMethodLabels[method] ?? method;
}

const paymentCards: Array<{ key: string; title: string; subtitle: string }> = [];

if (paymentSettings.bancolombia) {
  paymentCards.push({
    key: PAYMENT_METHODS.bancolombia,
    title: 'Bancolombia',
    subtitle: `${paymentSettings.bancolombia.accountType} · ${paymentSettings.bancolombia.accountNumber}`,
  });
}

if (paymentSettings.nequi) {
  paymentCards.push({
    key: PAYMENT_METHODS.nequi,
    title: 'Nequi',
    subtitle: paymentSettings.nequi.phoneNumber,
  });
}

if (paymentQr) {
  paymentCards.push({
    key: PAYMENT_METHODS.qr,
    title: 'QR',
    subtitle: 'Escaneá con tu app bancaria',
  });
}

const paymentMethodOptionsSet = new Set<string>();

for (const method of paymentSettings.availableMethods) {
  if (paymentMethodLabels[method]) {
    paymentMethodOptionsSet.add(method);
  }
}

if (order.payment.method && paymentMethodLabels[order.payment.method]) {
  paymentMethodOptionsSet.add(order.payment.method);
}

const paymentMethodOptions = Array.from(paymentMethodOptionsSet);

const hasSelectablePaymentMethods = paymentMethodOptions.length > 0;
---

<Layout title={`Pago pedido ${order.id.slice(0, 8)} | Guacamole Shop`} description="Revisá el pedido persistido y cargá tu comprobante.">
  <main class="min-h-screen px-4 py-8 md:px-8">
    <div class="mx-auto max-w-6xl space-y-6">
        <BreadcrumbTrail
          items={paymentBreadcrumbs}
          eyebrow="Paso 2 de 2"
          summary="Este link ya está ligado a un pedido real. Pagás, subís el comprobante y después seguimos todo desde estado persistido, como corresponde."
        />

        <!-- Page header -->
        <div class="space-y-3">
          <span class="premium-chip">Paso 2 de 2 · Pago del pedido</span>
          {isProofSubmitted ? (
            <h1 class="text-3xl font-black uppercase tracking-wide text-[var(--color-heading)] md:text-4xl">
              Pago en revisión
            </h1>
          ) : (
            <h1 class="text-3xl font-black uppercase tracking-wide text-[var(--color-heading)] md:text-4xl">
              Completá tu pago
            </h1>
          )}
          {isProofSubmitted ? (
              <p class="text-[var(--color-text-muted)]">
                Tu comprobante fue recibido. Estamos verificando el pago y te avisamos cuando el pedido sea confirmado.
              </p>
          ) : (
              <p class="text-[var(--color-text-muted)]">
                Realizá el pago con los datos de abajo, subí el comprobante y el pedido pasa a revisión automáticamente.
              </p>
          )}
          <div class="flex flex-wrap gap-3 pt-1 text-sm">
            {isProofSubmitted ? (
              <span class="inline-flex items-center gap-2 rounded-full border border-guacamole-b/40 bg-guacamole-b/10 px-4 py-2 font-semibold text-guacamole-b shadow-sm">
                <svg class="h-3.5 w-3.5 flex-shrink-0" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                  <circle cx="8" cy="8" r="6" stroke="currentColor" stroke-width="1.5"/>
                  <path d="M5.5 8l2 2 3-3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                Comprobante enviado
              </span>
            ) : (
              <span class="inline-flex items-center gap-2 rounded-full border border-[var(--color-border)] bg-[var(--color-surface-elevated)] px-4 py-2 text-[var(--color-text-muted)] shadow-sm">
                <span class="h-2 w-2 rounded-full bg-guacamole-b"></span>
                Paso actual: pago y comprobante
              </span>
            )}
            <span class="inline-flex items-center gap-2 rounded-full border border-[var(--color-border)] bg-[var(--color-surface-elevated)] px-4 py-2 text-[var(--color-text-subtle)] shadow-sm">
              <span class="h-2 w-2 rounded-full bg-[var(--color-border-strong)]"></span>
              Siguiente: confirmación del comercio
            </span>
          </div>
        </div>

        {uploadSuccess && (
          <div class="rounded-3xl border border-guacamole-b/30 bg-[var(--color-surface-elevated)] p-6">
            <div class="flex gap-4">
              <div class="flex h-12 w-12 flex-shrink-0 items-center justify-center rounded-2xl bg-guacamole-b/15">
                <svg class="h-6 w-6 text-guacamole-b" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                  <circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.5"/>
                  <path d="M8 12l3 3 5-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>
              <div>
                <p class="font-black uppercase tracking-wide text-[var(--color-heading)]">¡Comprobante recibido!</p>
                <p class="mt-1 text-sm text-[var(--color-text-muted)]">
                  Tu pedido quedó <strong class="text-guacamole-b">en revisión</strong>. El comercio va a verificar tu pago y te va a avisar cuando todo esté confirmado. Si tenés dudas, guardá el número de pedido como referencia.
                </p>
              </div>
            </div>
          </div>
        )}

        <section class="grid gap-6 lg:grid-cols-[1.5fr_1fr]">
          <div class="space-y-6">

            <!-- Order reference card -->
            <article class="premium-panel rounded-3xl p-6">
              <div class="flex flex-col gap-4 border-b border-[var(--color-border)] pb-5 md:flex-row md:items-start md:justify-between">
                <div>
                  <p class="text-xs font-bold uppercase tracking-[0.22em] text-guacamole-b">Referencia pública</p>
                  <h2 class="mt-2 text-2xl font-black uppercase tracking-wide text-[var(--color-heading)]">Pedido {order.id.slice(0, 8)}</h2>
                  <p class="mt-2 text-sm text-[var(--color-text-muted)]">Cliente: <strong class="text-[var(--color-heading-sub)]">{order.customerName}</strong> · {order.customerEmail} · {order.customerPhone}</p>
                </div>
                <span class="premium-chip self-start">{statusLabel}</span>
              </div>

              <div class="mt-5 grid gap-4 md:grid-cols-2">
                <div class="rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface-elevated)] p-4 text-sm text-[var(--color-text-muted)]">
                  <p class="font-bold text-[var(--color-heading-sub)]">Entrega</p>
                  <p class="mt-2">{order.deliveryMethod}</p>
                  <p>{order.address}</p>
                  <p>{order.city}</p>
                  {order.notes && <p class="mt-2">Notas: {order.notes}</p>}
                </div>
                <div class="rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface-elevated)] p-4 text-sm text-[var(--color-text-muted)]">
                  <p class="font-bold text-[var(--color-heading-sub)]">Pago actual</p>
                  <p class="mt-2">Método: <strong id="current-payment-method" class="text-[var(--color-heading-sub)]">{labelPaymentMethod(order.payment.method)}</strong></p>
                  <p>Estado: <strong class="text-[var(--color-heading-sub)]">{order.payment.status}</strong></p>
                  {order.payment.rejectionReason && (
                    <p class="mt-2 font-semibold text-[var(--color-danger-text)]">Motivo rechazo: {order.payment.rejectionReason}</p>
                  )}
                </div>
              </div>
            </article>

            <!-- Payment methods -->
            <article class="premium-panel rounded-3xl p-6">
              <div class="flex items-center gap-3 border-b border-[var(--color-border)] pb-5">
                <div class="flex h-9 w-9 flex-shrink-0 items-center justify-center rounded-xl bg-[var(--color-surface-soft)]">
                  <svg class="h-5 w-5 text-guacamole-b" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                    <rect x="2" y="5" width="16" height="11" rx="2" stroke="currentColor" stroke-width="1.5"/>
                    <path d="M2 9h16" stroke="currentColor" stroke-width="1.5"/>
                    <path d="M6 13h2M10 13h4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                  </svg>
                </div>
                <div>
                  <h2 class="text-xl font-black uppercase tracking-wide text-[var(--color-heading)]">Medios de pago</h2>
                  <p class="mt-0.5 text-xs text-[var(--color-text-subtle)]">Usá el monto exacto del pedido</p>
                </div>
              </div>

              {paymentCards.length > 0 ? (
                <div class="mt-5 grid gap-4 md:grid-cols-3">
                  {paymentCards.map((method) => (
                    <div class="rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface-elevated)] p-4 transition-colors hover:border-[var(--color-border-strong)]">
                      <div class="mb-3 flex h-8 w-8 items-center justify-center rounded-lg bg-[var(--color-surface-soft)]">
                        {method.key === PAYMENT_METHODS.bancolombia && (
                          <svg class="h-4 w-4 text-guacamole-b" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                            <path d="M3 5h14M3 10h14M3 15h8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                          </svg>
                        )}
                        {method.key === PAYMENT_METHODS.nequi && (
                          <svg class="h-4 w-4 text-guacamole-b" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                            <rect x="5" y="2" width="10" height="16" rx="2" stroke="currentColor" stroke-width="1.5"/>
                            <path d="M8 15h4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                          </svg>
                        )}
                        {method.key === PAYMENT_METHODS.qr && (
                          <svg class="h-4 w-4 text-guacamole-b" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                            <rect x="3" y="3" width="5" height="5" rx="0.5" stroke="currentColor" stroke-width="1.5"/>
                            <rect x="12" y="3" width="5" height="5" rx="0.5" stroke="currentColor" stroke-width="1.5"/>
                            <rect x="3" y="12" width="5" height="5" rx="0.5" stroke="currentColor" stroke-width="1.5"/>
                            <path d="M12 12h2v2h-2zM14 14h3v3h-3zM12 17h2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                          </svg>
                        )}
                      </div>
                      <p class="font-bold text-guacamole-a">{method.title}</p>
                      <p class="mt-1 text-xs text-[var(--color-text-subtle)]">{method.subtitle}</p>
                    </div>
                  ))}
                </div>
              ) : (
                <div class="mt-5 rounded-2xl border border-dashed border-[var(--color-border-strong)] bg-[var(--color-surface-soft)] p-5 text-sm text-[var(--color-text-subtle)]">
                  Todavía no hay medios de pago configurados desde el admin. Antes de pagar, pedile al comercio que cargue Bancolombia, Nequi o QR.
                </div>
              )}
            </article>

            <!-- Proof upload -->
            <article class="premium-panel rounded-3xl p-6">
              <div class="flex items-center gap-3 border-b border-[var(--color-border)] pb-5">
                <div class="flex h-9 w-9 flex-shrink-0 items-center justify-center rounded-xl bg-[var(--color-surface-soft)]">
                  <svg class="h-5 w-5 text-guacamole-b" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                    <path d="M4 14v2a1 1 0 001 1h10a1 1 0 001-1v-2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                    <path d="M10 3v9M7 6l3-3 3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </div>
                <div>
                  <h2 class="text-xl font-black uppercase tracking-wide text-[var(--color-heading)]">Comprobante</h2>
                  <p class="mt-0.5 text-xs text-[var(--color-text-subtle)]">JPG, PNG, WEBP o PDF · máx. 8 MB</p>
                </div>
              </div>

              {order.latestProof ? (
                <div class="mt-5 space-y-4 rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface-elevated)] p-4">
                  <div class="flex flex-wrap items-center justify-between gap-3 text-sm text-[var(--color-text-muted)]">
                    <p><strong class="text-[var(--color-heading-sub)]">Último archivo:</strong> {order.latestProof.originalFilename}</p>
                    <a href={order.latestProof.assetUrl} target="_blank" rel="noreferrer" class="font-semibold text-guacamole-b hover:underline">Abrir archivo</a>
                  </div>
                  {proofIsImage ? (
                    <img src={order.latestProof.assetUrl} alt="Comprobante de pago" class="max-h-[26rem] w-full rounded-2xl object-contain" />
                  ) : (
                    <iframe src={order.latestProof.assetUrl} class="h-[26rem] w-full rounded-2xl border border-[var(--color-border)]" title="Comprobante PDF" />
                  )}
                </div>
              ) : (
                <div class="mt-5 rounded-2xl border border-dashed border-[var(--color-border-strong)] bg-[var(--color-surface-soft)] p-5 text-center text-sm text-[var(--color-text-subtle)]">
                  <svg class="mx-auto mb-3 h-8 w-8 text-[var(--color-border-strong)]" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                    <path d="M9 13h6m-3-3v6m-9 1V7a2 2 0 012-2h6l2 2h6a2 2 0 012 2v8a2 2 0 01-2 2H4a2 2 0 01-2-2z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                  Todavía no subiste comprobante. Cuando hagas el pago, cargalo abajo y el pedido pasa a revisión.
                </div>
              )}

              {canUploadProof && hasSelectablePaymentMethods ? (
                <form id="payment-proof-form" class="mt-5 space-y-4" enctype="multipart/form-data">
                  <input type="hidden" name="token" value={token} />
                  <div>
                    <label for="paymentMethod" class="mb-2 block text-sm font-semibold text-[var(--color-heading-sub)]">Medio usado</label>
                    <select id="paymentMethod" name="paymentMethod" class="premium-field">
                      {paymentMethodOptions.map((method) => (
                        <option value={method} selected={order.payment.method === method}>
                          {paymentMethodLabels[method] ?? method}
                        </option>
                      ))}
                    </select>
                  </div>

                  {/* Bancolombia banner */}
                  {paymentSettings.bancolombia && (
                    <div id="banner-bancolombia" class="hidden rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface-elevated)] p-6">
                      <p class="mb-4 text-center text-sm font-semibold text-[var(--color-heading-sub)]">Datos para transferir por Bancolombia</p>
                      <dl class="space-y-2 text-center">
                        <div>
                          <dt class="text-xs text-[var(--color-text-subtle)]">Tipo de cuenta</dt>
                          <dd class="text-sm font-semibold text-[var(--color-heading-sub)]">{paymentSettings.bancolombia.accountType}</dd>
                        </div>
                        <div>
                          <dt class="text-xs text-[var(--color-text-subtle)]">Número</dt>
                          <dd class="text-lg font-black tracking-widest text-[var(--color-heading)]">{paymentSettings.bancolombia.accountNumber}</dd>
                        </div>
                        <div>
                          <dt class="text-xs text-[var(--color-text-subtle)]">Titular</dt>
                          <dd class="text-sm font-semibold text-[var(--color-heading-sub)]">{paymentSettings.bancolombia.holderName}</dd>
                        </div>
                      </dl>
                      <p class="mt-4 text-center text-xs text-[var(--color-text-subtle)]">{paymentSettings.bancolombia.note ?? 'Usá el monto exacto del pedido · Guardá el comprobante'}</p>
                    </div>
                  )}

                  {/* Nequi banner */}
                  {paymentSettings.nequi && (
                    <div id="banner-nequi" class="hidden rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface-elevated)] p-6">
                      <p class="mb-4 text-center text-sm font-semibold text-[var(--color-heading-sub)]">Datos para transferir por Nequi</p>
                      <dl class="space-y-2 text-center">
                        <div>
                          <dt class="text-xs text-[var(--color-text-subtle)]">Celular</dt>
                          <dd class="text-lg font-black tracking-widest text-[var(--color-heading)]">{paymentSettings.nequi.phoneNumber}</dd>
                        </div>
                        <div>
                          <dt class="text-xs text-[var(--color-text-subtle)]">Titular</dt>
                          <dd class="text-sm font-semibold text-[var(--color-heading-sub)]">{paymentSettings.nequi.holderName}</dd>
                        </div>
                      </dl>
                      <p class="mt-4 text-center text-xs text-[var(--color-text-subtle)]">{paymentSettings.nequi.note ?? 'Ideal para pago rápido desde la app · Guardá el comprobante'}</p>
                    </div>
                  )}

                  {/* QR banner — visible only when paymentQr exists */}
                  {paymentQr && (
                    <div id="banner-qr" class="hidden rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface-elevated)] p-6">
                      <p class="mb-4 text-center text-sm font-semibold text-[var(--color-heading-sub)]">Escaneá este código con tu app bancaria</p>
                      <div class="flex justify-center">
                        <img src={paymentQr.url} alt="QR de pago" class="h-64 w-64 rounded-2xl object-contain shadow-lg" />
                      </div>
                      <p class="mt-4 text-center text-xs text-[var(--color-text-subtle)]">Usá el monto exacto del pedido · Guardá el comprobante</p>
                    </div>
                  )}

                  <div>
                    <label for="proofFile" class="mb-2 block text-sm font-semibold text-[var(--color-heading-sub)]">Archivo</label>
                    <input id="proofFile" name="proofFile" type="file" accept="image/jpeg,image/png,image/webp,application/pdf" class="premium-field file:mr-4 file:rounded-full file:border-0 file:bg-guacamole-b file:px-4 file:py-2 file:font-semibold file:text-white" required />
                  </div>
                  <p id="payment-proof-feedback" class="min-h-[1.25rem] text-sm text-[var(--color-text-muted)]" aria-live="polite"></p>
                  <button id="payment-proof-submit" type="submit" class="premium-action-primary w-full justify-center">
                    <svg class="h-4 w-4" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                      <path d="M4 14v2a1 1 0 001 1h10a1 1 0 001-1v-2M10 3v9M7 6l3-3 3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                    Subir comprobante y pasar a revisión
                  </button>
                </form>
              ) : canUploadProof ? (
                <div class="mt-5 rounded-2xl border border-dashed border-[var(--color-border-strong)] bg-[var(--color-surface-soft)] p-5 text-sm text-[var(--color-text-subtle)]">
                  No hay medios de pago configurados para este pedido. Antes de subir un comprobante, el comercio tiene que cargar Bancolombia, Nequi o QR desde el panel admin.
                </div>
              ) : (
                <div class="mt-5 rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface-elevated)] p-5 text-sm text-[var(--color-text-muted)]">
                  Este pedido ya no necesita una nueva carga desde el link público. Si ves algo raro, revisalo con el comercio desde el backoffice.
                </div>
              )}
            </article>
          </div>

          <!-- Sidebar: order summary -->
          <aside class="space-y-6">
            <article class="premium-panel sticky top-24 rounded-3xl p-6">
              <div class="flex items-center gap-3 border-b border-[var(--color-border)] pb-5">
                <div class="flex h-9 w-9 flex-shrink-0 items-center justify-center rounded-xl bg-[var(--color-surface-soft)]">
                  <svg class="h-5 w-5 text-guacamole-b" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                    <path d="M4 4h12l-1.5 9H5.5L4 4zM4 4H2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    <circle cx="7.5" cy="16.5" r="1" fill="currentColor"/>
                    <circle cx="13.5" cy="16.5" r="1" fill="currentColor"/>
                  </svg>
                </div>
                <div>
                  <h2 class="text-xl font-black uppercase tracking-wide text-[var(--color-heading)]">Resumen</h2>
                  <p class="mt-0.5 text-xs text-[var(--color-text-subtle)]">{order.items.length} {order.items.length === 1 ? 'producto' : 'productos'}</p>
                </div>
              </div>

              <div class="mt-5 space-y-3">
                {order.items.map((item) => (
                  <div class="flex gap-3 rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface-elevated)] p-3">
                    <img src={item.image} alt={item.title} class="h-16 w-16 rounded-xl object-cover" />
                    <div class="min-w-0 flex-1">
                      <p class="line-clamp-1 font-bold text-[var(--color-heading)]">{item.title}</p>
                      <p class="text-sm text-[var(--color-text-subtle)]">{item.size} · x{item.quantity}</p>
                      <p class="text-sm font-semibold text-guacamole-a">{Formatter.currency(item.lineTotal)}</p>
                    </div>
                  </div>
                ))}
              </div>

              <div class="mt-5 space-y-3 border-t border-[var(--color-border)] pt-4 text-sm text-[var(--color-text-muted)]">
                <div class="flex justify-between">
                  <span>Subtotal</span>
                  <strong class="text-[var(--color-heading-sub)]">{Formatter.currency(order.subtotal)}</strong>
                </div>
                <div class="flex justify-between">
                  <span>Impuesto</span>
                  <strong class="text-[var(--color-heading-sub)]">{Formatter.currency(order.tax)}</strong>
                </div>
                <div class="flex justify-between rounded-xl bg-[var(--color-surface-soft)] px-3 py-2 text-base font-black text-[var(--color-heading)]">
                  <span>Total</span>
                  <strong>{Formatter.currency(order.total)}</strong>
                </div>
              </div>
            </article>
          </aside>
        </section>
    </div>
  </main>

  <script>
      // @ts-nocheck
      import { actions } from 'astro:actions';

      document.addEventListener('astro:page-load', () => {
        const formNode = document.getElementById('payment-proof-form');
        const submitNode = document.getElementById('payment-proof-submit');
        const feedbackNode = document.getElementById('payment-proof-feedback');
        const selectNode = document.getElementById('paymentMethod');
        const currentMethodEl = document.getElementById('current-payment-method');
        const banners = {
          bancolombia: document.getElementById('banner-bancolombia'),
          nequi:       document.getElementById('banner-nequi'),
          qr:          document.getElementById('banner-qr'),
        };
        const methodLabels = /** @type {Record<string, string>} */ ({
          bancolombia: 'Bancolombia',
          nequi: 'Nequi',
          qr: 'QR',
        });

        const form = formNode instanceof HTMLFormElement ? formNode : null;
        const submit = submitNode instanceof HTMLButtonElement ? submitNode : null;
        const feedback = feedbackNode instanceof HTMLParagraphElement ? feedbackNode : null;
        const select = selectNode instanceof HTMLSelectElement ? selectNode : null;

        if (select) {
          const syncBanners = () => {
            const active = select.value;
            for (const [key, el] of Object.entries(banners)) {
              el?.classList.toggle('hidden', key !== active);
            }
            if (currentMethodEl) {
              currentMethodEl.textContent = methodLabels[active] ?? active;
            }
          };
          select.addEventListener('change', syncBanners);
          syncBanners(); // estado inicial
        }

        if (!form || !submit || !feedback) return;

        form.addEventListener('submit', async (event) => {
          event.preventDefault();

          const formData = new FormData(form);
          const file = formData.get('proofFile');

          if (!(file instanceof File) || file.size === 0) {
            feedback.textContent = 'Elegí un comprobante antes de enviarlo.';
            feedback.className = 'min-h-[1.25rem] text-sm text-[var(--color-danger)]';
            return;
          }

          submit.disabled = true;
          submit.textContent = 'Subiendo comprobante...';
          feedback.textContent = 'Estamos subiendo el archivo y moviendo el pedido a revisión.';
          feedback.className = 'min-h-[1.25rem] text-sm text-[var(--color-text-muted)]';

          const { error } = await actions.uploadPaymentProof(formData);

          if (error) {
            feedback.textContent = error.message;
            feedback.className = 'min-h-[1.25rem] text-sm text-[var(--color-danger)]';
            submit.disabled = false;
            submit.textContent = 'Subir comprobante y pasar a revisión';
            return;
          }

          window.location.href = `${window.location.pathname}?uploaded=1`;
        });
      });
  </script>
</Layout>
