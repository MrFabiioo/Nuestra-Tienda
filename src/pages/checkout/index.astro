---
import Layout from '@layouts/Layout.astro'
import { actions } from 'astro:actions';
import {Formatter} from '@utils/formatter'
import BreadcrumbTrail from '../../components/shared/BreadcrumbTrail.astro';

const cart = Astro.cookies.get('cart');

export const prerender = false

const {data:products,error}= await Astro.callAction(actions.loadProductsFromCart,{});



if (error || !products) {
   console.error(error)
   return Astro.redirect('/');
}

const total = products.reduce(
  (acc, product) => acc + product.price * product.quantity,
  0
);

const isEmpty = products.length === 0;
const lockedDeliveryData = {
  method: 'wemi',
  address: 'CR 48 14 49',
  city: 'Medellin - Poblado',
  notes: 'Grupo Emi Falk - Sala de Rdio'
};

const checkoutBreadcrumbs = [
  { label: 'Inicio', href: '/' },
  { label: 'Tienda', href: '/tienda' },
  { label: 'Checkout' },
];
---

<Layout title="Checkout | Nuestra Tienda" description="Revisá tu pedido y prepará el pago">
  <main class="theme-checkout-page min-h-screen bg-guacamole-fondo/10 py-8 px-4 md:px-8">
    <div class="max-w-6xl mx-auto mb-6">
      <BreadcrumbTrail
        items={checkoutBreadcrumbs}
        eyebrow="Paso 1 de 2"
        summary={isEmpty
          ? 'Tu checkout está listo para recibir productos. Volvé a la tienda para armar el pedido y después completás tus datos acá.'
          : 'Estás revisando tu pedido antes de pagar. Si necesitás ajustar productos, podés volver a la tienda o entrar al detalle desde esta misma pantalla.'}
      />
    </div>
    
    {isEmpty ? (
      <!-- Empty Cart State -->
      <div class="mx-auto max-w-2xl py-16 text-center">
        <!-- Pending order banner: filled by JS if localStorage has a token -->
        <div id="pending-order-banner" class="hidden mb-8 rounded-3xl border border-guacamole-b/30 bg-guacamole-fondo/20 px-6 py-5 text-left">
          <p class="text-xs font-bold uppercase tracking-[0.2em] text-guacamole-b">Pedido pendiente de pago</p>
          <p class="mt-1 text-sm text-gray-600">Tenés un pedido que todavía espera el comprobante. Podés volver a tu página de pago en cualquier momento.</p>
          <a id="pending-order-link" href="#" class="mt-3 inline-flex items-center gap-1.5 rounded-full bg-guacamole-b px-5 py-2.5 text-sm font-bold text-white hover:bg-guacamole-a">
            Ver mi pedido pendiente →
          </a>
        </div>
        <div class="premium-subtle-panel p-8 md:p-12">
          <!-- Icon -->
          <div class="w-24 h-24 mx-auto mb-6 bg-guacamole-fondo/20 rounded-full flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-12 h-12 text-guacamole-b" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
            </svg>
          </div>
          
          <h1 class="mb-4 text-3xl font-black uppercase tracking-wide text-guacamole-icons md:text-4xl">
            Tu pedido todavía está vacío
          </h1>
          
          <p class="mb-8 text-lg text-gray-600">
            Sumá productos desde la tienda para revisar tu compra y avanzar al pago cuando quieras.
          </p>
          
          <a 
            href="/tienda" 
            class="premium-action-primary"
          >
            Ir a la tienda
          </a>
          
          <!-- Trust badges -->
          <div class="mt-10 grid grid-cols-1 gap-4 border-t border-gray-200 pt-8 md:grid-cols-2">
            <div class="flex items-center gap-3 rounded-2xl border border-neutral-200 bg-neutral-50 px-4 py-3 text-guacamole-icons">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-guacamole-b" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4" />
              </svg>
              <span class="text-sm font-semibold">Envío gratis +$50</span>
            </div>
            <div class="flex items-center gap-3 rounded-2xl border border-neutral-200 bg-neutral-50 px-4 py-3 text-guacamole-icons">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-guacamole-b" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <span class="text-sm font-semibold">Garantía de 30 días</span>
            </div>
          </div>
        </div>
      </div>
    ) : (
      <!-- Checkout with Items -->
        <div class="max-w-6xl mx-auto">
          <!-- Header -->
          <div class="mb-8 space-y-3">
            <span class="premium-chip">
              Paso 1 de 2 · Datos y entrega
            </span>
            <h1 class="text-3xl md:text-4xl font-black text-guacamole-icons uppercase tracking-wide">
              Revisar pedido
            </h1>
            <p class="text-gray-600 mt-2">
              Revisá tus productos, completá tus datos con calma y dejá listo el paso a pago sin fricción.
            </p>
            <div class="mt-4 flex flex-wrap gap-3 text-sm text-gray-600">
              <span class="inline-flex items-center gap-2 rounded-full border border-gray-200 bg-white px-4 py-2 shadow-sm">
                <span class="h-2 w-2 rounded-full bg-guacamole-b"></span>
                Paso actual: validar pedido y datos
              </span>
                <span class="inline-flex items-center gap-2 rounded-full border border-gray-200 bg-white px-4 py-2 shadow-sm">
                  <span class="h-2 w-2 rounded-full bg-guacamole-b/70"></span>
                Próximo paso: elegir medio de pago
              </span>
            </div>
          </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
          <!-- Main Content Column -->
          <div class="lg:col-span-2 space-y-6">
            <!-- Back button -->
            <div class="flex flex-wrap items-center gap-3">
              <a
                href="/tienda"
                class="premium-action-secondary"
              >
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
                </svg>
                <span>Volver a la tienda</span>
              </a>
              <span class="checkout-status-pill inline-flex items-center rounded-full px-4 py-2 text-xs font-semibold uppercase tracking-[0.18em]">
                Estás a un paso del pago
              </span>
            </div>

            <!-- Products Card -->
            <div class="premium-panel overflow-hidden rounded-3xl">
              <div class="bg-guacamole-a px-6 py-4">
                <h2 class="text-xl font-black text-white uppercase tracking-wide">
                  Tu selección ({products.length})
                </h2>
              </div>

              <div class="divide-y divide-gray-100">
                {products.map((product) => (
                  <div class="flex gap-4 p-4 transition-colors hover:bg-gray-50 md:gap-6 md:p-6">
                    <!-- Product Image -->
                    <div class="shrink-0">
                      <img
                        src={product.image}
                        alt={product.title}
                         class="h-20 w-20 rounded-xl border-2 border-guacamole-b/20 object-cover shadow-sm md:h-24 md:w-24"
                      />
                    </div>

                    <!-- Product Details -->
                    <div class="flex-1 min-w-0">
                      <div class="flex flex-col md:flex-row md:justify-between md:items-start gap-2">
                        <div>
                          <a
                            href={`/products/${product.slug}`}
                            class="text-lg font-bold text-guacamole-icons hover:text-guacamole-b hover:underline transition-colors line-clamp-1"
                          >
                            {product.title}
                          </a>
                          <div class="flex items-center gap-3 mt-1 text-sm text-gray-500">
                            <span class="rounded-full border border-guacamole-fondo/30 bg-guacamole-fondo/20 px-3 py-1 font-semibold text-guacamole-icons">
                              {product.sizes}
                            </span>
                            <span>Cantidad: <strong>{product.quantity}</strong></span>
                          </div>
                        </div>

                        <div class="text-right">
                          <p class="text-xl font-black text-guacamole-a">
                            {Formatter.currency(product.price * product.quantity)}
                          </p>
                          <p class="text-xs text-gray-400">
                            {Formatter.currency(product.price)} c/u
                          </p>
                        </div>
                      </div>

                      <!-- Remove Button -->
                       <button
                         data-id={product.productId}
                         data-size={product.sizes}
                         class="btn-delete mt-3 inline-flex items-center gap-1 rounded-full border border-guacamole-b/15 bg-guacamole-fondo/10 px-3 py-1.5 text-sm font-semibold text-guacamole-a transition-colors hover:border-guacamole-b/25 hover:bg-guacamole-fondo/15 hover:text-guacamole-b disabled:cursor-wait disabled:border-guacamole-b/10 disabled:bg-guacamole-fondo/10 disabled:text-guacamole-b/40"
                        >
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                        </svg>
                        Quitar
                      </button>
                    </div>
                  </div>
                ))}
              </div>
            </div>

            <!-- Customer Form -->
            <div class="premium-panel overflow-hidden">
              <div class="bg-guacamole-b px-6 py-4">
                <h2 class="text-xl font-black text-white uppercase tracking-wide">
                  Tus datos
                </h2>
              </div>

              <form id="customer-form" class="p-6 space-y-6">
                <div id="form-feedback" class="hidden rounded-2xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700" role="alert"></div>

                <div class="rounded-2xl border border-guacamole-fondo/40 bg-guacamole-fondo/10 px-4 py-4 text-sm text-guacamole-icons">
                  <p class="font-bold">Tus datos se usan solo para confirmar el pedido y coordinar la entrega en la WEMI.</p>
                  <p class="mt-1 text-gray-600">Los campos con <span class="font-bold text-red-500">*</span> son los mínimos para avanzar a pago sin perder contexto.</p>
                </div>

                <!-- Section: Contact Information -->
                <div class="space-y-4">
                  <div class="border-b border-gray-100 pb-2">
                    <h3 class="text-lg font-bold text-guacamole-icons">Información de contacto</h3>
                    <p class="text-sm text-gray-500">Así te confirmamos el pedido y cualquier detalle importante de entrega.</p>
                  </div>

                  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <!-- Nombre completo -->
                    <div data-field-wrapper>
                      <label for="fullName" class="block text-sm font-semibold text-guacamole-icons mb-2">
                        Nombre completo <span class="text-red-500">*</span>
                      </label>
                      <input
                        type="text"
                        id="fullName"
                        name="fullName"
                        required
                        autocomplete="name"
                        class="premium-field"
                        placeholder="Ej. Juan Pérez"
                      />
                      <p class="field-help">Usá nombre y apellido para identificar tu pedido más rápido.</p>
                      <p class="field-error hidden" data-field-error></p>
                    </div>

                    <!-- Teléfono -->
                    <div data-field-wrapper>
                      <label for="phone" class="block text-sm font-semibold text-guacamole-icons mb-2">
                        Teléfono <span class="text-red-500">*</span>
                      </label>
                      <input
                        type="tel"
                        id="phone"
                        name="phone"
                        required
                        autocomplete="tel"
                        inputmode="tel"
                        class="premium-field"
                        placeholder="+58 412 123 4567"
                      />
                      <p class="field-help">Te contactamos por acá si surge algo con la entrega en la WEMI.</p>
                      <p class="field-error hidden" data-field-error></p>
                    </div>
                  </div>

                  <!-- Correo electrónico -->
                  <div data-field-wrapper>
                    <label for="email" class="block text-sm font-semibold text-guacamole-icons mb-2">
                      Correo electrónico <span class="text-red-500">*</span>
                    </label>
                    <input
                      type="email"
                      id="email"
                      name="email"
                      required
                      autocomplete="email"
                      class="premium-field"
                      placeholder="juan@email.com"
                    />
                    <p class="field-help">Acá te llega la confirmación del pedido y cualquier actualización relevante.</p>
                    <p class="field-error hidden" data-field-error></p>
                  </div>
                </div>

                <!-- Section: Delivery Information -->
                <div class="space-y-4 pt-4">
                  <div class="border-b border-gray-100 pb-2">
                    <h3 class="text-lg font-bold text-guacamole-icons">Entrega y referencias</h3>
                    <p class="text-sm text-gray-500">Dejanos el contexto justo para que la coordinación salga prolija desde el primer mensaje.</p>
                  </div>

                  <!-- Método de entrega -->
                  <div data-field-wrapper>
                    <label class="block text-sm font-semibold text-guacamole-icons mb-3">
                      Método de entrega <span class="text-red-500">*</span>
                    </label>
                    <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
                      <label class="checkout-delivery-option flex cursor-pointer items-start gap-3 rounded-2xl px-4 py-4 transition-all">
                        <input
                          type="radio"
                          name="deliveryMethod"
                          value={lockedDeliveryData.method}
                          checked
                          class="mt-1 h-5 w-5 text-guacamole-b focus:ring-guacamole-b"
                        />
                        <span>
                          <span class="block font-semibold text-guacamole-icons">En la WEMI</span>
                          <span class="mt-1 block text-sm text-gray-500">Retirás o recibís tu pedido en el punto fijo habilitado por ahora.</span>
                        </span>
                      </label>
                      <label class="checkout-delivery-option checkout-delivery-option-disabled flex items-start gap-3 rounded-2xl px-4 py-4 transition-all" aria-disabled="true">
                        <input
                          type="radio"
                          name="deliveryMethod"
                          value="domicilio"
                          disabled
                          class="mt-1 h-5 w-5 text-guacamole-b focus:ring-guacamole-b"
                        />
                        <span>
                          <span class="block font-semibold text-guacamole-icons">Domicilio</span>
                          <span class="mt-1 block text-sm text-gray-500">La opción sigue visible, pero por ahora no está disponible para nuevos pedidos.</span>
                        </span>
                      </label>
                    </div>
                    <p class="field-help">Por ahora todos los pedidos se entregan únicamente en la WEMI.</p>
                    <p class="field-error hidden" data-field-error></p>
                  </div>

                  <!-- Dirección -->
                  <div data-field-wrapper>
                    <label for="address" class="block text-sm font-semibold text-guacamole-icons mb-2">
                      Dirección de entrega <span class="text-red-500">*</span>
                    </label>
                    <input
                      type="text"
                      id="address"
                      name="address"
                      required
                      autocomplete="street-address"
                      readonly
                      class="premium-field"
                      value={lockedDeliveryData.address}
                    />
                    <p class="field-help">Dirección fija habilitada para las entregas actuales.</p>
                    <p class="field-error hidden" data-field-error></p>
                  </div>

                  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <!-- Ciudad / Sector -->
                    <div data-field-wrapper>
                      <label for="city" class="block text-sm font-semibold text-guacamole-icons mb-2">
                        Ciudad / Sector <span class="text-red-500">*</span>
                      </label>
                      <input
                        type="text"
                        id="city"
                        name="city"
                        required
                        autocomplete="address-level2"
                        readonly
                        class="premium-field"
                        value={lockedDeliveryData.city}
                      />
                      <p class="field-help">Ciudad y sector definidos para este punto de entrega.</p>
                      <p class="field-error hidden" data-field-error></p>
                    </div>

                    <!-- Referencias / Notas -->
                    <div data-field-wrapper>
                      <label for="notes" class="block text-sm font-semibold text-guacamole-icons mb-2">
                        Referencia del punto de entrega
                      </label>
                      <textarea
                        id="notes"
                        name="notes"
                        rows="4"
                        readonly
                        class="premium-field min-h-[112px] resize-y"
                      >{lockedDeliveryData.notes}</textarea>
                      <p class="field-help">Referencia hardcodeada para identificar el punto exacto dentro de la WEMI.</p>
                      <p class="field-error hidden" data-field-error></p>
                    </div>
                  </div>
                </div>

                <div class="checkout-review-note rounded-2xl px-4 py-4 text-sm text-gray-600">
                  <p class="font-semibold text-guacamole-icons">Antes de pasar a pago</p>
                  <p class="mt-1">Chequeá que el teléfono esté bien escrito. El punto de entrega ya queda fijado automáticamente en la WEMI.</p>
                </div>
              </form>
            </div>
          </div>

          <!-- Summary Panel -->
          <div class="lg:col-span-1">
            <div class="premium-panel sticky top-24 rounded-3xl">
              <div class="bg-guacamole-a px-6 py-4 rounded-t-2xl">
                <h2 class="text-xl font-black text-white uppercase tracking-wide">
                  Resumen de tu pedido
                </h2>
              </div>
              
              <div class="p-6 space-y-4">
                <!-- Order Details -->
                <div class="space-y-3 text-gray-600">
                  <div class="flex justify-between items-center">
                    <span class="font-semibold">Subtotal</span>
                    <span class="font-bold text-guacamole-icons">{Formatter.currency(total)}</span>
                  </div>
                  
                  <div class="flex justify-between items-center">
                    <span class="font-semibold">Entrega</span>
                    <span class="font-bold text-guacamole-b">A coordinar</span>
                  </div>
                  
                  <div class="flex justify-between items-center">
                    <span class="font-semibold">Impuesto (15%)</span>
                    <span class="font-bold text-guacamole-icons">{Formatter.currency(total * 0.15)}</span>
                  </div>
                </div>
                
                <!-- Divider -->
                <div
                  class="border-t-2 border-guacamole-b/20 pt-4"
                  data-checkout-total
                  data-subtotal={total}
                  data-tax={total * 0.15}
                  data-total={total * 1.15}
                >
                  <div class="flex justify-between items-center">
                    <span class="text-xl font-black text-guacamole-icons uppercase">Total</span>
                    <span class="text-2xl font-black text-guacamole-a">
                      {Formatter.currency(total * 1.15)}
                    </span>
                  </div>
                </div>
                
                <!-- Trust Badges -->
                <div class="rounded-2xl border border-guacamole-fondo/25 bg-guacamole-fondo/10 p-4 space-y-2">
                  <p class="text-xs font-bold uppercase tracking-[0.22em] text-guacamole-b">Checklist premium</p>
                  <div class="flex items-center gap-2 text-sm text-guacamole-icons">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-guacamole-b" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4" />
                    </svg>
                    <span class="font-semibold">Envío gratis en pedidos +$50</span>
                  </div>
                  <div class="flex items-center gap-2 text-sm text-guacamole-icons">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-guacamole-b" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                    <span class="font-semibold">Garantía de devolución de 30 días</span>
                  </div>
                  <div class="flex items-center gap-2 text-sm text-guacamole-icons">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-guacamole-b" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10m-11 8h12a2 2 0 002-2V7a2 2 0 00-2-2H6a2 2 0 00-2 2v10a2 2 0 002 2z" />
                    </svg>
                    <span class="font-semibold">Confirmación por WhatsApp o correo después del pago</span>
                  </div>
                </div>
                
                <!-- Pay Button -->
                <button
                  type="button"
                  id="proceed-to-payment"
                  class="group block w-full rounded-full bg-guacamole-b px-8 py-4 text-center text-sm font-bold uppercase tracking-wider text-white shadow-[0_4px_12px_rgba(86,130,3,0.3)] transition-all duration-300 hover:-translate-y-0.5 hover:bg-guacamole-a hover:shadow-[0_6px_20px_rgba(62,97,2,0.35)]"
                >
                  <span id="proceed-to-payment-label" class="flex items-center justify-center gap-2">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z" />
                    </svg>
                    Continuar a medios de pago
                  </span>
                </button>
                <p id="checkout-feedback" class="min-h-[1.25rem] text-center text-xs font-medium text-gray-500" aria-live="polite">
                  Completá tus datos y, cuando esté todo listo, seguimos al pago sin perder tu pedido.
                </p>
                
                <!-- Secure Badge -->
                <p class="text-center text-xs text-gray-400 flex items-center justify-center gap-1">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                  </svg>
                  Compra 100% segura
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    )}
  </main>
</Layout>

<style>
  .line-clamp-1 {
    display: -webkit-box;
    -webkit-line-clamp: 1;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  [data-field-wrapper] {
    scroll-margin-top: 7rem;
  }

  .theme-checkout-page {
    background: linear-gradient(180deg, color-mix(in srgb, var(--color-bg) 94%, transparent) 0%, color-mix(in srgb, var(--color-bg-alt) 96%, transparent) 100%);
    color: var(--color-text);
  }

  .theme-checkout-page .premium-panel,
  .theme-checkout-page .premium-subtle-panel {
    border-color: var(--color-border);
