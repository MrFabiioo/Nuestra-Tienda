---
import Layout from '@layouts/Layout.astro'
import { actions } from 'astro:actions';
import {Formatter} from '@utils/formatter'

const cart = Astro.cookies.get('cart');

export const prerender = false

const {data:products,error}= await Astro.callAction(actions.loadProductsFromCart,{});



if (error || !products) {
   console.error(error)
   return Astro.redirect('/');
}

const total = products.reduce(
  (acc, product) => acc + product.price * product.quantity,
  0
);

const isEmpty = products.length === 0;
---

<Layout title="Checkout | Guacamole Shop" description="Finaliza tu compra">
  <main class="min-h-screen bg-guacamole-fondo/10 py-8 px-4 md:px-8">
    
    {isEmpty ? (
      <!-- Empty Cart State -->
      <div class="max-w-2xl mx-auto text-center py-16">
        <div class="bg-white rounded-3xl shadow-xl p-8 md:p-12 border-2 border-guacamole-b">
          <!-- Icon -->
          <div class="w-24 h-24 mx-auto mb-6 bg-guacamole-fondo/20 rounded-full flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-12 h-12 text-guacamole-b" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
            </svg>
          </div>
          
          <h1 class="text-3xl md:text-4xl font-black text-guacamole-icons uppercase tracking-wide mb-4">
            Tu carrito está vacío
          </h1>
          
          <p class="text-lg text-gray-600 mb-8">
            Parece que aún no has añadido ningún producto a tu carrito.
          </p>
          
          <a 
            href="/tienda" 
            class="inline-flex items-center justify-center gap-2 group relative focus:ring-3 focus:outline-hidden"
          >
            <span class="absolute inset-0 translate-x-1.5 translate-y-1.5 bg-guacamole-f transition-transform group-hover:translate-x-0 group-hover:translate-y-0"></span>
            <span class="relative inline-block border-2 border-current px-8 py-4 text-sm font-bold tracking-widest text-black uppercase text-center">
              Continuar comprando
            </span>
          </a>
          
          <!-- Trust badges -->
          <div class="mt-10 pt-8 border-t border-gray-200 grid grid-cols-1 md:grid-cols-2 gap-4">
            <div class="flex items-center gap-3 text-guacamole-icons">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-guacamole-b" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4" />
              </svg>
              <span class="text-sm font-semibold">Envío gratis +$50</span>
            </div>
            <div class="flex items-center gap-3 text-guacamole-icons">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-guacamole-b" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <span class="text-sm font-semibold">Garantía de 30 días</span>
            </div>
          </div>
        </div>
      </div>
    ) : (
      <!-- Checkout with Items -->
      <div class="max-w-6xl mx-auto">
        <!-- Header -->
        <div class="mb-8">
          <h1 class="text-3xl md:text-4xl font-black text-guacamole-icons uppercase tracking-wide">
            Finalizar Compra
          </h1>
          <p class="text-gray-600 mt-2">
            Revisa tus productos y procede al pago
          </p>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
          <!-- Main Content Column -->
          <div class="lg:col-span-2 space-y-6">
            <!-- Back button -->
            <a 
              href="/tienda" 
              class="inline-flex items-center gap-2 text-guacamole-icons hover:text-guacamole-b transition-colors"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
              </svg>
              <span class="font-semibold">Continuar comprando</span>
            </a>

            <!-- Customer Form -->
            <div class="bg-white rounded-2xl shadow-lg border border-gray-100 overflow-hidden">
              <div class="bg-guacamole-b px-6 py-4">
                <h2 class="text-xl font-black text-white uppercase tracking-wide">
                  Datos del Cliente
                </h2>
              </div>
              
              <form id="customer-form" class="p-6 space-y-6">
                <!-- Section: Contact Information -->
                <div class="space-y-4">
                  <div class="border-b border-gray-100 pb-2">
                    <h3 class="text-lg font-bold text-guacamole-icons">Información de contacto</h3>
                    <p class="text-sm text-gray-500">¿Cómo te contactaremos?</p>
                  </div>
                  
                  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <!-- Nombre completo -->
                    <div>
                      <label for="fullName" class="block text-sm font-semibold text-guacamole-icons mb-2">
                        Nombre completo <span class="text-red-500">*</span>
                      </label>
                      <input 
                        type="text" 
                        id="fullName" 
                        name="fullName" 
                        required
                        class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-guacamole-b focus:ring-2 focus:ring-guacamole-b/20 outline-none transition-all text-guacamole-icons"
                        placeholder="Juan Pérez"
                      />
                    </div>
                    
                    <!-- Teléfono -->
                    <div>
                      <label for="phone" class="block text-sm font-semibold text-guacamole-icons mb-2">
                        Teléfono <span class="text-red-500">*</span>
                      </label>
                      <input 
                        type="tel" 
                        id="phone" 
                        name="phone" 
                        required
                        class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-guacamole-b focus:ring-2 focus:ring-guacamole-b/20 outline-none transition-all text-guacamole-icons"
                        placeholder="+58 412 123 4567"
                      />
                    </div>
                  </div>
                  
                  <!-- Correo electrónico -->
                  <div>
                    <label for="email" class="block text-sm font-semibold text-guacamole-icons mb-2">
                      Correo electrónico <span class="text-red-500">*</span>
                    </label>
                    <input 
                      type="email" 
                      id="email" 
                      name="email" 
                      required
                      class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-guacamole-b focus:ring-2 focus:ring-guacamole-b/20 outline-none transition-all text-guacamole-icons"
                      placeholder="juan@email.com"
                    />
                  </div>
                </div>
                
                <!-- Section: Delivery Information -->
                <div class="space-y-4 pt-4">
                  <div class="border-b border-gray-100 pb-2">
                    <h3 class="text-lg font-bold text-guacamole-icons">Dirección de entrega</h3>
                    <p class="text-sm text-gray-500">¿A dónde entregamos tu pedido?</p>
                  </div>
                  
                  <!-- Método de entrega -->
                  <div>
                    <label class="block text-sm font-semibold text-guacamole-icons mb-3">
                      Método de entrega <span class="text-red-500">*</span>
                    </label>
                    <div class="flex flex-wrap gap-4">
                      <label class="flex items-center gap-3 cursor-pointer">
                        <input 
                          type="radio" 
                          name="deliveryMethod" 
                          value="domicilio" 
                          checked
                          class="w-5 h-5 text-guacamole-b focus:ring-guacamole-b"
                        />
                        <span class="text-guacamole-icons font-medium">Domicilio</span>
                      </label>
                      <label class="flex items-center gap-3 cursor-pointer">
                        <input 
                          type="radio" 
                          name="deliveryMethod" 
                          value="recoger"
                          class="w-5 h-5 text-guacamole-b focus:ring-guacamole-b"
                        />
                        <span class="text-guacamole-icons font-medium">Recoger en tienda</span>
                      </label>
                    </div>
                  </div>
                  
                  <!-- Dirección -->
                  <div>
                    <label for="address" class="block text-sm font-semibold text-guacamole-icons mb-2">
                      Dirección de entrega <span class="text-red-500">*</span>
                    </label>
                    <input 
                      type="text" 
                      id="address" 
                      name="address" 
                      required
                      class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-guacamole-b focus:ring-2 focus:ring-guacamole-b/20 outline-none transition-all text-guacamole-icons"
                      placeholder="Av. Principal, Calle 5, Edif. Miramar, Piso 3, Apto. 3B"
                    />
                  </div>
                  
                  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <!-- Ciudad / Sector -->
                    <div>
                      <label for="city" class="block text-sm font-semibold text-guacamole-icons mb-2">
                        Ciudad / Sector <span class="text-red-500">*</span>
                      </label>
                      <input 
                        type="text" 
                        id="city" 
                        name="city" 
                        required
                        class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-guacamole-b focus:ring-2 focus:ring-guacamole-b/20 outline-none transition-all text-guacamole-icons"
                        placeholder="Caracas, El Hatillo"
                      />
                    </div>
                    
                    <!-- Referencias / Notas -->
                    <div>
                      <label for="notes" class="block text-sm font-semibold text-guacamole-icons mb-2">
                        Referencias / Notas <span class="text-gray-400">(opcional)</span>
                      </label>
                      <input 
                        type="text" 
                        id="notes" 
                        name="notes"
                        class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-guacamole-b focus:ring-2 focus:ring-guacamole-b/20 outline-none transition-all text-guacamole-icons"
                        placeholder="Portón verde, llamar al llegar"
                      />
                    </div>
                  </div>
                </div>
              </form>
            </div>

            <!-- Products Card -->
            <div class="bg-white rounded-2xl shadow-lg border border-gray-100 overflow-hidden">
              <div class="bg-guacamole-f px-6 py-4">
                <h2 class="text-xl font-black text-black uppercase tracking-wide">
                  Productos ({products.length})
                </h2>
              </div>
              
              <div class="divide-y divide-gray-100">
                {products.map((product) => (
                  <div class="flex gap-4 md:gap-6 p-4 md:p-6 hover:bg-gray-50 transition-colors">
                    <!-- Product Image -->
                    <div class="shrink-0">
                      <img 
                        src={product.image} 
                        alt={product.title} 
                        class="w-20 h-20 md:w-24 md:h-24 object-cover rounded-xl border-2 border-guacamole-f shadow-sm"
                      />
                    </div>
                    
                    <!-- Product Details -->
                    <div class="flex-1 min-w-0">
                      <div class="flex flex-col md:flex-row md:justify-between md:items-start gap-2">
                        <div>
                          <a 
                            href={`/products/${product.slug}`} 
                            class="text-lg font-bold text-guacamole-icons hover:text-guacamole-b hover:underline transition-colors line-clamp-1"
                          >
                            {product.title}
                          </a>
                          <div class="flex items-center gap-3 mt-1 text-sm text-gray-500">
                            <span class="bg-guacamole-fondo/20 px-2 py-1 rounded-xl font-semibold text-guacamole-icons">
                              {product.sizes}
                            </span>
                            <span>Cantidad: <strong>{product.quantity}</strong></span>
                          </div>
                        </div>
                        
                        <div class="text-right">
                          <p class="text-xl font-black text-guacamole-pulpa">
                            {Formatter.currency(product.price * product.quantity)}
                          </p>
                          <p class="text-xs text-gray-400">
                            {Formatter.currency(product.price)} c/u
                          </p>
                        </div>
                      </div>
                      
                      <!-- Remove Button -->
                      <button
                        data-id={product.productId}
                        data-size={product.sizes}
                        class="mt-3 text-sm text-red-500 hover:text-red-700 font-semibold flex items-center gap-1 transition-colors btn-delete"
                      >
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                        </svg>
                        Remover
                      </button>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          </div>

          <!-- Summary Panel -->
          <div class="lg:col-span-1">
            <div class="bg-white rounded-2xl shadow-lg border border-gray-100 sticky top-24">
              <div class="bg-guacamole-f px-6 py-4">
                <h2 class="text-xl font-black text-black uppercase tracking-wide">
                  Resumen del Pedido
                </h2>
              </div>
              
              <div class="p-6 space-y-4">
                <!-- Order Details -->
                <div class="space-y-3 text-gray-600">
                  <div class="flex justify-between items-center">
                    <span class="font-semibold">Subtotal</span>
                    <span class="font-bold text-guacamole-icons">{Formatter.currency(total)}</span>
                  </div>
                  
                  <div class="flex justify-between items-center">
                    <span class="font-semibold">Envío</span>
                    <span class="font-bold text-green-600">Gratis</span>
                  </div>
                  
                  <div class="flex justify-between items-center">
                    <span class="font-semibold">Impuesto (15%)</span>
                    <span class="font-bold text-guacamole-icons">{Formatter.currency(total * 0.15)}</span>
                  </div>
                </div>
                
                <!-- Divider -->
                <div class="border-t-2 border-guacamole-f pt-4">
                  <div class="flex justify-between items-center">
                    <span class="text-xl font-black text-guacamole-icons uppercase">Total</span>
                    <span class="text-2xl font-black text-guacamole-pulpa">
                      {Formatter.currency(total * 1.15)}
                    </span>
                  </div>
                </div>
                
                <!-- Trust Badges -->
                <div class="bg-guacamole-fondo/10 rounded-lg p-4 space-y-2">
                  <div class="flex items-center gap-2 text-sm text-guacamole-icons">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-guacamole-b" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4" />
                    </svg>
                    <span class="font-semibold">Envío gratis en pedidos +$50</span>
                  </div>
                  <div class="flex items-center gap-2 text-sm text-guacamole-icons">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-guacamole-b" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                    <span class="font-semibold">Garantía de devolución de 30 días</span>
                  </div>
                </div>
                
                <!-- Pay Button -->
                <a
                  href="/pagos"
                  id="proceed-to-payment"
                  class="group block w-full bg-guacamole-pulpa text-white text-center font-bold text-sm py-4 px-8 tracking-wider uppercase rounded-full shadow-[0_4px_12px_rgba(86,130,3,0.3)] hover:bg-guacamole-f hover:shadow-[0_6px_20px_rgba(86,130,3,0.4)] hover:-translate-y-0.5 transition-all duration-300"
                >
                  <span class="flex items-center justify-center gap-2">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z" />
                    </svg>
                    Proceder al Pago
                  </span>
                </a>
                
                <!-- Secure Badge -->
                <p class="text-center text-xs text-gray-400 flex items-center justify-center gap-1">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                  </svg>
                  Compra 100% segura
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    )}
  </main>
</Layout>

<style>
  .line-clamp-1 {
    display: -webkit-box;
    -webkit-line-clamp: 1;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>

<script>
import { CartCookiesClient } from "@utils/cart-cookies";
import { navigate } from "astro:transitions/client";

document.addEventListener('astro:page-load',()=>{
  // Restore customer data from sessionStorage on page load
  const savedCustomerData = sessionStorage.getItem('guacamole-customer-data');
  if (savedCustomerData) {
    try {
      const data = JSON.parse(savedCustomerData);
      const form = document.getElementById('customer-form') as HTMLFormElement;
      if (form) {
        (form.elements.namedItem('fullName') as HTMLInputElement).value = data.fullName || '';
        (form.elements.namedItem('phone') as HTMLInputElement).value = data.phone || '';
        (form.elements.namedItem('email') as HTMLInputElement).value = data.email || '';
        (form.elements.namedItem('address') as HTMLInputElement).value = data.address || '';
        (form.elements.namedItem('city') as HTMLInputElement).value = data.city || '';
        (form.elements.namedItem('notes') as HTMLInputElement).value = data.notes || '';
        const deliveryMethods = form.elements.namedItem('deliveryMethod') as RadioNodeList;
        if (deliveryMethods) {
          for (let i = 0; i < deliveryMethods.length; i++) {
            const radio = deliveryMethods[i] as HTMLInputElement;
            if (radio.value === data.deliveryMethod) {
              radio.checked = true;
              break;
            }
          }
        }
      }
    } catch (e) {
      // Ignore parse errors
    }
  }

  // Handle delete buttons
  const deleteButtons = document.querySelectorAll('.btn-delete');
  deleteButtons.forEach(button => {
    button.addEventListener('click',(event)=>{
      const target = event.target as HTMLButtonElement;
      const productId = target.dataset.id ?? "";
      const size= target.dataset.size ?? "";
      const cart =CartCookiesClient.removeItem(productId, size)
      
      navigate('/checkout')
    })
  })

  // Handle proceed to payment button with customer data persistence
  const proceedButton = document.getElementById('proceed-to-payment');
  if (proceedButton) {
    proceedButton.addEventListener('click', (e) => {
      const form = document.getElementById('customer-form') as HTMLFormElement;
      if (!form) return;
      
      // Check form validity
      if (!form.checkValidity()) {
        form.reportValidity();
        return;
      }
      
      // Save customer data to sessionStorage before navigating
      const formData = new FormData(form);
      const customerData = {
        fullName: formData.get('fullName'),
        phone: formData.get('phone'),
        email: formData.get('email'),
        address: formData.get('address'),
        city: formData.get('city'),
        notes: formData.get('notes'),
        deliveryMethod: formData.get('deliveryMethod')
      };
      sessionStorage.setItem('guacamole-customer-data', JSON.stringify(customerData));
      
      // Navigate to payment page
      navigate('/pagos');
    });
  }
});
</script>
