<script>
  // Show pending order banner if cart is empty but user has a pending order
  document.addEventListener('astro:page-load', () => {
    const banner = document.getElementById('pending-order-banner');
    const link = document.getElementById('pending-order-link');
    if (!banner || !link) return;
    const token = localStorage.getItem('pendingOrderToken');
    if (!token) return;
    (link as HTMLAnchorElement).href = `/pagos/${token}`;
    banner.classList.remove('hidden');
  });
</script>

<script>
import { CartCookiesClient } from "@utils/cart-cookies";
import { actions } from "astro:actions";
import { navigate } from "astro:transitions/client";

document.addEventListener('astro:page-load',()=>{
  const form = document.getElementById('customer-form') as HTMLFormElement | null;
  const checkoutFeedback = document.getElementById('checkout-feedback') as HTMLParagraphElement | null;
  const feedbackBox = document.getElementById('form-feedback') as HTMLDivElement | null;
  const lockedDeliveryData = {
    method: 'wemi',
    address: 'CR 48 14 49',
    city: 'Medellin - Poblado',
    notes: 'Grupo Emi Falk - Sala de Rdio'
  };

  const validationMessages: Record<string, string> = {
    fullName: 'Decinos tu nombre completo para identificar el pedido.',
    phone: 'Necesitamos un teléfono válido para coordinar cualquier detalle.',
    email: 'Ingresá un correo válido para enviarte la confirmación.',
    address: 'La dirección de entrega en la WEMI debe quedar cargada.',
    city: 'La ciudad del punto de entrega en la WEMI debe quedar cargada.',
    deliveryMethod: 'La entrega se realiza únicamente en la WEMI.'
  };

  const applyLockedDeliveryData = () => {
    if (!form) return;

    const addressField = form.elements.namedItem('address') as HTMLInputElement | null;
    const cityField = form.elements.namedItem('city') as HTMLInputElement | null;
    const notesField = form.elements.namedItem('notes') as HTMLTextAreaElement | null;
    const deliveryMethods = form.elements.namedItem('deliveryMethod') as RadioNodeList | null;

    if (addressField) addressField.value = lockedDeliveryData.address;
    if (cityField) cityField.value = lockedDeliveryData.city;
    if (notesField) notesField.value = lockedDeliveryData.notes;

    if (deliveryMethods) {
      for (let i = 0; i < deliveryMethods.length; i++) {
        const radio = deliveryMethods[i] as HTMLInputElement;
        radio.checked = radio.value === lockedDeliveryData.method;
      }
    }
  };

  const setCheckoutFeedback = (message: string, tone: 'default' | 'error' | 'success' = 'default') => {
    if (!checkoutFeedback) return;

    checkoutFeedback.textContent = message;
    checkoutFeedback.classList.remove('text-gray-500', 'text-red-500', 'text-guacamole-b');

    if (tone === 'error') {
      checkoutFeedback.classList.add('text-red-500');
      return;
    }

    if (tone === 'success') {
      checkoutFeedback.classList.add('text-guacamole-b');
      return;
    }

    checkoutFeedback.classList.add('text-gray-500');
  };

  const showFormFeedback = (message: string) => {
    if (!feedbackBox) return;

    feedbackBox.textContent = message;
    feedbackBox.classList.remove('hidden');
  };

  const hideFormFeedback = () => {
    if (!feedbackBox) return;

    feedbackBox.textContent = '';
    feedbackBox.classList.add('hidden');
  };

  const setFieldError = (field: HTMLElement, message: string) => {
    const wrapper = field.closest('[data-field-wrapper]');
    const errorEl = wrapper?.querySelector<HTMLElement>('[data-field-error]');

    field.setAttribute('aria-invalid', 'true');

    if (errorEl) {
      errorEl.textContent = message;
      errorEl.classList.remove('hidden');
    }
  };

  const clearFieldError = (field: HTMLElement) => {
    const wrapper = field.closest('[data-field-wrapper]');
    const errorEl = wrapper?.querySelector<HTMLElement>('[data-field-error]');

    field.removeAttribute('aria-invalid');

    if (errorEl) {
      errorEl.textContent = '';
      errorEl.classList.add('hidden');
    }
  };

  const getFieldMessage = (field: HTMLInputElement | HTMLTextAreaElement) => {
    if (field.validity.valueMissing) {
      return validationMessages[field.name] ?? 'Este campo es obligatorio.';
    }

    if (field.validity.typeMismatch && field.name === 'email') {
      return 'Ese correo no parece válido. Revisalo antes de seguir.';
    }

    return '';
  };

  const validateForm = () => {
    if (!form) return true;

    hideFormFeedback();

    const invalidFields: HTMLElement[] = [];
    const methodRadios = Array.from(form.querySelectorAll<HTMLInputElement>('input[name="deliveryMethod"]'));
    const hasDeliveryMethod = methodRadios.some((radio) => radio.checked);

    if (!hasDeliveryMethod && methodRadios.length > 0) {
      methodRadios.forEach((radio) => setFieldError(radio, validationMessages.deliveryMethod));
      invalidFields.push(methodRadios[0]);
    } else {
      methodRadios.forEach((radio) => clearFieldError(radio));
    }

    form.querySelectorAll<HTMLInputElement | HTMLTextAreaElement>('input, textarea').forEach((field) => {
      if (field.type === 'radio') return;

      const message = getFieldMessage(field);
      if (message) {
        setFieldError(field, message);
        invalidFields.push(field);
        return;
      }

      clearFieldError(field);
    });

    if (invalidFields.length > 0) {
      showFormFeedback('Hay algunos datos para ajustar antes de pasar al pago. Revisá los campos marcados y seguimos.');
      invalidFields[0].focus();
      return false;
    }

    return true;
  };

  if (form) {
    applyLockedDeliveryData();

    form.querySelectorAll<HTMLInputElement | HTMLTextAreaElement>('input, textarea').forEach((field) => {
      if (field.type === 'radio') {
        field.addEventListener('change', () => {
          Array.from(form.querySelectorAll<HTMLInputElement>('input[name="deliveryMethod"]')).forEach((radio) => clearFieldError(radio));
          hideFormFeedback();
        });
        return;
      }

      field.addEventListener('input', () => {
        if (field.checkValidity()) {
          clearFieldError(field);
        }
      });

      field.addEventListener('blur', () => {
        const message = getFieldMessage(field);
        if (message) {
          setFieldError(field, message);
        } else {
          clearFieldError(field);
        }
      });
    });
  }

  // Handle delete buttons
  const deleteButtons = document.querySelectorAll('.btn-delete');
  deleteButtons.forEach(button => {
    button.addEventListener('click',(event)=>{
      const target = event.currentTarget as HTMLButtonElement;
      if (target.disabled) return;

      target.disabled = true;
      target.setAttribute('aria-busy', 'true');
      target.textContent = 'Quitando...';
      setCheckoutFeedback('Actualizando tu pedido...', 'success');

      const productId = target.dataset.id ?? "";
      const size= target.dataset.size ?? "";
      CartCookiesClient.removeItem(productId, size)
      
      navigate('/checkout')
    })
  })

  // Handle proceed to payment button with real order creation
  const proceedButton = document.getElementById('proceed-to-payment');
  const proceedButtonLabel = document.getElementById('proceed-to-payment-label');
  if (proceedButton) {
    const setProceedPending = (isPending: boolean, label: string) => {
      proceedButton.classList.toggle('pointer-events-none', isPending);
      proceedButton.classList.toggle('opacity-80', isPending);
      proceedButton.setAttribute('aria-disabled', String(isPending));
      proceedButton.setAttribute('aria-busy', String(isPending));

      if (proceedButtonLabel) {
        proceedButtonLabel.innerHTML = isPending
          ? '<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 animate-spin" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 12a8 8 0 018-8m0 0a8 8 0 018 8m-8-8v8" /></svg>' + label
          : '<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z" /></svg>' + label;
      }
    };

    proceedButton.addEventListener('click', async (e) => {
      e.preventDefault();
      if (!form) return;

       if (proceedButton.getAttribute('aria-disabled') === 'true') return;
      
      // Check form validity
      if (!validateForm()) {
        setCheckoutFeedback('Falta completar algunos datos antes de pasar al pago.', 'error');
        return;
      }

      setProceedPending(true, 'Creando pedido...');
      setCheckoutFeedback('Estamos guardando tu pedido para que el pago quede trazable.', 'success');

      const formData = new FormData(form);

      const { data, error } = await actions.createOrder(formData);

      if (error || !data) {
        console.error(error);
        showFormFeedback(error?.message ?? 'No pudimos crear tu pedido. Revisá los datos e intentá otra vez.');
        setCheckoutFeedback('Hubo un problema al persistir el pedido. No seguimos hasta dejarlo bien guardado.', 'error');
        setProceedPending(false, 'Continuar a medios de pago');
        return;
      }

      setCheckoutFeedback('Pedido creado. Te llevamos a la referencia pública de pago.', 'success');
      localStorage.setItem('pendingOrderToken', data.publicToken);
      window.location.href = data.redirectUrl;
    });
  }
});
</script>
