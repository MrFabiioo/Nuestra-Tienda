---
import Layout from "../layouts/Layout.astro";
import Card from "../components/Card.astro";
import { actions } from "astro:actions";
import Pagination from "../components/shared/Pagination.astro";

export const prerender = false
const url = Astro.url;
const pageParam = Number(url.searchParams.get('page') ?? 1);


const {data,error} = await Astro.callAction(actions.getProductsByPage,{
    page:pageParam
})

if (error) {
    return Astro.redirect('/');
}

const  {products,totalPages} = data;



---

<Layout>
    <div class="flex flex-col justify-center items-center">
        <input
            type="text"
            placeholder="Buscar libro"
            class="font-mono rounded-lg border border-black-medium w-80 p-4 mb-12 mt-6"
            
          />
    </div>
        
    <section
        class="grid sm:gap-6 gap-12 lg:grid-cols-4 md:grid-cols-2  w-full  max-w-screen grid-cols-1 place-items-center "
    >
        {
            products.map((product)=>(
                <Card product={product}/>
            ))
        }


    </section>

    <Pagination pageParam={pageParam} totalPages={totalPages}/>
</Layout>

