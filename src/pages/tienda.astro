---
import Layout from "../layouts/Layout.astro";
import Card from "../components/Card.astro";
import { actions } from "astro:actions";
import BreadcrumbTrail from "../components/shared/BreadcrumbTrail.astro";

export const prerender = false

// Fetch products
const {data: productsData, error: productsError} = await Astro.callAction(actions.getProductsByPage,{
    page: 1,
    limit: 9999,
})

if (productsError || !productsData) {
    return Astro.redirect('/');
}

const {products} = productsData;

// Fetch categories
const {data: categoriesData, error: categoriesError} = await Astro.callAction(actions.getCategories, {})

const categories = (categoriesError || !categoriesData) ? [] : categoriesData.categories;

// Map categories to expected format for filter pills
const categoryMap: Record<string, string> = {
    'cat-salsas': 'Salsas y Aderezos',
    'cat-charcuteria': 'Charcutería', 
    'cat-postres': 'Postres'
};

// Get category names from the fetched categories or use fallback
const categoryNames = categories.length > 0 
    ? categories.reduce((acc, cat) => {
        acc[cat.slug] = cat.name;
        return acc;
    }, {} as Record<string, string>)
    : categoryMap;

const totalCategories = Object.keys(categoryNames).length;
const storeBreadcrumbs = [
    { label: 'Inicio', href: '/' },
    { label: 'Tienda' },
];
const catalogSkeletonCards = Array.from({ length: 4 });

---

<Layout
    title="Tienda"
    description="Explora el catálogo completo de Guacamole Shop, filtra por categoría y encuentra productos frescos para comprar online con facilidad."
>
    <div class="store-page min-h-screen" data-store-page>
        <!-- Hero Section -->
        <section class="store-hero-section px-4 pb-6 pt-8 md:pb-8 md:pt-10">
            <div class="mx-auto max-w-6xl">
                <BreadcrumbTrail
                    items={storeBreadcrumbs}
                    eyebrow="Ubicación"
                    summary="Estás en el catálogo completo. Desde aquí puedes descubrir productos, ver el detalle o volver al inicio sin perder el recorrido."
                />
            </div>

            <div class="store-hero-shell mx-auto mt-4 flex max-w-6xl flex-col gap-6 rounded-[1.75rem] px-5 py-6 sm:px-6 sm:py-7 md:gap-8 md:rounded-[2rem] md:px-10 md:py-10">
                <div class="max-w-3xl">
                    <span class="store-eyebrow inline-flex items-center rounded-full px-3 py-1 text-xs font-semibold uppercase tracking-[0.22em]">
                        Catálogo completo
                    </span>
                    <h1 class="store-heading mt-4 text-3xl font-bold leading-tight tracking-tight sm:text-4xl md:text-5xl">
                        Nuestra Tienda: todo el catálogo en un solo lugar
                    </h1>
                    <p class="store-copy mt-3 max-w-2xl text-base leading-relaxed sm:mt-4 sm:text-lg">
                        Descubre la selección disponible, filtra por categoría o busca directamente lo que necesitas para comprar más fácil y con claridad.
                    </p>
                </div>

                <div class="store-copy grid gap-2 text-sm sm:flex sm:flex-wrap sm:gap-3">
                    <span class="store-stat-pill inline-flex items-center gap-2 rounded-full px-4 py-2">
                        <span class="h-2 w-2 rounded-full bg-guacamole-b"></span>
                        {totalCategories} categorías para explorar
                    </span>
                    <span class="store-stat-pill inline-flex items-center gap-2 rounded-full px-4 py-2">
                        <span class="h-2 w-2 rounded-full bg-guacamole-a"></span>
                        {products.length} productos en el catálogo
                    </span>
                    <span class="store-stat-pill inline-flex items-center gap-2 rounded-full px-4 py-2">
                        <span class="store-stat-dot h-2 w-2 rounded-full"></span>
                        Búsqueda por nombre, ingrediente y descripción
                    </span>
                </div>

                <div class="grid gap-4 lg:grid-cols-[minmax(0,1.4fr)_minmax(280px,0.9fr)] lg:items-center">
                    <div class="flex flex-col gap-3 sm:flex-row sm:flex-wrap">
                        <a href="#category-filters" class="premium-action-primary">
                            Explorar categorías
                        </a>
                    </div>

                    <div class="store-tip-panel rounded-3xl p-4 text-left sm:p-5">
                        <p class="store-accent-label text-sm font-semibold uppercase tracking-[0.18em]">
                            Cómo recorrer la tienda
                        </p>
                        <ul class="store-copy mt-3 space-y-2 text-sm leading-relaxed">
                            <li>1. Empieza por la categoría que mejor combine con tu antojo.</li>
                            <li>2. Usa el buscador si ya tienes un producto o ingrediente en mente.</li>
                            <li>3. Entra al detalle para revisar tamaños, precio y compra.</li>
                            <li>4. Si ya avanzaste hasta checkout o pagos, puedes volver a esta tienda para ajustar tu pedido.</li>
                        </ul>
                    </div>
                </div>
            </div>
        </section>

        <!-- Search & Filter Bar -->
        <section class="mx-auto max-w-6xl px-4 pb-8">
            <div class="store-filter-header mb-4 rounded-3xl px-4 py-4 sm:mb-5 sm:px-5">
                <div class="flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
                    <div class="max-w-2xl">
                        <p class="store-accent-label text-sm font-semibold uppercase tracking-[0.18em]">
                            Empieza aquí
                        </p>
                        <h2 class="store-heading mt-1 text-xl font-semibold tracking-tight sm:text-2xl">
                            Buscador y filtros para encontrar más rápido lo que quieres
                        </h2>
                    </div>
                        <p class="store-copy max-w-xl text-sm leading-relaxed md:text-right">
                            Combina la búsqueda y las categorías para encontrar más rápido lo que quieres o descubrir algo nuevo.
                        </p>
                </div>
            </div>

            <div class="flex flex-col gap-4 md:flex-row md:items-start md:justify-between">
                <!-- Search Input -->
                <div class="relative w-full max-w-lg md:w-auto md:flex-1">
                    <label for="search-input" class="sr-only">Buscar productos en la tienda</label>
                    <div class="absolute inset-y-0 left-5 flex items-center pointer-events-none">
                        <svg class="store-search-icon h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
                        </svg>
                    </div>
                    <input
                        type="search"
                        id="search-input"
                        placeholder="Busca por producto, ingrediente o sabor..."
                        aria-describedby="results-count results-loading"
                        class="store-search-input premium-field w-full py-3 pr-4 shadow-sm transition-all duration-300"
                    />
                </div>

                <!-- Category Filter Pills -->
                <div class="flex w-full gap-2 overflow-x-auto pb-1 md:w-auto md:flex-wrap md:justify-center md:pb-0" id="category-filters" aria-label="Filtrar productos por categoría">
                    <button 
                        class="category-pill store-filter-pill is-active shrink-0 rounded-full px-4 py-2 text-sm font-medium transition-all duration-200"
                        data-category="todos"
                        aria-pressed="true"
                        aria-controls="product-grid"
                    >
                        Todos
                    </button>
                    {Object.entries(categoryNames).map(([slug, name]) => (
                        <button 
                            class="category-pill store-filter-pill shrink-0 rounded-full px-4 py-2 text-sm font-medium transition-all duration-200"
                            data-category={slug}
                            aria-pressed="false"
                            aria-controls="product-grid"
                        >
                            {name}
                        </button>
                    ))}
                </div>
            </div>
        </section>

        <!-- Results Count -->
        <section class="mx-auto max-w-6xl px-4 pb-4">
            <div class="store-results-panel flex flex-col gap-2 rounded-2xl px-4 py-3 text-sm md:flex-row md:items-center md:justify-between">
                <div class="flex flex-col gap-2">
                    <p id="results-count" role="status" aria-live="polite">
                        Estás viendo {products.length} productos en esta página de la tienda
                    </p>
                    <p id="results-loading" role="status" aria-live="polite" class="hidden items-center gap-2 text-xs font-semibold uppercase tracking-[0.18em] text-guacamole-b">
                        <span class="h-2 w-2 rounded-full bg-guacamole-b premium-skeleton"></span>
                        Actualizando selección...
                    </p>
                </div>
                <p id="results-hint">
                    Si todavía no aparece lo que buscas, cambia de categoría o ajusta el filtro.
                </p>
            </div>
        </section>

        <!-- Product Grid -->
        <section 
            class="mx-auto max-w-6xl px-4 pb-10 md:pb-12"
            id="product-grid"
            aria-busy="false"
        >
            <div class="relative">
                <div class="catalog-grid-loading store-grid-loading pointer-events-none absolute inset-0 z-10 hidden grid-cols-1 gap-4 rounded-[2rem] p-2 backdrop-blur-[2px] sm:grid-cols-2 sm:gap-5 lg:grid-cols-3 xl:grid-cols-4 xl:gap-6" id="catalog-grid-loading" aria-hidden="true">
                    {catalogSkeletonCards.map(() => (
                        <div class="premium-skeleton-card overflow-hidden">
                            <div class="premium-skeleton h-44 rounded-[1.25rem]"></div>
                            <div class="mt-4 space-y-3">
                                <div class="premium-skeleton-line h-4 w-3/4"></div>
                                <div class="premium-skeleton-line h-3.5 w-full"></div>
                                <div class="premium-skeleton-line h-3.5 w-5/6"></div>
                                <div class="flex items-center justify-between pt-2">
                                    <div class="premium-skeleton-line h-5 w-20"></div>
                                    <div class="premium-skeleton-line h-10 w-28"></div>
                                </div>
                            </div>
                        </div>
                    ))}
                </div>

                <div class="grid grid-cols-1 gap-4 transition-opacity duration-200 sm:grid-cols-2 sm:gap-5 lg:grid-cols-3 xl:grid-cols-4 xl:gap-6" id="catalog-grid-list">
                    {products.map((product) => (
                        <div 
                            class="product-card-wrapper h-full"
                            data-title={product.title?.toLowerCase() ?? ''}
                            data-description={product.description?.toLowerCase() ?? ''}
                            data-category={product.categorySlug ?? 'sin-categoria'}
                        >
                            <Card product={product} />
                        </div>
                    ))}
                </div>
            </div>
        </section>

        <!-- Empty State -->
        <section 
            class="mx-auto hidden max-w-6xl px-4 pb-10 text-center md:pb-12"
            id="empty-state"
        >
            <div class="store-empty-panel rounded-[2rem] px-5 py-10 sm:px-6 md:px-10 md:py-14">
                <div class="store-empty-icon mb-6 inline-flex h-20 w-20 items-center justify-center rounded-full">
                    <svg class="store-empty-icon-svg h-10 w-10" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                    </svg>
                </div>
                <span class="store-eyebrow inline-flex items-center rounded-full px-3 py-1 text-xs font-semibold uppercase tracking-[0.22em]">
                    Probemos otro camino
                </span>
                <h3 class="store-heading mb-2 mt-5 text-xl font-semibold" id="empty-state-title">
                    No encontramos productos para esa búsqueda
                </h3>
                <p class="store-copy mx-auto mb-6 max-w-2xl" id="empty-state-description">
                    En esta página no encontramos coincidencias. Prueba con otra palabra, cambia la categoría o limpia los filtros para volver a empezar.
                </p>

                <div class="mb-8 flex flex-wrap items-center justify-center gap-2" id="empty-state-context">
                    <span id="empty-search-chip" class="store-empty-chip hidden rounded-full px-4 py-2 text-sm font-medium"></span>
                    <span id="empty-category-chip" class="store-empty-chip hidden rounded-full px-4 py-2 text-sm font-medium"></span>
                </div>

                <div class="mx-auto mb-8 grid max-w-3xl gap-3 text-left md:grid-cols-3">
                    <div class="store-empty-card rounded-2xl px-4 py-4">
                        <p class="store-heading text-sm font-semibold">Busca con menos detalle</p>
                        <p class="store-copy mt-1 text-sm leading-relaxed">Prueba con un nombre más corto, un ingrediente o una categoría para abrir más opciones.</p>
                    </div>
                    <div class="store-empty-card rounded-2xl px-4 py-4">
                        <p class="store-heading text-sm font-semibold">Vuelve a “Todos”</p>
                        <p class="store-copy mt-1 text-sm leading-relaxed">Si filtraste demasiado, limpiar te devuelve la vista completa de esta página en un clic.</p>
                    </div>
                    <div class="store-empty-card rounded-2xl px-4 py-4">
                        <p class="store-heading text-sm font-semibold">Sigue recorriendo la tienda</p>
                        <p class="store-copy mt-1 text-sm leading-relaxed">Puedes cambiar de categoría o avanzar de página para descubrir más productos disponibles.</p>
                    </div>
                </div>

                <div class="flex flex-col items-center justify-center gap-3 sm:flex-row">
                    <button 
                        id="clear-filters"
                        class="premium-action-primary"
                    >
                        Reiniciar búsqueda y filtros
                    </button>
                    <a
                        href="#category-filters"
                        class="premium-action-secondary"
                    >
                        Explorar categorías
                    </a>
                </div>
            </div>
        </section>

    </div>
</Layout>

<script>
    function initStoreFilters() {
        const searchInput = document.getElementById('search-input') as HTMLInputElement;
        const productCards = document.querySelectorAll('.product-card-wrapper');
        const categoryPills = document.querySelectorAll('.category-pill');
        const resultsCount = document.getElementById('results-count');
        const resultsHint = document.getElementById('results-hint');
        const emptyState = document.getElementById('empty-state');
        const emptyStateTitle = document.getElementById('empty-state-title');
        const emptyStateDescription = document.getElementById('empty-state-description');
        const emptySearchChip = document.getElementById('empty-search-chip');
        const emptyCategoryChip = document.getElementById('empty-category-chip');
        const productGrid = document.getElementById('product-grid');
        const productGridList = document.getElementById('catalog-grid-list');
        const productGridLoading = document.getElementById('catalog-grid-loading');
        const clearFiltersBtn = document.getElementById('clear-filters');
        const resultsLoading = document.getElementById('results-loading');

        let activeCategory = 'todos';
        const totalProductsOnPage = productCards.length;
        let filterTimer: number | null = null;
        let filterRequestId = 0;

        function setFilteringState(isFiltering: boolean) {
            resultsLoading?.classList.toggle('hidden', !isFiltering);
            resultsLoading?.classList.toggle('flex', isFiltering);
            productGrid?.setAttribute('aria-busy', String(isFiltering));
            productGridLoading?.classList.toggle('hidden', !isFiltering);
            productGridLoading?.classList.toggle('grid', isFiltering);
            productGridList?.classList.toggle('opacity-40', isFiltering);
        }

        function getCategoryLabel(categorySlug: string) {
            if (categorySlug === 'todos') return 'Todas las categorías';

            const activeButton = document.querySelector(`[data-category="${categorySlug}"]`) as HTMLButtonElement | null;

            return activeButton?.textContent?.trim() || 'la categoría seleccionada';
        }

        function updateResultsCopy(searchTerm: string, visibleCount: number) {
            if (!resultsCount || !resultsHint) return;

            const hasSearch = searchTerm.length > 0;
            const hasCategory = activeCategory !== 'todos';
            const categoryLabel = getCategoryLabel(activeCategory);

            if (!hasSearch && !hasCategory) {
                resultsCount.textContent = `Estás viendo ${visibleCount} productos en el catálogo`;
                resultsHint.textContent = 'Si todavía no aparece lo que buscas, cambia de categoría o ajusta el filtro.';
                return;
            }

            const resultLabel = visibleCount === 1 ? 'resultado' : 'resultados';
            const context: string[] = [];

            if (hasSearch) context.push(`para “${searchTerm}”`);
            if (hasCategory) context.push(`en ${categoryLabel}`);

            resultsCount.textContent = `Mostrando ${visibleCount} ${resultLabel} ${context.join(' ')}`.trim();

            if (visibleCount === 0) {
                resultsHint.textContent = 'Prueba reiniciar la búsqueda o volver a “Todos” para ver más opciones.';
                return;
            }

            if (visibleCount < totalProductsOnPage) {
                resultsHint.textContent = 'Si quieres ver más resultados, usa términos más amplios o quita algún filtro activo.';
                return;
            }

            resultsHint.textContent = 'Buen punto de partida: si todavía no ves lo ideal, prueba otra categoría o sigue explorando la tienda.';
        }

        function updateEmptyState(searchTerm: string) {
            if (!emptyStateTitle || !emptyStateDescription || !emptySearchChip || !emptyCategoryChip) return;

            const hasSearch = searchTerm.length > 0;
            const hasCategory = activeCategory !== 'todos';
            const categoryLabel = getCategoryLabel(activeCategory);

            if (hasSearch && hasCategory) {
                emptyStateTitle.textContent = `No vimos coincidencias en ${categoryLabel}`;
                emptyStateDescription.textContent = `No apareció ningún producto para “${searchTerm}” dentro de esta categoría. Prueba una búsqueda más amplia o cambia el filtro para ver más opciones.`;
            } else if (hasSearch) {
                emptyStateTitle.textContent = `No vimos resultados para “${searchTerm}”`;
                emptyStateDescription.textContent = 'Prueba buscar por nombre corto, ingrediente o categoría. También puedes reiniciar la búsqueda para volver al catálogo completo de esta página.';
            } else if (hasCategory) {
                emptyStateTitle.textContent = `No hay productos visibles en ${categoryLabel}`;
                emptyStateDescription.textContent = 'No hay productos para esa categoría. Prueba volver a “Todos” o ajusta los filtros.';
            } else {
                emptyStateTitle.textContent = 'No vimos productos para esa búsqueda';
                emptyStateDescription.textContent = 'En esta página no encontramos coincidencias. Prueba con otra palabra o reinicia los filtros.';
            }

            if (hasSearch) {
                emptySearchChip.textContent = `Búsqueda: “${searchTerm}”`;
                emptySearchChip.classList.remove('hidden');
            } else {
                emptySearchChip.textContent = '';
                emptySearchChip.classList.add('hidden');
            }

            if (hasCategory) {
                emptyCategoryChip.textContent = `Filtro: ${categoryLabel}`;
                emptyCategoryChip.classList.remove('hidden');
            } else {
                emptyCategoryChip.textContent = '';
                emptyCategoryChip.classList.add('hidden');
            }
        }

        function filterProducts() {
            const searchTerm = searchInput.value.toLowerCase().trim();
            let visibleCount = 0;

            productCards.forEach((card) => {
                const wrapper = card as HTMLElement;
                const title = wrapper.dataset.title || '';
                const description = wrapper.dataset.description || '';
                const category = wrapper.dataset.category || '';

                // Check search match
                const matchesSearch = searchTerm === '' || 
                    title.includes(searchTerm) || 
                    description.includes(searchTerm);

                // Check category match
                const matchesCategory = activeCategory === 'todos' || 
                    category === activeCategory;

                if (matchesSearch && matchesCategory) {
                    wrapper.style.display = 'block';
                    visibleCount++;
                } else {
                    wrapper.style.display = 'none';
                }
            });

            // Update results count
            updateResultsCopy(searchTerm, visibleCount);
            updateEmptyState(searchTerm);

            // Show/hide empty state
            if (visibleCount === 0) {
                emptyState?.classList.remove('hidden');
                productGrid?.classList.add('hidden');
            } else {
                emptyState?.classList.add('hidden');
                productGrid?.classList.remove('hidden');
            }
        }

        function runFilterWithFeedback() {
            if (filterTimer) {
                window.clearTimeout(filterTimer);
            }

            const currentRequestId = ++filterRequestId;
            setFilteringState(true);

            filterTimer = window.setTimeout(() => {
                if (currentRequestId !== filterRequestId) return;

                filterProducts();
                setFilteringState(false);
            }, 140);
        }

        // Search input event
        searchInput?.addEventListener('input', runFilterWithFeedback);

        // Category filter events
        categoryPills.forEach((pill) => {
            pill.addEventListener('click', () => {
                const button = pill as HTMLButtonElement;
                
                // Update active category
                activeCategory = button.dataset.category || 'todos';

                // Update pill styles
                categoryPills.forEach((p) => {
                    const btn = p as HTMLButtonElement;
                    btn.classList.remove('is-active');
                    btn.setAttribute('aria-pressed', 'false');
                });

                button.classList.add('is-active');
                button.setAttribute('aria-pressed', 'true');

                runFilterWithFeedback();
            });
        });

        // Clear filters
        clearFiltersBtn?.addEventListener('click', () => {
            searchInput.value = '';
            activeCategory = 'todos';

            // Reset category pills
            categoryPills.forEach((p) => {
                const btn = p as HTMLButtonElement;
                btn.classList.remove('is-active');
                btn.setAttribute('aria-pressed', 'false');
            });

            // Set "Todos" as active
            const todosPill = document.querySelector('[data-category="todos"]');
            if (todosPill) {
                const btn = todosPill as HTMLButtonElement;
                btn.classList.add('is-active');
                btn.setAttribute('aria-pressed', 'true');
            }

            runFilterWithFeedback();
        });
    }

    initStoreFilters();
    document.addEventListener('astro:page-load', initStoreFilters);
</script>

<style>
    .store-page {
        background:
            linear-gradient(180deg, color-mix(in srgb, var(--color-bg-alt) 90%, transparent) 0%, color-mix(in srgb, var(--color-bg) 96%, transparent) 100%);
    }

    .store-hero-section {
        background:
            linear-gradient(135deg, color-mix(in srgb, var(--color-accent) 12%, transparent) 0%, transparent 46%, color-mix(in srgb, var(--color-accent-strong) 12%, transparent) 100%),
            linear-gradient(180deg, color-mix(in srgb, var(--color-bg-alt) 84%, transparent) 0%, transparent 100%);
    }

    .store-hero-shell,
    .store-filter-header,
    .store-results-panel,
    .store-empty-panel {
        border: 1px solid var(--color-border);
        background: color-mix(in srgb, var(--color-surface-elevated) 94%, transparent);
        box-shadow: 0 14px 30px var(--color-shadow-soft);
        backdrop-filter: blur(14px);
    }

    .store-tip-panel,
    .store-empty-card {
        border: 1px solid var(--color-border);
        background: color-mix(in srgb, var(--color-surface) 94%, var(--color-accent) 6%);
        box-shadow: 0 10px 24px var(--color-shadow-soft);
    }

    .store-eyebrow {
        border: 1px solid color-mix(in srgb, var(--color-accent) 22%, transparent);
        background: color-mix(in srgb, var(--color-accent) 12%, var(--color-surface-elevated) 88%);
        color: var(--color-accent);
    }

    .store-accent-label {
        color: color-mix(in srgb, var(--color-accent) 82%, var(--color-text) 18%);
    }

    .store-heading {
        color: var(--color-text);
    }

    .store-copy,
    .store-results-panel {
        color: var(--color-text-muted);
    }

    .store-stat-pill,
    .store-empty-chip {
        border: 1px solid var(--color-border);
        background: color-mix(in srgb, var(--color-surface-elevated) 92%, transparent);
        color: var(--color-text-muted);
        box-shadow: 0 8px 18px var(--color-shadow-soft);
    }

    .store-stat-dot {
        background: var(--color-text);
    }

    .store-search-input {
        appearance: none;
        -webkit-appearance: none;
        padding-left: 4rem;
        border-radius: 9999px;
        box-shadow: 0 8px 18px var(--color-shadow-soft);
    }

    .store-search-input::-webkit-search-decoration,
    .store-search-input::-webkit-search-cancel-button,
    .store-search-input::-webkit-search-results-button,
    .store-search-input::-webkit-search-results-decoration {
        -webkit-appearance: none;
        appearance: none;
        display: none;
    }

    .store-search-icon {
        color: var(--color-text-subtle);
    }

    .store-filter-pill {
        border: 1px solid var(--color-border);
        background: color-mix(in srgb, var(--color-surface-elevated) 94%, transparent);
        color: var(--color-text-muted);
        box-shadow: 0 6px 16px var(--color-shadow-soft);
    }

    .store-filter-pill:hover {
