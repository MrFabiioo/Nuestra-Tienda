---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <main class=" w-full flex items-center justify-center bg-guacamole-fondo text-guacamole-icons font-mono p-4 md:p-10">
    <div class="max-w-7xl w-full mx-auto grid grid-cols-1 md:grid-cols-2 gap-8">
      <!-- Formulario de Envío -->
      <section class="bg-guacamole-f text-amber-950 font-bold border-4  border-black rounded-lg px-3 md:px-6 py-1 md:py-3 shadow-[4px_4px_0_0_#3E6102] hover:shadow-[2px_2px_0_0_#3E6102]  text-sm md:text-xl">
        <h2 class="text-2xl md:text-3xl font-black mb-4 tracking-wide">📝 Información de Envío</h2>

        <div class="space-y-4">
          <input type="text" placeholder="Nombre completo" class="w-full p-3 rounded border-2 border-guacamole-g focus:outline-none focus:ring-2 focus:ring-guacamole-c" />
          <input type="email" placeholder="Correo electrónico" class="w-full p-3 rounded border-2 border-guacamole-g focus:outline-none focus:ring-2 focus:ring-guacamole-c" />
          <input type="tel" placeholder="Teléfono" class="w-full p-3 rounded border-2 border-guacamole-g focus:outline-none focus:ring-2 focus:ring-guacamole-c" />

          <select class="w-full p-3 rounded border-2 border-guacamole-g focus:outline-none focus:ring-2 focus:ring-guacamole-c">
            <option value="">Selecciona tu país</option>
            <option value="mx">México</option>
            <option value="co">Colombia</option>
          </select>

          <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
            <input type="text" placeholder="Ciudad" class="p-3 rounded border-2 border-guacamole-g focus:outline-none focus:ring-2 focus:ring-guacamole-c" />
            <input type="text" placeholder="Estado" class="p-3 rounded border-2 border-guacamole-g focus:outline-none focus:ring-2 focus:ring-guacamole-c" />
            <input type="text" placeholder="Código Postal" class="p-3 rounded border-2 border-guacamole-g focus:outline-none focus:ring-2 focus:ring-guacamole-c" />
          </div>
        </div>

        <label class="mt-4 inline-flex items-start gap-2">
          <input type="checkbox" class="mt-1" />
          <span class="text-sm">He leído y acepto los <a href="#" class="underline">términos y condiciones</a>.</span>
        </label>
      </section>

      <!-- Resumen del Carrito -->
      <section class="bg-guacamole-f text-amber-950 font-bold border-4  border-black rounded-lg px-3 md:px-6 py-1 md:py-3 shadow-[4px_4px_0_0_#3E6102] hover:shadow-[2px_2px_0_0_#3E6102]  text-sm md:text-xl p-6 flex flex-col justify-between ">
        <div>
          <h2 class="text-2xl md:text-3xl font-black mb-4 tracking-wide">🛒 Tu Carrito</h2>

          <div class="flex items-center gap-4 mb-4">
            <img src="/guacamoleIA.png" alt="Tazón de guacamole" class="w-20 h-20 rounded border-2 border-guacamole-h" />
            <div>
              <p class="font-bold text-lg">Tazón de Guacamole</p>
              <p class="text-sm">x1</p>
              <p class="font-black">$9.000</p>
            </div>
          </div>

          <div class="mt-4 border-t border-guacamole-g pt-4 text-sm space-y-2">
            <p class="flex justify-between"><span>Subtotal</span><span>$9.000</span></p>
            <p class="flex justify-between"><span>Envío</span><span>$5.000</span></p>
            <p class="flex justify-between font-black text-lg border-t pt-2 border-guacamole-h"><span>Total</span><span>$14.000</span></p>
          </div>
        </div>

        <button class="mt-6 bg-guacamole-f text-amber-950 font-bold border-4  border-black rounded-lg px-3 md:px-6 py-1 md:py-3 shadow-[4px_4px_0_0_#3E6102] hover:bg-guacamole-b active:translate-y-1 active:shadow-[0px_0px_0_0_#3E6102] transition-all text-sm md:text-xl  mb-5">
          Ir a pagar 🥑
          <a href="/pagos/" class="text-amber-950 hover:underline">Pagar ahora</a>
        </button>
      </section>
    </div>
  </main>
</Layout>