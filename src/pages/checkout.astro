---
import Layout from "../layouts/Layout.astro";
---

<Layout>
  <main
    class="w-full flex items-center justify-center bg-guacamole-fondo text-guacamole-icons font-mono p-4 md:p-10"
  >
    <div class="max-w-7xl w-full mx-auto grid grid-cols-1 md:grid-cols-2 gap-8">
      <!-- Formulario de Envío -->
      <section
        class="bg-guacamole-f text-black font-bold border-2 border-black px-3 md:px-6 py-1 md:py-3  text-sm md:text-xl"
      >
        <h2 class="text-2xl md:text-3xl font-black mb-4 tracking-wide uppercase">
          📝 Información de Envío
        </h2>

        <div class="space-y-4">
          <input
            type="text"
            placeholder="Nombre completo"
            class="w-full p-3 rounded border-2 text-black border-guacamole-g focus:outline-none focus:ring-2 focus:ring-guacamole-c uppercase"
          />
          <input
            type="email"
            placeholder="Correo electrónico"
            class="w-full p-3 rounded border-2 text-black border-guacamole-g focus:outline-none focus:ring-2 focus:ring-guacamole-c uppercase"
          />
          <input
            type="tel"
            placeholder="Teléfono"
            class="w-full p-3 rounded border-2 text-black border-guacamole-g focus:outline-none focus:ring-2 focus:ring-guacamole-c uppercase"
          />

          <select
            class="w-full p-3 rounded border-2 text-black border-guacamole-g focus:outline-none focus:ring-2 focus:ring-guacamole-c uppercase"
          >
            <option value="">Selecciona tu país</option>
            <option value="mx">México</option>
            <option value="co">Colombia</option>
          </select>

          <div class="grid grid-cols-1 md:grid-cols-3 gap-4 uppercase">
            <input
              type="text"
              placeholder="Ciudad"
              class="p-3 rounded border-2 border-guacamole-g focus:outline-none focus:ring-2 focus:ring-guacamole-c uppercase"
            />
            <input
              type="text"
              placeholder="Estado"
              class="p-3 rounded border-2 border-guacamole-g focus:outline-none focus:ring-2 focus:ring-guacamole-c uppercase"
            />
            <input
              type="text"
              placeholder="Código Postal"
              class="p-3 rounded border-2 border-guacamole-g focus:outline-none focus:ring-2 focus:ring-guacamole-c uppercase"
            />
          </div>
        </div>

        <label class="mt-4 inline-flex items-start gap-2">
          <input type="checkbox" class="mt-1" />
          <span class="text-sm uppercase"
            >He leído y acepto los <a href="#" class="underline"
              >términos y condiciones</a
            >.</span
          >
        </label>
      </section>

      <!-- Resumen del Carrito -->
      <section
        class="bg-guacamole-f text-black  font-bold border-2 border-black  px-3 md:px-6 py-1 md:py-3 text-sm md:text-xl p-6 flex flex-col justify-between"
      >
        <div>
          <h2 class="text-2xl md:text-3xl font-black mb-4 tracking-wide uppercase">
            🛒 Tu Carrito
          </h2>

          <div class="flex items-center gap-4 mb-4">
            <img
              src="/images/guacamoleIA.png"
              alt="Tazón de guacamole"
              class="w-20 h-20 rounded border-2 border-guacamole-h"
            />
            <div>
              <p class="font-bold text-lg uppercase">Tazón de Guacamole</p>
              <p class="text-sm">x1</p>
              <p class="font-black">$9.000</p>
            </div>
          </div>

          <div class="mt-4 border-t border-guacamole-g pt-4 text-sm space-y-2">
            <p class="flex justify-between">
              <span class="uppercase">Subtotal</span><span>$9.000</span>
            </p>
            <p class="flex justify-between uppercase">
              <span>Envío</span><span>Gratis</span>
            </p>
            <p
              class="flex justify-between font-black text-lg border-t pt-2 border-guacamole-h uppercase"
            >
              <span>Total</span><span>$14.000</span>
            </p>
          </div>
        </div>

        <div class="flex justify-center items-center h-full my-6">
          <a
            class="grid content-center w-1/2 group relative focus:ring-3 focus:outline-hidden"
            href="/pagos"
          >
            <span
              class="absolute inset-0 translate-x-1.5 translate-y-1.5 bg-guacamole-icons transition-transform group-hover:translate-x-0 group-hover:translate-y-0"
            ></span>

            <span
              class="relative inline-block border-2 border-current px-8 py-3 text-sm font-bold tracking-widest text-black uppercase text-center"
            >
              Ir a pagar
            </span>
          </a>
        </div>
      </section>
    </div>
  </main>
</Layout>
