---
import Layout from "../layouts/Layout.astro";
import BreadcrumbTrail from "../components/shared/BreadcrumbTrail.astro";

const paymentBreadcrumbs = [
  { label: 'Inicio', href: '/' },
  { label: 'Tienda', href: '/tienda' },
  { label: 'Checkout', href: '/checkout' },
  { label: 'Pago' },
];
---

<Layout title="Métodos de pago | Guacamole Shop" description="Elegí cómo querés pagar y confirmá tu pedido">
  <main class="theme-payment-page min-h-screen bg-guacamole-fondo/10 py-8 px-4 md:px-8">

    <!-- Step indicator -->
    <div class="max-w-6xl mx-auto mb-8">
      <BreadcrumbTrail
        items={paymentBreadcrumbs}
        eyebrow="Paso 2 de 2"
        summary="Acá definís cómo pagar y confirmás el pedido. Si necesitás ajustar datos o productos, podés volver a checkout sin perder la referencia del recorrido."
      />

      <!-- Progress Steps -->
      <div class="premium-subtle-panel mb-8 mt-5 flex items-center gap-0 px-4 py-4 sm:px-5">
        <div class="flex items-center gap-2">
          <div class="w-8 h-8 rounded-full bg-guacamole-b flex items-center justify-center text-white font-bold text-sm">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
            </svg>
          </div>
          <span class="text-sm font-semibold text-guacamole-b hidden sm:block">Tus datos</span>
        </div>
        <div class="flex-1 h-0.5 bg-guacamole-b mx-3 max-w-[80px]"></div>
        <div class="flex items-center gap-2">
          <div class="w-8 h-8 rounded-full bg-guacamole-icons flex items-center justify-center text-white font-bold text-sm">2</div>
          <span class="text-sm font-bold text-guacamole-icons hidden sm:block">Pago</span>
        </div>
        <div class="flex-1 h-0.5 bg-gray-200 mx-3 max-w-[80px]"></div>
        <div class="flex items-center gap-2">
          <div class="w-8 h-8 rounded-full bg-gray-200 flex items-center justify-center text-gray-400 font-bold text-sm">3</div>
          <span class="text-sm font-semibold text-gray-400 hidden sm:block">Confirmación</span>
        </div>
      </div>

      <h1 class="text-3xl md:text-4xl font-black text-guacamole-icons uppercase tracking-wide">
        Elegí cómo querés pagar
      </h1>
      <p class="text-gray-600 mt-1">Elegí el medio que te quede más cómodo, seguí los pasos indicados y confirmá el comprobante cuando ya esté listo.</p>
      <div class="mt-4 flex flex-wrap gap-3 text-sm text-gray-600">
        <a href="/checkout" class="premium-action-secondary">
          <span>←</span>
          <span>Volver a checkout</span>
        </a>
        <span class="inline-flex items-center gap-2 rounded-full border border-gray-200 bg-white px-4 py-2 shadow-sm">
          <span class="h-2 w-2 rounded-full bg-guacamole-b"></span>
          Último paso: elegir medio y confirmar pago
        </span>
      </div>
      <div class="premium-subtle-panel mt-4 px-4 py-4 text-sm text-gray-600">
        <p class="font-semibold text-guacamole-icons">Tip para un checkout premium</p>
        <p class="mt-1">Tené a mano el monto exacto, hacé el pago por el canal que prefieras y guardá la captura o referencia antes de tocar el botón de confirmación.</p>
      </div>
    </div>

    <!-- Main Layout: 2 cols -->
    <div class="max-w-6xl mx-auto grid grid-cols-1 lg:grid-cols-3 gap-8">

        <!-- Payment Methods Column -->
        <div class="lg:col-span-2 space-y-4">

          <!-- Back link -->
        <a
          href="/checkout"
          class="premium-action-secondary mb-2"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
          <span>Volver al checkout</span>
        </a>

        <!-- Payment Methods Card -->
        <div class="premium-panel overflow-hidden rounded-3xl">
          <div class="bg-guacamole-b px-6 py-4">
            <h2 class="text-xl font-black text-white uppercase tracking-wide">
              Elegí tu medio de pago
            </h2>
          </div>

          <div class="p-6">
            <div class="mb-6 flex flex-wrap items-center gap-3 rounded-2xl border border-guacamole-fondo/30 bg-guacamole-fondo/10 px-4 py-4 text-sm text-gray-600">
              <span class="premium-chip">Método activo</span>
              <p id="selected-method-copy" class="font-semibold text-guacamole-icons">Bancolombia · QR o transferencia a cuenta</p>
            </div>

            <!-- Tab Buttons -->
            <div class="flex flex-wrap gap-3 mb-6" role="tablist" aria-label="Métodos de pago">
              <button
                type="button"
                role="tab"
                aria-selected="true"
                aria-controls="panel-bancolombia"
                id="tab-btn-bancolombia"
                class="payment-tab active-tab inline-flex min-h-11 items-center gap-2 rounded-full border-2 border-guacamole-b bg-guacamole-b px-5 py-3 text-sm font-bold text-white transition-all"
                data-target="panel-bancolombia"
              >
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z" />
                </svg>
                Bancolombia
              </button>

              <button
                type="button"
                role="tab"
                aria-selected="false"
                aria-controls="panel-nequi"
                id="tab-btn-nequi"
                class="payment-tab inline-flex min-h-11 items-center gap-2 rounded-full border-2 border-gray-200 bg-white px-5 py-3 text-sm font-bold text-guacamole-icons transition-all hover:border-guacamole-b hover:text-guacamole-b"
                data-target="panel-nequi"
              >
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z" />
                </svg>
                Nequi
              </button>

              <button
                type="button"
                role="tab"
                aria-selected="false"
                aria-controls="panel-transferencia"
                id="tab-btn-transferencia"
                class="payment-tab inline-flex min-h-11 items-center gap-2 rounded-full border-2 border-gray-200 bg-white px-5 py-3 text-sm font-bold text-guacamole-icons transition-all hover:border-guacamole-b hover:text-guacamole-b"
                data-target="panel-transferencia"
              >
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4" />
                </svg>
                Transferencia
              </button>
            </div>

            <!-- Panel: Bancolombia -->
            <div
              id="panel-bancolombia"
              role="tabpanel"
              aria-labelledby="tab-btn-bancolombia"
              class="payment-panel"
            >
              <div class="bg-guacamole-fondo/5 border border-guacamole-fondo/20 rounded-xl p-5 space-y-5">
                <!-- Instructions -->
                <div class="flex items-start gap-3 rounded-lg border border-guacamole-b/20 bg-guacamole-fondo/10 p-4">
                  <svg xmlns="http://www.w3.org/2000/svg" class="mt-0.5 h-5 w-5 shrink-0 text-guacamole-b" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                  <div>
                    <p class="text-sm font-bold text-guacamole-a">Pagá con Bancolombia</p>
                    <p class="mt-1 text-sm text-guacamole-icons/80">
                      Escaneá el QR desde la app o transferí a la cuenta indicada. Cuando termines, guardá el comprobante para confirmar tu pedido con nosotros sin demoras.
                    </p>
                  </div>
                </div>
                <div class="rounded-2xl border border-guacamole-b/15 bg-white px-4 py-4 text-sm text-gray-600">
                  <p class="font-semibold text-guacamole-icons">Ideal si ya usás la app de Bancolombia</p>
                  <p class="mt-1">Podés pagar escaneando el QR o copiando los datos de la cuenta. Elegí la opción que te dé más confianza.</p>
                </div>

                <!-- QR Code -->
                <div class="text-center">
                  <p class="text-sm font-semibold text-guacamole-icons mb-3 uppercase tracking-wide">Código QR — Bancolombia</p>
                  <div class="inline-block rounded-xl border-2 border-guacamole-b/20 bg-white p-3 shadow-sm">
                    <img
                      src="/images/guacamoleIA.png"
                      alt="Código QR Bancolombia para pago"
                      class="w-48 h-48 object-contain"
                    />
                  </div>
                </div>

                <!-- Account Info -->
                <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
                  <div class="px-4 py-3 bg-gray-50 border-b border-gray-200">
                    <p class="text-xs font-bold text-gray-500 uppercase tracking-wide">Datos de la cuenta</p>
                  </div>
                  <div class="p-4 space-y-3">
                    <div class="flex justify-between items-center">
                      <span class="text-sm text-gray-500">Banco</span>
                      <span class="text-sm font-bold text-guacamole-icons">Bancolombia</span>
                    </div>
                    <div class="flex justify-between items-center">
                      <span class="text-sm text-gray-500">Tipo</span>
                      <span class="text-sm font-bold text-guacamole-icons">Cuenta de Ahorros</span>
                    </div>
                    <div class="flex justify-between items-center">
                      <span class="text-sm text-gray-500">Número</span>
                      <span class="text-sm font-bold text-guacamole-icons font-mono tracking-wider">331-85984-045</span>
                    </div>
                  </div>
                </div>
              </div>
            </div>

            <!-- Panel: Nequi -->
            <div
              id="panel-nequi"
              role="tabpanel"
              aria-labelledby="tab-btn-nequi"
              class="payment-panel hidden"
            >
              <div class="bg-guacamole-fondo/5 border border-guacamole-fondo/20 rounded-xl p-5 space-y-5">
                <!-- Instructions -->
                <div class="flex items-start gap-3 rounded-lg border border-guacamole-b/20 bg-guacamole-fondo/10 p-4">
                  <svg xmlns="http://www.w3.org/2000/svg" class="mt-0.5 h-5 w-5 shrink-0 text-guacamole-b" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                  <div>
                    <p class="text-sm font-bold text-guacamole-a">Pagá con Nequi</p>
                    <p class="mt-1 text-sm text-guacamole-icons/80">
                      Abrí la app, escaneá el QR o usá el número de celular. Enviá el monto exacto del pedido y guardá la captura para validarlo más rápido.
                    </p>
                  </div>
                </div>
                <div class="rounded-2xl border border-guacamole-b/15 bg-white px-4 py-4 text-sm text-gray-600">
                  <p class="font-semibold text-guacamole-icons">Ideal si querés resolverlo en segundos</p>
                  <p class="mt-1">Nequi suele ser el camino más rápido si ya tenés saldo disponible o la app abierta en el celu.</p>
                </div>

                <!-- QR Code -->
                <div class="text-center">
                  <p class="text-sm font-semibold text-guacamole-icons mb-3 uppercase tracking-wide">Código QR — Nequi</p>
                  <div class="inline-block rounded-xl border-2 border-guacamole-b/20 bg-white p-3 shadow-sm">
                    <img
                      src="/images/guacamoleIA.png"
                      alt="Código QR Nequi para pago"
                      class="w-48 h-48 object-contain"
                    />
                  </div>
                </div>

                <!-- Account Info -->
                <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
                  <div class="px-4 py-3 bg-gray-50 border-b border-gray-200">
                    <p class="text-xs font-bold text-gray-500 uppercase tracking-wide">Número Nequi</p>
                  </div>
                  <div class="p-4 flex justify-between items-center">
                    <span class="text-sm text-gray-500">Celular</span>
                    <span class="text-lg font-black text-guacamole-icons font-mono tracking-widest">350 201 8487</span>
                  </div>
                </div>
              </div>
            </div>

            <!-- Panel: Transferencia Bancaria -->
            <div
              id="panel-transferencia"
              role="tabpanel"
              aria-labelledby="tab-btn-transferencia"
              class="payment-panel hidden"
            >
              <div class="bg-guacamole-fondo/5 border border-guacamole-fondo/20 rounded-xl p-5 space-y-5">
                <!-- Instructions -->
                <div class="flex items-start gap-3 rounded-lg border border-guacamole-b/20 bg-guacamole-fondo/10 p-4">
                  <svg xmlns="http://www.w3.org/2000/svg" class="mt-0.5 h-5 w-5 shrink-0 text-guacamole-b" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                  <div>
                    <p class="text-sm font-bold text-guacamole-a">Pagá por transferencia</p>
                    <p class="mt-1 text-sm text-guacamole-icons/80">
                      Ingresá a tu banca en línea o app, usá los datos de la cuenta y transferí el monto exacto. Después compartinos el comprobante para terminar la validación.
                    </p>
                  </div>
                </div>
                <div class="rounded-2xl border border-guacamole-b/15 bg-white px-4 py-4 text-sm text-gray-600">
                  <p class="font-semibold text-guacamole-icons">Ideal si preferís revisar cada dato antes de pagar</p>
                  <p class="mt-1">Esta opción te deja confirmar banco, titular y cuenta con más detalle antes de hacer la operación.</p>
                </div>

                <!-- Account Info -->
                <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
                  <div class="px-4 py-3 bg-gray-50 border-b border-gray-200">
                    <p class="text-xs font-bold text-gray-500 uppercase tracking-wide">Datos de transferencia</p>
                  </div>
                  <div class="p-4 space-y-3">
                    <div class="flex justify-between items-center">
                      <span class="text-sm text-gray-500">Banco</span>
                      <span class="text-sm font-bold text-guacamole-icons">Bancolombia</span>
                    </div>
                    <div class="flex justify-between items-center">
                      <span class="text-sm text-gray-500">Tipo</span>
                      <span class="text-sm font-bold text-guacamole-icons">Cuenta de Ahorros</span>
                    </div>
                    <div class="flex justify-between items-center">
                      <span class="text-sm text-gray-500">Número</span>
                      <span class="text-sm font-bold text-guacamole-icons font-mono tracking-wider">331-85984-045</span>
                    </div>
                    <div class="flex justify-between items-center">
                      <span class="text-sm text-gray-500">Titular</span>
                      <span class="text-sm font-bold text-guacamole-icons">Guacamole Shop</span>
                    </div>
                  </div>
                </div>

                <!-- Important Note -->
                <div class="flex items-start gap-3 rounded-lg border border-guacamole-b/25 bg-guacamole-fondo/10 p-4">
                  <svg xmlns="http://www.w3.org/2000/svg" class="mt-0.5 h-5 w-5 shrink-0 text-guacamole-a" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
                  </svg>
                  <p class="text-sm font-semibold text-guacamole-a">
                     Transferí el monto exacto del pedido y, si tu banco lo permite, dejá tu nombre completo como referencia.
                  </p>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Next Steps Card -->
        <div class="premium-panel overflow-hidden rounded-3xl">
          <div class="bg-guacamole-a px-6 py-4">
            <h2 class="text-xl font-black text-white uppercase tracking-wide">
              Qué sigue ahora
            </h2>
          </div>
          <div class="p-6">
            <div class="mb-5 rounded-2xl border border-gray-100 bg-gray-50 px-4 py-4 text-sm text-gray-600">
              <p class="font-semibold text-guacamole-icons">Confirmá cuando ya tengas el comprobante</p>
              <p class="mt-1">La idea es simple: pagás, guardás la evidencia y recién ahí nos avisás para que validemos el pedido sin confusiones.</p>
            </div>
            <ol class="space-y-4">
              <li class="flex items-start gap-4">
                <div class="w-8 h-8 rounded-full bg-guacamole-b/10 border-2 border-guacamole-b flex items-center justify-center shrink-0 mt-0.5">
                  <span class="text-sm font-black text-guacamole-b">1</span>
                </div>
                <div>
                  <p class="font-bold text-guacamole-icons">Hacé el pago</p>
                  <p class="text-sm text-gray-500">Usá el medio seleccionado arriba y enviá el monto exacto que figura en el resumen.</p>
                </div>
              </li>
              <li class="flex items-start gap-4">
                <div class="w-8 h-8 rounded-full bg-guacamole-b/10 border-2 border-guacamole-b flex items-center justify-center shrink-0 mt-0.5">
                  <span class="text-sm font-black text-guacamole-b">2</span>
                </div>
                <div>
                  <p class="font-bold text-guacamole-icons">Guardá el comprobante</p>
                  <p class="text-sm text-gray-500">Sacá una captura o guardá el número de transacción para tenerlo a mano.</p>
                </div>
              </li>
              <li class="flex items-start gap-4">
                <div class="w-8 h-8 rounded-full bg-guacamole-b/10 border-2 border-guacamole-b flex items-center justify-center shrink-0 mt-0.5">
                  <span class="text-sm font-black text-guacamole-b">3</span>
                </div>
                <div>
                  <p class="font-bold text-guacamole-icons">Confirmá tu pedido</p>
                  <p class="text-sm text-gray-500">Cuando ya lo tengas listo, usá el botón de abajo para avisarnos que el pago fue realizado y podamos validarlo.</p>
                </div>
              </li>
            </ol>
          </div>
        </div>

      </div>

      <!-- Summary Panel -->
      <div class="lg:col-span-1">
        <div class="premium-panel sticky top-24 rounded-3xl">
          <div class="bg-guacamole-a px-6 py-4">
            <h2 class="text-xl font-black text-white uppercase tracking-wide">
              Resumen de tu pedido
            </h2>
          </div>

          <div class="p-6 space-y-4">
            <!-- Customer Info (from sessionStorage) -->
            <div id="customer-summary" class="hidden space-y-2 pb-4 border-b border-gray-100">
              <p class="text-xs font-bold text-gray-400 uppercase tracking-wide">Pedido para</p>
              <p id="summary-name" class="font-bold text-guacamole-icons text-sm"></p>
              <p id="summary-address" class="text-sm text-gray-500"></p>
            </div>

            <div class="rounded-2xl border border-guacamole-fondo/30 bg-guacamole-fondo/10 px-4 py-4 text-sm text-gray-600">
              <p class="font-semibold text-guacamole-icons">Antes de confirmar</p>
              <p class="mt-1">Verificá que el monto y el comprobante coincidan. Ese detalle hace la validación mucho más rápida.</p>
            </div>

            <!-- Order total placeholder (populated from sessionStorage) -->
            <div id="order-summary-detail" class="space-y-3 text-gray-600 hidden">
              <div class="flex justify-between items-center">
                <span class="font-semibold text-sm">Subtotal</span>
                <span id="summary-subtotal" class="font-bold text-guacamole-icons text-sm"></span>
              </div>
              <div class="flex justify-between items-center">
                <span class="font-semibold text-sm">Entrega</span>
                <span class="font-bold text-guacamole-b text-sm">A coordinar</span>
              </div>
              <div class="flex justify-between items-center">
                <span class="font-semibold text-sm">Impuesto (15%)</span>
                <span id="summary-tax" class="font-bold text-guacamole-icons text-sm"></span>
              </div>
            </div>

            <!-- Fallback if no data -->
            <div id="order-summary-fallback" class="text-center py-4">
              <p class="text-sm text-gray-400">Para ver el resumen, completá primero tus datos en <a href="/checkout" class="text-guacamole-b hover:underline font-semibold">checkout</a>.</p>
            </div>

            <!-- Total -->
            <div class="border-t-2 border-guacamole-b/20 pt-4">
              <div class="flex justify-between items-center">
                <span class="text-xl font-black text-guacamole-icons uppercase">Total</span>
                <span id="summary-total" class="text-2xl font-black text-guacamole-a">—</span>
              </div>
            </div>

            <!-- Confirm Payment Button -->
            <button
              type="button"
              id="confirm-payment-btn"
              class="group block w-full rounded-full bg-guacamole-b px-8 py-4 text-center text-sm font-bold uppercase tracking-wider text-white shadow-[0_4px_12px_rgba(86,130,3,0.3)] transition-all duration-300 hover:-translate-y-0.5 hover:bg-guacamole-a hover:shadow-[0_6px_20px_rgba(86,130,3,0.4)] disabled:cursor-not-allowed disabled:bg-gray-300 disabled:text-white/90 disabled:shadow-none disabled:hover:translate-y-0 disabled:hover:bg-gray-300"
              disabled
              aria-disabled="true"
            >
              <span id="confirm-payment-label" class="flex items-center justify-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                Completá checkout para confirmar
              </span>
            </button>
            <p id="payment-feedback" class="min-h-[1.25rem] text-center text-xs font-medium text-gray-500" aria-live="polite">
              Necesitamos tu resumen del checkout para confirmar que este pago corresponde a un pedido listo.
            </p>

            <!-- Secure Badge -->
            <p class="text-center text-xs text-gray-400 flex items-center justify-center gap-1">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
              </svg>
              Compra 100% segura
            </p>

            <!-- Trust Badges -->
            <div class="mt-2 space-y-2 rounded-2xl border border-guacamole-fondo/25 bg-guacamole-fondo/10 p-4">
              <p class="text-xs font-bold uppercase tracking-[0.22em] text-guacamole-b">Confianza de compra</p>
              <div class="flex items-center gap-2 text-sm text-guacamole-icons">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-guacamole-b shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4" />
                </svg>
                <span class="font-semibold">Envío gratis en pedidos +$50</span>
              </div>
              <div class="flex items-center gap-2 text-sm text-guacamole-icons">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-guacamole-b shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                <span class="font-semibold">Garantía de devolución 30 días</span>
              </div>
              <div class="flex items-center gap-2 text-sm text-guacamole-icons">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-guacamole-b shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-4l-4 4v-4z" />
                </svg>
                <span class="font-semibold">Confirmación humana del pago y la entrega</span>
              </div>
            </div>
          </div>
        </div>
      </div>

    </div>

    <!-- Confirmation Modal -->
    <div
      id="confirm-modal"
      class="hidden fixed inset-0 z-50 flex items-center justify-center px-4"
      role="dialog"
      aria-modal="true"
      aria-labelledby="modal-title"
    >
      <div class="absolute inset-0 bg-black/60 backdrop-blur-sm" id="modal-backdrop"></div>
      <div class="relative w-full max-w-md rounded-3xl bg-white p-8 text-center shadow-2xl">
        <div class="mx-auto mb-6 flex h-20 w-20 items-center justify-center rounded-full bg-guacamole-fondo/15">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 text-guacamole-a" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
        </div>
        <h2 id="modal-title" class="text-2xl font-black text-guacamole-icons uppercase mb-3">¡Gracias por tu compra!</h2>
        <p class="text-gray-600 mb-6">
          Recibimos tu confirmación. En breve te vamos a escribir para validar el pago y coordinar la entrega o el retiro con todo en orden.
        </p>
        <p class="mb-6 text-sm text-gray-500">Si necesitás volver a comprar, tu carrito ya quedó limpio para arrancar desde cero.</p>
        <a
          href="/tienda"
          class="premium-action-primary"
        >
          Seguir comprando
        </a>
      </div>
    </div>

  </main>
</Layout>

<style>
  .theme-payment-page {
    background: linear-gradient(180deg, color-mix(in srgb, var(--color-bg) 94%, transparent) 0%, color-mix(in srgb, var(--color-bg-alt) 96%, transparent) 100%);
    color: var(--color-text);
  }

  .theme-payment-page .premium-panel,
  .theme-payment-page .premium-subtle-panel {
    border-color: var(--color-border);
    background: color-mix(in srgb, var(--color-surface) 96%, transparent);
    box-shadow: 0 18px 36px var(--color-shadow-strong);
  }

  .theme-payment-page .bg-guacamole-b,
  .theme-payment-page .bg-guacamole-a,
  .theme-payment-page .active-tab {
    background: linear-gradient(135deg, var(--color-accent) 0%, var(--color-accent-strong) 100%);
    color: var(--color-text-on-accent);
  }

  .theme-payment-page .bg-white,
  .theme-payment-page .bg-gray-50,
  .theme-payment-page .bg-guacamole-fondo\/10,
  .theme-payment-page .bg-guacamole-fondo\/5 {
    background: color-mix(in srgb, var(--color-surface-elevated) 94%, transparent);
  }

  .theme-payment-page .border-gray-200,
  .theme-payment-page .border-gray-100,
  .theme-payment-page .border-guacamole-fondo\/30,
  .theme-payment-page .border-guacamole-fondo\/25,
  .theme-payment-page .border-guacamole-fondo\/20,
  .theme-payment-page .border-guacamole-b\/20,
  .theme-payment-page .border-guacamole-b\/15,
  .theme-payment-page .border-guacamole-b\/25,
  .theme-payment-page .border-guacamole-b\/10 {
    border-color: var(--color-border);
  }

  .theme-payment-page .text-guacamole-icons,
  .theme-payment-page .text-black-dark {
    color: var(--color-text);
  }

  .theme-payment-page .text-guacamole-a,
  .theme-payment-page .text-guacamole-b {
    color: var(--color-accent);
  }

  .theme-payment-page .text-gray-600,
  .theme-payment-page .text-gray-500 {
    color: var(--color-text-muted);
  }

  .theme-payment-page .text-gray-400,
  .theme-payment-page .border-gray-200.text-gray-400,
  .theme-payment-page .bg-gray-200.text-gray-400 {
    color: var(--color-text-subtle);
  }

  .theme-payment-page .bg-gray-200 {
    background: var(--color-surface-soft-strong);
  }

  .theme-payment-page .payment-tab:not(.active-tab) {
    background: color-mix(in srgb, var(--color-surface-elevated) 95%, transparent);
    color: var(--color-text);
  }

  .theme-payment-page .payment-tab:hover {
    border-color: var(--color-border-strong);
    color: var(--color-accent);
    background: var(--color-surface-soft);
  }

  .theme-payment-page #payment-feedback {
    color: var(--color-text-muted);
  }

  .theme-payment-page #confirm-modal .relative {
    background: color-mix(in srgb, var(--color-surface) 98%, transparent);
    color: var(--color-text);
  }
</style>

<script>
  document.addEventListener('astro:page-load', () => {
    const paymentFeedback = document.getElementById('payment-feedback') as HTMLParagraphElement | null;
    const selectedMethodCopy = document.getElementById('selected-method-copy') as HTMLParagraphElement | null;

    const paymentMethodDescriptions: Record<string, string> = {
      'panel-bancolombia': 'Bancolombia · QR o transferencia a cuenta',
      'panel-nequi': 'Nequi · Pago rápido desde la app o por número celular',
      'panel-transferencia': 'Transferencia · Validación detallada con datos bancarios'
    };

    const setPaymentFeedback = (message: string, tone: 'default' | 'success' | 'error' = 'default') => {
      if (!paymentFeedback) return;

      paymentFeedback.textContent = message;
      paymentFeedback.classList.remove('text-gray-500', 'text-guacamole-b', 'text-red-500');

      if (tone === 'success') {
        paymentFeedback.classList.add('text-guacamole-b');
        return;
      }

      if (tone === 'error') {
        paymentFeedback.classList.add('text-red-500');
        return;
      }

      paymentFeedback.classList.add('text-gray-500');
    };

    const confirmBtn = document.getElementById('confirm-payment-btn') as HTMLButtonElement | null;
    const confirmBtnLabel = document.getElementById('confirm-payment-label') as HTMLSpanElement | null;

    const setConfirmButtonState = (options: { disabled: boolean; label: string; busy?: boolean }) => {
      if (!confirmBtn || !confirmBtnLabel) return;

      confirmBtn.disabled = options.disabled;
      confirmBtn.setAttribute('aria-disabled', String(options.disabled));

      if (options.busy) {
        confirmBtn.setAttribute('aria-busy', 'true');
      } else {
        confirmBtn.removeAttribute('aria-busy');
      }

      confirmBtnLabel.innerHTML = options.busy
        ? '<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 animate-spin" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 12a8 8 0 018-8m0 0a8 8 0 018 8m-8-8v8" /></svg>' + options.label
        : '<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>' + options.label;
    };

    // ─── Tab switching logic ───────────────────────────────────────────────
    const tabs = document.querySelectorAll<HTMLButtonElement>('.payment-tab');
    const panels = document.querySelectorAll<HTMLDivElement>('.payment-panel');

    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        const targetId = tab.dataset.target;

        // Update tab states
        tabs.forEach(t => {
          const isActive = t === tab;
          t.setAttribute('aria-selected', String(isActive));
          if (isActive) {
            t.classList.add('active-tab', 'bg-guacamole-b', 'border-guacamole-b', 'text-white');
            t.classList.remove('bg-white', 'border-gray-200', 'text-guacamole-icons');
          } else {
            t.classList.remove('active-tab', 'bg-guacamole-b', 'border-guacamole-b', 'text-white');
            t.classList.add('bg-white', 'border-gray-200', 'text-guacamole-icons');
          }
        });

        // Update panel visibility
        panels.forEach(panel => {
          if (panel.id === targetId) {
            panel.classList.remove('hidden');
          } else {
            panel.classList.add('hidden');
          }
        });

        if (targetId && selectedMethodCopy) {
          selectedMethodCopy.textContent = paymentMethodDescriptions[targetId] ?? 'Elegí el medio que mejor te quede.';
        }
      });
    });

    // ─── Load customer data from sessionStorage ────────────────────────────
    const savedCustomerData = sessionStorage.getItem('guacamole-customer-data');
    const summaryContainer = document.getElementById('customer-summary');
    const orderDetailContainer = document.getElementById('order-summary-detail');
    const orderFallback = document.getElementById('order-summary-fallback');
    const summaryName = document.getElementById('summary-name');
    const summaryAddress = document.getElementById('summary-address');
    const summaryTotal = document.getElementById('summary-total');
    const summarySubtotal = document.getElementById('summary-subtotal');
    const summaryTax = document.getElementById('summary-tax');

    if (savedCustomerData) {
      try {
        const data = JSON.parse(savedCustomerData);

        // Show customer info
        if (summaryContainer && summaryName && summaryAddress && data.fullName) {
          summaryName.textContent = data.fullName;
          summaryAddress.textContent = [data.address, data.city].filter(Boolean).join(', ') || '';
          summaryContainer.classList.remove('hidden');
          setPaymentFeedback('Ya podés revisar el método de pago y avisarnos cuando lo completes.');
        }
      } catch (e) {
        // Silently ignore parse errors
      }
    }

    // Load cart total from sessionStorage (set by checkout page)
    const savedOrderTotal = sessionStorage.getItem('guacamole-order-total');
    if (savedOrderTotal) {
      try {
        const { subtotal, tax, total } = JSON.parse(savedOrderTotal);

        const fmt = (n: number) => new Intl.NumberFormat('es-CO', {
          style: 'currency',
          currency: 'COP',
          maximumFractionDigits: 0
        }).format(n);

        if (summarySubtotal) summarySubtotal.textContent = fmt(subtotal);
        if (summaryTax) summaryTax.textContent = fmt(tax);
        if (summaryTotal) summaryTotal.textContent = fmt(total);
        if (orderDetailContainer) orderDetailContainer.classList.remove('hidden');
        if (orderFallback) orderFallback.classList.add('hidden');
        setConfirmButtonState({ disabled: false, label: 'Ya hice el pago' });
        setPaymentFeedback('Resumen cargado. Cuando termines el pago, confirmalo desde acá.', 'success');
      } catch (e) {
        // Fallback stays visible
      }
    }

    // ─── Confirm Payment button ────────────────────────────────────────────
    const confirmModal = document.getElementById('confirm-modal');
    const modalBackdrop = document.getElementById('modal-backdrop');

    if (confirmBtn && confirmModal) {
      confirmBtn.addEventListener('click', () => {
        if (confirmBtn.disabled) {
          setPaymentFeedback('Primero completá checkout para traer el resumen y confirmar este pago.', 'error');
          return;
        }

        setConfirmButtonState({ disabled: true, label: 'Confirmando pago...', busy: true });
        setPaymentFeedback('Listo, registramos tu confirmación para revisar el comprobante.', 'success');

        // Clear session data
        sessionStorage.removeItem('guacamole-customer-data');
        sessionStorage.removeItem('guacamole-order-total');
        // Show confirmation modal
        confirmModal.classList.remove('hidden');
      });
    }

    if (modalBackdrop) {
      modalBackdrop.addEventListener('click', () => {
        confirmModal?.classList.add('hidden');
      });
    }
  });
</script>
