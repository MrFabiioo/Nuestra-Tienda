                    stroke-linejoin="round"
                    d="M19.5 8.25l-7.5 7.5-7.5-7.5"></path>
                </svg>
              </span>
            </summary>
            <div
              class="divide-y divide-gray-300 border-t border-gray-300 bg-white dark:divide-gray-600 dark:border-gray-600 dark:bg-gray-900"
            >
              <h1
                class="text-lg bg-guacamole-icons text-center font-semibold text-gray-700 dark:text-gray-200"
              >
                3502018487
              </h1>
            </div>
            
          </details>
          <button class="bg-guacamole-icons text-white font-bold py-2 px-4 rounded">
            <div class="flex items-center justify-center gap-2 active:translate-y-1 active:shadow-[0px_0px_0_0_#3E6102] transition-all">
              finalizar compra
            </div>
          </button>
          
        </div>
      </div>
    </div>
