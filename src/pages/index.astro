---
import Layout from "@layouts/Layout.astro";
import CardProducts from "@components/products/CardProducts.astro";
import SliderImageAutomatic from "@components/SliderImageAutomatic.astro";
import TrustBanner from "@components/TrustBanner.astro";
import ValueProposition from "@components/ValueProposition.astro";
import HowItWorks from "@components/HowItWorks.astro";
import { actions } from "astro:actions";

export const prerender = false;

const { data: featuredData } = await Astro.callAction(actions.getFeaturedProducts, {});
const featuredProducts = featuredData?.products ?? [];

const { data, error } = await Astro.callAction(actions.getProductsByCategory, {});

let productsByCategory: Array<{
    categoryName: string;
    products: Array<{
        id?: string;
        name: string;
        price: number;
        description: string;
        image: string;
        sizes?: string;
        slug: string;
        isEnabled?: boolean;
    }>;
}> = [];

if (error) {
    console.error('Error loading products:', error);
} else if (data?.productsByCategory) {
    // Map the data to match CardProducts expected format
    productsByCategory = data.productsByCategory.map((category: any) => ({
        categoryName: category.categoryName,
        products: category.products.map((product: any) => ({
            id: product.id,
            name: product.title,
            price: product.price,
            description: product.description,
            image: product.image,
            sizes: product.sizes,
            slug: `/products/${product.slug}`,
            isEnabled: product.isEnabled,
        }))
    }));
}
---

<Layout
    description="Nuestra Tienda online con catálogo fresco, compras ágiles y entregas coordinadas para disfrutar tus favoritos con facilidad."
>
    <!-- ═══════════════════════════════════════════════
         HERO SECTION — Editorial, premium, above the fold
         ═══════════════════════════════════════════════ -->
    <section class="hero" aria-label="Sección principal">
        <!-- Fondo decorativo: blob orgánico verde sutil -->
        <div class="hero__bg-blob" aria-hidden="true"></div>

        <div class="hero__inner">
            <!-- Eyebrow: label pequeño que ancla la marca -->
            <div class="hero__eyebrow">
                <span class="hero__eyebrow-dot" aria-hidden="true"></span>
                <span class="font-unique text-xs tracking-[0.2em] uppercase text-guacamole-b">Catálogo fresco · compra ágil</span>
            </div>

            <!-- Headline principal — editorial y directo -->
            <h1 class="hero__headline">
                Descubre sabores<br/>
                <em class="hero__headline-accent">hechos para compartir</em><br/>
                en cada pedido.
            </h1>

            <!-- Sub-headline: propuesta de valor concreta -->
            <p class="hero__sub">
                Explora el catálogo, encuentra tus favoritos y completa tu compra online en minutos.<br class="hero__sub-br" />
                Recetas frescas, combinaciones artesanales y una experiencia pensada para comprar con calma y confianza.
            </p>

            <!-- Trust badges: rápidos, sin ruido visual -->
            <ul class="hero__badges" aria-label="Por qué elegirnos">
                <li class="hero__badge">
                    <svg class="hero__badge-icon" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                        <path d="M10 2C6.13 2 3 5.13 3 9c0 2.72 1.52 5.08 3.75 6.35L10 18l3.25-2.65C15.48 14.08 17 11.72 17 9c0-3.87-3.13-7-7-7z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
                        <path d="M7 9l2 2 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                    Sin conservantes añadidos
                </li>
                <li class="hero__badge">
                    <svg class="hero__badge-icon" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                        <circle cx="10" cy="10" r="7" stroke="currentColor" stroke-width="1.5"/>
                        <path d="M10 6v4l2.5 2.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                    </svg>
                    Entrega coordinada el mismo día
                </li>
                <li class="hero__badge">
                    <svg class="hero__badge-icon" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                        <path d="M10 3l1.8 3.6 4 .6-2.9 2.8.7 4L10 12l-3.6 1.9.7-4L4.2 7.2l4-.6L10 3z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
                    </svg>
                    Preparado con ingredientes seleccionados
                </li>
            </ul>

            <!-- CTAs -->
            <div class="hero__ctas">
                <a href="/tienda" class="hero__cta-primary">
                    Ir a la tienda
                    <svg class="hero__cta-arrow" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                        <path d="M4 10h12M11 5l5 5-5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                </a>
                <a href="#catalogo" class="hero__cta-secondary">
                    Compra rápida
                </a>
            </div>
        </div>
    </section>

    <!-- Slider inmediatamente después del hero — prueba visual del producto -->
    <SliderImageAutomatic featuredProducts={featuredProducts} />

    <!-- Barra de señales de confianza — debajo del slider, antes del catálogo -->
    <TrustBanner />

    <!-- Catálogo de productos por categoría -->
    <section id="catalogo" aria-label="Catálogo destacado">
        {productsByCategory.length > 0 ? (
            productsByCategory.map((category) => (
                <CardProducts 
                    title={category.categoryName} 
                    products={category.products} 
                />
            ))
        ) : (
            <div class="theme-index-empty text-center py-10">
                <p class="text-xl">No hay productos disponibles en este momento.</p>
            </div>
        )}
    </section>

    <div class="hero-echo hero-echo--story">
        <div class="hero-echo__inner">
            <!-- Propuesta de valor + storytelling de marca -->
            <ValueProposition />

            <!-- Proceso de compra / conversión -->
            <HowItWorks />
        </div>
    </div>
</Layout>

<style>
.hero-echo {
    position: relative;
    margin-left: -1rem;
    margin-right: -1rem;
    padding: 1.25rem 1rem;
    overflow: hidden;
    isolation: isolate;
    border-radius: 0.75rem;
}

.hero-echo__inner {
    position: relative;
    z-index: 1;
}

.hero-echo::before,
.hero-echo::after {
    content: '';
    position: absolute;
    pointer-events: none;
}

.hero-echo::before {
    inset: 0;
    background:
        linear-gradient(180deg, color-mix(in srgb, var(--color-bg-alt) 92%, white 8%) 0%, color-mix(in srgb, var(--color-surface) 94%, transparent) 52%, color-mix(in srgb, var(--color-bg-alt) 92%, transparent) 100%),
        linear-gradient(135deg, color-mix(in srgb, var(--color-bg) 98%, var(--color-accent) 2%) 0%, color-mix(in srgb, var(--color-bg-alt) 98%, var(--color-accent) 2%) 100%);
}

.hero-echo::after {
    width: 30rem;
    height: 30rem;
    border-radius: 50%;
    background: radial-gradient(circle, color-mix(in srgb, var(--color-accent) 20%, transparent) 0%, color-mix(in srgb, var(--color-accent-strong) 10%, transparent) 45%, transparent 72%);
    filter: blur(10px);
    opacity: 0.8;
}

.hero-echo--trust {
    padding-top: 1rem;
    padding-bottom: 1.5rem;
}

.hero-echo--trust::after {
    top: -10rem;
    right: -8rem;
}

.hero-echo--story {
    padding-top: 2.25rem;
    padding-bottom: 2.75rem;
}

.hero-echo--story::after {
    bottom: -12rem;
    left: -8rem;
}

.hero-echo--story .hero-echo__inner {
    display: grid;
    gap: 0.5rem;
}

/* ─── Hero container ─────────────────────────────────── */
.hero {
    position: relative;
    /* Romper el max-width del main con márgenes negativos para el fondo */
    margin-left: -1rem;
    margin-right: -1rem;
    padding: 4rem 1rem 3.5rem;
    overflow: hidden;
    /* Fondo oscuro editorial — coherente con la navbar */
    background: var(--color-hero-bg);
    border-bottom: 1px solid var(--color-border-strong);
    border-radius: 0.75rem;;
}

/* Blob decorativo orgánico — da vida al fondo sin ser ruidoso */
.hero__bg-blob {
    position: absolute;
    top: -60px;
    right: -80px;
    width: 420px;
    height: 420px;
    border-radius: 60% 40% 70% 30% / 50% 60% 40% 50%;
    background: radial-gradient(
        ellipse at center,
        color-mix(in srgb, var(--color-accent) 22%, transparent) 0%,
        color-mix(in srgb, var(--color-accent-strong) 10%, transparent) 55%,
        transparent 75%
    );
    pointer-events: none;
}

/* ─── Inner layout ───────────────────────────────────── */
.hero__inner {
    max-width: 680px;
    display: flex;
    flex-direction: column;
    gap: 0;
}

/* ─── Eyebrow ────────────────────────────────────────── */
.hero__eyebrow {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1.25rem;
}

.hero__eyebrow-dot {
    display: inline-block;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--color-accent);
    box-shadow: 0 0 8px color-mix(in srgb, var(--color-accent) 60%, transparent);
    animation: hero-dot-pulse 2.5s ease-in-out infinite;
}

@keyframes hero-dot-pulse {
    0%, 100% { opacity: 1; box-shadow: 0 0 8px color-mix(in srgb, var(--color-accent) 60%, transparent); }
    50% { opacity: 0.6; box-shadow: 0 0 14px color-mix(in srgb, var(--color-accent) 28%, transparent); }
}

/* ─── Headline ───────────────────────────────────────── */
.hero__headline {
    font-size: clamp(2.25rem, 5.5vw, 3.75rem);
    font-weight: 800;
    line-height: 1.08;
    letter-spacing: -0.025em;
    color: var(--color-heading);
    margin-bottom: 1.25rem;
}

.hero__headline-accent {
    font-style: normal;
    color: var(--color-accent);
    position: relative;
    /* Subrayado decorativo sutil */
}

.hero__headline-accent::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: 2px;
    width: 100%;
    height: 3px;
    background: linear-gradient(90deg, var(--color-accent), color-mix(in srgb, var(--color-accent) 74%, #cdb902 26%));
    border-radius: 2px;
    opacity: 0.7;
}

/* ─── Sub-headline ───────────────────────────────────── */
.hero__sub {
    font-size: 1.0625rem;
    line-height: 1.65;
    color: var(--color-text-muted);
    margin-bottom: 1.75rem;
    max-width: 520px;
}

/* ─── Trust badges ───────────────────────────────────── */
.hero__badges {
    list-style: none;
    padding: 0;
    margin: 0 0 2rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.625rem;
}

.hero__badge {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.375rem 0.875rem;
    background: var(--color-surface-soft);
    border: 1px solid var(--color-border);
    border-radius: 999px;
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--color-text-muted);
    letter-spacing: 0.01em;
}

.hero__badge-icon {
    width: 14px;
    height: 14px;
    color: var(--color-accent);
    flex-shrink: 0;
}

/* ─── CTAs ───────────────────────────────────────────── */
.hero__ctas {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
}

/* CTA primario: dominante, sólido, con micro-animación */
.hero__cta-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.8125rem 1.75rem;
    background: linear-gradient(135deg, var(--color-accent) 0%, var(--color-accent-strong) 100%);
    color: var(--color-text-on-accent);
    font-size: 0.9375rem;
    font-weight: 700;
    letter-spacing: 0.015em;
    border-radius: 8px;
    text-decoration: none;
    transition: background 0.2s ease, box-shadow 0.2s ease, transform 0.15s ease;
    box-shadow: 0 8px 24px color-mix(in srgb, var(--color-accent) 28%, transparent);
}

.hero__cta-primary:hover {
    background: linear-gradient(135deg, var(--color-accent-strong) 0%, var(--color-accent) 100%);
    box-shadow: 0 12px 28px color-mix(in srgb, var(--color-accent-strong) 34%, transparent);
    transform: translateY(-1px);
}

.hero__cta-primary:active {
    transform: translateY(0);
    box-shadow: 0 4px 12px color-mix(in srgb, var(--color-accent-strong) 24%, transparent);
}

.hero__cta-arrow {
    width: 18px;
    height: 18px;
    transition: transform 0.2s ease;
}

.hero__cta-primary:hover .hero__cta-arrow {
    transform: translateX(3px);
}

/* CTA secundario: ghost, discreto pero visible */
.hero__cta-secondary {
    display: inline-flex;
    align-items: center;
    padding: 0.8125rem 1.5rem;
    background: transparent;
    color: var(--color-text-muted);
    font-size: 0.9375rem;
    font-weight: 600;
    letter-spacing: 0.01em;
    border-radius: 8px;
    border: 1px solid var(--color-border);
    text-decoration: none;
    transition: border-color 0.2s ease, color 0.2s ease, background 0.2s ease;
}

.hero__cta-secondary:hover {
    border-color: var(--color-border-strong);
    color: var(--color-accent);
    background: var(--color-surface-soft);
}

.theme-index-empty {
    color: var(--color-text-muted);
}

/* ─── Responsive ─────────────────────────────────────── */
@media (min-width: 768px) {
    .hero-echo {
        margin-left: -1rem;
        margin-right: -1rem;
        padding-left: 2.5rem;
        padding-right: 2.5rem;
    }

    .hero-echo--story {
        padding-top: 2.75rem;
        padding-bottom: 3.25rem;
    }

    .hero {
        padding: 5.5rem 2.5rem 4.5rem;
        margin-left: -1rem;
        margin-right: -1rem;
    }

    .hero__bg-blob {
        width: 560px;
        height: 560px;
        top: -100px;
        right: -60px;
    }
}

@media (min-width: 1200px) {
    /* A max-width el main ya tiene margen auto, ajustar el blob a la derecha */
    .hero__bg-blob {
        right: 5%;
    }
}

@media (max-width: 480px) {
    .hero-echo {
        padding-left: 1rem;
        padding-right: 1rem;
    }

    .hero-echo--trust::after {
        top: -12rem;
        right: -11rem;
    }

    .hero-echo--story::after {
        bottom: -14rem;
        left: -11rem;
    }

    .hero {
        padding: 3rem 1rem 2.75rem;
    }

    .hero__sub-br {
        display: none;
    }

    .hero__ctas {
        flex-direction: column;
        align-items: flex-start;
        gap: 0.75rem;
    }

    .hero__cta-primary,
    .hero__cta-secondary {
        width: 100%;
        justify-content: center;
    }
}
</style>
