---
import Layout from "@layouts/Layout.astro";
import CardProducts from "@components/products/CardProducts.astro";
import SliderImageAutomatic from "@components/SliderImageAutomatic.astro";
import { actions } from "astro:actions";

export const prerender = false;

const { data, error } = await Astro.callAction(actions.getProductsByCategory, {});

let productsByCategory: Array<{
    categoryName: string;
    products: Array<{
        name: string;
        price: number;
        description: string;
        image: string;
        slug: string;
    }>;
}> = [];

if (error) {
    console.error('Error loading products:', error);
} else if (data?.productsByCategory) {
    // Map the data to match CardProducts expected format
    productsByCategory = data.productsByCategory.map((category: any) => ({
        categoryName: category.categoryName,
        products: category.products.map((product: any) => ({
            name: product.title,
            price: product.price,
            description: product.description,
            // Only add /images/ prefix if image is NOT already an absolute URL
            image: product.image?.startsWith('http') ? product.image : `/images/${product.image}`,
            slug: `/products/${product.slug}`
        }))
    }));
}
---

<Layout>  
    <h1 class="text-4xl font-bold text-center mt-10">Bienvenido a Guacamole Shop</h1>
    <p class="text-center mt-4 text-lg">Tu tienda online de guacamole y productos relacionados.</p>  
    
    <SliderImageAutomatic />
    
    {productsByCategory.length > 0 ? (
        productsByCategory.map((category) => (
            <CardProducts 
                title={category.categoryName} 
                products={category.products} 
            />
        ))
    ) : (
        <div class="text-center py-10">
            <p class="text-xl text-gray-600">No hay productos disponibles en este momento.</p>
        </div>
    )}
</Layout>
