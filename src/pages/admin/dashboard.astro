---
import Layout from "@layouts/Layout.astro";

import { actions } from "astro:actions";
import Pagination from "@components/shared/Pagination.astro";
import { Formatter } from "@utils/formatter";
import ProductImage from "@components/products/ProductImage.astro";

export const prerender = false;
const url = Astro.url;
const pageParam = Number(url.searchParams.get("page") ?? 1);

const { data, error } = await Astro.callAction(actions.getProductsByPage, {
    page: pageParam,
});

if (error) {
    return Astro.redirect("/");
}

const { products, totalPages } = data;
---

<Layout title={`Dashboard`}>
    <h1 class="text-3xl text-center">Dashboard</h1>
    <p class="text-2xl text-center mt-10">Listado de productos</p>
    <div class="flex justify-end m-3">
        <a
            href="/admin/products/new-product"
            class="group relative inline-block focus:ring-3 focus:outline-hidden active:translate-y-1 active:shadow-[0px_0px_0_0_#3E6102] transition-all"
        >
            <span
                class="absolute inset-0 translate-x-1.5 translate-y-1.5 bg-guacamole-f transition-transform group-hover:translate-x-0 group-hover:translate-y-0"
            ></span>
            <span
                class="relative inline-block border-2 border-current px-8 py-3 text-sm font-bold tracking-widest text-black uppercase"
            >
                Nuevo producto
            </span>
        </a>
    </div>

    <table class="w-full mt-5 text-center">
        <thead>
            <tr>
                <th class="text-left">Imagen</th>
                <th class="text-center">Titulo</th>
                <th class="text-center">Precio</th>
                <th class="text-center">Tamaños </th>
            </tr>
        </thead>
        <tbody>
            {
                products.map((p) => (
                    <tr>
                        <td>
                            <ProductImage
                                src={p.images.split(",")[0]}
                                alt={p.title}
                                className={`w-20 h-20`}
                            />
                        </td>
                        <td>
                            <a
                                class="hover:underline cursor-pointer"
                                href={`/admin/products/${p.slug}`}
                            >
                                {p.title}
                            </a>
                        </td>
                        <td>{Formatter.currency(p.price)}</td>
                        <td>{p.sizes}</td>
                    </tr>
                ))
            }
        </tbody>
    </table>
    <Pagination pageParam={pageParam} totalPages={totalPages} />
</Layout>
