<div class="relative flex flex-col  h-full overflow-scroll text-gray-700 bg-white shadow-md rounded-lg bg-clip-border my-6 mx-6">
  <table class="w-full text-left table-auto min-w-max">
    <thead>
      <tr class="border-b border-slate-300 bg-slate-50">
        <th class="p-4 text-xl font-normal leading-none text-slate-500">Imagen</th>
        <th class="p-4 text-xl font-normal leading-none text-slate-500">Nombre</th>
        <th class="p-4 text-xl font-normal leading-none text-slate-500">Categoría</th>
        <th class="p-4 text-xl font-normal leading-none text-slate-500">Id</th>
        <th class="p-4 text-xl font-normal leading-none text-slate-500">Precio</th>
        <th class="p-4 text-xl font-normal leading-none text-slate-500">Descripción</th>
        <th class="p-4 text-xl font-normal leading-none text-slate-500"></th>
      </tr>
    </thead>
    <tbody>
      {
        products.map((p)=>(
            <tr class="hover:bg-slate-50">
            <td class="p-4 border-b border-slate-200 py-5">
              <ProductImage
                                src={p.images.split(",")[0]}
                                alt={p.title}
                                className={`w-20 h-20`}
                            />
            </td>
            <td class="p-4 border-b border-slate-200 py-5">
              <p class="block font-semibold text-lg text-slate-800">
                <a class="hover:underline cursor-pointer"
                   href={`/admin/products/${p.slug}`}>{p.title}
                </a>
              </p>
            </td>
            <td class="p-4 border-b border-slate-200 py-5">
              <p class="text-lg text-slate-500">{p.categoryName ?? '-'}</p>
            </td>
            <td class="p-4 border-b border-slate-200 py-5">
              <p class="text-lg text-slate-500">{p.id}</p>
            </td>
            <td class="p-4 border-b border-slate-200 py-5">
              <p class="text-lg text-slate-500">$ {p.price}</p>
            </td>
            <td class="p-4 border-b border-slate-200 py-5">
              <p class="text-lg text-slate-500">{p.description}</p>
            </td>
            <td class="p-4 border-b border-slate-200 py-5">
              <button type="button" class="text-slate-500 hover:text-slate-700">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-6 h-6">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                </svg>
              </button>
            </td>
          </tr>
        ))

          
      }
    </tbody>
  </table>
</div>
    <Pagination pageParam={pageParam} totalPages={totalPages} />
</Layout>
<style>
    #btn-nuevo-producto:hover,
    #btn-ver-categorias:hover {
        transform: scale(1.05);
    }
</style>