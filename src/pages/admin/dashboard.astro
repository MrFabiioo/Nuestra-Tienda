---
import Layout from "@layouts/Layout.astro";

import { actions } from "astro:actions";
import Pagination from "@components/shared/Pagination.astro";
import { Formatter } from "@utils/formatter";
import ProductImage from "@components/products/ProductImage.astro";

export const prerender = false;
const url = Astro.url;
const pageParam = Number(url.searchParams.get("page") ?? 1);

const { data, error } = await Astro.callAction(actions.getProductsByPage, {
    page: pageParam,
});

if (error) {
    return Astro.redirect("/");
}

const { products, totalPages } = data;
---

<Layout title={`Dashboard`}>
    <section class="px-2 py-8 sm:px-4 lg:px-6">
        <div class="premium-subtle-panel px-5 py-6 sm:px-7">
            <div class="flex flex-col gap-5 lg:flex-row lg:items-end lg:justify-between">
                <div class="max-w-3xl">
                    <span class="premium-chip">Admin · productos</span>
                    <h1 class="mt-4 text-3xl font-black tracking-tight theme-text-primary sm:text-4xl">Listado de productos</h1>
                    <p class="theme-text-muted mt-3 max-w-2xl text-sm leading-relaxed sm:text-base">
                        Vista editorial para revisar catálogo, precio, categoría y acceso rápido a edición con buena legibilidad en light y dark mode.
                    </p>
                </div>

                <div class="flex flex-col gap-3 sm:flex-row sm:flex-wrap sm:justify-end">
                    <a href="/admin/products/new-product" id="btn-nuevo-producto" class="premium-action-primary">
                        Nuevo producto
                    </a>

                    <a href="/admin/categories" id="btn-ver-categorias" class="premium-action-secondary">
                        Ver categorías
                    </a>
                </div>
            </div>

            <div class="mt-6 grid gap-3 sm:grid-cols-3">
                <div class="theme-soft-surface rounded-2xl border px-4 py-3">
                    <p class="admin-table-subcopy text-[0.72rem] font-bold uppercase tracking-[0.18em]">Productos visibles</p>
                    <p class="admin-table-title mt-2 text-2xl font-black">{products.length}</p>
                </div>

                <div class="theme-soft-surface rounded-2xl border px-4 py-3">
                    <p class="admin-table-subcopy text-[0.72rem] font-bold uppercase tracking-[0.18em]">Página actual</p>
                    <p class="admin-table-title mt-2 text-2xl font-black">{pageParam}</p>
                </div>

                <div class="theme-soft-surface rounded-2xl border px-4 py-3">
                    <p class="admin-table-subcopy text-[0.72rem] font-bold uppercase tracking-[0.18em]">Páginas totales</p>
                    <p class="admin-table-title mt-2 text-2xl font-black">{totalPages}</p>
                </div>
            </div>
        </div>

        <div class="mt-6">
            {products.length === 0 ? (
                <div class="admin-empty-state premium-panel">
                    <div class="admin-empty-state__icon">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor" class="h-7 w-7">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5m-16.5 0A2.25 2.25 0 016 4.5h12a2.25 2.25 0 012.25 2.25m-16.5 0v10.5A2.25 2.25 0 006 19.5h12a2.25 2.25 0 002.25-2.25V6.75m-10.5 4.5h4.5" />
                        </svg>
                    </div>

                    <h2 class="admin-table-title text-xl font-bold">Todavía no hay productos cargados</h2>
                    <p class="admin-table-copy mt-2 max-w-xl text-sm leading-relaxed sm:text-base">
                        Podés crear el primer producto para empezar a poblar el catálogo y después administrarlo desde esta misma tabla.
                    </p>

                    <a href="/admin/products/new-product" class="premium-action-primary mt-6">
                        Crear primer producto
                    </a>
                </div>
            ) : (
                <div class="admin-table-shell">
                    <div class="admin-table-scroll">
                        <table class="admin-table">
                            <thead>
                                <tr>
                                    <th>Imagen</th>
                                    <th>Producto</th>
                                    <th>Categoría</th>
                                    <th>Precio</th>
                                    <th class="hidden xl:table-cell">Descripción</th>
                                    <th class="text-right">Acción</th>
                                </tr>
                            </thead>

                            <tbody>
                                {products.map((p) => (
                                    <tr>
                                        <td>
                                            <div class="admin-table-thumbnail">
                                                <ProductImage
                                                    src={p.images.split(",")[0]}
                                                    alt={p.title}
                                                    className="h-full w-full object-cover"
                                                />
                                            </div>
                                        </td>

                                        <td>
                                            <div class="min-w-[15rem]">
                                                <a class="admin-table-link admin-table-title text-base font-bold sm:text-lg" href={`/admin/products/${p.slug}`}>
                                                    {p.title}
                                                </a>

                                                <div class="mt-2 flex flex-wrap items-center gap-2">
                                                    <span class="admin-table-badge admin-table-badge--accent">
                                                        {p.sizes?.split(',').length ?? 0} tamaños
                                                    </span>
                                                    <span class="admin-table-subcopy text-xs font-medium">
                                                        ID: <span class="font-semibold">{p.id}</span>
                                                    </span>
                                                </div>
                                            </div>
                                        </td>

                                        <td>
                                            <span class="admin-table-badge">
                                                {p.categoryName ?? 'Sin categoría'}
                                            </span>
                                        </td>

                                        <td>
                                            <div class="admin-table-title text-base font-bold sm:text-lg">{Formatter.currency(p.price)}</div>
                                            <p class="admin-table-subcopy mt-1 text-xs">Precio base del producto</p>
                                        </td>

                                        <td class="hidden xl:table-cell">
                                            <p class="admin-table-copy line-clamp-2 max-w-md text-sm leading-relaxed">
                                                {p.description || 'Sin descripción cargada.'}
                                            </p>
                                        </td>

                                        <td class="text-right">
                                            <a href={`/admin/products/${p.slug}`} class="admin-table-action">
                                                Editar
                                            </a>
                                        </td>
                                    </tr>
                                ))}
                            </tbody>
                        </table>
                    </div>
                </div>
            )}
        </div>

        <Pagination pageParam={pageParam} totalPages={totalPages} />
    </section>
</Layout>
