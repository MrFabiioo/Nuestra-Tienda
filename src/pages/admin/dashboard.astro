---
import Layout from "@layouts/Layout.astro";

import { actions } from "astro:actions";
import Pagination from "@components/shared/Pagination.astro";
import { Formatter } from "@utils/formatter";
import ProductImage from "@components/products/ProductImage.astro";

export const prerender = false;
const url = Astro.url;
const pageParam = Number(url.searchParams.get("page") ?? 1);

const { data, error } = await Astro.callAction(actions.getProductsByPage, {
    page: pageParam,
});

if (error) {
    return Astro.redirect("/");
}

const { products, totalPages } = data;
---

<Layout title={`Dashboard`}>
    <p class="text-2xl text-center mt-10 text-black-dark font-bold">Listado de productos</p>

    <div class="mx-6 flex gap-4">
        <a href="/admin/products/new-product"
        id="btn-nuevo-producto"
        class="text-black-medium border-black-dark border-2 bg-guacamole-pulpa px-4 py-2 transition">
        NUEVO PRODUCTO</a>
        
        <a href="/admin/categories"
        id="btn-ver-categorias"
        class="text-black-medium border-black-dark border-2 bg-guacamole-verde px-4 py-2 transition">
        VER CATEGORÍAS</a>
    </div>
    
        
