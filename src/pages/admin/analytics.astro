---
import Layout from '@layouts/Layout.astro';
import { actions } from 'astro:actions';
import AnalyticsPanel from '@components/admin/analytics/AnalyticsPanel.astro';
import AnalyticsMetricCard from '@components/admin/analytics/AnalyticsMetricCard.astro';

import { BUSINESS_TIMEZONE_LABEL } from '../../services/analytics/business-timezone';
import { buildAdminAnalyticsDashboardModel } from '../../services/analytics/admin-analytics-view-model';

export const prerender = false;

const adminUser = Astro.locals.user!;
const { data, error } = await Astro.callAction(actions.getAnalytics, undefined);

if (error || !data) {
  return Astro.redirect('/admin/dashboard');
}

const statusLabels: Record<string, string> = {
  pending_payment: 'Pendiente pago',
  under_review: 'En revisión',
  approved: 'Aprobado',
  rejected: 'Rechazado',
  cancelled: 'Cancelado',
};

function labelStatus(status: string) {
  return statusLabels[status] ?? status;
}

function withShare(items: Array<{ label: string; count: number }>) {
  const total = items.reduce((acc, item) => acc + item.count, 0);

  return items.map(item => ({
    ...item,
    share: total > 0 ? Math.round((item.count / total) * 100) : 0,
  }));
}

const labeledStatus = data.byStatus.map(item => ({ ...item, label: labelStatus(item.label) }));
const dashboardModel = buildAdminAnalyticsDashboardModel({ ...data, byStatus: labeledStatus });

const statusMix = withShare(labeledStatus);
const paymentMix = withShare(data.byPaymentMethod);
const deliveryMix = withShare(data.byDeliveryMethod);

const approvedShare = data.summary.totalOrders > 0
  ? Math.round((data.summary.approvedOrders / data.summary.totalOrders) * 100)
  : 0;

const pendingShare = data.summary.totalOrders > 0
  ? Math.round((data.summary.pendingOrders / data.summary.totalOrders) * 100)
  : 0;

const rejectedShare = data.summary.totalOrders > 0
  ? Math.round((data.summary.rejectedOrders / data.summary.totalOrders) * 100)
  : 0;

const executiveHighlights = [
  {
    label: 'Aprobación',
    value: `${approvedShare}%`,
    detail: `${data.summary.approvedOrders} de ${data.summary.totalOrders} pedidos`,
  },
  {
    label: 'Pendientes',
    value: `${data.summary.pendingOrders}`,
    detail: pendingShare > 0 ? `${pendingShare}% del pipeline` : 'Sin backlog actual',
  },
  {
    label: 'Rechazos',
    value: `${rejectedShare}%`,
    detail: `${data.summary.rejectedOrders} pedidos caídos`,
  },
];

const temporalWarnings = [
  `Las vistas por día, hora y evolución diaria siguen afectadas por el bug pendiente de timezone (${BUSINESS_TIMEZONE_LABEL}).`,
  'Tomalas como señal exploratoria; no sirven todavía para decisiones finas de staffing, cortes horarios o calendarización exacta.',
  'Las métricas de monto bruto e histórico NO equivalen a caja confirmada salvo que el pedido esté aprobado.',
];
---

<Layout title="Admin · Analytics">
  <section class="px-2 py-8 sm:px-4 lg:px-6">
    <div class="premium-subtle-panel analytics-hero px-5 py-6 sm:px-7">
      <div class="flex flex-col gap-5 lg:flex-row lg:items-end lg:justify-between">
        <div class="max-w-3xl">
          <div class="flex flex-wrap items-center gap-3">
            <span class="premium-chip">Admin · analytics</span>
            <span class="admin-chip text-xs">Resumen ejecutivo + pipeline + mix operativo</span>
            <span class="admin-chip admin-chip--warning text-xs">Patrones temporales referenciales</span>
          </div>

          <h1 class="mt-4 text-3xl font-black tracking-tight theme-text-primary sm:text-4xl">
            Analytics con lectura honesta del negocio
          </h1>

          <p class="theme-text-muted mt-3 max-w-2xl text-sm leading-relaxed sm:text-base">
            Primero separá demanda bruta, facturación confirmada y carga operativa. Después mirá productos, mix y recién al final los patrones temporales provisorios.
          </p>

          <p class="mt-2 text-xs text-gray-500">Sesión activa: {adminUser.email}</p>
        </div>

        <div class="flex flex-wrap gap-3">
          <a href="/admin/dashboard" class="premium-action-secondary">← Volver al dashboard</a>
          <a href="/admin/orders" class="premium-action-secondary">Ver pedidos</a>
        </div>
      </div>

      <div class="mt-6 grid gap-3 sm:grid-cols-2 xl:grid-cols-5">
        {dashboardModel.executiveMetrics.map(metric => (
          <AnalyticsMetricCard {...metric} />
        ))}
      </div>

      <div class="mt-6 grid gap-3 lg:grid-cols-3">
        {dashboardModel.executiveNarrative.map(item => (
          <article class:list={['analytics-story-card', `analytics-story-card--${item.tone}`]}>
            <p class="analytics-story-card__title">{item.title}</p>
            <p class="analytics-story-card__description">{item.description}</p>
          </article>
        ))}
      </div>
    </div>

    <div class="mt-6">
      <AnalyticsPanel
        eyebrow={dashboardModel.trend.eyebrow}
        title={dashboardModel.trend.title}
        description={dashboardModel.trend.description}
        icon="M2.25 18L9 11.25l4.306 4.307a11.95 11.95 0 015.814-5.519l2.74-1.22m0 0l-5.94-2.28m5.94 2.28l-2.28 5.941"
        tone="warning"
      >
        <div class="analytics-alert analytics-alert--warning" role="alert">
          <strong>Advertencia temporal:</strong>
          la serie diaria sigue siendo referencial por el bug pendiente de timezone. Úsala para contexto, no para cierre fino de operación.
        </div>

        <div class="mt-4 grid gap-3 md:grid-cols-3">
          {executiveHighlights.map(item => (
            <div class="analytics-mini-stat">
              <p class="analytics-mini-stat__label">{item.label}</p>
              <p class="analytics-mini-stat__value">{item.value}</p>
              <p class="analytics-mini-stat__detail">{item.detail}</p>
            </div>
          ))}
        </div>

        <div class="chart-wrap chart-wrap--tall mt-5">
          <canvas id="chart-trend" aria-label="Serie diaria de demanda bruta y pedidos"></canvas>
        </div>
      </AnalyticsPanel>
    </div>

    <div class="mt-6 grid gap-6 xl:grid-cols-3">
      <AnalyticsPanel
        eyebrow="Pipeline comercial"
        title={dashboardModel.mix.operationalCharts.status.title}
        description={dashboardModel.mix.operationalCharts.status.description}
        icon="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
      >
        {statusMix.length === 0 ? (
          <p class="analytics-empty">Todavía no hay pedidos para construir el pipeline.</p>
        ) : (
          <>
            <ul class="analytics-breakdown-list">
              {statusMix.map(item => (
                <li class="analytics-breakdown-item">
                  <div>
                    <p class="analytics-breakdown-item__label">{item.label}</p>
                    <p class="analytics-breakdown-item__sub">{item.count} pedidos · {item.share}% del total</p>
                  </div>
                  <span class="analytics-breakdown-item__value">{item.share}%</span>
                </li>
              ))}
            </ul>

            <div class="chart-wrap chart-wrap--medium mt-5">
              <canvas id="chart-status" aria-label="Pipeline por estado del pedido"></canvas>
            </div>
          </>
        )}
      </AnalyticsPanel>

      <AnalyticsPanel
        eyebrow="Productos · demanda"
        title={dashboardModel.productHighlights.byQty.title}
        description={dashboardModel.productHighlights.byQty.description}
        icon="M3 7h18M3 12h18M3 17h18"
      >
        {data.topByQty.length === 0 ? (
          <p class="analytics-empty">Sin historial suficiente para rankear productos todavía.</p>
        ) : (
          <div class="chart-wrap chart-wrap--medium">
            <canvas id="chart-top-qty" aria-label="Top productos por unidades demandadas"></canvas>
          </div>
        )}
      </AnalyticsPanel>

      <AnalyticsPanel
        eyebrow="Productos · valor histórico"
        title={dashboardModel.productHighlights.byRevenue.title}
        description={dashboardModel.productHighlights.byRevenue.description}
        icon="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
      >
        {data.topByRevenue.length === 0 ? (
          <p class="analytics-empty">Sin historial suficiente para medir valor histórico por producto.</p>
        ) : (
          <div class="chart-wrap chart-wrap--medium">
            <canvas id="chart-top-rev" aria-label="Top productos por monto bruto histórico"></canvas>
          </div>
        )}
      </AnalyticsPanel>
    </div>

    <div class="mt-6 grid gap-6 lg:grid-cols-2">
      <AnalyticsPanel
        eyebrow="Mix operativo"
        title={dashboardModel.mix.operationalCharts.payment.title}
        description={dashboardModel.mix.operationalCharts.payment.description}
        icon="M2.25 8.25h19.5M2.25 9h19.5m-16.5 5.25h6m-6 2.25h3m-3.75 3h15a2.25 2.25 0 002.25-2.25V6.75A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25v10.5A2.25 2.25 0 004.5 19.5z"
      >
        {paymentMix.length === 0 ? (
          <p class="analytics-empty">Todavía no hay pagos registrados para comparar métodos.</p>
        ) : (
          <>
            <ul class="analytics-inline-list">
              {paymentMix.map(item => <li>{item.label}: {item.share}%</li>)}
            </ul>

            <div class="chart-wrap chart-wrap--medium mt-4">
              <canvas id="chart-payment" aria-label="Comparación por método de pago"></canvas>
            </div>
          </>
        )}
      </AnalyticsPanel>

      <AnalyticsPanel
        eyebrow="Mix operativo"
        title={dashboardModel.mix.operationalCharts.delivery.title}
        description={dashboardModel.mix.operationalCharts.delivery.description}
        icon="M8.25 18.75a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 01-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 00-3.213-9.193 2.056 2.056 0 00-1.58-.86H14.25M16.5 18.75h-2.25m0-11.177v-.958c0-.568-.422-1.048-.987-1.106a48.554 48.554 0 00-10.026 0 1.106 1.106 0 00-.987 1.106v7.635m12-6.677v6.677m0 4.5v-4.5m0 0h-12"
      >
        {deliveryMix.length === 0 ? (
          <p class="analytics-empty">Todavía no hay entregas registradas para comparar logística.</p>
        ) : (
          <>
            <ul class="analytics-inline-list">
              {deliveryMix.map(item => <li>{item.label}: {item.share}%</li>)}
            </ul>

            <div class="chart-wrap chart-wrap--medium mt-4">
              <canvas id="chart-delivery" aria-label="Comparación por método de entrega"></canvas>
            </div>
          </>
        )}
      </AnalyticsPanel>
    </div>

    {data.neverOrdered.length > 0 && (
      <div class="mt-6">
        <AnalyticsPanel
          eyebrow="Acción de catálogo"
          title="Productos sin movimiento histórico"
          description="Este bloque sí es accionable hoy: revisar visibilidad, precio, copy o continuidad del producto."
          icon="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z"
          tone="warning"
          badge={data.neverOrdered.length}
        >
          <div class="admin-table-scroll">
            <table class="admin-table">
              <thead>
                <tr>
                  <th>Producto</th>
                  <th>Acción sugerida</th>
                  <th>Ir al detalle</th>
                </tr>
              </thead>
              <tbody>
                {data.neverOrdered.map(product => (
                  <tr>
                    <td>
                      <p class="font-semibold" style="color: var(--color-text);">{product.title}</p>
                      <p class="text-xs" style="color: var(--color-text-subtle);">Sin pedidos históricos registrados</p>
                    </td>
                    <td class="text-sm" style="color: var(--color-text-muted);">
                      Revisar posicionamiento, precio o continuidad en catálogo.
                    </td>
                    <td>
                      <a href={`/admin/products/${product.id}`} class="premium-action-secondary text-xs">Editar producto</a>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </AnalyticsPanel>
      </div>
    )}

    <div class="mt-6">
      <AnalyticsPanel
        eyebrow="Patrones temporales · lectura provisoria"
        title={dashboardModel.temporal.notice.title}
        description={dashboardModel.temporal.notice.description}
        icon="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 9v7.5"
        tone="warning"
      >
        <ul class="analytics-warning-list">
          {temporalWarnings.map(item => <li>{item}</li>)}
        </ul>

        <div class="mt-5 grid gap-6 lg:grid-cols-2">
          <div class="analytics-temporal-card">
            <p class="analytics-temporal-card__eyebrow">Provisorio · día de semana</p>
            <h3 class="analytics-temporal-card__title">{dashboardModel.temporal.byDayOfWeek.title}</h3>
            <p class="analytics-temporal-card__description">{dashboardModel.temporal.byDayOfWeek.description}</p>
            <div class="chart-wrap chart-wrap--small mt-4">
              <canvas id="chart-dow" aria-label="Pedidos por día de la semana"></canvas>
            </div>
          </div>

          <div class="analytics-temporal-card">
            <p class="analytics-temporal-card__eyebrow">Provisorio · hora</p>
            <h3 class="analytics-temporal-card__title">{dashboardModel.temporal.byHour.title}</h3>
            <p class="analytics-temporal-card__description">{dashboardModel.temporal.byHour.description}</p>
            <div class="chart-wrap chart-wrap--small mt-4">
              <canvas id="chart-hour" aria-label="Pedidos por hora del día"></canvas>
            </div>
          </div>
        </div>
      </AnalyticsPanel>
    </div>
  </section>
</Layout>

<script
  id="analytics-data"
  type="application/json"
  set:html={JSON.stringify({
    byDay: data.byDay,
    topByQty: data.topByQty,
    topByRevenue: data.topByRevenue,
    byDayOfWeek: data.byDayOfWeek,
    byHour: data.byHour,
    byStatus: labeledStatus,
    byPaymentMethod: data.byPaymentMethod,
    byDeliveryMethod: data.byDeliveryMethod,
  })}
/>

<style is:global>
  .analytics-hero {
    display: block;
  }

  .admin-chip--warning {
    background: color-mix(in srgb, #D97706 10%, var(--color-surface-soft));
    color: #B45309;
    border: 1px solid color-mix(in srgb, #D97706 18%, var(--color-border));
  }

  .analytics-metric-card {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    padding: 1rem 1.125rem;
    border-radius: 1.25rem;
    border: 1px solid var(--color-border);
    background: color-mix(in srgb, var(--color-surface-elevated) 94%, transparent);
  }

  .analytics-metric-card--accent {
    border-color: color-mix(in srgb, var(--color-accent) 30%, var(--color-border));
    background: color-mix(in srgb, var(--color-accent) 6%, var(--color-surface-elevated));
  }

  .analytics-metric-card--warning {
    border-color: color-mix(in srgb, #D97706 24%, var(--color-border));
    background: color-mix(in srgb, #D97706 5%, var(--color-surface-elevated));
  }

  .analytics-metric-card__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border-radius: 9999px;
    background: color-mix(in srgb, var(--color-accent) 12%, var(--color-surface-soft));
    color: var(--color-accent);
  }

  .analytics-metric-card__icon--warning {
    background: color-mix(in srgb, #D97706 12%, var(--color-surface-soft));
    color: #D97706;
  }

  .analytics-metric-card__label {
    font-size: 0.68rem;
    font-weight: 800;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-text-subtle);
  }

  .analytics-metric-card__value {
    font-size: 1.55rem;
    font-weight: 900;
    line-height: 1.1;
    color: var(--color-text);
  }

  .analytics-metric-card__sub {
    font-size: 0.76rem;
    line-height: 1.45;
    color: var(--color-text-subtle);
  }

  .analytics-story-card {
    padding: 1rem 1.125rem;
    border-radius: 1.25rem;
    border: 1px solid var(--color-border);
    background: color-mix(in srgb, var(--color-surface) 72%, transparent);
  }

  .analytics-story-card--accent {
    border-color: color-mix(in srgb, var(--color-accent) 24%, var(--color-border));
  }

  .analytics-story-card--warning {
    border-color: color-mix(in srgb, #D97706 24%, var(--color-border));
    background: color-mix(in srgb, #D97706 5%, var(--color-surface));
  }

  .analytics-story-card__title {
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-text-subtle);
  }

  .analytics-story-card__description {
    margin-top: 0.5rem;
    font-size: 0.92rem;
    line-height: 1.6;
    color: var(--color-text);
  }

  .analytics-panel {
    border: 1px solid var(--color-border);
    border-radius: 1.5rem;
    overflow: hidden;
    background: color-mix(in srgb, var(--color-surface-elevated) 92%, transparent);
  }

  .analytics-panel--warning {
    border-color: color-mix(in srgb, #D97706 22%, var(--color-border));
    background: color-mix(in srgb, #D97706 4%, var(--color-surface-elevated));
  }

  .analytics-panel__header {
    display: flex;
    align-items: flex-start;
    gap: 0.875rem;
    padding: 1rem 1.25rem;
    border-bottom: 1px solid var(--color-border);
    background: color-mix(in srgb, var(--color-surface) 60%, transparent);
  }

  .analytics-panel__heading {
    min-width: 0;
  }

  .analytics-panel__icon-wrap {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 9999px;
    background: color-mix(in srgb, var(--color-accent) 12%, var(--color-surface-soft));
    color: var(--color-accent);
  }

  .analytics-panel__icon-wrap--warning {
    background: color-mix(in srgb, #D97706 12%, var(--color-surface-soft));
    color: #D97706;
  }

  .analytics-panel__eyebrow {
    font-size: 0.65rem;
    font-weight: 800;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .analytics-panel__eyebrow--warning {
    color: #B45309;
  }

  .analytics-panel__title {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-top: 0.15rem;
    font-size: 1rem;
    font-weight: 800;
    color: var(--color-text);
  }

  .analytics-panel__description {
    margin-top: 0.35rem;
    font-size: 0.84rem;
    line-height: 1.55;
    color: var(--color-text-muted);
  }

  .analytics-panel__body {
    padding: 1.25rem;
  }

  .analytics-alert {
    padding: 0.9rem 1rem;
    border-radius: 1rem;
    border: 1px solid var(--color-border);
    font-size: 0.84rem;
    line-height: 1.55;
  }

  .analytics-alert--warning {
    border-color: color-mix(in srgb, #D97706 28%, var(--color-border));
    background: color-mix(in srgb, #D97706 7%, var(--color-surface-soft));
    color: var(--color-text);
  }

  .analytics-mini-stat {
    padding: 0.9rem 1rem;
    border-radius: 1rem;
    border: 1px solid var(--color-border);
    background: color-mix(in srgb, var(--color-surface) 74%, transparent);
  }

  .analytics-mini-stat__label {
    font-size: 0.68rem;
    font-weight: 800;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-text-subtle);
  }

  .analytics-mini-stat__value {
    margin-top: 0.35rem;
    font-size: 1.2rem;
    font-weight: 900;
    color: var(--color-text);
  }

  .analytics-mini-stat__detail {
    margin-top: 0.15rem;
    font-size: 0.76rem;
    color: var(--color-text-muted);
  }

  .analytics-breakdown-list {
    display: grid;
    gap: 0.75rem;
  }

  .analytics-breakdown-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.8rem 0.9rem;
    border-radius: 1rem;
    border: 1px solid var(--color-border);
    background: color-mix(in srgb, var(--color-surface) 76%, transparent);
  }

  .analytics-breakdown-item__label {
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--color-text);
  }

  .analytics-breakdown-item__sub {
    margin-top: 0.15rem;
    font-size: 0.76rem;
    color: var(--color-text-muted);
  }

  .analytics-breakdown-item__value {
    font-size: 0.9rem;
    font-weight: 800;
    color: var(--color-accent);
  }

  .analytics-inline-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .analytics-inline-list li {
    padding: 0.4rem 0.65rem;
    border-radius: 9999px;
    border: 1px solid var(--color-border);
    background: color-mix(in srgb, var(--color-surface) 76%, transparent);
    font-size: 0.76rem;
    color: var(--color-text-muted);
  }

  .analytics-warning-list {
    display: grid;
    gap: 0.75rem;
    margin: 0;
    padding-left: 1.1rem;
    color: var(--color-text);
    font-size: 0.88rem;
    line-height: 1.6;
  }

  .analytics-temporal-card {
    padding: 1rem;
    border-radius: 1.25rem;
    border: 1px dashed color-mix(in srgb, #D97706 30%, var(--color-border));
    background: color-mix(in srgb, var(--color-surface) 72%, transparent);
  }

  .analytics-temporal-card__eyebrow {
    font-size: 0.65rem;
    font-weight: 800;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #B45309;
  }

  .analytics-temporal-card__title {
    margin-top: 0.35rem;
    font-size: 0.95rem;
    font-weight: 800;
    color: var(--color-text);
  }

  .analytics-temporal-card__description {
    margin-top: 0.35rem;
    font-size: 0.82rem;
    line-height: 1.55;
    color: var(--color-text-muted);
  }

  .analytics-count-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 1.5rem;
    height: 1.5rem;
    padding: 0 0.4rem;
    border-radius: 9999px;
    font-size: 0.7rem;
    font-weight: 700;
    background: color-mix(in srgb, var(--color-accent) 14%, var(--color-surface-soft));
    color: var(--color-accent);
    border: 1px solid color-mix(in srgb, var(--color-accent) 22%, var(--color-border));
  }

  .analytics-count-badge--warning {
    background: color-mix(in srgb, #D97706 14%, var(--color-surface-soft));
    color: #D97706;
    border-color: color-mix(in srgb, #D97706 22%, var(--color-border));
  }

  .chart-wrap {
    position: relative;
    width: 100%;
    height: 260px;
  }

  .chart-wrap--tall {
    height: 320px;
  }

  .chart-wrap--medium {
    height: 280px;
  }

  .chart-wrap--small {
    height: 220px;
  }

  .analytics-empty {
    padding: 1.5rem 0;
    text-align: center;
    font-size: 0.9rem;
    color: var(--color-text-subtle);
  }

  :root[data-theme='dark'] .admin-chip--warning,
  :root[data-theme='dark'] .analytics-panel__eyebrow--warning,
  :root[data-theme='dark'] .analytics-temporal-card__eyebrow {
    color: #fbbf24;
  }

  :root[data-theme='dark'] .analytics-story-card__description,
  :root[data-theme='dark'] .analytics-metric-card__value,
  :root[data-theme='dark'] .analytics-panel__title,
  :root[data-theme='dark'] .analytics-mini-stat__value,
  :root[data-theme='dark'] .analytics-breakdown-item__label,
  :root[data-theme='dark'] .analytics-temporal-card__title {
    color: rgba(241, 243, 249, 0.96);
  }

  :root[data-theme='dark'] .analytics-story-card__title,
  :root[data-theme='dark'] .analytics-metric-card__label,
  :root[data-theme='dark'] .analytics-metric-card__sub,
  :root[data-theme='dark'] .analytics-panel__description,
  :root[data-theme='dark'] .analytics-mini-stat__detail,
  :root[data-theme='dark'] .analytics-breakdown-item__sub,
  :root[data-theme='dark'] .analytics-inline-list li,
  :root[data-theme='dark'] .analytics-empty,
  :root[data-theme='dark'] .analytics-temporal-card__description {
    color: rgba(241, 243, 249, 0.66);
  }
</style>

<script>
  import { Chart, registerables } from 'chart.js';

  Chart.register(...registerables);

  const raw = document.getElementById('analytics-data')?.textContent ?? '{}';
  const data = JSON.parse(raw) as {
    byDay: Array<{ date: string; orders: number; revenue: number }>;
    topByQty: Array<{ title: string; qty: number; revenue: number }>;
    topByRevenue: Array<{ title: string; revenue: number; qty: number }>;
    byDayOfWeek: Array<{ dayName: string; count: number }>;
    byHour: Array<{ hour: number; count: number }>;
    byStatus: Array<{ label: string; count: number }>;
    byPaymentMethod: Array<{ label: string; count: number }>;
    byDeliveryMethod: Array<{ label: string; count: number }>;
  };

  const isDark = document.documentElement.dataset.theme === 'dark';

  const C = {
    accent: isDark ? '#84a903' : '#6BA32A',
    accentSoft: isDark ? 'rgba(132,169,3,0.25)' : 'rgba(107,163,42,0.22)',
    accentStrong: isDark ? '#9BC53D' : '#4A7A1A',
    warning: '#F59E0B',
    warningSoft: 'rgba(245,158,11,0.24)',
    warningStrong: '#B45309',
    blue: '#0077BB',
    blueSoft: 'rgba(0,119,187,0.24)',
    teal: '#009988',
    tealSoft: 'rgba(0,153,136,0.24)',
    red: '#CC3311',
    redSoft: 'rgba(204,51,17,0.24)',
    magenta: '#EE3377',
    magentaSoft: 'rgba(238,51,119,0.24)',
    gray: '#BBBBBB',
    graySoft: 'rgba(187,187,187,0.24)',
    grid: isDark ? 'rgba(255,255,255,0.08)' : 'rgba(0,0,0,0.07)',
    text: isDark ? 'rgba(241,243,249,0.74)' : 'rgba(0,0,0,0.56)',
    textStrong: isDark ? 'rgba(241,243,249,0.94)' : 'rgba(0,0,0,0.76)',
  };

  Chart.defaults.font.family = 'Inter, system-ui, sans-serif';
  Chart.defaults.font.size = 12;
  Chart.defaults.color = C.text;

  const baseScale = {
    grid: { color: C.grid, drawBorder: false },
    ticks: { color: C.text },
  };

  const tooltip = {
    backgroundColor: isDark ? '#1a1a1a' : '#ffffff',
    borderColor: isDark ? 'rgba(255,255,255,0.12)' : 'rgba(0,0,0,0.10)',
    borderWidth: 1,
    titleColor: isDark ? '#f3f4f6' : '#111827',
    bodyColor: isDark ? '#9ca3af' : '#6b7280',
    padding: 10,
    cornerRadius: 10,
    displayColors: true,
    boxPadding: 4,
  };

  function currency(value: number | null | undefined) {
    return '$' + Number(value ?? 0).toLocaleString('es-VE', {
      minimumFractionDigits: 2,
      maximumFractionDigits: 2,
    });
  }

  function truncate(label: string, max = 26) {
    return label.length > max ? `${label.slice(0, max)}…` : label;
  }

  function getCtx(id: string) {
    const element = document.getElementById(id) as HTMLCanvasElement | null;
    return element?.getContext('2d') ?? null;
  }

  function buildBarColors(length: number, primary: string, soft: string) {
    return Array.from({ length }, (_, index) => (index === 0 ? primary : soft));
  }

  function createHorizontalBarChart(options: {
    id: string;
    labels: string[];
    values: number[];
    datasetLabel: string;
    primary: string;
    soft: string;
    tooltipLabel: (value: number, label: string) => string;
    valueFormatter?: (value: number) => string;
  }) {
    const ctx = getCtx(options.id);

    if (!ctx || options.values.length === 0) return;

    new Chart(ctx, {
      type: 'bar',
      data: {
        labels: options.labels.map(label => truncate(label)),
        datasets: [{
          label: options.datasetLabel,
          data: options.values,
          backgroundColor: buildBarColors(options.values.length, options.primary, options.soft),
          borderColor: buildBarColors(options.values.length, options.primary, options.primary),
          borderWidth: 1.5,
          borderRadius: 8,
          borderSkipped: false,
        }],
      },
      options: {
        indexAxis: 'y',
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: { display: false },
          tooltip: {
            ...tooltip,
            callbacks: {
              title: items => options.labels[items[0].dataIndex] ?? '',
              label: context => options.tooltipLabel(Number(context.parsed.x ?? 0), options.labels[context.dataIndex] ?? ''),
            },
          },
        },
        scales: {
          x: {
            ...baseScale,
            ticks: options.valueFormatter
              ? { ...baseScale.ticks, callback: value => options.valueFormatter?.(Number(value)) }
              : { ...baseScale.ticks, stepSize: 1 },
          },
          y: { ...baseScale },
        },
      },
    });
  }

  function createVerticalBarChart(options: {
    id: string;
    labels: string[];
    values: number[];
    datasetLabel: string;
    primary: string;
    soft: string;
  }) {
    const ctx = getCtx(options.id);

    if (!ctx) return;

    const maxValue = Math.max(...options.values, 1);

    new Chart(ctx, {
      type: 'bar',
      data: {
        labels: options.labels,
        datasets: [{
          label: options.datasetLabel,
          data: options.values,
          backgroundColor: options.values.map(value => value === maxValue ? options.primary : options.soft),
          borderColor: options.values.map(value => value === maxValue ? options.primary : options.primary),
          borderWidth: 1.2,
          borderRadius: 6,
          borderSkipped: false,
        }],
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: { display: false },
          tooltip: {
            ...tooltip,
            callbacks: {
              label: context => ` ${Number(context.parsed.y ?? 0)} pedido${Number(context.parsed.y ?? 0) === 1 ? '' : 's'}`,
            },
          },
        },
        scales: {
          x: { ...baseScale, ticks: { ...baseScale.ticks, maxRotation: 0, font: { size: 10 } } },
          y: { ...baseScale, ticks: { ...baseScale.ticks, stepSize: 1 } },
        },
      },
    });
  }

  const trendCtx = getCtx('chart-trend');

  if (trendCtx && data.byDay.length > 0) {
    const labels = data.byDay.map(item => {
      const [, month, day] = item.date.split('-');
      return `${day}/${month}`;
    });

    new Chart(trendCtx, {
      type: 'line',
      data: {
        labels,
        datasets: [
          {
            label: 'Monto bruto histórico',
            data: data.byDay.map(item => item.revenue),
            borderColor: C.accent,
            backgroundColor: C.accentSoft,
            borderWidth: 2.5,
            pointRadius: 2.5,
            pointHoverRadius: 5,
            pointBackgroundColor: C.accent,
            tension: 0.35,
            fill: true,
            yAxisID: 'yRevenue',
          },
          {
            label: 'Pedidos',
            data: data.byDay.map(item => item.orders),
            borderColor: C.warning,
            backgroundColor: C.warningSoft,
            borderWidth: 2,
            pointRadius: 2.5,
            pointHoverRadius: 5,
            pointBackgroundColor: C.warning,
            tension: 0.35,
            fill: false,
            yAxisID: 'yOrders',
          },
        ],
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        interaction: { mode: 'index', intersect: false },
        plugins: {
          legend: { labels: { color: C.textStrong, boxWidth: 12, padding: 16 } },
          tooltip: {
            ...tooltip,
            callbacks: {
              label: context => context.datasetIndex === 0
                ? ` Monto bruto: ${currency(Number(context.parsed.y ?? 0))}`
                : ` Pedidos: ${Number(context.parsed.y ?? 0)}`,
            },
          },
        },
        scales: {
          x: { ...baseScale, ticks: { ...baseScale.ticks, maxRotation: 45, maxTicksLimit: 15 } },
          yRevenue: {
            ...baseScale,
            position: 'left',
            ticks: { ...baseScale.ticks, callback: value => currency(Number(value)) },
          },
          yOrders: {
            ...baseScale,
            position: 'right',
            grid: { drawOnChartArea: false },
            ticks: { ...baseScale.ticks, stepSize: 1 },
          },
        },
      },
    });
  }

  createHorizontalBarChart({
    id: 'chart-status',
    labels: data.byStatus.map(item => item.label),
    values: data.byStatus.map(item => item.count),
    datasetLabel: 'Pedidos',
    primary: C.accentStrong,
    soft: C.accentSoft,
    tooltipLabel: (value, label) => ` ${label}: ${value} pedido${value === 1 ? '' : 's'}`,
  });

  createHorizontalBarChart({
    id: 'chart-top-qty',
    labels: data.topByQty.map(item => item.title),
    values: data.topByQty.map(item => item.qty),
    datasetLabel: 'Unidades demandadas',
    primary: C.blue,
    soft: C.blueSoft,
    tooltipLabel: (value, label) => ` ${label}: ${value} unidad${value === 1 ? '' : 'es'}`,
  });

  createHorizontalBarChart({
    id: 'chart-top-rev',
    labels: data.topByRevenue.map(item => item.title),
    values: data.topByRevenue.map(item => item.revenue),
    datasetLabel: 'Monto bruto',
    primary: C.teal,
    soft: C.tealSoft,
    tooltipLabel: (value, label) => ` ${label}: ${currency(value)}`,
    valueFormatter: value => currency(value),
  });

  createHorizontalBarChart({
    id: 'chart-payment',
    labels: data.byPaymentMethod.map(item => item.label),
    values: data.byPaymentMethod.map(item => item.count),
    datasetLabel: 'Pedidos',
    primary: C.blue,
    soft: C.blueSoft,
    tooltipLabel: (value, label) => ` ${label}: ${value} pedido${value === 1 ? '' : 's'}`,
  });

  createHorizontalBarChart({
    id: 'chart-delivery',
    labels: data.byDeliveryMethod.map(item => item.label),
    values: data.byDeliveryMethod.map(item => item.count),
    datasetLabel: 'Pedidos',
    primary: C.magenta,
    soft: C.magentaSoft,
    tooltipLabel: (value, label) => ` ${label}: ${value} pedido${value === 1 ? '' : 's'}`,
  });

  createVerticalBarChart({
    id: 'chart-dow',
    labels: data.byDayOfWeek.map(item => item.dayName.slice(0, 3)),
    values: data.byDayOfWeek.map(item => item.count),
    datasetLabel: 'Pedidos',
    primary: C.warning,
    soft: C.warningSoft,
  });

  createVerticalBarChart({
    id: 'chart-hour',
    labels: data.byHour.map(item => `${item.hour.toString().padStart(2, '0')}h`),
    values: data.byHour.map(item => item.count),
    datasetLabel: 'Pedidos',
    primary: C.red,
    soft: C.redSoft,
  });
</script>
