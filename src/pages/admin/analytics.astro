<script>
  document.addEventListener('astro:page-load', () => {
    const fromInput  = document.getElementById('export-from') as HTMLInputElement | null;
    const toInput    = document.getElementById('export-to')   as HTMLInputElement | null;
    const exportBtn  = document.getElementById('export-btn')  as HTMLButtonElement | null;
    const presetBtns = document.querySelectorAll<HTMLButtonElement>('[data-preset]');

    if (!fromInput || !toInput) return;

    // ── Highlight active preset based on current URL params ───────────
    const urlFrom = new URLSearchParams(window.location.search).get('from');
    const urlTo   = new URLSearchParams(window.location.search).get('to');

    function toDateStr(d: Date): string {
      return d.toISOString().slice(0, 10);
    }

    function getMondayOf(d: Date): Date {
      const day  = d.getDay();
      const diff = day === 0 ? -6 : 1 - day;
      const monday = new Date(d);
      monday.setDate(d.getDate() + diff);
      monday.setHours(0, 0, 0, 0);
      return monday;
    }

    function computePreset(preset: string): { from: string; to: string; label: string } | null {
      const now = new Date();
      let from: Date, to: Date, label: string;

      switch (preset) {
        case 'this-week': {
          from  = getMondayOf(now);
          to    = new Date(now); to.setHours(0, 0, 0, 0);
          label = `semana-${toDateStr(from)}`;
          break;
        }
        case 'last-week': {
          const thisMonday = getMondayOf(now);
          from  = new Date(thisMonday); from.setDate(thisMonday.getDate() - 7);
          to    = new Date(thisMonday); to.setDate(thisMonday.getDate() - 1);
          label = `semana-${toDateStr(from)}`;
          break;
        }
        case 'this-month': {
          from  = new Date(now.getFullYear(), now.getMonth(), 1);
          to    = new Date(now); to.setHours(0, 0, 0, 0);
          label = `mes-${now.getFullYear()}-${String(now.getMonth() + 1).padStart(2, '0')}`;
          break;
        }
        case 'last-month': {
          const lm = new Date(now.getFullYear(), now.getMonth() - 1, 1);
          from  = lm;
          to    = new Date(now.getFullYear(), now.getMonth(), 0);
          label = `mes-${lm.getFullYear()}-${String(lm.getMonth() + 1).padStart(2, '0')}`;
          break;
        }
        default: return null;
      }

      return { from: toDateStr(from), to: toDateStr(to), label };
    }

    // Highlight preset that matches current URL filter
    presetBtns.forEach(btn => {
      const result = computePreset(btn.dataset.preset ?? '');
      if (result && result.from === urlFrom && result.to === urlTo) {
        btn.classList.add('export-preset--active');
      }
    });

    // ── Preset click → fill inputs ────────────────────────────────────
    presetBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const result = computePreset(btn.dataset.preset ?? '');
        if (!result) return;

        fromInput.value = result.from;
        toInput.value   = result.to;

        presetBtns.forEach(p => p.classList.remove('export-preset--active'));
        btn.classList.add('export-preset--active');
      });
    });

    // ── Export button → download Excel with current inputs ────────────
    exportBtn?.addEventListener('click', () => {
      const from = fromInput.value;
      const to   = toInput.value;

      if (!from || !to) {
        fromInput.reportValidity();
        return;
      }

      if (from > to) {
        alert('"Desde" debe ser anterior a "Hasta"');
        return;
      }

      const label = `${from}_${to}`;
      window.location.href = `/admin/analytics-export?from=${encodeURIComponent(from)}&to=${encodeURIComponent(to)}&label=${encodeURIComponent(label)}`;
    });
  });
</script>
