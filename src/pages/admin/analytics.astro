---
import Layout from '@layouts/Layout.astro';
import AnalyticsPanel from '@components/admin/analytics/AnalyticsPanel.astro';
import AnalyticsMetricCard from '@components/admin/analytics/AnalyticsMetricCard.astro';

import { buildAdminAnalyticsStaticCopy } from '../../services/analytics/admin-analytics-copy';
import { buildAdminAnalyticsSectionsLayout } from '../../services/analytics/admin-analytics-sections';
import { buildAdminAnalyticsDashboardModel } from '../../services/analytics/admin-analytics-view-model';
import { getAnalyticsData } from '../../services/analytics/repository';
import { businessDateToUTC } from '../../services/analytics/business-timezone';
import { Formatter } from '@utils/formatter';

export const prerender = false;

const adminUser = Astro.locals.user!;

// ── Date range filter ──────────────────────────────────────────────────────
const fromParam = Astro.url.searchParams.get('from');
const toParam   = Astro.url.searchParams.get('to');
const isValidDate = (s: string | null): s is string => !!s && /^\d{4}-\d{2}-\d{2}$/.test(s);
const isFiltered  = isValidDate(fromParam) && isValidDate(toParam) && fromParam! < toParam!;

const range = isFiltered
  ? { from: businessDateToUTC(fromParam!, false), to: businessDateToUTC(toParam!, true) }
  : undefined;

let data: Awaited<ReturnType<typeof getAnalyticsData>>;
try {
  data = await getAnalyticsData(range);
} catch {
  return Astro.redirect('/admin/dashboard');
}

const statusLabels: Record<string, string> = {
  pending_payment: 'Pendiente pago',
  under_review: 'En revisión',
  approved: 'Aprobado',
  rejected: 'Rechazado',
  cancelled: 'Cancelado',
};

function labelStatus(status: string) {
  return statusLabels[status] ?? status;
}

function withShare(items: Array<{ label: string; count: number }>) {
  const total = items.reduce((acc, item) => acc + item.count, 0);

  return items.map(item => ({
    ...item,
    share: total > 0 ? Math.round((item.count / total) * 100) : 0,
  }));
}

const labeledStatus = data.byStatus.map(item => ({ ...item, label: labelStatus(item.label) }));
const dashboardModel = buildAdminAnalyticsDashboardModel({ ...data, byStatus: labeledStatus });
const staticCopy = buildAdminAnalyticsStaticCopy();
const sectionsLayout = buildAdminAnalyticsSectionsLayout();

const statusMix = withShare(labeledStatus);
const paymentMix = withShare(data.byPaymentMethod);

const profitTotal = data.topByEstimatedProfit.reduce((sum, item) => sum + item.estimatedProfit, 0);
const profitMix = data.topByEstimatedProfit.map(item => ({
  ...item,
  share: profitTotal > 0 ? Math.round((item.estimatedProfit / profitTotal) * 100) : 0,
}));

const approvedShare = data.summary.totalOrders > 0
  ? Math.round((data.summary.approvedOrders / data.summary.totalOrders) * 100)
  : 0;

const pendingShare = data.summary.totalOrders > 0
  ? Math.round((data.summary.pendingOrders / data.summary.totalOrders) * 100)
  : 0;

const rejectedShare = data.summary.totalOrders > 0
  ? Math.round((data.summary.rejectedOrders / data.summary.totalOrders) * 100)
  : 0;

const executiveHighlights = [
  {
    label: 'Aprobación',
    value: `${approvedShare}%`,
    detail: `${data.summary.approvedOrders} de ${data.summary.totalOrders} pedidos`,
  },
  {
    label: 'Pendientes',
    value: `${data.summary.pendingOrders}`,
    detail: pendingShare > 0 ? `${pendingShare}% del pipeline` : 'Sin backlog actual',
  },
  {
    label: 'Rechazos',
    value: `${rejectedShare}%`,
    detail: `${data.summary.rejectedOrders} pedidos caídos`,
  },
];

const temporalWarnings = staticCopy.temporalWarnings;
---

<Layout title="Admin · Analytics">
  <section class="px-2 py-8 sm:px-4 lg:px-6">
    <div class="premium-subtle-panel analytics-hero px-5 py-6 sm:px-7">
      <div class="flex flex-col gap-5 lg:flex-row lg:items-end lg:justify-between">
        <div class="max-w-3xl">
          <div class="flex flex-wrap items-center gap-3">
            <span class="premium-chip">Admin · analytics</span>
            <span class="admin-chip text-xs">{staticCopy.hero.badges.context}</span>
            {isFiltered && (
              <span class="period-active-chip">
                {fromParam} → {toParam}
                <a href="/admin/analytics" class="period-active-chip__clear" title="Limpiar filtro">✕</a>
              </span>
            )}
          </div>

          <h1 class="mt-4 text-3xl font-black tracking-tight theme-text-primary sm:text-4xl">
            {staticCopy.hero.title}
          </h1>

          <p class="theme-text-muted mt-3 max-w-2xl text-sm leading-relaxed sm:text-base">
            {isFiltered
              ? `Mostrando datos del ${fromParam} al ${toParam}. Todos los gráficos y métricas reflejan solo ese período.`
              : staticCopy.hero.description
            }
          </p>

          <p class="mt-2 text-xs text-gray-500">Sesión activa: {adminUser.email}</p>
        </div>

        <div class="flex flex-wrap gap-3">
          <a href="/admin/dashboard" class="premium-action-secondary">← Volver al dashboard</a>
          <a href="/admin/orders" class="premium-action-secondary">Ver pedidos</a>
        </div>
      </div>

      <!-- Period filter + export widget -->
      <div class="export-widget mt-6 border-t pt-5" style="border-color: var(--color-border);">
        <p class="export-eyebrow">Filtrar por período</p>
        <p class="export-hint mt-1">Elige un rango para ver métricas y gráficos de ese período exacto, o exportarlo a Excel.</p>

        <form id="filter-form" action="/admin/analytics" method="get" class="mt-3 flex flex-wrap items-end gap-3">
          <!-- Presets -->
          <div class="flex flex-wrap gap-2">
            <button type="button" class="export-preset" data-preset="this-week">Esta semana</button>
            <button type="button" class="export-preset" data-preset="last-week">Semana pasada</button>
            <button type="button" class="export-preset" data-preset="this-month">Este mes</button>
            <button type="button" class="export-preset" data-preset="last-month">Mes pasado</button>
          </div>

          <!-- Date inputs -->
          <div class="flex flex-wrap items-end gap-2">
            <div class="export-field">
              <label for="export-from" class="export-label">Desde</label>
              <input type="date" id="export-from" name="from" class="export-date-input"
                value={fromParam ?? ''} required />
            </div>
            <div class="export-field">
              <label for="export-to" class="export-label">Hasta</label>
              <input type="date" id="export-to" name="to" class="export-date-input"
                value={toParam ?? ''} required />
            </div>
          </div>

          <!-- Actions -->
          <div class="flex flex-wrap items-center gap-2">
            <button type="submit" class="filter-submit">
              <svg class="h-4 w-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2a1 1 0 01-.293.707L13 13.414V19a1 1 0 01-.553.894l-4 2A1 1 0 017 21v-7.586L3.293 6.707A1 1 0 013 6V4z" />
              </svg>
              Aplicar filtro
            </button>

            <button type="button" id="export-btn" class="export-submit">
              <svg class="h-4 w-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
              </svg>
              Exportar Excel
            </button>

            {isFiltered && (
              <a href="/admin/analytics" class="clear-filter-link">Limpiar filtro</a>
            )}
          </div>
        </form>
      </div>

      <div class="mt-6 grid gap-3 sm:grid-cols-2 xl:grid-cols-5">
        {dashboardModel.executiveMetrics.map(metric => (
          <AnalyticsMetricCard {...metric} />
        ))}
      </div>

      <div class="mt-6 grid gap-3 lg:grid-cols-3">
        {dashboardModel.executiveNarrative.map(item => (
          <article class:list={['analytics-story-card', `analytics-story-card--${item.tone}`]}>
            <p class="analytics-story-card__title">{item.title}</p>
            <p class="analytics-story-card__description">{item.description}</p>
          </article>
        ))}
      </div>
    </div>

    <div class="mt-6">
      <AnalyticsPanel
        eyebrow={dashboardModel.trend.eyebrow}
        title={dashboardModel.trend.title}
        description={dashboardModel.trend.description}
        icon="M2.25 18L9 11.25l4.306 4.307a11.95 11.95 0 015.814-5.519l2.74-1.22m0 0l-5.94-2.28m5.94 2.28l-2.28 5.941"
        tone="warning"
      >
        <div class="analytics-alert analytics-alert--warning" role="alert">
          <strong>{staticCopy.trendAlert.title}:</strong>
          {staticCopy.trendAlert.description}
        </div>

        <div class="mt-4 grid gap-3 md:grid-cols-3">
          {executiveHighlights.map(item => (
            <div class="analytics-mini-stat">
              <p class="analytics-mini-stat__label">{item.label}</p>
              <p class="analytics-mini-stat__value">{item.value}</p>
              <p class="analytics-mini-stat__detail">{item.detail}</p>
            </div>
          ))}
        </div>

        <div class="chart-wrap chart-wrap--tall mt-5">
          <canvas id="chart-trend" aria-label="Serie diaria de demanda bruta y pedidos"></canvas>
        </div>
      </AnalyticsPanel>
    </div>

    <div class:list={['mt-6', 'grid', 'gap-6', sectionsLayout.productGridClass]}>
      {sectionsLayout.productPanels.includes('status') && (
        <AnalyticsPanel
          eyebrow="Pipeline comercial"
          title={dashboardModel.mix.operationalCharts.status.title}
          description={dashboardModel.mix.operationalCharts.status.description}
          icon="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
        >
          {statusMix.length === 0 ? (
            <p class="analytics-empty">Todavía no hay pedidos para construir el pipeline.</p>
          ) : (
            <>
              <ul class="analytics-breakdown-list">
                {statusMix.map(item => (
                  <li class="analytics-breakdown-item">
                    <div>
                      <p class="analytics-breakdown-item__label">{item.label}</p>
                      <p class="analytics-breakdown-item__sub">{item.count} pedidos · {item.share}% del total</p>
                    </div>
                    <span class="analytics-breakdown-item__value">{item.share}%</span>
                  </li>
                ))}
              </ul>

              <div class="chart-wrap chart-wrap--medium mt-5">
                <canvas id="chart-status" aria-label="Pipeline por estado del pedido"></canvas>
              </div>
            </>
          )}
        </AnalyticsPanel>
      )}

      {sectionsLayout.productPanels.includes('topByQty') && (
        <AnalyticsPanel
          eyebrow="Productos · demanda"
          title={dashboardModel.productHighlights.byQty.title}
          description={dashboardModel.productHighlights.byQty.description}
          icon="M3 7h18M3 12h18M3 17h18"
        >
          {data.topByQty.length === 0 ? (
            <p class="analytics-empty">Sin historial suficiente para rankear productos todavía.</p>
          ) : (
            <div class="chart-wrap chart-wrap--medium">
              <canvas id="chart-top-qty" aria-label="Top productos por unidades demandadas"></canvas>
            </div>
          )}
        </AnalyticsPanel>
      )}

      {sectionsLayout.productPanels.includes('topByRevenue') && (
        <AnalyticsPanel
          eyebrow="Productos · valor histórico"
          title={dashboardModel.productHighlights.byRevenue.title}
          description={dashboardModel.productHighlights.byRevenue.description}
          icon="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
        >
          {data.topByRevenue.length === 0 ? (
            <p class="analytics-empty">Sin historial suficiente para medir valor histórico por producto.</p>
          ) : (
            <div class="chart-wrap chart-wrap--medium">
              <canvas id="chart-top-rev" aria-label="Top productos por monto bruto histórico"></canvas>
            </div>
          )}
        </AnalyticsPanel>
      )}
    </div>

    <div class:list={['mt-6', 'grid', 'gap-6', sectionsLayout.mixGridClass]}>
      {sectionsLayout.mixPanels.includes('payment') && (
        <AnalyticsPanel
          eyebrow="Mix operativo"
          title={dashboardModel.mix.operationalCharts.payment.title}
          description={dashboardModel.mix.operationalCharts.payment.description}
          icon="M2.25 8.25h19.5M2.25 9h19.5m-16.5 5.25h6m-6 2.25h3m-3.75 3h15a2.25 2.25 0 002.25-2.25V6.75A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25v10.5A2.25 2.25 0 004.5 19.5z"
        >
          {paymentMix.length === 0 ? (
            <p class="analytics-empty">Todavía no hay pagos registrados para comparar métodos.</p>
          ) : (
            <>
              <ul class="analytics-inline-list">
                {paymentMix.map(item => <li>{item.label}: {item.share}%</li>)}
              </ul>

              <div class="chart-wrap chart-wrap--medium mt-4">
                <canvas id="chart-payment" aria-label="Comparación por método de pago"></canvas>
              </div>
            </>
          )}
        </AnalyticsPanel>
      )}

      {sectionsLayout.mixPanels.includes('estimatedProfit') && (
        <AnalyticsPanel
          eyebrow="Productos · rentabilidad estimada"
          title={dashboardModel.productHighlights.byEstimatedProfit.title}
          icon="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
        >
          {data.topByEstimatedProfit.length === 0 ? (
            <p class="analytics-empty">Todavía no hay productos con costo estimable y pedidos aprobados para rankear rentabilidad.</p>
          ) : (
            <>
              <ul class="analytics-breakdown-list analytics-breakdown-list--compact">
                {profitMix.map(item => (
                  <li class="analytics-breakdown-item analytics-breakdown-item--sm">
                    <div>
                      <p class="analytics-breakdown-item__label">{item.title}</p>
                      <p class="analytics-breakdown-item__sub">{item.qty} unid. · {item.share}% del total</p>
                    </div>
                    <span class="analytics-breakdown-item__value">{Formatter.currency(item.estimatedProfit, 0)}</span>
                  </li>
                ))}
                <li class="analytics-breakdown-item analytics-breakdown-item--sm analytics-breakdown-item--total">
                  <div>
                    <p class="analytics-breakdown-item__label">Ganancia total estimada</p>
                    <p class="analytics-breakdown-item__sub">{profitMix.length} producto{profitMix.length === 1 ? '' : 's'} rankeados</p>
                  </div>
                  <span class="analytics-breakdown-item__value">{Formatter.currency(profitTotal, 0)}</span>
                </li>
              </ul>

              <div class="chart-wrap chart-wrap--medium">
                <canvas id="chart-top-profit" aria-label="Top productos por ganancia estimada"></canvas>
              </div>
            </>
          )}
        </AnalyticsPanel>
      )}
    </div>

    {data.neverOrdered.length > 0 && (
      <div class="mt-6">
        <AnalyticsPanel
          eyebrow="Acción de catálogo"
          title="Productos sin movimiento histórico"
          description="Este bloque sí es accionable hoy: revisar visibilidad, precio, copy o continuidad del producto."
          icon="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z"
          tone="warning"
          badge={data.neverOrdered.length}
        >
          <div class="admin-table-scroll">
            <table class="admin-table">
              <thead>
                <tr>
                  <th>Producto</th>
                  <th>Acción sugerida</th>
                  <th>Ir al detalle</th>
                </tr>
              </thead>
              <tbody>
                {data.neverOrdered.map(product => (
                  <tr>
                    <td>
                      <p class="font-semibold" style="color: var(--color-text);">{product.title}</p>
                      <p class="text-xs" style="color: var(--color-text-subtle);">Sin pedidos históricos registrados</p>
                    </td>
                    <td class="text-sm" style="color: var(--color-text-muted);">
                      Revisar posicionamiento, precio o continuidad en catálogo.
                    </td>
                    <td>
                      <a href={`/admin/products/${product.id}`} class="premium-action-secondary text-xs">Editar producto</a>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </AnalyticsPanel>
      </div>
    )}

    <div class="mt-6">
      <AnalyticsPanel
        eyebrow={staticCopy.temporalSectionEyebrow}
        title={dashboardModel.temporal.notice.title}
        description={dashboardModel.temporal.notice.description}
        icon="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 9v7.5"
        tone="warning"
      >
        <ul class="analytics-warning-list">
          {temporalWarnings.map(item => <li>{item}</li>)}
        </ul>

        <div class="mt-5 grid gap-6 lg:grid-cols-2">
          <div class="analytics-temporal-card">
            <p class="analytics-temporal-card__eyebrow">{staticCopy.temporalCards.byDayOfWeekEyebrow}</p>
            <h3 class="analytics-temporal-card__title">{dashboardModel.temporal.byDayOfWeek.title}</h3>
            <p class="analytics-temporal-card__description">{dashboardModel.temporal.byDayOfWeek.description}</p>
            <div class="chart-wrap chart-wrap--small mt-4">
              <canvas id="chart-dow" aria-label="Pedidos por día de la semana"></canvas>
            </div>
          </div>

          <div class="analytics-temporal-card">
            <p class="analytics-temporal-card__eyebrow">{staticCopy.temporalCards.byHourEyebrow}</p>
            <h3 class="analytics-temporal-card__title">{dashboardModel.temporal.byHour.title}</h3>
            <p class="analytics-temporal-card__description">{dashboardModel.temporal.byHour.description}</p>
            <div class="chart-wrap chart-wrap--small mt-4">
              <canvas id="chart-hour" aria-label="Pedidos por hora del día"></canvas>
            </div>
          </div>
        </div>
      </AnalyticsPanel>
    </div>
  </section>
</Layout>

<script
  id="analytics-data"
  type="application/json"
  set:html={JSON.stringify({
    byDay: data.byDay,
    topByQty: data.topByQty,
    topByRevenue: data.topByRevenue,
    topByEstimatedProfit: data.topByEstimatedProfit,
    byDayOfWeek: data.byDayOfWeek,
    byHour: data.byHour,
    byStatus: labeledStatus,
    byPaymentMethod: data.byPaymentMethod,
  })}
/>

<style is:global>
  .analytics-hero {
    display: block;
  }

  .admin-chip--warning {
    background: color-mix(in srgb, #D97706 10%, var(--color-surface-soft));
    color: #B45309;
    border: 1px solid color-mix(in srgb, #D97706 18%, var(--color-border));
  }

  .analytics-metric-card {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    padding: 1rem 1.125rem;
    border-radius: 1.25rem;
    border: 1px solid var(--color-border);
    background: color-mix(in srgb, var(--color-surface-elevated) 94%, transparent);
  }

  .analytics-metric-card--accent {
    border-color: color-mix(in srgb, var(--color-accent) 30%, var(--color-border));
    background: color-mix(in srgb, var(--color-accent) 6%, var(--color-surface-elevated));
  }

  .analytics-metric-card--warning {
    border-color: color-mix(in srgb, #D97706 24%, var(--color-border));
    background: color-mix(in srgb, #D97706 5%, var(--color-surface-elevated));
  }

  .analytics-metric-card__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border-radius: 9999px;
    background: color-mix(in srgb, var(--color-accent) 12%, var(--color-surface-soft));
    color: var(--color-accent);
  }

  .analytics-metric-card__icon--warning {
    background: color-mix(in srgb, #D97706 12%, var(--color-surface-soft));
    color: #D97706;
  }

  .analytics-metric-card__label {
    font-size: 0.68rem;
    font-weight: 800;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-text-subtle);
  }

  .analytics-metric-card__value {
    font-size: 1.55rem;
    font-weight: 900;
    line-height: 1.1;
    color: var(--color-text);
  }

  .analytics-metric-card__sub {
    font-size: 0.76rem;
    line-height: 1.45;
    color: var(--color-text-subtle);
  }

  .analytics-story-card {
    padding: 1rem 1.125rem;
    border-radius: 1.25rem;
    border: 1px solid var(--color-border);
    background: color-mix(in srgb, var(--color-surface) 72%, transparent);
  }

  .analytics-story-card--accent {
    border-color: color-mix(in srgb, var(--color-accent) 24%, var(--color-border));
  }

  .analytics-story-card--warning {
    border-color: color-mix(in srgb, #D97706 24%, var(--color-border));
    background: color-mix(in srgb, #D97706 5%, var(--color-surface));
  }

  .analytics-story-card__title {
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-text-subtle);
  }

  .analytics-story-card__description {
    margin-top: 0.5rem;
    font-size: 0.92rem;
    line-height: 1.6;
    color: var(--color-text);
  }

  .analytics-panel {
    border: 1px solid var(--color-border);
    border-radius: 1.5rem;
    overflow: hidden;
    background: color-mix(in srgb, var(--color-surface-elevated) 92%, transparent);
  }

  .analytics-panel--warning {
    border-color: color-mix(in srgb, #D97706 22%, var(--color-border));
    background: color-mix(in srgb, #D97706 4%, var(--color-surface-elevated));
  }

  .analytics-panel__header {
    display: flex;
    align-items: flex-start;
    gap: 0.875rem;
    padding: 1rem 1.25rem;
    border-bottom: 1px solid var(--color-border);
    background: color-mix(in srgb, var(--color-surface) 60%, transparent);
  }

  .analytics-panel__heading {
    min-width: 0;
  }

  .analytics-panel__icon-wrap {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 9999px;
    background: color-mix(in srgb, var(--color-accent) 12%, var(--color-surface-soft));
    color: var(--color-accent);
  }

