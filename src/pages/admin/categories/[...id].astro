---
import Layout from "@layouts/Layout.astro";
import { actions } from "astro:actions";

export const prerender = false;

const { id } = Astro.params;
const isNew = id === "new";

let category = null;

if (!isNew && id) {
    // Fetch existing category by ID
    const { data, error } = await Astro.callAction(actions.getCategories, {});
    
    if (!error && data.categories) {
        category = data.categories.find((c: any) => c.id === id);
    }
    
    if (!category) {
        return Astro.redirect("/admin/categories");
    }
}
---

<Layout title={isNew ? "Nueva Categoría" : "Editar Categoría"}>
    <section class="admin-shell max-w-3xl mx-auto">
        <div class="admin-shell__header">
            <div class="space-y-4">
                <a
                    href="/admin/categories"
                    class="premium-action-ghost w-fit"
                >
                    <span aria-hidden="true">←</span>
                    Volver a categorías
                </a>

                <div>
                    <p class="admin-shell__eyebrow">Dashboard admin</p>
                    <h1 class="admin-shell__title">
                        {isNew ? "Nueva categoría" : `Editar categoría: ${category?.name || ""}`}
                    </h1>
                    <p class="admin-shell__copy">
                        Ajusta el nombre visible y el slug con el mismo lenguaje visual premium que ya usa la vitrina pública, sin tocar la lógica CRUD.
                    </p>
                </div>

                <div class="admin-chip-row">
                    {isNew ? (
                        <span class="admin-chip">Alta rápida</span>
                    ) : (
                        <span class="admin-chip"><strong>ID</strong> #{category?.id}</span>
                    )}
                    <span class="premium-chip">{isNew ? "Modo creación" : "Modo edición"}</span>
                </div>
            </div>
        </div>

        <form id="category-form" class="premium-panel space-y-6 p-6 md:p-8">
            {!isNew && <input type="hidden" name="id" value={id} />}
            
            <div class="grid gap-6 md:grid-cols-2">
                <div>
                <label for="name" class="block text-sm font-semibold theme-text-primary mb-2">
                    Nombre
                </label>
                <input
                    type="text"
                    id="name"
                    name="name"
                    value={category?.name || ""}
                    required
                    class="premium-field"
                    placeholder="Ej: Guacamole Tradicional"
                />
                <p class="field-help">Este nombre se muestra en el admin y puede ayudarte a identificar mejor la categoría.</p>
                </div>

                <div>
                <label for="slug" class="block text-sm font-semibold theme-text-primary mb-2">
                    Slug
                </label>
                <input
                    type="text"
                    id="slug"
                    name="slug"
                    value={category?.slug || ""}
                    required
                    class="premium-field"
                    placeholder="Ej: guacamole-tradicional"
                />
                <p class="field-help">
                    Se usa en la URL: /productos/{category?.slug || 'slug'}
                </p>
                </div>
            </div>

            <div class="rounded-[1.5rem] border px-4 py-4 theme-soft-surface md:px-5">
                <div class="admin-chip-row">
                    <span class="premium-chip">Edición segura</span>
                    <span class="admin-chip">Sin cambios sobre la lógica de negocio</span>
                </div>
            </div>

            <div class="flex flex-wrap justify-end gap-3 pt-2">
                <a 
                    href="/admin/categories"
                    class="premium-action-secondary"
                >
                    Cancelar
                </a>
                <button 
                    type="submit"
                    class="premium-action-primary"
                >
                    {isNew ? "Crear Categoría" : "Guardar Cambios"}
                </button>
            </div>
        </form>
    </section>
</Layout>

<script>
    import { actions } from "astro:actions";
    import { navigate } from "astro:transitions/client";

    document.addEventListener("astro:page-load", () => {
        const form = document.getElementById("category-form") as HTMLFormElement;
        const nameInput = document.getElementById("name") as HTMLInputElement;
        const slugInput = document.getElementById("slug") as HTMLInputElement;

        if (!form) return;

        // Auto-generate slug from name
        nameInput?.addEventListener("input", () => {
            if (slugInput && !slugInput.dataset.userModified) {
                const slug = nameInput.value
                    .toLowerCase()
                    .replace(/\s+/g, "-")
                    .replace(/[^a-z0-9-]/g, "")
                    .trim();
                slugInput.value = slug;
            }
        });

        // Mark slug as user-modified if they type in it
        slugInput?.addEventListener("input", () => {
            if (slugInput) {
                slugInput.dataset.userModified = "true";
            }
        });

        form.addEventListener("submit", async (e) => {
            e.preventDefault();

            const formData = new FormData(form);

            const { error } = await actions.createUpdateCategory(formData);

            if (error) {
                alert(`Error: ${error.message}`);
                return;
            }

            navigate("/admin/categories");
        });
    });
</script>
