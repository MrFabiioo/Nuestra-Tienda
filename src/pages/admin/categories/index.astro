---
import Layout from "@layouts/Layout.astro";
import { actions } from "astro:actions";

export const prerender = false;

const { data, error } = await Astro.callAction(actions.getCategories, {});

if (error) {
    console.error("Error fetching categories:", error);
    return Astro.redirect("/");
}

const { categories } = data;
---

<Layout title="Categorías">
    <section class="admin-shell">
        <div class="admin-shell__header">
            <div class="space-y-4">
                <a href="/admin/dashboard" class="premium-action-ghost w-fit">
                    <span aria-hidden="true">←</span>
                    Volver a productos
                </a>

                <div>
                    <p class="admin-shell__eyebrow">Dashboard admin</p>
                    <h1 class="admin-shell__title">Categorías con una lectura más premium</h1>
                    <p class="admin-shell__copy">
                        Gestioná la taxonomía con una tabla más clara, acciones consistentes y soporte visual coherente entre light y dark mode.
                    </p>
                </div>

                <div class="admin-chip-row">
                    <span class="admin-chip"><strong>{categories.length}</strong> categorías activas</span>
                    <span class="admin-chip">Acciones rápidas alineadas al storefront</span>
                </div>
            </div>

            <div class="flex flex-wrap gap-3">
                <a
                    href="/admin/categories/new"
                    id="btn-nueva-categoria"
                    class="premium-action-primary"
                >
                    Nueva categoría
                </a>
            </div>
        </div>

        <div class="admin-table-wrap">
            <div class="admin-table-scroll">
                <table class="admin-table">
            <thead>
                <tr>
                    <th>Nombre</th>
                    <th>Slug</th>
                    <th>ID</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                {categories.length === 0 ? (
                    <tr>
                        <td colspan="4">
                            <div class="admin-empty-state">
                                <span class="premium-chip">Sin registros</span>
                                <strong>Todavía no hay categorías creadas.</strong>
                                <p>Creá la primera categoría para empezar a organizar el catálogo desde el admin.</p>
                                <a href="/admin/categories/new" class="premium-action-primary">Crear primera categoría</a>
                            </div>
                        </td>
                    </tr>
                ) : (
                    categories.map((category) => (
                        <tr>
                            <td>
                                <p class="admin-table__primary">
                                    <a
                                        class="admin-table__link"
                                        href={`/admin/categories/${category.id}`}
                                    >
                                        {category.name}
                                    </a>
                                </p>
                                <p class="admin-table__secondary">Usala para ordenar productos y mejorar la navegación del catálogo.</p>
                            </td>
                            <td>
                                <span class="premium-chip">{category.slug}</span>
                            </td>
                            <td>
                                <span class="admin-chip">#{category.id}</span>
                            </td>
                            <td>
                                <div class="admin-table__actions">
                                    <a 
                                        href={`/admin/categories/${category.id}`}
                                        class="premium-icon-button"
                                        aria-label={`Editar ${category.name}`}
                                        title={`Editar ${category.name}`}
                                    >
                                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-6 h-6">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10" />
                                        </svg>
                                    </a>
                                    <button 
                                        type="button" 
                                        class="btn-delete-category premium-icon-button premium-icon-button--destructive"
                                        data-id={category.id}
                                        data-name={category.name}
                                        aria-label={`Eliminar ${category.name}`}
                                        title={`Eliminar ${category.name}`}
                                    >
                                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-6 h-6">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 00-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 013.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 00-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 00-7.5 0" />
                                        </svg>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    ))
                )}
            </tbody>
        </table>
            </div>
        </div>
    </section>
</Layout>

<script>
    import { actions } from "astro:actions";

    document.addEventListener("astro:page-load", () => {
        const deleteButtons = document.querySelectorAll(".btn-delete-category");

        deleteButtons.forEach((btn) => {
            btn.addEventListener("click", async (e) => {
                const button = btn as HTMLButtonElement;
                const id = button.getAttribute("data-id");
                const name = button.getAttribute("data-name");

                if (!id) return;

                if (!confirm(`¿Estás seguro de que deseas eliminar la categoría "${name}"?`)) {
                    return;
                }

                const { error } = await actions.deleteCategory({ id });

                if (error) {
                    alert(`Error al eliminar: ${error.message}`);
                    return;
                }

                // Reload the page to show updated list
                window.location.reload();
            });
        });
    });
</script>
