---
import Layout from "@layouts/Layout.astro";
import { actions } from "astro:actions";

export const prerender = false;

const { data, error } = await Astro.callAction(actions.getCategories, {});

if (error) {
    console.error("Error fetching categories:", error);
    return Astro.redirect("/");
}

const { categories } = data;
---

<Layout title="Categorías">
    <div class="flex justify-between items-center mx-6 mt-10">
        <p class="text-2xl text-black-dark font-bold">Listado de Categorías</p>
        <a 
            href="/admin/categories/new" 
            id="btn-nueva-categoria"
            class="text-black-medium border-black-dark border-2 bg-guacamole-pulpa px-4 py-2 transition hover:scale-105"
        >
            NUEVA CATEGORÍA
        </a>
    </div>

    <div class="mx-6 mt-4">
        <a 
            href="/admin/dashboard" 
            class="text-blue-500 hover:underline text-sm"
        >
            ← Volver a Productos
        </a>
    </div>

    <div class="relative flex flex-col h-full overflow-scroll text-gray-700 bg-white shadow-md rounded-lg bg-clip-border my-6 mx-6">
        <table class="w-full text-left table-auto min-w-max">
            <thead>
                <tr class="border-b border-slate-300 bg-slate-50">
                    <th class="p-4 text-xl font-normal leading-none text-slate-500">Nombre</th>
                    <th class="p-4 text-xl font-normal leading-none text-slate-500">Slug</th>
                    <th class="p-4 text-xl font-normal leading-none text-slate-500">ID</th>
                    <th class="p-4 text-xl font-normal leading-none text-slate-500">Acciones</th>
                </tr>
            </thead>
            <tbody>
                {categories.length === 0 ? (
                    <tr>
                        <td colspan="4" class="p-4 text-center text-slate-500">
                            No hay categorías. Crea una nueva.
                        </td>
                    </tr>
                ) : (
                    categories.map((category) => (
                        <tr class="hover:bg-slate-50">
                            <td class="p-4 border-b border-slate-200 py-5">
                                <p class="block font-semibold text-lg text-slate-800">
                                    <a 
                                        class="hover:underline cursor-pointer" 
                                        href={`/admin/categories/${category.id}`}
                                    >
                                        {category.name}
                                    </a>
                                </p>
                            </td>
                            <td class="p-4 border-b border-slate-200 py-5">
                                <p class="text-lg text-slate-500">{category.slug}</p>
                            </td>
                            <td class="p-4 border-b border-slate-200 py-5">
                                <p class="text-lg text-slate-500">{category.id}</p>
                            </td>
                            <td class="p-4 border-b border-slate-200 py-5">
                                <div class="flex gap-2">
                                    <a 
                                        href={`/admin/categories/${category.id}`}
                                        class="text-blue-500 hover:text-blue-700"
                                    >
                                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-6 h-6">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10" />
                                        </svg>
                                    </a>
                                    <button 
                                        type="button" 
                                        class="btn-delete-category text-red-500 hover:text-red-700"
                                        data-id={category.id}
                                        data-name={category.name}
                                    >
                                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-6 h-6">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 00-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 013.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 00-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 00-7.5 0" />
                                        </svg>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    ))
                )}
            </tbody>
        </table>
    </div>
</Layout>

<script>
    import { actions } from "astro:actions";

    document.addEventListener("astro:page-load", () => {
        const deleteButtons = document.querySelectorAll(".btn-delete-category");

        deleteButtons.forEach((btn) => {
            btn.addEventListener("click", async (e) => {
                const button = btn as HTMLButtonElement;
                const id = button.getAttribute("data-id");
                const name = button.getAttribute("data-name");

                if (!id) return;

                if (!confirm(`¿Estás seguro de que deseas eliminar la categoría "${name}"?`)) {
                    return;
                }

                const { error } = await actions.deleteCategory({ id });

                if (error) {
                    alert(`Error al eliminar: ${error.message}`);
                    return;
                }

                // Reload the page to show updated list
                window.location.reload();
            });
        });
    });
</script>
