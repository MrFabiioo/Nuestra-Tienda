<!-- Datos de receta inicial pasados del servidor al cliente -->
<script
  id="recipe-initial-data"
  type="application/json"
  set:html={JSON.stringify(initialRecipe)}
></script>

<script>
import { actions } from 'astro:actions';
import { navigate } from 'astro:transitions/client';

// ── Tipos inline (no podemos importar .ts en script Astro directamente) ────
type RecipeUnit = 'gr' | 'kg' | 'ml' | 'cc' | 'l' | 'unidad';

interface RecipeIngredient {
  name: string;
  paidAmount: number;
  purchasedQty: number;
  purchasedUnit: RecipeUnit;
  usedQty: number;
  usedUnit: RecipeUnit;
}

interface ProductRecipe {
  ingredients: RecipeIngredient[];
  yieldUnits: number;
  marginPercent: number | null;
}

// ── Helpers de cálculo (duplicados de recipe-calculator.ts para el cliente) ─
const CONVERSION_TO_BASE: Record<RecipeUnit, number | null> = {
  gr: 1, kg: 1000, ml: 1, cc: 1, l: 1000, unidad: null,
};

const DIMENSION: Record<RecipeUnit, string> = {
  gr: 'mass', kg: 'mass', ml: 'volume', cc: 'volume', l: 'volume', unidad: 'unit',
};

function convertUnit(qty: number, from: RecipeUnit, to: RecipeUnit): number | null {
  if (from === to) return qty;
  if (DIMENSION[from] !== DIMENSION[to]) return null;
  const bF = CONVERSION_TO_BASE[from];
  const bT = CONVERSION_TO_BASE[to];
  if (bF === null || bT === null) return null;
  return (qty * bF) / bT;
}

function calcIngredientCost(ing: RecipeIngredient): { cost: number; incompatible: boolean } {
  const { paidAmount, purchasedQty, purchasedUnit, usedQty, usedUnit } = ing;
  if (purchasedQty <= 0 || paidAmount < 0) return { cost: 0, incompatible: false };
  const usedConverted = convertUnit(usedQty, usedUnit, purchasedUnit);
  if (usedConverted === null) return { cost: 0, incompatible: true };
  return { cost: (paidAmount / purchasedQty) * usedConverted, incompatible: false };
}

// ── Formateo de moneda ────────────────────────────────────────────────────
function fmtCurrency(value: number): string {
  return new Intl.NumberFormat('es-CO', {
    style: 'currency',
    currency: 'COP',
    maximumFractionDigits: 0,
  }).format(value);
}

// ── Estado reactivo ───────────────────────────────────────────────────────
let recipe: ProductRecipe = {
  ingredients: [],
  yieldUnits: 1,
  marginPercent: 50,
};

const UNIT_OPTIONS: RecipeUnit[] = ['gr', 'kg', 'ml', 'cc', 'l', 'unidad'];

// ── Renderizado de ingredientes ───────────────────────────────────────────
function unitOptionsHtml(selected: RecipeUnit): string {
  return UNIT_OPTIONS.map(
    (u) => `<option value="${u}"${u === selected ? ' selected' : ''}>${u}</option>`,
  ).join('');
}

function renderIngredients(): void {
  const container = document.getElementById('ingredients-list');
  if (!container) return;

  if (recipe.ingredients.length === 0) {
    container.innerHTML = `
      <div class="ingredient-empty-state">
        <div class="ingredient-empty-state__icon">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z" />
          </svg>
        </div>
        <p class="ingredient-empty-state__title">Sin ingredientes</p>
        <p class="ingredient-empty-state__copy">Agregá el primer ingrediente para comenzar a calcular el costo de la receta.</p>
      </div>
    `;
    return;
  }

  const rows = recipe.ingredients.map((ing, idx) => {
    const ic = calcIngredientCost(ing);
    const num = String(idx + 1).padStart(2, '0');
    const costBadge = ic.incompatible
      ? `<span class="ingredient-row__cost ingredient-row__cost--incompatible">⚠ unidades incompatibles</span>`
      : `<span class="ingredient-row__cost">Costo: ${fmtCurrency(ic.cost)}</span>`;

    return `
      <div class="ingredient-row" data-index="${idx}">

        <!-- Strip: número + header flexible con nombre + meta -->
        <div class="ingredient-row__strip">
          <span class="ingredient-row__num" aria-hidden="true">
            <span class="ingredient-row__num-label">Ing.</span>
            <strong>${num}</strong>
          </span>
          <div class="ingredient-row__header">
            <input
              type="text"
              class="premium-field text-sm ingredient-row__name"
              placeholder="Nombre del ingrediente (ej: Palta)"
              value="${ing.name.replace(/"/g, '&quot;')}"
              data-field="name"
              data-index="${idx}"
            />
            <div class="ingredient-row__actions">
              ${costBadge}
              <button
                type="button"
                class="btn-delete-ingredient ingredient-row__del"
                data-index="${idx}"
                aria-label="Eliminar ingrediente"
              >
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                </svg>
              </button>
            </div>
          </div>
        </div>

        <!-- Body: campos de costo y cantidades -->
        <div class="ingredient-row__body">
          <div class="recipe-ingredient-grid text-sm">
            <div class="recipe-field-group recipe-field-group--price">
              <label class="field-help mb-1 block">Precio pagado</label>
              <input
                type="number"
                class="premium-field text-sm recipe-price-field"
                min="0"
                step="0.01"
                placeholder="0"
                value="${ing.paidAmount}"
                data-field="paidAmount"
                data-index="${idx}"
              />
            </div>
            <div class="recipe-field-group recipe-field-group--quantity">
              <label class="field-help mb-1 block">Cant. comprada</label>
              <div class="recipe-quantity-combo">
                <input
                  type="number"
                  class="premium-field text-sm recipe-quantity-input"
                  min="0.001"
                  step="any"
                  placeholder="1"
                  value="${ing.purchasedQty}"
                  data-field="purchasedQty"
                  data-index="${idx}"
                />
                <select
                  class="premium-field text-sm recipe-unit-select"
                  data-field="purchasedUnit"
                  data-index="${idx}"
                >${unitOptionsHtml(ing.purchasedUnit)}</select>
              </div>
            </div>
            <div class="recipe-field-group recipe-field-group--quantity">
              <label class="field-help mb-1 block">Cant. usada</label>
              <div class="recipe-quantity-combo">
                <input
                  type="number"
                  class="premium-field text-sm recipe-quantity-input"
                  min="0.001"
                  step="any"
                  placeholder="1"
                  value="${ing.usedQty}"
                  data-field="usedQty"
                  data-index="${idx}"
                />
                <select
                  class="premium-field text-sm recipe-unit-select"
                  data-field="usedUnit"
                  data-index="${idx}"
                >${unitOptionsHtml(ing.usedUnit)}</select>
              </div>
            </div>
          </div>
        </div>

      </div>
    `;
  });

  container.innerHTML = rows.join('');

  bindIngredientEvents();
  updateIngredientCountBadge();
}

function updateIngredientCountBadge(): void {
  const badge = document.getElementById('ingredient-count-badge');
  if (!badge) return;
  const count = recipe.ingredients.length;
  badge.textContent = String(count);
  badge.style.display = count > 0 ? '' : 'none';
}

function bindIngredientEvents(): void {
  const container = document.getElementById('ingredients-list');
  if (!container) return;

  // Campos de texto/número de ingredientes
  container.querySelectorAll<HTMLInputElement | HTMLSelectElement>('[data-field][data-index]').forEach((el) => {
    el.addEventListener('input', (e) => {
      const target = e.currentTarget as HTMLInputElement | HTMLSelectElement;
      const idx = Number(target.dataset.index);
      const field = target.dataset.field as keyof RecipeIngredient;
      if (!recipe.ingredients[idx]) return;

      const numFields: (keyof RecipeIngredient)[] = ['paidAmount', 'purchasedQty', 'usedQty'];
      const value = numFields.includes(field)
        ? parseFloat(target.value) || 0
        : target.value;

      (recipe.ingredients[idx] as any)[field] = value;
      updateResults();
      // Re-renderiza sólo la badge de costo sin borrar los campos (evita pérdida de focus)
      updateIngredientCostBadge(idx);
    });
  });

  // Botones eliminar ingrediente
  container.querySelectorAll<HTMLButtonElement>('.btn-delete-ingredient').forEach((btn) => {
    btn.addEventListener('click', () => {
      const idx = Number(btn.dataset.index);
      recipe.ingredients.splice(idx, 1);
      if (recipe.ingredients.length === 0) {
        recipe.ingredients.push(emptyIngredient());
      }
      renderIngredients();
      updateResults();
    });
  });
}

function updateIngredientCostBadge(idx: number): void {
  const row = document.querySelector<HTMLElement>(`.ingredient-row[data-index="${idx}"]`);
  if (!row) return;
  const badge = row.querySelector<HTMLElement>('.ingredient-row__cost');
  if (!badge) return;
  const ic = calcIngredientCost(recipe.ingredients[idx]);
  if (ic.incompatible) {
    badge.className = 'ingredient-row__cost ingredient-row__cost--incompatible';
    badge.textContent = '⚠ unidades incompatibles';
  } else {
    badge.className = 'ingredient-row__cost';
    badge.textContent = `Costo: ${fmtCurrency(ic.cost)}`;
  }
}

// ── Actualizar resultados ─────────────────────────────────────────────────
function updateResults(): void {
  const costs = recipe.ingredients.map(calcIngredientCost);
  const totalCost = costs.reduce((acc, ic) => acc + ic.cost, 0);
  const safeYield = (recipe.yieldUnits > 0 ? recipe.yieldUnits : 1);
  const costPerUnit = totalCost / safeYield;
  const margin = recipe.marginPercent ?? 0;
  const suggestedPrice = costPerUnit * (1 + margin / 100);

  setEl('rc-total-cost', fmtCurrency(totalCost));
  setEl('rc-yield', String(safeYield));
  setEl('rc-cost-per-unit', fmtCurrency(costPerUnit));
  setEl('rc-suggested-price', fmtCurrency(suggestedPrice));

  const btnUse = document.getElementById('btn-use-suggested-price') as HTMLButtonElement | null;
  if (btnUse) {
    btnUse.disabled = suggestedPrice <= 0;
    (btnUse as any)._suggestedPrice = suggestedPrice;
  }

  // Actualizar campo oculto de receta
  const hiddenInput = document.getElementById('recipe-hidden') as HTMLInputElement | null;
  if (hiddenInput) hiddenInput.value = JSON.stringify(recipe);
}

function setEl(id: string, text: string): void {
  const el = document.getElementById(id);
  if (el) el.textContent = text;
}

function emptyIngredient(): RecipeIngredient {
  return { name: '', paidAmount: 0, purchasedQty: 1, purchasedUnit: 'gr', usedQty: 1, usedUnit: 'gr' };
}

// ── Inicialización y eventos globales ─────────────────────────────────────
document.addEventListener('astro:page-load', () => {
  // ── Auto-slug desde título ─────────────────────────────────────────────
  const titleInput = document.getElementById('title') as HTMLInputElement | null;
  const slugInput  = document.getElementById('slug')  as HTMLInputElement | null;

  if (titleInput && slugInput) {
    // Si el slug ya tiene valor (edición), no lo sobreescribimos
    if (slugInput.value) slugInput.dataset.userModified = 'true';

    titleInput.addEventListener('input', () => {
      if (slugInput.dataset.userModified) return;
      slugInput.value = titleInput.value
        .toLowerCase()
        .normalize('NFD').replace(/[\u0300-\u036f]/g, '') // quita tildes
        .replace(/\s+/g, '-')
        .replace(/[^a-z0-9-]/g, '')
        .replace(/-+/g, '-')
        .trim();
    });

    slugInput.addEventListener('input', () => {
      slugInput.dataset.userModified = 'true';
    });
  }

  // Leer datos de receta inicial inyectados por el servidor
  const dataEl = document.getElementById('recipe-initial-data');
  if (dataEl) {
    try {
      recipe = JSON.parse(dataEl.textContent ?? '{}');
    } catch {
      recipe = { ingredients: [emptyIngredient()], yieldUnits: 1, marginPercent: 50 };
    }
  }

  // ── Render inicial ────────────────────────────────────────────────────
  renderIngredients();

  // Poblar yield
  const yieldInput = document.getElementById('recipe-yield') as HTMLInputElement | null;
  if (yieldInput) yieldInput.value = String(recipe.yieldUnits ?? 1);

  // Margen inicial — activar botón o cargar en custom
  const presets = [25, 50, 100, 200];
  if (recipe.marginPercent !== null && presets.includes(recipe.marginPercent)) {
    document.querySelector<HTMLButtonElement>(`.btn-margin[data-margin="${recipe.marginPercent}"]`)
      ?.classList.add('btn-margin--active');
  } else if (recipe.marginPercent !== null) {
    const customInput = document.getElementById('recipe-margin-custom') as HTMLInputElement | null;
    if (customInput) customInput.value = String(recipe.marginPercent);
  }

  updateResults();

  // ── Agregar ingrediente ───────────────────────────────────────────────
  document.getElementById('btn-add-ingredient')?.addEventListener('click', () => {
    recipe.ingredients.push(emptyIngredient());
    renderIngredients();
    updateResults();
  });

  // ── Rendimiento ───────────────────────────────────────────────────────
  yieldInput?.addEventListener('input', () => {
    recipe.yieldUnits = parseFloat(yieldInput.value) || 1;
    updateResults();
  });

  // ── Márgenes preset ───────────────────────────────────────────────────
  document.querySelectorAll<HTMLButtonElement>('.btn-margin').forEach((btn) => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.btn-margin').forEach((b) => b.classList.remove('btn-margin--active'));
      btn.classList.add('btn-margin--active');
      recipe.marginPercent = Number(btn.dataset.margin);
      // Limpiar input custom
      const customInput = document.getElementById('recipe-margin-custom') as HTMLInputElement | null;
      if (customInput) customInput.value = '';
      updateResults();
    });
  });

  // ── Margen personalizado ──────────────────────────────────────────────
  const customMarginInput = document.getElementById('recipe-margin-custom') as HTMLInputElement | null;
  customMarginInput?.addEventListener('input', () => {
    const val = parseFloat(customMarginInput.value);
    if (!isNaN(val) && val >= 0) {
      document.querySelectorAll('.btn-margin').forEach((b) => b.classList.remove('btn-margin--active'));
      recipe.marginPercent = val;
      updateResults();
    }
  });

  // ── Usar precio sugerido ──────────────────────────────────────────────
  document.getElementById('btn-use-suggested-price')?.addEventListener('click', (e) => {
    const btn = e.currentTarget as any;
    const suggested: number = btn._suggestedPrice ?? 0;
    const priceInput = document.querySelector<HTMLInputElement>('#price');
    if (priceInput && suggested > 0) {
      priceInput.value = String(Math.round(suggested));
      priceInput.dispatchEvent(new Event('input'));
      // Feedback visual breve
      btn.textContent = '✓ Precio aplicado';
      setTimeout(() => {
        btn.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" style="width:1rem;height:1rem;"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg> Usar como precio del producto`;
      }, 1800);
    }
  });

  // ── Form submit ───────────────────────────────────────────────────────
  const form = document.querySelector('#product-form') as HTMLFormElement;
  const sizeButtons = document.querySelectorAll('.btn-size');
  const btnsDeleteImage = document.querySelectorAll('.btn-delete-image');
  const lblSelectedFiles = document.querySelector('#lbl-selected-files') as HTMLParagraphElement;
  const dropZone = document.querySelector('#drop-zone') as HTMLLabelElement;
  const fileInput = document.querySelector('#file-upload') as HTMLInputElement;

  if (!form) return;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    // Serializar receta al hidden antes de enviar
    const recipeHidden = document.getElementById('recipe-hidden') as HTMLInputElement | null;
    if (recipeHidden) recipeHidden.value = JSON.stringify(recipe);

    const selectedSizes = Array.from(sizeButtons)
      .filter((btn) => btn.classList.contains('btn-size--active'))
      .map((btn) => btn.textContent?.trim())
      .join(',');

    const formData = new FormData(form);
    formData.set('sizes', selectedSizes);

    const { data, error } = await actions.createUpdateProduct(formData);

    if (error) {
      return alert(error.message);
    }

    navigate(`/admin/products/${data.slug}`);
  });

  // ── Eliminar imágenes ─────────────────────────────────────────────────
  btnsDeleteImage.forEach((btn) => {
    btn.addEventListener('click', async (e) => {
      const id = btn.getAttribute('data-id');
      if (!id) return;

      const { error } = await actions.deleteProductImage(id);
      if (error) {
        console.log(error);
        alert(error);
        return;
      }

      document.querySelector(`#${id}`)?.remove();
    });
  });

  // ── Drag & Drop ───────────────────────────────────────────────────────
  const preventDefaults = (e: DragEvent) => {
    e.preventDefault();
    e.stopPropagation();
  };

  const highlight = () => dropZone?.classList.add('product-drop-zone--highlight');
  const unHighlight = () => dropZone?.classList.remove('product-drop-zone--highlight');

  const createFileList = (files: File[]): FileList => {
    const dt = new DataTransfer();
    files.forEach((f) => dt.items.add(f));
    return dt.files;
  };

  const handleFiles = (files: FileList) => {
    const validFiles = Array.from(files).filter((f) => f.type.startsWith('image/'));
    if (fileInput && validFiles.length > 0) fileInput.files = createFileList(validFiles);
    if (lblSelectedFiles) {
      lblSelectedFiles.innerHTML = `<span class="font-semibold" style="color: var(--color-accent);">${validFiles.length} ${validFiles.length === 1 ? 'archivo seleccionado' : 'archivos seleccionados'}</span>`;
    }
  };

  (['dragenter', 'dragover', 'dragleave', 'drop'] as const).forEach((eventName) => {
    dropZone?.addEventListener(eventName, preventDefaults);
    document.body.addEventListener(eventName, preventDefaults);
  });

  (['dragenter', 'dragover'] as const).forEach((eventName) => {
    dropZone?.addEventListener(eventName, highlight);
  });

  (['dragleave', 'drop'] as const).forEach((eventName) => {
    dropZone?.addEventListener(eventName, unHighlight);
  });

  dropZone?.addEventListener('drop', (e) => {
    const files = e.dataTransfer?.files;
    if (files) handleFiles(files);
  });

  // ── Toggle featured ───────────────────────────────────────────────────
  const featuredBtn = document.getElementById('btn-toggle-featured-slug') as HTMLButtonElement | null;
  if (featuredBtn) {
    featuredBtn.addEventListener('click', async () => {
      const id = featuredBtn.getAttribute('data-id');
      if (!id) return;

      const currentFeatured = featuredBtn.getAttribute('data-featured') === 'true';
      featuredBtn.disabled = true;

      const { error } = await actions.toggleFeatured({ id, featured: !currentFeatured });

      if (error) {
        alert(`Error: ${error.message}`);
        featuredBtn.disabled = false;
        return;
      }

      window.location.reload();
    });
  }
});
</script>
