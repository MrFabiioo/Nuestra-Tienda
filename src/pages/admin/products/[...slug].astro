          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="h-4 w-4">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          Guardar producto
        </button>
      </div>

    </form>

  </section>

  <style>
    /* ── Botones de tamaño ──────────────────────────────────────── */
    .btn-size {
      @apply inline-flex min-h-10 cursor-pointer items-center justify-center rounded-full px-4 py-2 text-sm font-semibold transition-all duration-200;
      border: 1px solid var(--color-border);
      background: color-mix(in srgb, var(--color-surface-elevated) 94%, transparent);
      color: var(--color-text-muted);
    }

    .btn-size:hover {
      border-color: var(--color-border-strong);
      background: color-mix(in srgb, var(--color-surface-elevated) 86%, var(--color-accent) 14%);
      color: var(--color-accent);
    }

    .btn-size--active {
      border-color: color-mix(in srgb, var(--color-accent) 36%, var(--color-border));
      background: color-mix(in srgb, var(--color-accent) 14%, var(--color-surface));
      color: var(--color-accent);
      box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-accent) 14%, transparent);
    }

    /* ── Drop zone ──────────────────────────────────────────────── */
    .product-drop-zone {
      @apply block w-full cursor-pointer rounded-2xl transition-all duration-200;
      border: 2px dashed var(--color-border-strong);
      background: color-mix(in srgb, var(--color-surface-soft) 60%, transparent);
    }

    .product-drop-zone:hover {
      border-color: var(--color-accent);
      background: color-mix(in srgb, var(--color-accent) 06%, var(--color-surface-soft) 60%);
    }

    .product-drop-zone--highlight {
      border-color: var(--color-accent) !important;
      background: color-mix(in srgb, var(--color-accent) 10%, var(--color-surface-soft)) !important;
      box-shadow: 0 0 0 4px color-mix(in srgb, var(--color-accent) 14%, transparent);
    }

    /* ── Calculadora de receta ─────────────────────────────────── */
    #recipe-calculator {
      --recipe-ingredient-row-bg: linear-gradient(180deg, color-mix(in srgb, var(--color-surface-elevated) 98%, white 2%) 0%, color-mix(in srgb, var(--color-surface) 90%, var(--color-surface-elevated) 10%) 100%);
      --recipe-ingredient-row-shadow: 0 1px 3px color-mix(in srgb, var(--color-text) 6%, transparent), inset 0 1px 0 color-mix(in srgb, white 65%, transparent);
      --recipe-ingredient-row-hover-shadow: 0 10px 24px color-mix(in srgb, var(--color-text) 9%, transparent), 0 0 0 1px color-mix(in srgb, var(--color-accent) 10%, transparent);
      --recipe-ingredient-strip-bg: linear-gradient(180deg, color-mix(in srgb, var(--color-surface-soft) 78%, white 22%) 0%, color-mix(in srgb, var(--color-surface-soft) 62%, var(--color-surface-elevated) 38%) 100%);
      --recipe-ingredient-strip-border: color-mix(in srgb, var(--color-border) 82%, white 18%);
      --recipe-ingredient-accent-bar: linear-gradient(180deg, color-mix(in srgb, var(--color-accent) 65%, white 35%) 0%, color-mix(in srgb, var(--color-accent-strong) 82%, transparent) 100%);
      --recipe-ingredient-number-bg: linear-gradient(180deg, color-mix(in srgb, var(--color-accent) 12%, white 88%) 0%, color-mix(in srgb, var(--color-accent) 8%, var(--color-surface) 92%) 100%);
      --recipe-ingredient-number-border: color-mix(in srgb, var(--color-accent) 24%, var(--color-border));
      --recipe-ingredient-number-color: var(--color-accent-strong);
      --recipe-ingredient-number-label: color-mix(in srgb, var(--color-accent-strong) 72%, var(--color-text-subtle) 28%);
      --recipe-ingredient-number-shadow: inset 0 1px 0 color-mix(in srgb, white 75%, transparent), 0 8px 18px color-mix(in srgb, var(--color-accent) 8%, transparent);
      --recipe-ingredient-name-bg: color-mix(in srgb, var(--color-surface-elevated) 96%, white 4%);
      --recipe-field-group-bg: color-mix(in srgb, var(--color-surface-soft) 54%, var(--color-surface-elevated) 46%);
      --recipe-field-group-border: color-mix(in srgb, var(--color-border) 88%, white 12%);
      --recipe-field-group-shadow: inset 0 1px 0 color-mix(in srgb, white 55%, transparent);
      --recipe-count-badge-bg: color-mix(in srgb, var(--color-accent) 14%, var(--color-surface));
      --recipe-count-badge-border: color-mix(in srgb, var(--color-accent) 24%, var(--color-border));
      --recipe-cost-badge-bg: color-mix(in srgb, var(--color-surface-soft) 82%, white 18%);
      --recipe-cost-badge-border: color-mix(in srgb, var(--color-accent) 18%, var(--color-border));
      --recipe-summary-bg: color-mix(in srgb, var(--color-surface-elevated) 94%, transparent);
      --recipe-summary-border: var(--color-border);
      --recipe-results-border: var(--color-border);
      --recipe-results-header-bg: color-mix(in srgb, var(--color-accent) 12%, var(--color-surface-soft));
      --recipe-results-header-border: color-mix(in srgb, var(--color-accent) 18%, var(--color-border));
      --recipe-results-body-bg: color-mix(in srgb, var(--color-surface-soft) 60%, transparent);
      --recipe-stat-bg: color-mix(in srgb, var(--color-surface) 88%, transparent);
      --recipe-stat-border: var(--color-border);
      --recipe-stat-accent-bg: color-mix(in srgb, var(--color-accent) 10%, var(--color-surface));
      --recipe-stat-accent-border: color-mix(in srgb, var(--color-accent) 28%, var(--color-border));
      --recipe-add-button-bg: transparent;
    }

    :global(:root[data-theme='dark']) #recipe-calculator {
      --recipe-ingredient-row-bg: linear-gradient(180deg, color-mix(in srgb, var(--color-surface-elevated) 88%, var(--color-bg-alt) 12%) 0%, color-mix(in srgb, var(--color-surface) 84%, var(--color-surface-soft) 16%) 100%);
      --recipe-ingredient-row-shadow: 0 18px 34px color-mix(in srgb, black 30%, transparent), inset 0 1px 0 color-mix(in srgb, white 6%, transparent);
      --recipe-ingredient-row-hover-shadow: 0 22px 40px color-mix(in srgb, black 38%, transparent), 0 0 0 1px color-mix(in srgb, var(--color-accent) 12%, transparent);
      --recipe-ingredient-strip-bg: linear-gradient(180deg, color-mix(in srgb, var(--color-surface-soft) 56%, var(--color-surface-elevated) 44%) 0%, color-mix(in srgb, var(--color-surface-muted) 72%, var(--color-surface) 28%) 100%);
      --recipe-ingredient-strip-border: color-mix(in srgb, var(--color-border-strong) 74%, var(--color-border) 26%);
      --recipe-ingredient-accent-bar: linear-gradient(180deg, color-mix(in srgb, var(--color-accent) 76%, white 24%) 0%, color-mix(in srgb, var(--color-accent-strong) 70%, var(--color-surface) 30%) 100%);
      --recipe-ingredient-number-bg: linear-gradient(180deg, color-mix(in srgb, var(--color-accent) 18%, var(--color-surface-elevated) 82%) 0%, color-mix(in srgb, var(--color-accent-strong) 14%, var(--color-surface) 86%) 100%);
      --recipe-ingredient-number-border: color-mix(in srgb, var(--color-accent) 30%, var(--color-border-strong));
      --recipe-ingredient-number-color: color-mix(in srgb, var(--color-text) 88%, var(--color-accent) 12%);
      --recipe-ingredient-number-label: color-mix(in srgb, var(--color-accent-soft) 58%, var(--color-text-subtle) 42%);
      --recipe-ingredient-number-shadow: inset 0 1px 0 color-mix(in srgb, white 10%, transparent), 0 14px 28px color-mix(in srgb, black 24%, transparent);
      --recipe-ingredient-name-bg: color-mix(in srgb, var(--color-surface-elevated) 90%, var(--color-surface-soft) 10%);
      --recipe-field-group-bg: linear-gradient(180deg, color-mix(in srgb, var(--color-surface-muted) 72%, var(--color-surface-elevated) 28%) 0%, color-mix(in srgb, var(--color-surface-soft) 16%, var(--color-surface) 84%) 100%);
      --recipe-field-group-border: color-mix(in srgb, var(--color-border-strong) 72%, var(--color-border) 28%);
      --recipe-field-group-shadow: inset 0 1px 0 color-mix(in srgb, white 5%, transparent);
      --recipe-count-badge-bg: color-mix(in srgb, var(--color-accent) 14%, var(--color-surface-muted) 86%);
      --recipe-count-badge-border: color-mix(in srgb, var(--color-accent) 28%, var(--color-border-strong));
      --recipe-cost-badge-bg: color-mix(in srgb, var(--color-surface-soft) 42%, var(--color-surface-elevated) 58%);
      --recipe-cost-badge-border: color-mix(in srgb, var(--color-accent) 22%, var(--color-border-strong));
      --recipe-summary-bg: linear-gradient(180deg, color-mix(in srgb, var(--color-surface-elevated) 88%, var(--color-bg-alt) 12%) 0%, color-mix(in srgb, var(--color-surface) 92%, var(--color-surface-soft) 8%) 100%);
      --recipe-summary-border: color-mix(in srgb, var(--color-border-strong) 82%, var(--color-border) 18%);
      --recipe-results-border: color-mix(in srgb, var(--color-border-strong) 84%, var(--color-border) 16%);
      --recipe-results-header-bg: linear-gradient(135deg, color-mix(in srgb, var(--color-surface-soft) 58%, var(--color-surface-elevated) 42%) 0%, color-mix(in srgb, var(--color-accent) 14%, var(--color-surface-muted) 86%) 100%);
      --recipe-results-header-border: color-mix(in srgb, var(--color-accent) 24%, var(--color-border-strong));
      --recipe-results-body-bg: linear-gradient(180deg, color-mix(in srgb, var(--color-surface-muted) 76%, var(--color-surface) 24%) 0%, color-mix(in srgb, var(--color-surface-soft) 14%, var(--color-surface) 86%) 100%);
      --recipe-stat-bg: linear-gradient(180deg, color-mix(in srgb, var(--color-surface-elevated) 84%, var(--color-surface-soft) 16%) 0%, color-mix(in srgb, var(--color-surface) 90%, var(--color-surface-muted) 10%) 100%);
      --recipe-stat-border: color-mix(in srgb, var(--color-border-strong) 76%, var(--color-border) 24%);
      --recipe-stat-accent-bg: linear-gradient(180deg, color-mix(in srgb, var(--color-accent) 14%, var(--color-surface-muted) 86%) 0%, color-mix(in srgb, var(--color-accent) 10%, var(--color-surface) 90%) 100%);
      --recipe-stat-accent-border: color-mix(in srgb, var(--color-accent) 30%, var(--color-border-strong));
      --recipe-add-button-bg: color-mix(in srgb, var(--color-surface-soft) 34%, var(--color-surface-elevated) 66%);
    }

    .btn-margin {
      @apply inline-flex min-h-9 cursor-pointer items-center justify-center rounded-full px-3 py-1.5 text-sm font-semibold transition-all duration-200;
      border: 1px solid var(--color-border);
      background: color-mix(in srgb, var(--color-surface-elevated) 94%, transparent);
      color: var(--color-text-muted);
    }

    .btn-margin:hover {
      border-color: var(--color-border-strong);
      color: var(--color-accent);
    }

    .btn-margin--active {
      border-color: color-mix(in srgb, var(--color-accent) 36%, var(--color-border));
      background: color-mix(in srgb, var(--color-accent) 14%, var(--color-surface));
      color: var(--color-accent);
      box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-accent) 14%, transparent);
    }

    /* ── Ingredient card ───────────────────────────────────────── */
    :global(.ingredient-row) {
      position: relative;
      border: 1px solid var(--color-border);
      border-radius: 1.35rem;
      overflow: hidden;
      background: var(--recipe-ingredient-row-bg);
      box-shadow: var(--recipe-ingredient-row-shadow);
      transition: box-shadow 0.2s, border-color 0.2s, transform 0.2s;
    }

    :global(.ingredient-row)::before {
      content: '';
      position: absolute;
      inset: 0 auto 0 0;
      width: 3px;
      background: var(--recipe-ingredient-accent-bar);
      opacity: 0.7;
    }

    :global(.ingredient-row:hover) {
      border-color: color-mix(in srgb, var(--color-accent) 18%, var(--color-border-strong));
      box-shadow: var(--recipe-ingredient-row-hover-shadow);
      transform: translateY(-1px);
    }

    /* Strip superior de la card */
    :global(.ingredient-row__strip) {
      display: grid;
      grid-template-columns: auto minmax(0, 1fr);
      align-items: start;
      gap: 0.875rem;
      padding: 0.9rem 1rem 0.8rem 1rem;
      background: var(--recipe-ingredient-strip-bg);
      border-bottom: 1px solid var(--recipe-ingredient-strip-border);
    }

    /* Cuerpo de la card con los campos */
    :global(.ingredient-row__body) {
      padding: 0.95rem 1rem 1rem;
    }

    /* Número — badge premium */
    :global(.ingredient-row__num) {
      flex-shrink: 0;
      min-width: 3.2rem;
      min-height: 3rem;
      padding: 0.4rem 0.55rem;
      border-radius: 1rem;
      border: 1px solid var(--recipe-ingredient-number-border);
      background: var(--recipe-ingredient-number-bg);
      color: var(--recipe-ingredient-number-color);
      display: inline-flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 0.15rem;
      box-shadow: var(--recipe-ingredient-number-shadow);
      font-variant-numeric: tabular-nums;
    }

    :global(.ingredient-row__num strong) {
      font-size: 0.95rem;
      line-height: 1;
      font-weight: 800;
      letter-spacing: 0.08em;
    }

    :global(.ingredient-row__num-label) {
      font-size: 0.52rem;
      line-height: 1;
      font-weight: 700;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--recipe-ingredient-number-label);
    }

    :global(.ingredient-row__name) {
      width: 100%;
      min-width: 0;
      min-height: 3rem;
      font-weight: 600;
      background: var(--recipe-ingredient-name-bg);
    }

    :global(.ingredient-row__actions) {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 0.625rem;
      width: 100%;
      min-width: 0;
    }

    :global(.ingredient-row__del) {
      @apply inline-flex cursor-pointer items-center justify-center transition-all duration-200;
      width: 1.875rem;
      height: 1.875rem;
      border-radius: 0.5rem;
      border: 1px solid var(--color-border);
      background: transparent;
      color: var(--color-text-muted);
      flex-shrink: 0;
    }

    :global(.ingredient-row__del svg) {
      width: 0.8rem;
      height: 0.8rem;
    }

    :global(.ingredient-row__del:hover) {
      background: color-mix(in srgb, var(--color-danger-text, #dc2626) 10%, transparent);
      border-color: var(--color-danger-text, #dc2626);
      color: var(--color-danger-text, #dc2626);
    }

    /* ── Empty state ────────────────────────────────────────────── */
    :global(.ingredient-empty-state) {
      @apply flex flex-col items-center justify-center text-center py-12 px-4;
      border: 2px dashed var(--color-border);
      border-radius: 1rem;
      background: color-mix(in srgb, var(--color-surface-soft) 50%, transparent);
    }

    :global(.ingredient-empty-state__icon) {
      @apply flex items-center justify-center mb-4;
      width: 3rem;
      height: 3rem;
      border-radius: 9999px;
      background: color-mix(in srgb, var(--color-surface-elevated) 94%, transparent);
      color: var(--color-text-muted);
    }

    :global(.ingredient-empty-state__icon svg) {
      width: 1.5rem;
      height: 1.5rem;
    }

    :global(.ingredient-empty-state__title) {
      @apply text-sm font-semibold mb-1;
      color: var(--color-text);
    }

    :global(.ingredient-empty-state__copy) {
      @apply text-xs leading-relaxed max-w-xs;
      color: var(--color-text-subtle);
    }

    /* ── Ingredient count badge ─────────────────────────────────── */
    .recipe-count-badge {
      @apply text-xs font-bold tabular-nums px-2 py-0.5 rounded-full;
      background: var(--recipe-count-badge-bg);
      color: var(--color-accent);
      border: 1px solid var(--recipe-count-badge-border);
    }

    /* ── Recipe results card ────────────────────────────────────── */
    .recipe-results-card {
      border: 1px solid var(--recipe-results-border);
      border-radius: 1rem;
      overflow: hidden;
    }

    .recipe-results-card__header {
      @apply flex items-center gap-2 text-xs font-bold uppercase tracking-widest px-4 py-3;
      background: var(--recipe-results-header-bg);
      color: var(--color-accent);
