---
import ProductImage from '@components/products/ProductImage.astro';
import Layout from '@layouts/Layout.astro';
import { actions } from 'astro:actions';
import ProductSliceShow from "src/components/products/ProductSliceShow.astro";
import { MARGIN_PRESETS } from '@utils/recipe-calculator';
import type { ProductRecipe } from '@interfaces/recipe.interface';

export const prerender = false
const {slug} = Astro.params;

const {data,error} = await Astro.callAction(actions.getProductBySlug, slug ?? " ");

// Get categories for dropdown
const {data: categoriesData} = await Astro.callAction(actions.getCategories, {});

if (error) {
    return Astro.redirect('/')
}
const {product, images} = data;
const categories = categoriesData?.categories ?? [];
const selectedCategoryId = 'categoryId' in product ? product.categoryId : null;
const isNew = slug === 'new-product';
const isFeatured = !isNew && !!((product as any).featured);

// Receta: si el producto ya tiene una, la usamos; sino vacía
const initialRecipe: ProductRecipe = (product as any).recipe ?? {
    ingredients: [{ name: '', paidAmount: 0, purchasedQty: 1, purchasedUnit: 'gr', usedQty: 1, usedUnit: 'gr' }],
    yieldUnits: 1,
    marginPercent: 50,
};
---

<Layout title="Mantenimiento de producto">
  <section class="admin-shell">

    <!-- ── Header ─────────────────────────────────────────────── -->
    <div class="admin-shell__header">
      <div class="space-y-4">
        <a href="/admin/dashboard" class="premium-action-ghost w-fit">
          <span aria-hidden="true">←</span>
          Volver a productos
        </a>

        <div>
          <p class="admin-shell__eyebrow">Dashboard admin · productos</p>
          <h1 class="admin-shell__title">
            {isNew ? 'Nuevo producto' : product.title}
          </h1>
          <p class="admin-shell__copy">
            {isNew
              ? 'Completá los datos del nuevo producto y subí las imágenes para publicarlo en el catálogo.'
              : 'Editá los campos, actualizá las imágenes y guardá los cambios para reflejarlos en el storefront.'}
          </p>
        </div>

        <div class="admin-chip-row">
          {isNew ? (
            <span class="admin-chip">Alta rápida</span>
          ) : (
            <span class="admin-chip"><strong>Slug</strong> /{product.slug}</span>
          )}
          <span class="premium-chip">{isNew ? 'Modo creación' : 'Modo edición'}</span>
          {!isNew && (
            <span class="admin-chip">
              <strong>{images.length}</strong> {images.length === 1 ? 'imagen' : 'imágenes'}
            </span>
          )}
        </div>
      </div>

      <!-- ── Acción principal del header ──────────────────────── -->
      <div class="admin-shell__header-actions">
        <button
          type="submit"
          form="product-form"
          class="premium-action-primary"
        >
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="h-4 w-4">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          Guardar producto
        </button>
      </div>
    </div>

    <!-- ── Formulario ──────────────────────────────────────────── -->
    <form id="product-form" class="space-y-6">
      <input type="hidden" name="id" value={product.id}>
      <!-- Campo oculto donde se serializa la receta antes del submit -->
      <input type="hidden" name="recipe" id="recipe-hidden">

      <!-- Grid superior: datos del producto + imágenes -->
      <div class="grid grid-cols-1 gap-6 lg:grid-cols-2">

      <!-- Columna izquierda: datos del producto -->
      <div class="space-y-6">

        <!-- Sección: Datos generales -->
        <div class="premium-panel p-6 md:p-8">
          <div class="mb-6 flex items-center gap-3 border-b pb-5" style="border-color: var(--color-border);">
            <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full" style="background: var(--color-surface-soft); color: var(--color-accent);">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="h-4 w-4">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
              </svg>
            </div>
            <div>
              <p class="admin-shell__eyebrow text-[0.68rem]">Información</p>
              <h2 class="text-base font-bold" style="color: var(--color-text);">Datos generales</h2>
            </div>
          </div>

          <div class="space-y-5">
            <!-- Título -->
            <div>
              <label for="title" class="block text-sm font-semibold mb-2" style="color: var(--color-text);">
                Título
              </label>
              <input
                type="text"
                id="title"
                name="title"
                value={product.title}
                class="premium-field"
                placeholder="Ej: Guacamole Clásico 250g"
              />
              <p class="field-help">Nombre visible en el catálogo y en las páginas de detalle.</p>
            </div>

            <!-- Slug -->
            <div>
              <label for="slug" class="block text-sm font-semibold mb-2" style="color: var(--color-text);">
                Slug
              </label>
              <input
                type="text"
                id="slug"
                name="slug"
                value={product.slug}
                class="premium-field"
                placeholder="Ej: guacamole-clasico-250g"
              />
              <p class="field-help">Usado en la URL: /productos/<span style="color: var(--color-accent);">{product.slug || 'slug'}</span></p>
            </div>

            <!-- Descripción -->
            <div>
              <label for="description" class="block text-sm font-semibold mb-2" style="color: var(--color-text);">
                Descripción
              </label>
              <textarea
                id="description"
                name="description"
                class="premium-field resize-none"
                rows="6"
                placeholder="Describí el producto: ingredientes, usos, características…"
              >{product.description}</textarea>
              <p class="field-help">Se muestra en la página de detalle del producto.</p>
            </div>
          </div>
        </div>

        <!-- Sección: Precio y Categoría -->
        <div class="premium-panel p-6 md:p-8">
          <div class="mb-6 flex items-center gap-3 border-b pb-5" style="border-color: var(--color-border);">
            <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full" style="background: var(--color-surface-soft); color: var(--color-accent);">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="h-4 w-4">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9.568 3H5.25A2.25 2.25 0 003 5.25v4.318c0 .597.237 1.17.659 1.591l9.581 9.581c.699.699 1.78.872 2.607.33a18.095 18.095 0 005.223-5.223c.542-.827.369-1.908-.33-2.607L11.16 3.66A2.25 2.25 0 009.568 3z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 6h.008v.008H6V6z" />
              </svg>
            </div>
            <div>
              <p class="admin-shell__eyebrow text-[0.68rem]">Pricing &amp; taxonomía</p>
              <h2 class="text-base font-bold" style="color: var(--color-text);">Precio y categoría</h2>
            </div>
          </div>

          <div class="grid gap-5 sm:grid-cols-2">
            <!-- Precio -->
            <div>
              <label for="price" class="block text-sm font-semibold mb-2" style="color: var(--color-text);">
                Precio
              </label>
              <input
                type="number"
                id="price"
                name="price"
                value={product.price}
                class="premium-field"
                placeholder="0.00"
                min="0"
                step="0.01"
              />
              <p class="field-help">Precio base visible en el storefront.</p>
            </div>

            <!-- Categoría -->
            <div>
              <label for="categoryId" class="block text-sm font-semibold mb-2" style="color: var(--color-text);">
                Categoría
              </label>
              <select
                id="categoryId"
                name="categoryId"
                class="premium-field"
              >
                <option value="">Sin categoría</option>
                {categories.map((category: { id: string; name: string }) => (
                  <option
                    value={category.id}
                    selected={selectedCategoryId === category.id}
                  >
                    {category.name}
                  </option>
                ))}
              </select>
              <p class="field-help">Agrupá el producto dentro de una taxonomía del catálogo.</p>
            </div>
          </div>
        </div>

        <!-- Sección: Tamaños -->
        <div class="premium-panel p-6 md:p-8">
          <div class="mb-6 flex items-center gap-3 border-b pb-5" style="border-color: var(--color-border);">
            <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full" style="background: var(--color-surface-soft); color: var(--color-accent);">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="h-4 w-4">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3.75v4.5m0-4.5h4.5m-4.5 0L9 9M3.75 20.25v-4.5m0 4.5h4.5m-4.5 0L9 15M20.25 3.75h-4.5m4.5 0v4.5m0-4.5L15 9m5.25 11.25h-4.5m4.5 0v-4.5m0 4.5L15 15" />
              </svg>
            </div>
            <div>
              <p class="admin-shell__eyebrow text-[0.68rem]">Variantes</p>
              <h2 class="text-base font-bold" style="color: var(--color-text);">Tamaños disponibles</h2>
            </div>
          </div>

          <div class="flex flex-wrap gap-2">
            {(['Pequeño', 'Mediano', 'Grande', 'Exra-grande', 'Normal'] as const).map((size) => (
              <button
                type="button"
                class:list={['btn-size', { 'btn-size--active': product.sizes.split(',').includes(size) }]}
                onclick="this.classList.toggle('btn-size--active')"
              >
                {size}
              </button>
            ))}
          </div>
          <p class="field-help mt-3">Seleccioná los tamaños habilitados para este producto. Se guardan al presionar "Guardar".</p>
        </div>

        <!-- Sección: Banner del home -->
        {!isNew && (
          <div class="premium-panel p-6 md:p-8">
            <div class="mb-5 flex items-center gap-3 border-b pb-5" style="border-color: var(--color-border);">
              <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full" style="background: var(--color-surface-soft); color: var(--color-accent);">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="h-4 w-4">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z" />
                </svg>
              </div>
              <div>
                <p class="admin-shell__eyebrow text-[0.68rem]">Visibilidad</p>
                <h2 class="text-base font-bold" style="color: var(--color-text);">Banner del home</h2>
              </div>
            </div>

            <div class="flex items-center justify-between gap-4">
              <div>
                <p class="text-sm font-semibold" style="color: var(--color-text);">
                  {isFeatured ? 'Este producto aparece en el banner' : 'Este producto no está en el banner'}
                </p>
                <p class="field-help mt-1">Los productos destacados se muestran en el slider principal del home.</p>
              </div>
              <button
                type="button"
                id="btn-toggle-featured-slug"
                class:list={['premium-icon-button', { 'btn-featured--active': isFeatured }]}
                data-id={product.id}
                data-featured={isFeatured ? 'true' : 'false'}
                aria-label={isFeatured ? 'Quitar del banner' : 'Destacar en banner'}
                title={isFeatured ? 'Quitar del banner' : 'Destacar en banner'}
              >
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill={isFeatured ? 'currentColor' : 'none'} stroke="currentColor" stroke-width="1.8" class="h-5 w-5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z" />
                </svg>
              </button>
            </div>
          </div>
        )}

      </div>

      <!-- Columna derecha: imágenes -->
      <div class="space-y-6">

        <!-- Sección: Guardar + Upload -->
        <div class="premium-panel p-6 md:p-8">
          <div class="mb-6 flex items-center gap-3 border-b pb-5" style="border-color: var(--color-border);">
            <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full" style="background: var(--color-surface-soft); color: var(--color-accent);">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="h-4 w-4">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909m-18 3.75h16.5a1.5 1.5 0 001.5-1.5V6a1.5 1.5 0 00-1.5-1.5H3.75A1.5 1.5 0 002.25 6v12a1.5 1.5 0 001.5 1.5zm10.5-11.25h.008v.008h-.008V8.25zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z" />
              </svg>
            </div>
            <div>
              <p class="admin-shell__eyebrow text-[0.68rem]">Media</p>
              <h2 class="text-base font-bold" style="color: var(--color-text);">Subir imágenes</h2>
            </div>
          </div>

          <!-- Drop zone -->
          <label
            for="file-upload"
            id="drop-zone"
            class="product-drop-zone"
          >
            <div class="flex flex-col items-center justify-center gap-3 py-8 px-4 text-center">
              <div class="flex h-12 w-12 items-center justify-center rounded-full" style="background: var(--color-surface-soft); color: var(--color-accent);">
                <svg
                  class="h-6 w-6"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                  xmlns="http://www.w3.org/2000/svg"
                  aria-hidden="true"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M7 16V4a2 2 0 012-2h6a2 2 0 012 2v12m-6 4l-4-4m0 0l4-4m-4 4h12"
                  ></path>
                </svg>
              </div>

              <div>
                <p class="text-sm font-semibold" style="color: var(--color-text);" id="lbl-selected-files">
                  <span>Click aquí</span> o arrastrá los archivos
                </p>
                <p class="mt-1 text-xs" style="color: var(--color-text-subtle);">
                  PNG, JPG, GIF, SVG · máx. 800×400 px
                </p>
              </div>
            </div>

            <input
              id="file-upload"
              name="imageFiles"
              type="file"
              accept="image/*"
              multiple
              class="sr-only"
            />
          </label>
        </div>

        <!-- Slideshow preview -->
        {images.length > 0 && (
          <div class="premium-panel overflow-hidden">
            <div class="flex items-center gap-3 border-b px-6 py-4" style="border-color: var(--color-border);">
              <p class="admin-shell__eyebrow text-[0.68rem]">Preview</p>
              <span class="admin-table-badge admin-table-badge--accent">{images.length} {images.length === 1 ? 'imagen' : 'imágenes'}</span>
            </div>
            <div class="px-2 py-4">
              <ProductSliceShow images={images.map(i=>i.image)} />
            </div>
          </div>
        )}

        <!-- Galería actual -->
        <div class="admin-table-shell">
          <div class="flex items-center justify-between border-b px-5 py-4 theme-soft-surface">
            <div>
              <p class="admin-table-subcopy text-[0.72rem] font-bold uppercase tracking-[0.18em]">Galería actual</p>
              <h3 class="admin-table-title mt-1 text-lg font-bold">Imágenes del producto</h3>
            </div>
            <span class="admin-table-badge admin-table-badge--accent">
              {images.length} {images.length === 1 ? 'imagen' : 'imágenes'}
            </span>
          </div>

          <div class="admin-table-scroll">
            <table class="admin-table min-w-[640px]">
              <thead>
                <tr>
                  <th>Preview</th>
                  <th>Referencia</th>
                  <th class="text-right">Acción</th>
                </tr>
              </thead>

              <tbody>
                {images.length === 0 ? (
                  <tr>
                    <td colspan="3">
                      <div class="flex flex-col items-center justify-center px-4 py-10 text-center">
                        <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-full" style="background: var(--color-surface-soft); color: var(--color-accent);">
                          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor" class="h-6 w-6">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909m-18 3.75h16.5a1.5 1.5 0 001.5-1.5V6a1.5 1.5 0 00-1.5-1.5H3.75A1.5 1.5 0 002.25 6v12a1.5 1.5 0 001.5 1.5zm10.5-11.25h.008v.008h-.008V8.25zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z" />
                          </svg>
                        </div>
                        <p class="admin-table-title text-base font-semibold">No hay imágenes cargadas todavía</p>
                        <p class="admin-table-copy mt-2 max-w-md text-sm leading-relaxed">
                          Subí archivos desde el panel superior y la galería va a aparecer acá automáticamente.
                        </p>
                      </div>
                    </td>
                  </tr>
                ) : (
                  images.map(({image,id}, index) => (
                    <tr id={id}>
                      <td>
                        <div class="admin-table-thumbnail">
                          <ProductImage
                            src={image}
                            alt={product.title}
                            className="h-full w-full object-cover"
                          />
                        </div>
                      </td>

                      <td>
                        <div class="min-w-[16rem]">
                          <p class="admin-table-title text-sm font-bold">Imagen {index + 1}</p>
                          <p class="admin-table-copy mt-1 break-all text-xs leading-relaxed">{image}</p>
                        </div>
                      </td>

                      <td class="text-right">
                        <button
                          data-id={id}
                          class="btn-delete-image admin-table-action admin-table-action--danger"
                          type="button"
                          aria-label={`Eliminar imagen ${index + 1}`}
                        >
                          Eliminar
                        </button>
                      </td>
                    </tr>
                  ))
                )}
              </tbody>
            </table>
          </div>
        </div>

      </div>
      <!-- /Columna derecha -->

      </div>
      <!-- /Grid superior -->

      <!-- ── Calculadora de receta: sección full-width ─────────────── -->
      <div class="premium-panel p-6 md:p-8" id="recipe-calculator">
        <div class="recipe-calculator-shell">

          <!-- Main: lista de ingredientes -->
          <div class="recipe-calculator-main">
            <div class="mb-5 border-b pb-5" style="border-color: var(--color-border);">
              <div class="flex items-center gap-3">
                <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full" style="background: var(--color-surface-soft); color: var(--color-accent);">
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="h-4 w-4">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 15.75V18m-7.5-6.75h.008v.008H8.25v-.008zm0 2.25h.008v.008H8.25V13.5zm0 2.25h.008v.008H8.25v-.008zm0 2.25h.008v.008H8.25V18zm2.498-6.75h.007v.008h-.007v-.008zm0 2.25h.007v.008h-.007V13.5zm0 2.25h.007v.008h-.007v-.008zm0 2.25h.007v.008h-.007V18zm2.504-6.75h.008v.008h-.008v-.008zm0 2.25h.008v.008h-.008V13.5zm0 2.25h.008v.008h-.008v-.008zm0 2.25h.008v.008h-.008V18zm2.498-6.75h.008v.008h-.008v-.008zm0 2.25h.008v.008h-.008V13.5zM8.25 6h7.5v2.25h-7.5V6zM12 2.25c-1.892 0-3.758.11-5.593.322C5.307 2.7 4.5 3.756 4.5 4.981V19.5a2.25 2.25 0 002.25 2.25h10.5a2.25 2.25 0 002.25-2.25V4.981c0-1.225-.807-2.281-1.907-2.409A41.146 41.146 0 0012 2.25z" />
                  </svg>
                </div>
                <div>
                  <p class="admin-shell__eyebrow text-[0.68rem]">Costos</p>
                  <div class="flex items-center gap-2">
                    <h2 class="text-base font-bold" style="color: var(--color-text);">Calculadora de receta</h2>
                    <span id="ingredient-count-badge" class="recipe-count-badge" style="display:none;">0</span>
                  </div>
                  <p class="field-help mt-1">Agregá ingredientes y el resumen se actualiza en tiempo real.</p>
                </div>
              </div>

            </div>

            <!-- Lista de ingredientes con scroll cuando hay muchos -->
            <div id="ingredients-list" class="recipe-ingredients-scroll">
              <!-- Los ingredientes se renderizan vía JS con la receta inicial -->
            </div>

            <button
              type="button"
              id="btn-add-ingredient"
