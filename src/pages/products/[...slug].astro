---
import Layout from "@layouts/Layout.astro";
import { actions } from "astro:actions";
import ProductSliceShow from "src/components/products/ProductSliceShow.astro";
import ProductCard from "src/components/products/ProductCard.astro";
export const prerender = false;

const {slug}= Astro.params;

const {data,error} = await Astro.callAction(actions.getProductBySlug,slug ?? " ")

if (error) {
    console.error('ERROR: ',error)
    return Astro.redirect('/404')
}

const { data: catalogData, error: catalogError } = await Astro.callAction(actions.getProductsByCategory, {});
const {product, images} = data;

type RelatedProductCard = {
    name: string;
    price: number;
    description: string;
    image: string;
    slug: string;
};

const isEnabled = 'isEnabled' in product ? (product as any).isEnabled !== false : true;

const sizes = product.sizes
    .split(',')
    .map((size) => size.trim())
    .filter(Boolean);

const productDescription = product.description?.trim() ?? '';
const descriptionParts = productDescription
    .split(/(?<=[.!?])\s+/)
    .map((part) => part.trim())
    .filter(Boolean);

const leadDescription = descriptionParts[0] ?? productDescription;
const categoryName = 'categoryName' in product
    ? (product as { categoryName?: string }).categoryName
    : undefined;
const categoryLabel = categoryName ?? 'Selección premium';

const relatedProducts: RelatedProductCard[] = catalogError || !catalogData?.productsByCategory || !categoryName
    ? []
    : catalogData.productsByCategory
        .filter((category) => category.categoryName === categoryName)
        .flatMap((category) => category.products)
        .filter((candidate) => candidate.slug !== product.slug)
        .sort((a, b) => {
            const priceDifference = Math.abs(a.price - product.price) - Math.abs(b.price - product.price);
            if (priceDifference !== 0) return priceDifference;
            return a.title.localeCompare(b.title, 'es');
        })
        .slice(0, 4)
        .map((candidate) => ({
            name: candidate.title,
            price: candidate.price,
            description: candidate.description,
            image: candidate.image,
            slug: `/products/${candidate.slug}`,
        }));
---

<Layout title={product.title} description={product.description}>
    <div class="theme-product-page mx-auto max-w-6xl px-4 py-6 sm:py-8 md:py-10">

        <!-- Breadcrumb minimal -->
        <nav class="mb-5 flex flex-wrap items-center gap-x-2 gap-y-1 text-sm" aria-label="Breadcrumb" style="color: var(--color-text-subtle);">
            <a href="/" class="breadcrumb-link">Inicio</a>
            <span aria-hidden="true">/</span>
            <a href="/tienda" class="breadcrumb-link">Tienda</a>
            <span aria-hidden="true">/</span>
            <a href="/tienda" class="breadcrumb-link">{categoryLabel}</a>
            <span aria-hidden="true">/</span>
            <span class="font-semibold" style="color: var(--color-text);" aria-current="page">{product.title}</span>
        </nav>

        <!-- Hero Panel -->
        <div class="product-hero overflow-hidden rounded-3xl">
            <div class="grid grid-cols-1 md:grid-cols-2">

                <!-- Image — full bleed -->
                <div class="product-hero__media relative min-h-[300px] md:min-h-[540px]">
                    <ProductSliceShow images={images.map(i=>i.image)}/>
                    <input type="hidden" id="product-image" value={images?.[0]?.image || ''}/>
                </div>

                <!-- Info -->
                <div class="flex flex-col justify-center gap-5 p-7 sm:p-9 md:p-10 lg:p-12">

                    <!-- Badges -->
                    <div class="flex flex-wrap items-center gap-2">
                        <a href="/tienda" class="back-pill">← Tienda</a>
                        <span class="category-badge">{categoryLabel}</span>
                    </div>

                    <!-- Title & Description -->
                    <div class="space-y-3">
                        <h1 class="product-title">{product.title}</h1>
                        <input type="hidden" id="product-name" value={product.title}/>
                        <p class="product-description">{leadDescription}</p>
                    </div>

                    <!-- Price -->
                    <div class="price-row">
                        <span class="price-amount">${product.price.toLocaleString('es-CO')}</span>
                        <span class="price-label">precio base</span>
                        <input type="hidden" id="product-price" value={product.price}/>
                    </div>

                    <hr class="detail-divider"/>

                    {isEnabled ? (
                        <>
                            <!-- Size -->
                            <div class="space-y-2.5">
                                <p class="field-label">Tamaño</p>
                                <ul class="flex flex-wrap gap-2">
                                    {sizes.map((t) => (
                                        <li class="size-chip" data-size-option="true">{t.trim()}</li>
                                    ))}
                                </ul>
                            </div>

                            <!-- Quantity -->
                            <div class="space-y-2.5">
                                <p class="field-label">Cantidad <span class="qty-max-hint">(máx. 5)</span></p>
                                <div class="flex items-center gap-3">
                                    <button id="decrement" class="qty-btn-group" aria-label="Disminuir cantidad" disabled>−</button>
                                    <input id="quantity-input" class="qty-input" type="number" value="1" readonly/>
                                    <button id="increment" class="qty-btn-group" aria-label="Aumentar cantidad">+</button>
                                </div>
                            </div>

                            <!-- CTA -->
                            <div class="space-y-2 pt-1">
                                <button id="add-card" class="add-to-cart-btn" disabled aria-disabled="true">
                                    <span id="add-card-label">Elige un tamaño</span>
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 8a2 2 0 100-4 2 2 0 000 4z" />
                                    </svg>
                                </button>
                                <p id="cart-feedback-note" class="theme-text-muted min-h-[1.25rem] text-xs font-medium" aria-live="polite"></p>
                            </div>
                        </>
                    ) : (
                        <!-- Producto deshabilitado — bloque informativo -->
                        <div class="disabled-product-notice">
                            <div class="disabled-product-notice__icon" aria-hidden="true">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-6 w-6">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
                                </svg>
                            </div>
                            <div>
                                <p class="disabled-product-notice__title">Producto próximamente disponible</p>
                                <p class="disabled-product-notice__body">Este producto no está disponible para compra en este momento. Vuelve a revisarlo pronto.</p>
                            </div>
                            <a href="/tienda" class="disabled-product-notice__cta">
                                Ver otros productos
                            </a>
                        </div>
                    )}

                </div>
            </div>
        </div>

        <!-- Related Products -->
        {relatedProducts.length > 0 && (
            <section class="mt-12 md:mt-16">
                <div class="mb-6 flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
                    <div>
                        <p class="eyebrow-label">También en {categoryLabel}</p>
                        <h2 class="section-title">Sigue explorando</h2>
                    </div>
                    <a href="/tienda" class="back-pill self-start sm:self-auto">Ver catálogo completo</a>
                </div>
                <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-4">
                    {relatedProducts.map((rp) => (
                        <ProductCard {...rp} />
                    ))}
                </div>
            </section>
        )}

        <input id="product-id" type="hidden" value={product.id}/>
    </div>
</Layout>

<style>
    /* ── Design tokens ── */
    .theme-product-page {
        color: var(--color-text);
    }

    /* ── Breadcrumb ── */
    .breadcrumb-link {
        color: var(--color-text-subtle);
        transition: color 0.2s;
    }
    .breadcrumb-link:hover {
        color: var(--color-accent);
    }

    /* ── Hero ── */
    .product-hero {
        border: 1px solid var(--color-border);
        background: color-mix(in srgb, var(--color-surface) 96%, transparent);
        box-shadow: 0 20px 48px var(--color-shadow-strong);
        backdrop-filter: blur(20px);
    }

    /* Image — fills left column completely */
    .product-hero__media {
        overflow: hidden;
        background:
            radial-gradient(circle at top right, color-mix(in srgb, var(--color-accent) 16%, transparent) 0%, transparent 60%),
            linear-gradient(160deg, color-mix(in srgb, var(--color-surface-soft) 80%, var(--color-accent) 20%) 0%, color-mix(in srgb, var(--color-surface-elevated) 96%, transparent) 100%);
    }

    .product-hero__media :global(.swiper) {
        position: absolute;
        inset: 0;
        width: 100% !important;
        height: 100% !important;
    }

    .product-hero__media :global(.swiper-slide) {
        width: 100% !important;
        height: 100% !important;
    }

    .product-hero__media :global(.swiper-slide img) {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    /* ── Badges ── */
    .back-pill {
        display: inline-flex;
        align-items: center;
        border-radius: 9999px;
        border: 1px solid var(--color-border);
        background: color-mix(in srgb, var(--color-surface-elevated) 94%, transparent);
        color: var(--color-text-muted);
        padding: 0.25rem 0.875rem;
        font-size: 0.75rem;
        font-weight: 500;
        transition: all 0.2s;
    }
    .back-pill:hover {
        border-color: var(--color-border-strong);
        background: color-mix(in srgb, var(--color-surface-soft) 84%, var(--color-accent) 16%);
        color: var(--color-accent);
    }

    .category-badge {
        display: inline-flex;
        align-items: center;
        border-radius: 9999px;
        background: color-mix(in srgb, var(--color-accent) 12%, transparent);
        color: var(--color-accent);
        padding: 0.25rem 0.875rem;
        font-size: 0.7rem;
        font-weight: 700;
        letter-spacing: 0.18em;
        text-transform: uppercase;
    }

    /* ── Typography ── */
    .product-title {
        font-size: clamp(1.5rem, 3.5vw, 2.25rem);
        font-weight: 800;
        line-height: 1.2;
        letter-spacing: -0.02em;
        color: var(--color-text);
    }

    .product-description {
        font-size: 0.9375rem;
        line-height: 1.7;
        color: var(--color-text-muted);
        max-width: 52ch;
    }

    .price-row {
        display: flex;
        align-items: baseline;
        gap: 0.5rem;
    }

    .price-amount {
        font-size: clamp(1.75rem, 4vw, 2.5rem);
        font-weight: 800;
        letter-spacing: -0.03em;
        color: var(--color-text);
    }

    .price-label {
        font-size: 0.8125rem;
        color: var(--color-text-subtle);
    }

    .field-label {
        font-size: 0.6875rem;
        font-weight: 700;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--color-text-muted);
    }

    .qty-max-hint {
        font-weight: 400;
        font-size: 0.6875rem;
        letter-spacing: 0.05em;
        text-transform: none;
        color: var(--color-text-subtle);
    }

    .detail-divider {
        border-color: var(--color-border);
    }

    /* ── Size chips ── */
    .size-chip {
        cursor: pointer;
        border-radius: 9999px;
        border: 2px solid color-mix(in srgb, var(--color-accent) 28%, var(--color-border) 72%);
        background: color-mix(in srgb, var(--color-surface-elevated) 94%, transparent);
        color: var(--color-accent);
        padding: 0.375rem 1rem;
        font-size: 0.875rem;
        font-weight: 600;
        transition: all 0.2s;
    }
    .size-chip:hover {
        border-color: var(--color-accent);
        background: color-mix(in srgb, var(--color-surface-soft) 84%, var(--color-accent) 16%);
    }
    .selected-size {
        transform: scale(1.05);
        color: white;
        box-shadow: 0 4px 14px color-mix(in srgb, var(--color-accent) 30%, transparent);
        border-color: var(--color-accent-strong);
        background: linear-gradient(135deg, var(--color-accent) 0%, var(--color-accent-strong) 100%);
    }

    /* ── Quantity ── */
    .qty-btn-group {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 2.5rem;
        height: 2.5rem;
        border-radius: 9999px;
        border: 2px solid var(--color-accent);
        color: var(--color-accent);
        font-size: 1.25rem;
        font-weight: 700;
        transition: all 0.2s;
        cursor: pointer;
        background: transparent;
    }
    .qty-btn-group:hover {
        transform: scale(1.05);
        background: var(--color-accent);
        color: var(--color-text-on-accent);
    }
    .qty-btn-group:disabled {
        border-color: var(--color-border);
        color: var(--color-text-subtle);
        cursor: not-allowed;
    }
    .qty-btn-group:disabled:hover {
        transform: none;
        background: transparent;
        color: var(--color-text-subtle);
    }
    .qty-btn-group:active:not(:disabled) {
        transform: scale(0.95);
    }

    .qty-input {
        width: 4rem;
        height: 2.5rem;
        border-radius: 9999px;
        border: 2px solid var(--color-border);
        background: var(--color-surface-elevated);
        color: var(--color-text);
        text-align: center;
        font-weight: 600;
        font-size: 1rem;
    }
    .qty-input:focus {
        outline: none;
        border-color: var(--color-accent);
    }
    input[type="number"]::-webkit-outer-spin-button,
    input[type="number"]::-webkit-inner-spin-button {
        -webkit-appearance: none;
        margin: 0;
    }

    /* ── CTA ── */
    .add-to-cart-btn {
        width: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        border-radius: 9999px;
        padding: 1rem 1.5rem;
        font-size: 0.9375rem;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        background: linear-gradient(135deg, var(--color-accent) 0%, var(--color-accent-strong) 100%);
        color: var(--color-text-on-accent);
        box-shadow: 0 10px 24px color-mix(in srgb, var(--color-accent) 28%, transparent);
        transition: all 0.3s;
        cursor: pointer;
        border: none;
    }
    .add-to-cart-btn:hover:not(:disabled) {
        transform: scale(1.02);
        background: linear-gradient(135deg, var(--color-accent-strong) 0%, var(--color-accent) 100%);
        box-shadow: 0 14px 30px color-mix(in srgb, var(--color-accent-strong) 34%, transparent);
    }
    .add-to-cart-btn:active:not(:disabled) {
        transform: scale(0.98);
    }
    .add-to-cart-btn:disabled {
        background: var(--color-surface-soft-strong);
        color: var(--color-text-subtle);
        box-shadow: none;
        cursor: not-allowed;
    }

    /* ── Disabled product notice ── */
    .disabled-product-notice {
        display: flex;
        flex-direction: column;
        gap: 0.875rem;
        border-radius: 1.25rem;
        border: 1px solid color-mix(in srgb, var(--color-danger, #ef4444) 30%, var(--color-border) 70%);
        background: color-mix(in srgb, var(--color-danger, #ef4444) 6%, var(--color-surface-elevated) 94%);
        padding: 1.25rem 1.375rem;
    }

    .disabled-product-notice__icon {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 2.5rem;
        height: 2.5rem;
        border-radius: 9999px;
        background: color-mix(in srgb, var(--color-danger, #ef4444) 12%, transparent);
        color: var(--color-danger, #ef4444);
        flex-shrink: 0;
    }

    .disabled-product-notice__title {
        font-size: 0.9375rem;
        font-weight: 700;
        color: var(--color-text);
        margin-bottom: 0.25rem;
    }

    .disabled-product-notice__body {
        font-size: 0.8125rem;
        line-height: 1.55;
        color: var(--color-text-muted);
    }

    .disabled-product-notice__cta {
        display: inline-flex;
        align-items: center;
        align-self: flex-start;
        border-radius: 9999px;
        border: 1px solid var(--color-border);
        background: color-mix(in srgb, var(--color-surface-elevated) 94%, transparent);
        color: var(--color-text-muted);
        padding: 0.375rem 1rem;
        font-size: 0.8125rem;
        font-weight: 600;
        transition: all 0.2s;
        text-decoration: none;
    }

    .disabled-product-notice__cta:hover {
        border-color: var(--color-accent);
        color: var(--color-accent);
        background: color-mix(in srgb, var(--color-surface-soft) 84%, var(--color-accent) 16%);
    }

    /* ── Related Products ── */
    .eyebrow-label {
        font-size: 0.6875rem;
        font-weight: 700;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: color-mix(in srgb, var(--color-accent) 80%, var(--color-text) 20%);
    }

    .section-title {
        font-size: clamp(1.375rem, 3vw, 1.75rem);
        font-weight: 800;
        letter-spacing: -0.02em;
        color: var(--color-text);
        margin-top: 0.25rem;
    }
</style>

<script>
    import { navigate } from "astro:transitions/client";
    import { cartItems } from "src/store/cart.store";
    import { CartCookiesClient } from "src/utils/cart-cookies";
    import { emitCartFeedback } from "src/utils/cart-feedback";

    document.addEventListener('astro:page-load',()=>{

        // Size selection - PRESERVED original toggle logic
        const sizeElments = document.querySelectorAll('[data-size-option]');
        sizeElments.forEach((liElement) => {
            liElement.addEventListener("click", () => {
                sizeElments.forEach((s) => s.classList.remove("selected-size"));
                liElement.classList.add("selected-size");
                addToCardButton.disabled = false;
                addToCardButton.setAttribute('aria-disabled', 'false');
                addToCartLabel.textContent = 'Agregar al carrito';
                setCartFeedback('Tamaño listo. Si quieres, te llevamos directo al checkout.', 'success');
            });
        });

        // Quantity management - PRESERVED min=1, max=5 logic
        const quantityInput = document.querySelector('#quantity-input') as HTMLInputElement;
        const producIdInput = document.querySelector('#product-id') as HTMLInputElement;
        let quantity = 1;

        const incrementButton = document.querySelector('#increment') as HTMLButtonElement;
        const decrementButton = document.querySelector('#decrement') as HTMLButtonElement;
        const addToCardButton = document.querySelector('#add-card') as HTMLButtonElement;
        const addToCartLabel = document.querySelector('#add-card-label') as HTMLSpanElement;
        const cartFeedbackNote = document.querySelector('#cart-feedback-note') as HTMLParagraphElement;

        const productImageInput = document.querySelector('#product-image') as HTMLInputElement;

        const setCartFeedback = (message: string, tone: 'default' | 'error' | 'success' = 'default') => {
            if (!cartFeedbackNote) return;

            cartFeedbackNote.textContent = message;
            cartFeedbackNote.classList.remove('theme-text-muted', 'text-red-500', 'text-guacamole-b');

            if (tone === 'error') {
                cartFeedbackNote.classList.add('text-red-500');
                return;
            }

            if (tone === 'success') {
                cartFeedbackNote.classList.add('text-guacamole-b');
                return;
            }

            cartFeedbackNote.classList.add('theme-text-muted');
        };

        if(!incrementButton || !quantityInput || !addToCardButton || !decrementButton || !addToCartLabel) return;

        const syncQuantityButtons = () => {
            decrementButton.disabled = quantity <= 1;
            incrementButton.disabled = quantity >= 5;
        };

        syncQuantityButtons();

        // Increment - PRESERVED max=5 logic
        incrementButton.addEventListener('click',()=>{
            quantity = Math.min(quantity+1,5);
            quantityInput.value= quantity.toString();
            syncQuantityButtons();
        });

        // Decrement - PRESERVED min=1 logic
        decrementButton.addEventListener('click',()=>{
            quantity = Math.max(quantity-1,1);
            quantityInput.value= quantity.toString();
            syncQuantityButtons();
        });

        // Add to cart - PRESERVED CartCookiesClient.addItem() logic
        addToCardButton.addEventListener('click',async()=>{
            if (addToCardButton.disabled) {
                return;
            }

            const size = document.querySelector('.selected-size')?.textContent;
            if (!size) {
                setCartFeedback('Elige un tamaño antes de pasar al checkout.', 'error');
                return;
            }

            setCartFeedback('Preparando tu selección para el checkout...', 'success');
            addToCardButton.disabled = true;
            addToCardButton.setAttribute('aria-busy', 'true');
            addToCardButton.setAttribute('aria-disabled', 'true');
            addToCartLabel.textContent = 'Preparando checkout...';

            try {
                const cart = CartCookiesClient.addItem({
                    productId:producIdInput.value,
                    size:size,
                    quantity:quantity,
                    name:(document.querySelector('#product-name') as HTMLInputElement).value,
                    price:parseFloat((document.querySelector('#product-price') as HTMLInputElement).value),
                    image:productImageInput.value,
                })

                cartItems.set(cart);
                emitCartFeedback({
                    type:'add',
                    productName:(document.querySelector('#product-name') as HTMLInputElement).value,
                    quantity:quantity,
                    size:size,
                    totalItems:cart.reduce((total, item) => total + item.quantity, 0),
                    message:'Te llevamos al checkout con esta selección lista.',
                });

                // PRESERVED navigation to /checkout
                await navigate('/checkout')
            } finally {
                addToCardButton.disabled = false;
                addToCardButton.removeAttribute('aria-busy');
                addToCardButton.setAttribute('aria-disabled', document.querySelector('.selected-size') ? 'false' : 'true');
                addToCartLabel.textContent = document.querySelector('.selected-size') ? 'Agregar al carrito' : 'Elige un tamaño';
            }
        })
    })
</script>
