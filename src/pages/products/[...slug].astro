---
import Layout from "@layouts/Layout.astro";
import { actions } from "astro:actions";
import ProductSliceShow from "@components/products/ProductSliceShow.astro";
import ProductCard from "@components/products/ProductCard.astro";
import { resolveProductImageUrl, resolveSocialImageUrl } from "@utils/product-images";
export const prerender = false;

const {slug}= Astro.params;

const {data,error} = await Astro.callAction(actions.getProductBySlug,slug ?? " ")

if (error) {
    console.error('ERROR: ',error)
    return Astro.redirect('/404')
}

const { data: catalogData, error: catalogError } = await Astro.callAction(actions.getProductsByCategory, {});
const {product, images} = data;

type RelatedProductCard = {
    name: string;
    price: number;
    description: string;
    image: string;
    slug: string;
};

const isEnabled = 'isEnabled' in product ? (product as any).isEnabled !== false : true;

const sizes = product.sizes
    .split(',')
    .map((size) => size.trim())
    .filter(Boolean);

const productDescription = product.description?.trim() ?? '';
const descriptionParts = productDescription
    .split(/(?<=[.!?])\s+/)
    .map((part) => part.trim())
    .filter(Boolean);

const leadDescription = descriptionParts[0] ?? productDescription;
const categoryName = 'categoryName' in product
    ? (product as { categoryName?: string }).categoryName
    : undefined;
const categoryLabel = categoryName ?? 'Selección premium';

const relatedProducts: RelatedProductCard[] = catalogError || !catalogData?.productsByCategory || !categoryName
    ? []
    : catalogData.productsByCategory
        .filter((category) => category.categoryName === categoryName)
        .flatMap((category) => category.products)
        .filter((candidate) => candidate.slug !== product.slug)
        .sort((a, b) => {
            const priceDifference = Math.abs(a.price - product.price) - Math.abs(b.price - product.price);
            if (priceDifference !== 0) return priceDifference;
            return a.title.localeCompare(b.title, 'es');
        })
        .slice(0, 4)
        .map((candidate) => ({
            name: candidate.title,
            price: candidate.price,
            description: candidate.description,
            image: candidate.image,
            slug: `/products/${candidate.slug}`,
        }));

const primaryImage = images[0]?.image;
const resolvedPrimaryImage = resolveProductImageUrl(primaryImage, {
    baseUrl: Astro.url,
});
const seoImage = resolveSocialImageUrl(primaryImage, Astro.url);
---

<Layout title={product.title} description={product.description} image={seoImage} ogType="product">
    <div class="theme-product-page mx-auto max-w-6xl px-4 py-6 sm:py-8 md:py-10">

        <!-- Breadcrumb minimal -->
        <nav class="mb-5 flex flex-wrap items-center gap-x-2 gap-y-1 text-sm" aria-label="Breadcrumb" style="color: var(--color-text-subtle);">
            <a href="/" class="breadcrumb-link">Inicio</a>
            <span aria-hidden="true">/</span>
            <a href="/tienda" class="breadcrumb-link">Tienda</a>
            <span aria-hidden="true">/</span>
            <a href="/tienda" class="breadcrumb-link">{categoryLabel}</a>
            <span aria-hidden="true">/</span>
            <span class="font-semibold" style="color: var(--color-text);" aria-current="page">{product.title}</span>
        </nav>

        <!-- Hero Panel -->
        <div class="product-hero overflow-hidden rounded-3xl">
            <div class="grid grid-cols-1 md:grid-cols-2">

                <!-- Image — full bleed -->
                <div class="product-hero__media relative min-h-[300px] md:min-h-[540px]">
                    <ProductSliceShow images={images.map(i=>i.image)} alt={product.title}/>

                    <!-- AI image disclaimer -->
                    <div class="ai-photo-notice" aria-label="Nota sobre la imagen del producto">
                        <span class="ai-photo-notice__icon" aria-hidden="true">
                            <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M9.937 15.5A2 2 0 0 0 8.5 14.063l-6.135-1.582a.5.5 0 0 1 0-.962L8.5 9.936A2 2 0 0 0 9.937 8.5l1.582-6.135a.5.5 0 0 1 .963 0L14.063 8.5A2 2 0 0 0 15.5 9.937l6.135 1.581a.5.5 0 0 1 0 .964L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.963 0z"/>
                            </svg>
                        </span>
                        <p class="ai-photo-notice__text">
                            Inspirada en lo real, perfeccionada con IA. Receta real con un destello de magia digital.
                        </p>
                    </div>
                </div>

                <!-- Info -->
                <div
                    class="flex flex-col justify-center gap-5 p-7 sm:p-9 md:p-10 lg:p-12"
                    data-product-purchase
                    data-product-id={product.id}
                    data-product-name={product.title}
                    data-product-price={String(product.price)}
                    data-product-image={resolvedPrimaryImage}
                >

                    <!-- Badges -->
                    <div class="flex flex-wrap items-center gap-2">
                        <a href="/tienda" class="back-pill">← Tienda</a>
                        <span class="category-badge">{categoryLabel}</span>
                    </div>

                    <!-- Title & Description -->
                    <div class="space-y-3">
                        <h1 class="product-title">{product.title}</h1>
                        <p class="product-description">{leadDescription}</p>
                    </div>

                    <!-- Price -->
                    <div class="price-row">
                        <span class="price-amount">${product.price.toLocaleString('es-CO')}</span>
                        <span class="price-label">precio base</span>
                    </div>

                    <hr class="detail-divider"/>

                    {isEnabled ? (
                        <>
                            <!-- Size -->
                            <div class="space-y-2.5">
                                <p class="field-label">Tamaño</p>
                                <ul class="flex flex-wrap gap-2">
                                    {sizes.map((t) => (
                                        <li>
                                            <button
                                                type="button"
                                                class="size-chip"
                                                data-size-option
                                                data-size-value={t.trim()}
                                                aria-pressed="false"
                                            >
                                                {t.trim()}
                                            </button>
                                        </li>
                                    ))}
                                </ul>
                            </div>

                            <!-- Quantity -->
                            <div class="space-y-2.5">
                                <p class="field-label">Cantidad <span class="qty-max-hint">(máx. 5)</span></p>
                                <div class="flex items-center gap-3">
                                    <button type="button" id="decrement" class="qty-btn-group" aria-label="Disminuir cantidad" disabled>−</button>
                                    <input id="quantity-input" class="qty-input" type="number" value="1" readonly inputmode="numeric" />
                                    <button type="button" id="increment" class="qty-btn-group" aria-label="Aumentar cantidad">+</button>
                                </div>
                            </div>

                            <!-- CTA -->
                            <div class="space-y-2 pt-1">
                                <button type="button" id="add-card" class="add-to-cart-btn" disabled aria-disabled="true">
                                    <span id="add-card-label">Elige un tamaño</span>
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 8a2 2 0 100-4 2 2 0 000 4z" />
                                    </svg>
                                </button>
                                <p id="cart-feedback-note" class="theme-text-muted min-h-[1.25rem] text-xs font-medium" aria-live="polite"></p>
                            </div>
                        </>
                    ) : (
                        <!-- Producto deshabilitado — bloque informativo -->
                        <div class="disabled-product-notice">
                            <div class="disabled-product-notice__icon" aria-hidden="true">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-6 w-6">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
                                </svg>
                            </div>
                            <div>
                                <p class="disabled-product-notice__title">Producto próximamente disponible</p>
                                <p class="disabled-product-notice__body">Este producto no está disponible para compra en este momento. Vuelve a revisarlo pronto.</p>
                            </div>
                            <a href="/tienda" class="disabled-product-notice__cta">
                                Ver otros productos
                            </a>
                        </div>
                    )}

                </div>
            </div>
        </div>

        <!-- Related Products -->
        {relatedProducts.length > 0 && (
            <section class="mt-12 md:mt-16">
                <div class="mb-6 flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
                    <div>
                        <p class="eyebrow-label">También en {categoryLabel}</p>
                        <h2 class="section-title">Sigue explorando</h2>
                    </div>
                    <a href="/tienda" class="back-pill self-start sm:self-auto">Ver catálogo completo</a>
                </div>
                <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-4">
                    {relatedProducts.map((rp) => (
                        <ProductCard {...rp} />
                    ))}
                </div>
            </section>
        )}
    </div>
</Layout>

<style>
    /* ── Design tokens ── */
    .theme-product-page {
        color: var(--color-text);
    }

    /* ── Breadcrumb ── */
    .breadcrumb-link {
        color: var(--color-text-subtle);
        transition: color 0.2s;
    }
    .breadcrumb-link:hover {
        color: var(--color-accent);
    }

    /* ── Hero ── */
    .product-hero {
        border: 1px solid var(--color-border);
        background: color-mix(in srgb, var(--color-surface) 96%, transparent);
        box-shadow: 0 20px 48px var(--color-shadow-strong);
        backdrop-filter: blur(20px);
    }

    /* Image — fills left column completely */
    .product-hero__media {
        overflow: hidden;
        background:
            radial-gradient(circle at top right, color-mix(in srgb, var(--color-accent) 16%, transparent) 0%, transparent 60%),
            linear-gradient(160deg, color-mix(in srgb, var(--color-surface-soft) 80%, var(--color-accent) 20%) 0%, color-mix(in srgb, var(--color-surface-elevated) 96%, transparent) 100%);
    }

    /* ── AI photo notice ── */
    .ai-photo-notice {
        position: absolute;
        bottom: 1rem;
        left: 50%;
        transform: translateX(-50%);
        z-index: 10;
        display: flex;
        align-items: center;
        gap: 0.4rem;
        white-space: nowrap;
        border-radius: 999px;
        border: 1px solid rgba(255, 255, 255, 0.12);
        background: rgba(0, 0, 0, 0.52);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        padding: 0.35rem 0.85rem 0.35rem 0.65rem;
        max-width: calc(100% - 2rem);
    }

    .ai-photo-notice__icon {
        flex-shrink: 0;
        display: flex;
        align-items: center;
        color: rgba(255, 255, 255, 0.7);
    }

    .ai-photo-notice__text {
        font-size: 0.7rem;
        font-weight: 500;
        letter-spacing: 0.01em;
        color: rgba(255, 255, 255, 0.78);
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
        margin: 0;
    }

    @media (max-width: 480px) {
        .ai-photo-notice {
            bottom: 0.75rem;
            max-width: calc(100% - 1.5rem);
        }
        .ai-photo-notice__text {
            font-size: 0.65rem;
        }
    }

    /* ── Badges ── */
    .back-pill {
        display: inline-flex;
        align-items: center;
        border-radius: 9999px;
        border: 1px solid var(--color-border);
        background: color-mix(in srgb, var(--color-surface-elevated) 94%, transparent);
        color: var(--color-text-muted);
        padding: 0.25rem 0.875rem;
        font-size: 0.75rem;
        font-weight: 500;
        transition: all 0.2s;
    }
    .back-pill:hover {
        border-color: var(--color-border-strong);
        background: color-mix(in srgb, var(--color-surface-soft) 84%, var(--color-accent) 16%);
        color: var(--color-accent);
    }

    .category-badge {
        display: inline-flex;
        align-items: center;
        border-radius: 9999px;
        background: color-mix(in srgb, var(--color-accent) 12%, transparent);
        color: var(--color-accent);
        padding: 0.25rem 0.875rem;
        font-size: 0.7rem;
        font-weight: 700;
        letter-spacing: 0.18em;
        text-transform: uppercase;
    }

    /* ── Typography ── */
    .product-title {
        font-size: clamp(1.5rem, 3.5vw, 2.25rem);
        font-weight: 800;
        line-height: 1.2;
        letter-spacing: -0.02em;
        color: var(--color-text);
    }

    .product-description {
        font-size: 0.9375rem;
        line-height: 1.7;
        color: var(--color-text-muted);
        max-width: 52ch;
    }

    .price-row {
        display: flex;
        align-items: baseline;
        gap: 0.5rem;
    }

    .price-amount {
        font-size: clamp(1.75rem, 4vw, 2.5rem);
        font-weight: 800;
        letter-spacing: -0.03em;
        color: var(--color-text);
    }

    .price-label {
        font-size: 0.8125rem;
        color: var(--color-text-subtle);
    }

    .field-label {
        font-size: 0.6875rem;
        font-weight: 700;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--color-text-muted);
    }

    .qty-max-hint {
        font-weight: 400;
        font-size: 0.6875rem;
        letter-spacing: 0.05em;
        text-transform: none;
        color: var(--color-text-subtle);
    }

    .detail-divider {
        border-color: var(--color-border);
    }

    /* ── Size chips ── */
    .size-chip {
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 2.75rem;
        border-radius: 9999px;
        border: 2px solid color-mix(in srgb, var(--color-accent) 28%, var(--color-border) 72%);
        background: color-mix(in srgb, var(--color-surface-elevated) 94%, transparent);
        color: var(--color-accent);
        padding: 0.375rem 1rem;
        font-size: 0.875rem;
        font-weight: 600;
        transition: all 0.2s;
    }
    .size-chip:hover {
        border-color: var(--color-accent);
        background: color-mix(in srgb, var(--color-surface-soft) 84%, var(--color-accent) 16%);
    }
    .size-chip:focus-visible,
    .qty-btn-group:focus-visible,
    .add-to-cart-btn:focus-visible,
    .breadcrumb-link:focus-visible,
    .back-pill:focus-visible,
    .disabled-product-notice__cta:focus-visible {
        outline: 2px solid color-mix(in srgb, var(--color-accent) 82%, white 18%);
        outline-offset: 2px;
    }
    .selected-size {
        transform: scale(1.05);
        color: white;
        box-shadow: 0 4px 14px color-mix(in srgb, var(--color-accent) 30%, transparent);
        border-color: var(--color-accent-strong);
        background: linear-gradient(135deg, var(--color-accent) 0%, var(--color-accent-strong) 100%);
    }

    /* ── Quantity ── */
    .qty-btn-group {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 2.75rem;
        height: 2.75rem;
        border-radius: 9999px;
        border: 2px solid var(--color-accent);
        color: var(--color-accent);
        font-size: 1.25rem;
        font-weight: 700;
        transition: all 0.2s;
        cursor: pointer;
        background: transparent;
    }
    .qty-btn-group:hover {
        transform: scale(1.05);
        background: var(--color-accent);
        color: var(--color-text-on-accent);
    }
    .qty-btn-group:disabled {
        border-color: var(--color-border);
        color: var(--color-text-subtle);
        cursor: not-allowed;
    }
    .qty-btn-group:disabled:hover {
        transform: none;
        background: transparent;
        color: var(--color-text-subtle);
    }
    .qty-btn-group:active:not(:disabled) {
        transform: scale(0.95);
    }

    .qty-input {
        width: 4rem;
        height: 2.75rem;
        border-radius: 9999px;
        border: 2px solid var(--color-border);
        background: var(--color-surface-elevated);
        color: var(--color-text);
        text-align: center;
        font-weight: 600;
        font-size: 1rem;
    }
    .qty-input:focus {
        outline: none;
        border-color: var(--color-accent);
    }
    input[type="number"]::-webkit-outer-spin-button,
    input[type="number"]::-webkit-inner-spin-button {
        -webkit-appearance: none;
        margin: 0;
    }

    /* ── CTA ── */
    .add-to-cart-btn {
        width: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        border-radius: 9999px;
        padding: 1rem 1.5rem;
        font-size: 0.9375rem;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        background: linear-gradient(135deg, var(--color-accent) 0%, var(--color-accent-strong) 100%);
        color: var(--color-text-on-accent);
        box-shadow: 0 10px 24px color-mix(in srgb, var(--color-accent) 28%, transparent);
        transition: all 0.3s;
        cursor: pointer;
        border: none;
    }
    .add-to-cart-btn:hover:not(:disabled) {
        transform: scale(1.02);
        background: linear-gradient(135deg, var(--color-accent-strong) 0%, var(--color-accent) 100%);
        box-shadow: 0 14px 30px color-mix(in srgb, var(--color-accent-strong) 34%, transparent);
    }
    .add-to-cart-btn:active:not(:disabled) {
        transform: scale(0.98);
    }
    .add-to-cart-btn:disabled {
        background: var(--color-surface-soft-strong);
        color: var(--color-text-subtle);
        box-shadow: none;
        cursor: not-allowed;
    }

    /* ── Disabled product notice ── */
    .disabled-product-notice {
        display: flex;
        flex-direction: column;
        gap: 0.875rem;
        border-radius: 1.25rem;
        border: 1px solid color-mix(in srgb, var(--color-danger, #ef4444) 30%, var(--color-border) 70%);
        background: color-mix(in srgb, var(--color-danger, #ef4444) 6%, var(--color-surface-elevated) 94%);
        padding: 1.25rem 1.375rem;
    }

    .disabled-product-notice__icon {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 2.5rem;
        height: 2.5rem;
        border-radius: 9999px;
        background: color-mix(in srgb, var(--color-danger, #ef4444) 12%, transparent);
        color: var(--color-danger, #ef4444);
        flex-shrink: 0;
    }

    .disabled-product-notice__title {
        font-size: 0.9375rem;
        font-weight: 700;
        color: var(--color-text);
        margin-bottom: 0.25rem;
    }

    .disabled-product-notice__body {
        font-size: 0.8125rem;
        line-height: 1.55;
        color: var(--color-text-muted);
    }

    .disabled-product-notice__cta {
        display: inline-flex;
        align-items: center;
        align-self: flex-start;
        border-radius: 9999px;
        border: 1px solid var(--color-border);
        background: color-mix(in srgb, var(--color-surface-elevated) 94%, transparent);
        color: var(--color-text-muted);
        padding: 0.375rem 1rem;
        font-size: 0.8125rem;
        font-weight: 600;
        transition: all 0.2s;
        text-decoration: none;
    }

    .disabled-product-notice__cta:hover {
        border-color: var(--color-accent);
        color: var(--color-accent);
        background: color-mix(in srgb, var(--color-surface-soft) 84%, var(--color-accent) 16%);
    }

    /* ── Related Products ── */
    .eyebrow-label {
        font-size: 0.6875rem;
        font-weight: 700;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: color-mix(in srgb, var(--color-accent) 80%, var(--color-text) 20%);
    }

    .section-title {
        font-size: clamp(1.375rem, 3vw, 1.75rem);
        font-weight: 800;
        letter-spacing: -0.02em;
        color: var(--color-text);
        margin-top: 0.25rem;
    }
</style>

<script>
    import { initProductDetailPage } from '../../scripts/product-detail-page';
    import { bindDocumentEventOnce } from '../../utils/bind-document-event-once';

    const run = () => initProductDetailPage(document);

    run();
    bindDocumentEventOnce('astro:page-load', 'product-detail-page', run);
</script>
